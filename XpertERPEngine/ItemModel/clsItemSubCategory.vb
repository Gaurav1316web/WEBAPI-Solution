Imports common
Imports System.Data.SqlClient
Public Class clsItemSubCategory
#Region "Variables"
    Public Sub_Category_Code As String = ""
    Public Description As String = ""
    Public Category_Code As String = ""
    Public Category_Name As String = ""

#End Region
    Public Function SaveData(ByVal obj As clsItemSubCategory, ByVal isNewEntry As Boolean) As Boolean
        Dim isSaved As Boolean = True
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Category_Code", obj.Category_Code)
            clsCommon.AddColumnsForChange(coll, "Description", obj.Description)
            clsCommon.AddColumnsForChange(coll, "Comp_Code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "Modify_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modify_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code='" & obj.Category_Code & "'", trans)
                    If ChkNewEntry = 0 Then
                        obj.Category_Code = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.ItemSubCategory, "", "")
                        If clsCommon.myLen(obj.Category_Code) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Sub_Category_Code", obj.Sub_Category_Code)
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))

                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_SUB_CATEGORY", OMInsertOrUpdate.Insert, "", trans)
            Else
                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_SUB_CATEGORY", OMInsertOrUpdate.Update, "Sub_Category_Code='" + obj.Sub_Category_Code + "'", trans)
            End If
            If isSaved Then
                trans.Commit()
            End If
        Catch err As Exception
            trans.Rollback()
            Throw New Exception(err.Message)
        End Try
        Return isSaved
    End Function

    Public Shared Function GetData(ByVal SubCategoryCode As String, ByVal NavType As common.NavigatorType) As clsItemSubCategory
        Return GetData(SubCategoryCode, NavType, Nothing)
    End Function

    Public Shared Function GetData(ByVal SubCategoryCode As String, ByVal NavType As common.NavigatorType, ByVal trans As SqlTransaction) As clsItemSubCategory
        Dim obj As clsItemSubCategory = Nothing
        Dim qry As String = "SELECT TSPL_Item_Sub_Category.Sub_Category_Code, TSPL_Item_Sub_Category.Category_Code, TSPL_Item_Sub_Category.Description,TSPL_ITEM_CATEGORY.Category_Name as CatgName  from TSPL_Item_Sub_Category left outer join TSPL_ITEM_CATEGORY on TSPL_ITEM_CATEGORY.Category_Code=TSPL_Item_Sub_Category.Category_Code where  2=2"
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_ITEM_Sub_CATEGORY.Sub_Category_Code=(select MIN(Sub_Category_Code) from TSPL_ITEM_Sub_CATEGORY)"
            Case NavigatorType.Last
                qry += " and TSPL_ITEM_Sub_CATEGORY.Sub_Category_Code=(select Max(Sub_Category_Code) from TSPL_ITEM_Sub_CATEGORY)"
            Case NavigatorType.Next
                qry += " and TSPL_ITEM_Sub_CATEGORY.Sub_Category_Code=(select Min(Sub_Category_Code) from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code > '" + SubCategoryCode + "')"
            Case NavigatorType.Previous
                qry += " and TSPL_ITEM_SUB_CATEGORY.Sub_Category_Code=(select Max(Sub_Category_Code) from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code < '" + SubCategoryCode + "')"
            Case NavigatorType.Current
                qry += " and TSPL_ITEM_SUB_CATEGORY.Sub_Category_Code='" + SubCategoryCode + "'"
        End Select

        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New clsItemSubCategory()
            obj.Sub_Category_Code = clsCommon.myCstr(dt.Rows(0)("Sub_Category_Code"))
            obj.Category_Code = clsCommon.myCstr(dt.Rows(0)("Category_Code"))
            obj.Description = clsCommon.myCstr(dt.Rows(0)("Description"))
            obj.Category_Name = clsCommon.myCstr(dt.Rows(0)("CatgName"))

        End If

        Return obj
    End Function


    Public Shared Function DeleteData(ByVal Sub_Category_Code As String) As Boolean
        Dim isSaved As Boolean = False
        If (clsCommon.myLen(Sub_Category_Code) <= 0) Then
            Throw New Exception("Sub_Category_Code not found to Delete")
        End If
        Dim obj As clsItemSubCategory = clsItemSubCategory.GetData(Sub_Category_Code, NavigatorType.Current)
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Sub_Category_Code) > 0) Then
            Try
                Dim qry As String = "delete from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code='" + Sub_Category_Code + "'"
                isSaved = clsDBFuncationality.ExecuteNonQuery(qry, trans)

                qry = "delete from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code='" + Sub_Category_Code + "'"
                isSaved = isSaved AndAlso clsDBFuncationality.ExecuteNonQuery(qry, trans)

                If (isSaved) Then
                    trans.Commit()
                Else
                    trans.Rollback()
                End If
            Catch ex As Exception
                trans.Rollback()
                Throw New Exception(ex.Message)
            End Try
        End If
        Return isSaved
    End Function


    Public Shared Function SaveData(ByVal Sub_Category_Code As String, ByVal Arr As List(Of clsItemSubCategory), ByVal trans As SqlTransaction) As Boolean
        Dim Category_Name As String = ""
        Dim Category_Code As String = ""
        If (Arr IsNot Nothing AndAlso Arr.Count > 0) Then
            For Each obj As clsItemSubCategory In Arr
                Dim coll As New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Sub_Category_Code", Sub_Category_Code)
                clsCommon.AddColumnsForChange(coll, "Category_Code", Category_Code)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_SUB_CATEGORY", OMInsertOrUpdate.Insert, "", trans)

            Next
        End If
        Return True
    End Function


