            obj.Ecess = clsCommon.myCdbl(dt.Rows(0)("Ecess"))
            obj.Hcess = clsCommon.myCdbl(dt.Rows(0)("Hcess"))
            obj.Tax_Code_Excise = clsCommon.myCstr(dt.Rows(0)("Tax_Code_Excise"))
            obj.Tax_Code_Ecess = clsCommon.myCstr(dt.Rows(0)("Tax_Code_Ecess"))
            obj.Tax_Code_Hcess = clsCommon.myCstr(dt.Rows(0)("Tax_Code_Hcess"))

