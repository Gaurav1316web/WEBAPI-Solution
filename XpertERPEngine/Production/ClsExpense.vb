Imports System.Data.SqlClient
Imports common
Public Class ClsExpense

#Region "variables"
    Public EXPANSE_HEAD_CODE As String = Nothing
    Public EXPANSE_HEAD_NAME As String = Nothing
    Public DESCRIPTION As String = Nothing
    Public Created_By As String = Nothing
    Public Created_Date As Date? = Nothing
    Public Modified_By As String = Nothing
    Public Modified_Date As Date? = Nothing
#End Region
#Region "Functions"

    Public Shared Function SaveData(ByVal obj As ClsExpense, ByVal isNewEntry As Boolean, ByVal trans As SqlTransaction) As Boolean
        Dim qry As String = ""

        Try

            Dim coll As New Hashtable()

            clsCommon.AddColumnsForChange(coll, "comp_code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "EXPANSE_HEAD_NAME", obj.EXPANSE_HEAD_NAME)
            clsCommon.AddColumnsForChange(coll, "Description", obj.DESCRIPTION)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy"))
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_MF_EXPANSE_HEAD where EXPANSE_HEAD_CODE='" & obj.EXPANSE_HEAD_CODE & "'", trans)
                    If ChkNewEntry = 0 Then
                        obj.EXPANSE_HEAD_CODE = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.ExpenseHead, "", "")
                        If clsCommon.myLen(obj.EXPANSE_HEAD_CODE) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy"))
                clsCommon.AddColumnsForChange(coll, "EXPANSE_HEAD_CODE", obj.EXPANSE_HEAD_CODE)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MF_EXPANSE_HEAD", OMInsertOrUpdate.Insert, "", trans)
            Else
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MF_EXPANSE_HEAD", OMInsertOrUpdate.Update, "TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE='" + obj.EXPANSE_HEAD_CODE + "'", trans)
            End If

        Catch err As Exception

            Throw New Exception(err.Message)
        End Try
        Return True
    End Function


    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As ClsExpense
        Return GetData(strCode, NavType, Nothing)
    End Function

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType, ByVal trans As SqlTransaction) As ClsExpense
        Dim obj As ClsExpense = Nothing
        Dim Arr As List(Of ClsExpense) = Nothing
        Dim qry As String = "select EXPANSE_HEAD_CODE ,EXPANSE_HEAD_NAME,DESCRIPTION from TSPL_MF_EXPANSE_HEAD where 2=2 "
        Dim whrclas As String = ""
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE = (select MIN(EXPANSE_HEAD_CODE) from TSPL_MF_EXPANSE_HEAD WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE = (select Max(EXPANSE_HEAD_CODE) from TSPL_MF_EXPANSE_HEAD WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE = (select top 1 EXPANSE_HEAD_CODE from TSPL_MF_EXPANSE_HEAD WHERE 1=1 " + whrclas + " and EXPANSE_HEAD_CODE='" + strCode + "' )"
            Case NavigatorType.Next
                qry += " and TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE = (select Min(EXPANSE_HEAD_CODE) from TSPL_MF_EXPANSE_HEAD where EXPANSE_HEAD_CODE>'" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_MF_EXPANSE_HEAD.EXPANSE_HEAD_CODE = (select Max(EXPANSE_HEAD_CODE) from TSPL_MF_EXPANSE_HEAD where EXPANSE_HEAD_CODE<'" + strCode + "' " + whrclas + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New ClsExpense()
            obj.EXPANSE_HEAD_CODE = clsCommon.myCstr(dt.Rows(0)("EXPANSE_HEAD_CODE"))
            obj.EXPANSE_HEAD_NAME = clsCommon.myCstr(dt.Rows(0)("EXPANSE_HEAD_NAME"))
            obj.DESCRIPTION = clsCommon.myCstr(dt.Rows(0)("DESCRIPTION"))
        End If
        Return obj
    End Function

#End Region
End Class
