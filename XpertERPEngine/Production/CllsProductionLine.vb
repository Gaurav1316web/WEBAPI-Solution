Imports System.Data.SqlClient
Imports common
Public Class CllsProductionLine
#Region "variables"
    Public PRODUCTION_LINE_CODE As String = Nothing
    Public PRODUCTION_LINE_NAME As String = Nothing
    Public DESCRIPTION As String = Nothing
    Public Created_By As String = Nothing
    Public Created_Date As Date? = Nothing
    Public Modified_By As String = Nothing
    Public Modified_Date As Date? = Nothing
#End Region
#Region "Functions"

    Public Shared Function SaveData(ByVal obj As CllsProductionLine, ByVal isNewEntry As Boolean, ByVal trans As SqlTransaction) As Boolean
        Dim qry As String = ""
        Dim IsSaved As Boolean = False
        Try
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "comp_code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "PRODUCTION_LINE_NAME", obj.PRODUCTION_LINE_NAME)
            clsCommon.AddColumnsForChange(coll, "Description", obj.DESCRIPTION)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy"))
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_MF_PRODUCTION_LINES where PRODUCTION_LINE_CODE='" & obj.PRODUCTION_LINE_CODE & "'", trans)
                    If ChkNewEntry = 0 Then
                        obj.PRODUCTION_LINE_CODE = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.ProductionLine, "", "")
                        If clsCommon.myLen(obj.PRODUCTION_LINE_CODE) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy"))
                clsCommon.AddColumnsForChange(coll, "PRODUCTION_LINE_CODE", obj.PRODUCTION_LINE_CODE)
                IsSaved = clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MF_PRODUCTION_LINES", OMInsertOrUpdate.Insert, "", trans)
            Else
                IsSaved = clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MF_PRODUCTION_LINES", OMInsertOrUpdate.Update, "TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE='" + obj.PRODUCTION_LINE_CODE + "'", trans)
            End If

            If IsSaved Then
                IsSaved = IsSaved AndAlso SaveData_CostCenter(obj, isNewEntry, trans)
            End If
        Catch err As Exception
            Throw New Exception(err.Message)
        End Try
        Return IsSaved
    End Function

    Public Shared Function SaveData_CostCenter(ByVal obj As CllsProductionLine, ByVal isNewEntry As Boolean, ByVal trans As SqlTransaction) As Boolean
        'Dim qry As String = "Delete FROM TSPL_CostCenter_MASTER WHERE Cost_Code='" + obj.PRODUCTION_LINE_CODE + "'"
        'clsDBFuncationality.ExecuteNonQuery(qry, trans)
        Try
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Cost_name", obj.PRODUCTION_LINE_NAME)
            If isNewEntry Then
                clsCommon.AddColumnsForChange(coll, "Cost_Code", obj.PRODUCTION_LINE_CODE)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_CostCenter_MASTER", OMInsertOrUpdate.Insert, "", trans)
            Else
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_CostCenter_MASTER", OMInsertOrUpdate.Update, "TSPL_CostCenter_MASTER.Cost_Code='" + obj.PRODUCTION_LINE_CODE + "'", trans)
            End If
        Catch err As Exception
            Throw New Exception(err.Message)
        End Try
        Return True
    End Function


    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As CllsProductionLine
        Return GetData(strCode, NavType, Nothing)
    End Function

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType, ByVal trans As SqlTransaction) As CllsProductionLine
        Dim obj As CllsProductionLine = Nothing
        Dim Arr As List(Of CllsProductionLine) = Nothing
        Dim qry As String = "select PRODUCTION_LINE_CODE ,PRODUCTION_LINE_NAME,DESCRIPTION from TSPL_MF_PRODUCTION_LINES where 2=2 "
        Dim whrclas As String = ""
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE = (select MIN(PRODUCTION_LINE_CODE) from TSPL_MF_PRODUCTION_LINES WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE = (select Max(PRODUCTION_LINE_CODE) from TSPL_MF_PRODUCTION_LINES WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE = (select top 1 PRODUCTION_LINE_CODE from TSPL_MF_PRODUCTION_LINES WHERE 1=1 " + whrclas + " and PRODUCTION_LINE_CODE='" + strCode + "' )"
            Case NavigatorType.Next
                qry += " and TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE = (select Min(PRODUCTION_LINE_CODE) from TSPL_MF_PRODUCTION_LINES where PRODUCTION_LINE_CODE>'" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_MF_PRODUCTION_LINES.PRODUCTION_LINE_CODE = (select Max(PRODUCTION_LINE_CODE) from TSPL_MF_PRODUCTION_LINES where PRODUCTION_LINE_CODE<'" + strCode + "' " + whrclas + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New CllsProductionLine()
            obj.PRODUCTION_LINE_CODE = clsCommon.myCstr(dt.Rows(0)("PRODUCTION_LINE_CODE"))
            obj.PRODUCTION_LINE_NAME = clsCommon.myCstr(dt.Rows(0)("PRODUCTION_LINE_NAME"))
            obj.DESCRIPTION = clsCommon.myCstr(dt.Rows(0)("DESCRIPTION"))
        End If
        Return obj
    End Function

#End Region
End Class
