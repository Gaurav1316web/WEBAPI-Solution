    Public Shared Function GetLeaveRegisterDTPeriod(ByVal arrLoc As ArrayList, ByVal arrDivision As ArrayList, ByVal arrEmp As ArrayList, ByVal strfromdate As Date, ByVal strTodate As Date, ByRef Qrystring As String) As DataTable
        Dim dt As DataTable
        Try
            Dim qry As String = ""
            qry = qry & " select Leave_Fun.EMP_CODE,emp.Emp_Name,emp.Location_Code,emp.Devision_Code,Leave_Fun.Leave_Code,Leave.Leave_Name,OPENING,ALLOTED,AVAILED,ADJUSTMENT_PLUS,ADJUSTMENT_MINUS,BALANCE from TSPL_FUN_LEAVE_STATUS_PERIOD(convert(date,'" + strfromdate + "',103),convert(date,'" + strTodate + "',103)) AS Leave_Fun " & _
                " left join tspl_employee_master emp on Leave_Fun.Emp_Code=emp.Emp_Code " & _
                " left join TSPL_LEAVE_MASTER Leave on Leave.Leave_Code=Leave_Fun.Leave_Code where 2=2 "
            If Not arrLoc Is Nothing AndAlso arrLoc.Count > 0 Then
                qry = qry & " and emp.Location_Code in (" & clsCommon.GetMulcallString(arrLoc) & ")"
            End If
            If Not arrDivision Is Nothing AndAlso arrDivision.Count > 0 Then
                qry = qry & " and emp.Devision_Code in (" & clsCommon.GetMulcallString(arrDivision) & ")"
            End If
            If Not arrEmp Is Nothing AndAlso arrEmp.Count > 0 Then
                qry = qry & " and emp.Devision_Code in (" & clsCommon.GetMulcallString(arrEmp) & ")"
            End If

            Qrystring = qry
            dt = clsDBFuncationality.GetDataTable(qry)

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return dt
    End Function
    Public Shared Function CheckNewEntry(ByVal Code As String, Optional ByVal trans As SqlTransaction = Nothing) As String
        Dim qry As String = "select LEAVE_CODE from TSPL_LEAVE_MASTER where LEAVE_CODE ='" + Code + "'   "
        Dim dt As DataTable
        dt = clsDBFuncationality.GetDataTable(qry)
        If dt.Rows.Count > 0 Then
            Return False
        Else
            Return True
        End If

    End Function
    Public Shared Function GetCboLeaveTypeDataTable() As DataTable
        Dim DT As DataTable = New DataTable
        DT.Columns.Add("Code", GetType(String))
        DT.Columns.Add("Name", GetType(String))
        Dim DR As DataRow = DT.NewRow()
        DR("Code") = "EL"
        DR("Name") = "Earned Leave"
        DT.Rows.Add(DR)

        DR = DT.NewRow()
        DR("Code") = "CL"
        DR("Name") = "Casual Leave"
        DT.Rows.Add(DR)

        DR = DT.NewRow()
        DR("Code") = "MED"
        DR("Name") = "Medical Leave"
        DT.Rows.Add(DR)

        DR = DT.NewRow()
        DR("Code") = "COFF"
        DR("Name") = "Compensatory Off"
        DT.Rows.Add(DR)

        DR = DT.NewRow()
        DR("Code") = "MATRL"
        DR("Name") = "Maternity Leave"
        DT.Rows.Add(DR)

        DR = DT.NewRow()
        DR("Code") = "Other"
        DR("Name") = "Other"
        DT.Rows.Add(DR)
        DT.AcceptChanges()
        Return DT
    End Function
