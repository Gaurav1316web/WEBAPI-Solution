    Public Shared Function GetLeaveRegisterDT(ByVal strPayPeriod As String, ByRef Qrystring As String) As DataTable
        Dim dt As DataTable
        Try
            Dim qry As String = ""
            qry += " select Leave_Fun.EMP_CODE,emp.Emp_Name,Leave_Fun.Leave_Code,Leave.Leave_Name,OPENING,ALLOTED,AVAILED,ADJUSTMENT_PLUS,ADJUSTMENT_MINUS,BALANCE from TSPL_FUN_LEAVE_STATUS('" + strPayPeriod + "') AS Leave_Fun " & _
                " left join tspl_employee_master emp on Leave_Fun.Emp_Code=emp.Emp_Code " & _
                " left join TSPL_LEAVE_MASTER Leave on Leave.Leave_Code=Leave_Fun.Leave_Code "
            Qrystring = qry
            dt = clsDBFuncationality.GetDataTable(qry)

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return dt
    End Function
    Public Shared Function GetLeaveLedgerBaseQry(ByVal arrLoc As ArrayList, ByVal arrDiv As ArrayList, arrEmp As ArrayList, ByVal arrLeave As ArrayList, ByVal arrDept As ArrayList, ByVal ShowResgnEmp As Boolean, ByVal FromDate As Date, ByVal ToDate As Date) As String
        Dim qry As String = ""
        Dim EmpCond As String = ""
        If ShowResgnEmp = False Then
            EmpCond = " and emp.RELIEVING_DATE is null "
        End If
        qry = " select *,row_number() over (partition by empcode,leavecode order by empcode,leavecode,TransDate) as Tr_id from ("
        '" select lv.EMP_CODE as empcode,emp.Emp_Name as empname,emp.DEPARTMENT_CODE as departmentcode,emp.Location_Code as loccode,emp.Devision_Code as divcode,Null as Month,lv.LEAVE_CODE as Leavecode," & _
        '" Null as TransDate,Null TransCode,'Opening' as Remarks,sum(lv.ALLOTED-lv.AVAILED) as Alloted,0 as Taken,sum(lv.ALLOTED-lv.AVAILED) as Balance " & _
        '" from TSPL_VIEW_LEAVE_LEDGER as lv " & _
        '" left join TSPL_EMPLOYEE_MASTER emp on lv.EMP_CODE=emp.EMP_CODE " & _
        '" where lv.DATE_FROM <'" & clsCommon.GetPrintDate(FromDate, "dd/MMM/yyyy") & "' " & EmpCond & " " & _
        '" group by emp.LOCATION_CODE,emp.Devision_Code,lv.EMP_CODE,emp.DEPARTMENT_CODE,emp.Emp_Name,lv.LEAVE_CODE " & _
        '" union all " & _
        qry += " select lv.EMP_CODE as empcode,emp.Emp_Name as empname,emp.DEPARTMENT_CODE as departmentcode,emp.Location_Code as loccode,emp.Devision_Code as divcode,lv.PAY_PERIOD_CODE as Month,lv.LEAVE_CODE as Leavecode, " & _
              " coalesce(lv.TR_DATE,lv.DATE_FROM) as TransDate,lv.TR_CODE,lv.REMARKS,lv.ALLOTED as Alloted,lv.AVAILED as Taken,(lv.ALLOTED-lv.AVAILED) as Balance " & _
              " from TSPL_VIEW_LEAVE_LEDGER as lv " & _
              " left join TSPL_EMPLOYEE_MASTER emp on lv.EMP_CODE=emp.EMP_CODE " & _
              " where lv.DATE_FROM >='" & clsCommon.GetPrintDate(FromDate, "dd/MMM/yyyy") & "' and lv.DATE_FROM <='" & clsCommon.GetPrintDate(ToDate, "dd/MMM/yyyy") & "' " & EmpCond & " " & _
              "  and (lv.ALLOTED >0 or lv.AVAILED>0) ) as Final where 2=2 "
        If Not arrLoc Is Nothing AndAlso arrLoc.Count > 0 Then
            qry = qry & " and Final.loccode in (" & clsCommon.GetMulcallString(arrLoc) & ")"
        End If
        If Not arrDiv Is Nothing AndAlso arrDiv.Count > 0 Then
            qry = qry & " and Final.divcode in (" & clsCommon.GetMulcallString(arrDiv) & ")"
        End If
        If Not arrEmp Is Nothing AndAlso arrEmp.Count > 0 Then
            qry = qry & " and Final.empcode in (" & clsCommon.GetMulcallString(arrEmp) & ")"
        End If
        If Not arrLeave Is Nothing AndAlso arrLeave.Count > 0 Then
            qry = qry & " and Final.leavecode in (" & clsCommon.GetMulcallString(arrLeave) & ")"
        End If
        If Not arrDept Is Nothing AndAlso arrDept.Count > 0 Then
            qry = qry & " and Final.departmentcode in (" & clsCommon.GetMulcallString(arrDept) & ")"
        End If
        
        Return qry
    End Function
    Public Shared Function GetLeaveLedgerDetailQry(ByVal arrLoc As ArrayList, ByVal arrDiv As ArrayList, arrEmp As ArrayList, ByVal arrLeave As ArrayList, ByVal arrDept As ArrayList, ByVal ShowResgnEmp As Boolean, ByVal FromDate As Date, ByVal ToDate As Date) As String
        'Outermost.TransCode, Outermost.Alloted
        Dim qry As String = GetLeaveLedgerBaseQry(arrLoc, arrDiv, arrEmp, arrLeave, arrDept, ShowResgnEmp, FromDate, ToDate)
        qry = " select Outermost.empcode,Outermost.empname,emp.Joining_date as doj,convert(varchar,emp.RELIEVING_DATE,103) as dol,Outermost.departmentcode,Dept.Department_Name as departmentname,emp.location_code as location,loc.Location_desc as locationDesc,emp.Devision_code as Divisioncode,Div.Devision_Name as DevisionDesc,Outermost.Month,Outermost.Leavecode,Outermost.TransDate," & _
              " Outermost.Remarks,(case when Outermost.Alloted>0 then Outermost.Alloted else sum(outermost.Balance) over (partition by outermost.empcode,outermost.leavecode order by outermost.empcode,outermost.leavecode,outermost.Tr_Id)+Outermost.Taken end) as Alloted " & _
              ",Outermost.Taken,Outermost.Balance, " & _
              " sum(outermost.Balance) over (partition by outermost.empcode,outermost.leavecode order by outermost.empcode,outermost.leavecode,outermost.Tr_Id) as RunningBalance from " & _
              " (" & qry & ") as Outermost " & _
              " left join tspl_employee_master emp on Outermost.empcode=emp.emp_code " & _
              " left join tspl_location_master loc on emp.location_code=loc.location_code " & _
              " left join TSPL_DEVISION_MASTER Div on emp.devision_code=Div.Devision_code " & _
              " left join TSPL_DEPARTMENT_MASTER Dept on emp.department_code=Dept.department_code " & _
              " order by Outermost.empcode,Outermost.Leavecode,Outermost.TransDate"
        Return qry
    End Function
    Public Shared Function GetLeaveLedgerSummaryQry(ByVal arrLoc As ArrayList, ByVal arrDiv As ArrayList, arrEmp As ArrayList, ByVal arrLeave As ArrayList, ByVal arrDept As ArrayList, ByVal ShowResgnEmp As Boolean, ByVal FromDate As Date, ByVal ToDate As Date) As String
        Dim qry As String = GetLeaveLedgerBaseQry(arrLoc, arrDiv, arrEmp, arrLeave, arrDept, ShowResgnEmp, FromDate, ToDate)
        qry = " select Outermost.empcode,Outermost.empname,emp.Joining_date as doj,convert(varchar,emp.RELIEVING_DATE,103) as dol,Outermost.departmentcode,Dept.Department_Name as departmentname,emp.location_code as location,loc.Location_desc as locationDesc,emp.Devision_code as Divisioncode,Div.Devision_Name as DevisionDesc,Outermost.Leavecode,sum(Outermost.Balance) as Balance from " & _
              " (" & qry & ") as Outermost " & _
              " left join tspl_employee_master emp on Outermost.empcode=emp.emp_code " & _
              " left join tspl_location_master loc on emp.location_code=loc.location_code " & _
              " left join TSPL_DEVISION_MASTER Div on emp.devision_code=Div.Devision_code " & _
              " left join TSPL_DEPARTMENT_MASTER Dept on emp.department_code=Dept.department_code " & _
              " group by Outermost.empcode,Outermost.empname,emp.Joining_date,emp.RELIEVING_DATE,Outermost.Leavecode,emp.location_code,loc.Location_desc,emp.Devision_code,Div.Devision_Name,Outermost.departmentcode,Dept.Department_Name " & _
              " order by Outermost.empcode,Outermost.Leavecode"
        Return qry
    End Function
    Public Shared Function GetLeaveLedgerDetaildt(ByVal arrLoc As ArrayList, ByVal arrDiv As ArrayList, arrEmp As ArrayList, ByVal arrLeave As ArrayList, ByVal arrDept As ArrayList, ByVal ShowResgnEmp As Boolean, ByVal FromDate As Date, ByVal ToDate As Date) As DataTable
        Dim qry As String = GetLeaveLedgerDetailQry(arrLoc, arrDiv, arrEmp, arrLeave, arrDept, ShowResgnEmp, FromDate, ToDate)
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
