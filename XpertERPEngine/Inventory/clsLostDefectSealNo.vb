    Public Shared Function deleteData(ByVal doc_No As String, ByVal tran As SqlTransaction) As Boolean
        Try
            Dim isDeleted As Boolean = True
            Dim qry As String = "delete from Tspl_Lost_defect_sealNo_Details where  doc_No='" & doc_No & "'"
            isDeleted = isDeleted AndAlso clsDBFuncationality.ExecuteNonQuery(qry, tran)
            qry = "delete from Tspl_Lost_defect_sealNo_Head where  doc_No='" & doc_No & "'"
            isDeleted = isDeleted AndAlso clsDBFuncationality.ExecuteNonQuery(qry, tran)
            Return isDeleted
        Catch ex As Exception
            Throw New Exception(ex.Message)
            Return False
        End Try
    End Function
