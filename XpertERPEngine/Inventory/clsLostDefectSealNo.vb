            '        If clsCommon.myLen(strGITLoc) > 0 Then
            '            Dim strInvCntrlAcFrom As String = dt.Rows(0)("Inv_Control_Account")
            '            strInvCntrlAcFrom = clsERPFuncationality.ChangeGLAccountLocationSegment(strInvCntrlAcFrom, dt.Rows(0)("MCC_Code"), trans)
            '            Dim strInvCntrlAcTo As String = dt.Rows(0)("Inv_Control_Account")
            '            strInvCntrlAcTo = clsERPFuncationality.ChangeGLAccountLocationSegment(strInvCntrlAcTo, strGITLoc, trans)
            '            Dim strStkTrnsfAcFrom As String = strStocktrnsfrAc
            '            strStkTrnsfAcFrom = clsERPFuncationality.ChangeGLAccountLocationSegment(strStkTrnsfAcFrom, strGITLoc, trans)
            '            Dim strStkTrnsfAcTo As String = strStocktrnsfrAc
            '            strStkTrnsfAcTo = clsERPFuncationality.ChangeGLAccountLocationSegment(strStkTrnsfAcTo, dt.Rows(0)("MCC_Code"), trans)
            '            ArryLst.Add(New String() {strInvCntrlAcTo, dt.Rows(0)("Amt")})
