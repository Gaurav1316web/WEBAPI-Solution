Public Class clsLostDefectSealNoDetails
    Public DOC_No As String = Nothing
    Public Seal_No As String = Nothing


    Public Shared Function SaveData(ByVal arr As List(Of clsLostDefectSealNoDetails), ByVal tran As SqlTransaction) As Boolean
        Dim issaved As Boolean = True
        Try
            Dim i As Integer = 0
            If arr.Count > 0 Then
                Dim qry As String = "delete from Tspl_Lost_defect_sealNo_Details where  Doc_No='" & arr.Item(0).DOC_No & "'"
                clsDBFuncationality.ExecuteNonQuery(qry, tran)
                For i = 0 To arr.Count - 1
                    Dim coll As New Hashtable()
                    clsCommon.AddColumnsForChange(coll, "DOC_No", arr.Item(i).DOC_No)
                    clsCommon.AddColumnsForChange(coll, "Seal_No", arr.Item(i).Seal_No)
                    issaved = issaved And clsCommonFunctionality.UpdateDataTable(coll, "Tspl_Lost_defect_sealNo_Details", OMInsertOrUpdate.Insert, "", tran)
                Next
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return issaved
    End Function
    Public Shared Function getData(ByVal doc_no As String) As List(Of clsLostDefectSealNoDetails)
        Dim arr As New List(Of clsLostDefectSealNoDetails)
        Try
            Dim obj As New clsLostDefectSealNoDetails
            Dim q As String = "select * from Tspl_Lost_defect_sealNo_Details where doc_no='" & doc_no & "'"
            Dim dtbl As DataTable = clsDBFuncationality.GetDataTable(q)
            If dtbl IsNot Nothing AndAlso dtbl.Rows.Count > 0 Then
                For i As Integer = 0 To dtbl.Rows.Count - 1
                    obj = New clsLostDefectSealNoDetails
                    obj.DOC_No = clsCommon.myCstr(dtbl.Rows(i)("DOC_No"))
                    obj.Seal_No = clsCommon.myCstr(dtbl.Rows(i)("Seal_No"))
                    arr.Add(obj)
                Next
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return arr
    End Function

