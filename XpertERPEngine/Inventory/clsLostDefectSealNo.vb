            'qry = " select TSPL_MCC_Dispatch_Challan.MCC_Code,TSPL_MCC_Dispatch_Challan.Mcc_Or_Plant_Code ,TSPL_PURCHASE_ACCOUNTS.Inv_Control_Account,TSPL_MCC_Dispatch_Challan.Transfer_Price*TSPL_MCC_Dispatch_Challan.Net_Qty as Amt   from TSPL_PURCHASE_ACCOUNTS left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Purchase_Class_Code =TSPL_PURCHASE_ACCOUNTS.Purchase_Class_Code left outer join TSPL_MCC_Dispatch_Challan  on TSPL_MCC_Dispatch_Challan .Item_Code=TSPL_ITEM_MASTER.Item_Code where TSPL_MCC_Dispatch_Challan.Chalan_NO ='" & obj.Chalan_NO & "' "
