    Public Shared Function getFinder(ByVal whrcls As String, ByVal curcode As String, ByVal isButtonClicked As Boolean) As String
        Dim str As String = ""
        Try
            Dim qry As String = "  select Tspl_Lost_defect_sealNo_Head.DOC_No as [DocNo] ,Tspl_Lost_defect_sealNo_Head.DOC_DATE as [Doc Date] ,Tspl_Lost_defect_sealNo_Head.Doc_type as [Doc Type],case when  isnull(Tspl_Lost_defect_sealNo_Head.Isposted,0)=0 then 'Yes' else 'No'end as [Is Posted] ,Tspl_Lost_defect_sealNo_Head.Location_code as [Location Code] ,Tspl_Lost_defect_sealNo_Head.Created_By as [Created By] ,Tspl_Lost_defect_sealNo_Head.Created_Date as [Created Date] ,Tspl_Lost_defect_sealNo_Head.Modified_By as [Modified By] ,Tspl_Lost_defect_sealNo_Head.Modified_Date as [Modified Date] ,Tspl_Lost_defect_sealNo_Head.Comp_Code as [Comp Code],Tspl_Lost_defect_sealNo_Head.Seal_Type as [Seal Type]  From Tspl_Lost_defect_sealNo_Head  "
            str = clsCommon.ShowSelectForm("LostDefectSealNo", qry, "DocNo", whrcls, curcode, "DocNo", isButtonClicked)

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return str
    End Function
    Public Shared Function SaveData(ByVal obj As clsLostDefectSealNoHead, ByVal tran As SqlTransaction) As Boolean
        Dim issaved As Boolean = True
        Try
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Doc_type", obj.Doc_type)
            clsCommon.AddColumnsForChange(coll, "DOC_DATE", clsCommon.GetPrintDate(obj.DOC_DATE, "dd/MMM/yyyy"))
            clsCommon.AddColumnsForChange(coll, "Location_code", obj.Location_code)
            clsCommon.AddColumnsForChange(coll, "item_code", obj.item_code)
            clsCommon.AddColumnsForChange(coll, "qty", clsCommon.myCdbl(obj.qty))
            clsCommon.AddColumnsForChange(coll, "Modified_By", obj.Modified_By)
            clsCommon.AddColumnsForChange(coll, "remarks", obj.remarks)
            clsCommon.AddColumnsForChange(coll, "seal_Type", obj.seal_type)
            'clsCommon.AddColumnsForChange(coll, "item_code", obj.item_code)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(obj.Modified_Date, "dd/MMM/yyyy"))
            clsCommon.AddColumnsForChange(coll, "isPosted", 0)
            clsCommon.AddColumnsForChange(coll, "Comp_Code", obj.Comp_Code)
            If obj.isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from Tspl_Lost_defect_sealNo_Head where DOC_No='" & obj.DOC_No & "'")
                    If ChkNewEntry = 0 Then
                        obj.DOC_No = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(obj.DOC_DATE, "dd/MM/yyyy"), clsDocType.LostDefectSealNo, "", "")
                        If clsCommon.myLen(obj.DOC_No) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "DOC_No", obj.DOC_No)
                clsCommon.AddColumnsForChange(coll, "Created_By", obj.Created_By)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(obj.Created_Date, "dd/MMM/yyyy"))
                issaved = issaved And clsCommonFunctionality.UpdateDataTable(coll, "Tspl_Lost_defect_sealNo_Head", OMInsertOrUpdate.Insert, "", tran)
            Else
                issaved = issaved And clsCommonFunctionality.UpdateDataTable(coll, "Tspl_Lost_defect_sealNo_Head", OMInsertOrUpdate.Update, "Tspl_Lost_defect_sealNo_Head.doc_no='" + obj.DOC_No + "'", tran)
            End If
            issaved = issaved And clsLostDefectSealNoDetails.SaveData(obj.arrObj, tran)

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return issaved
    End Function
    Public Shared Function getData(ByVal strCode As String, ByVal navtype As NavigatorType) As clsLostDefectSealNoHead
        Dim obj As New clsLostDefectSealNoHead
        Try

            Dim whrCls As String = String.Empty
            If clsCommon.myLen(objCommonVar.strCurrUserLocations) > 0 And clsCommon.myLen(strCode) <= 0 Then
                whrCls = " and Location_code in (" & objCommonVar.strCurrUserLocations & ") "
            End If
            obj.arrObj = New List(Of clsLostDefectSealNoDetails)
            Dim qst As String = " select *   From Tspl_Lost_defect_sealNo_Head   where 1=1 " & whrCls
            Select Case navtype
                Case NavigatorType.Current
                    qst += " and Tspl_Lost_defect_sealNo_Head.doc_no in ('" + strCode + "')"
                Case NavigatorType.Next
                    qst += " and Tspl_Lost_defect_sealNo_Head.doc_no in (select min(doc_no ) from Tspl_Lost_defect_sealNo_Head where doc_no  >'" + strCode + "' " & whrCls & ") "
                Case NavigatorType.First
                    qst += " and Tspl_Lost_defect_sealNo_Head.doc_no in (select MIN(doc_no ) from Tspl_Lost_defect_sealNo_Head where 1=1 " & whrCls & ") "
                Case NavigatorType.Last
                    qst += " and Tspl_Lost_defect_sealNo_Head.doc_no in (select Max(doc_no ) from Tspl_Lost_defect_sealNo_Head where 1=1 " & whrCls & ") "
                Case NavigatorType.Previous
                    qst += " and Tspl_Lost_defect_sealNo_Head.doc_no in (select Max(doc_no ) from Tspl_Lost_defect_sealNo_Head where doc_no  <'" + strCode + "' " & whrCls & ") "
            End Select
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                obj.DOC_No = clsCommon.myCstr(dt.Rows(0)("DOC_No"))
                obj.Doc_type = clsCommon.myCstr(dt.Rows(0)("Doc_type"))
                obj.item_code = clsCommon.myCstr(dt.Rows(0)("item_code"))
                obj.qty = clsCommon.myCdbl(dt.Rows(0)("qty"))
                obj.DOC_DATE = clsCommon.myCDate(dt.Rows(0)("DOC_DATE"))
                obj.Location_code = clsCommon.myCstr(dt.Rows(0)("Location_code"))
                obj.remarks = clsCommon.myCstr(dt.Rows(0)("remarks"))
                obj.seal_type = clsCommon.myCstr(dt.Rows(0)("seal_type"))
                obj.isPosted = clsCommon.myCdbl(dt.Rows(0)("isPosted"))
                If obj.isPosted = 1 Then
                    obj.Posting_Date = clsCommon.myCDate(dt.Rows(0)("Posting_Date"))
                End If
                obj.arrObj = clsLostDefectSealNoDetails.getData(obj.DOC_No)
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return obj
    End Function

    Public Shared Function PostData(ByVal FormId As String, ByVal strDocNo As String) As Boolean
