Imports common
Imports System.Data.SqlClient
Public Class clsBreakageHead

#Region "Variables"
    Public Breakage_Type As String = ""
    Public Description As String = ""
#End Region


    Public Function SaveData(ByVal obj As clsBreakageHead, ByVal isNewEntry As Boolean) As Boolean
        Dim isSaved As Boolean = True
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Description", obj.Description)
            clsCommon.AddColumnsForChange(coll, "Comp_Code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "Modify_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modify_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_BREAKAGE_HEAD where Breakage_Type='" & obj.Breakage_Type & "'", trans)
                    If ChkNewEntry = 0 Then
                        obj.Breakage_Type = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.BreakageHead, "", "")
                        If clsCommon.myLen(obj.Breakage_Type) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Breakage_Type", obj.Breakage_Type)
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))

                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_BREAKAGE_HEAD", OMInsertOrUpdate.Insert, "", trans)
            Else
                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_BREAKAGE_HEAD", OMInsertOrUpdate.Update, "Breakage_Type='" + obj.Breakage_Type + "'", trans)
            End If
            If isSaved Then
                trans.Commit()
            End If
        Catch err As Exception
            trans.Rollback()
            Throw New Exception(err.Message)
        End Try
        Return isSaved
    End Function

    Public Shared Function GetData(ByVal BreakageType As String, ByVal NavType As common.NavigatorType) As clsBreakageHead
        Return GetData(BreakageType, NavType, Nothing)
    End Function

    Public Shared Function GetData(ByVal BreakageType As String, ByVal NavType As common.NavigatorType, ByVal trans As SqlTransaction) As clsBreakageHead
        Dim obj As clsBreakageHead = Nothing
        Dim qry As String = "SELECT TSPL_BREAKAGE_HEAD.Breakage_Type, TSPL_BREAKAGE_HEAD.Description from TSPL_BREAKAGE_HEAD where  2=2"
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_BREAKAGE_HEAD.Breakage_Type=(select MIN(Breakage_Type) from TSPL_BREAKAGE_HEAD)"
            Case NavigatorType.Last
                qry += " and TSPL_BREAKAGE_HEAD.Breakage_type=(select Max(Breakage_Type) from TSPL_BREAKAGE_HEAD)"
            Case NavigatorType.Next
                qry += " and TSPL_BREAKAGE_HEAD.Breakage_type=(select Min(Breakage_Type) from TSPL_BREAKAGE_HEAD where Breakage_Type > '" + BreakageType + "')"
            Case NavigatorType.Previous
                qry += " and TSPL_BREAKAGE_HEAD.Breakage_type=(select Max(Breakage_Type) from TSPL_BREAKAGE_HEAD where Breakage_Type < '" + BreakageType + "')"
            Case NavigatorType.Current
                qry += " and TSPL_BREAKAGE_HEAD.Breakage_type='" + BreakageType + "'"
        End Select

        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New clsBreakageHead()
            obj.Breakage_Type = clsCommon.myCstr(dt.Rows(0)("Breakage_Type"))
            obj.Description = clsCommon.myCstr(dt.Rows(0)("Description"))
        End If

        Return obj
    End Function


    Public Shared Function DeleteData(ByVal Breakage_Type As String) As Boolean
        Dim isSaved As Boolean = False
        If (clsCommon.myLen(Breakage_Type) <= 0) Then
            Throw New Exception("Breakage Type not found to Delete")
        End If
        Dim obj As clsBreakageHead = clsBreakageHead.GetData(Breakage_Type, NavigatorType.Current)
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Breakage_Type) > 0) Then
            Try
                Dim qry As String = "delete from TSPL_ITEM_SUB_CATEGORY where Sub_Category_Code='" + Breakage_Type + "'"
                isSaved = clsDBFuncationality.ExecuteNonQuery(qry, trans)

                qry = "delete from TSPL_BREAKAGE_HEAD where Breakage_Type='" + Breakage_Type + "'"
                isSaved = isSaved AndAlso clsDBFuncationality.ExecuteNonQuery(qry, trans)

                If (isSaved) Then
                    trans.Commit()
                Else
                    trans.Rollback()
                End If
            Catch ex As Exception
                trans.Rollback()
                Throw New Exception(ex.Message)
            End Try
        End If
        Return isSaved
    End Function


    Public Shared Function SaveData(ByVal Breakage_Type As String, ByVal Arr As List(Of clsBreakageHead), ByVal trans As SqlTransaction) As Boolean
        Dim Description As String = ""
        If (Arr IsNot Nothing AndAlso Arr.Count > 0) Then
            For Each obj As clsBreakageHead In Arr
                Dim coll As New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Breakkage_Type", Breakage_Type)
                clsCommon.AddColumnsForChange(coll, "Description", Description)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_BREAKAGE_HEAD", OMInsertOrUpdate.Insert, "", trans)

            Next
        End If
        Return True
    End Function


