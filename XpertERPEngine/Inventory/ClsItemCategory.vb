Imports common
Imports System.Data.SqlClient
Public Class ClsItemCategory



#Region "Variables"
    Public Category_Code As String
    Public Category_Name As String
    Public ArrTr As List(Of ClsItemCategory) = Nothing
    Public Status As ERPTransactionStatus = 0
#End Region


    Public Function SaveData(ByVal obj As ClsItemCategory, ByVal isNewEntry As Boolean) As Boolean
        Dim isSaved As Boolean = True
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Category_Name", obj.Category_Name)
            clsCommon.AddColumnsForChange(coll, "Comp_Code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "Modify_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modify_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from tspl_Item_Category where Category_code='" & obj.Category_Code & "'", trans)
                    If ChkNewEntry = 0 Then
                        obj.Category_Code = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.ItemCategory, "", "")
                        If clsCommon.myLen(obj.Category_Code) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Category_Code", obj.Category_Code)
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))
                Dim qry As String = "select COUNT (*) from tspl_Item_Category where Category_code = '" & obj.Category_Code & "'"
                Dim check As Integer = clsDBFuncationality.getSingleValue(qry, trans)
                If check = 0 Then
                    isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_CATEGORY", OMInsertOrUpdate.Insert, "", trans)
                Else
                    Throw New Exception("This value Is Already Exist")
                End If
                'isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_CATEGORY", OMInsertOrUpdate.Insert, "", trans)
            Else
                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_CATEGORY", OMInsertOrUpdate.Update, "Category_Code='" + obj.Category_Code + "'", trans)
            End If
            If isSaved Then
                trans.Commit()
            End If
        Catch err As Exception
            trans.Rollback()
            Throw New Exception(err.Message)
        End Try
        Return isSaved
    End Function

    Public Shared Function GetData(ByVal CategoryCode As String, ByVal NavType As common.NavigatorType) As ClsItemCategory
        Return GetData(CategoryCode, NavType, Nothing)
    End Function

    Public Shared Function GetData(ByVal CategoryCode As String, ByVal NavType As common.NavigatorType, ByVal trans As SqlTransaction) As ClsItemCategory
        Dim obj As ClsItemCategory = Nothing
        Dim qry As String = "SELECT Category_Code, Category_name from TSPL_Item_Category where  2=2"
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_ITEM_CATEGORY.Category_Code=(select MIN(Category_Code) from TSPL_ITEM_CATEGORY)"
            Case NavigatorType.Last
                qry += " and TSPL_ITEM_CATEGORY.Category_Code=(select Max(Category_Code) from TSPL_ITEM_CATEGORY)"
            Case NavigatorType.Next
                qry += " and TSPL_ITEM_CATEGORY.Category_Code=(select Min(Category_Code) from TSPL_ITEM_CATEGORY where Category_Code > '" + CategoryCode + "')"
            Case NavigatorType.Previous
                qry += " and TSPL_ITEM_CATEGORY.Category_Code=(select Max(Category_Code) from TSPL_ITEM_CATEGORY where Category_Code < '" + CategoryCode + "')"
            Case NavigatorType.Current
                qry += " and TSPL_ITEM_CATEGORY.Category_Code='" + CategoryCode + "'"
        End Select

        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New ClsItemCategory()
            obj.Category_Code = clsCommon.myCstr(dt.Rows(0)("Category_Code"))
            obj.Category_Name = clsCommon.myCstr(dt.Rows(0)("Category_Name"))
        End If

        Return obj
    End Function

    Public Shared Function GetCategoryDescription(ByVal strCategoryCode As String, Optional ByVal trans As SqlTransaction = Nothing) As String
        Try
            Return clsCommon.myCstr(clsDBFuncationality.getSingleValue("Select Category_Name from TSPL_ITEM_CATEGORY WHERE Category_Code='" + strCategoryCode + "'", trans))
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function

    Public Shared Function DeleteData(ByVal Category_Code As String) As Boolean
        Dim isSaved As Boolean = False
        If (clsCommon.myLen(Category_Code) <= 0) Then
            Throw New Exception("Category_Code not found to Delete")
        End If
        Dim obj As ClsItemCategory = ClsItemCategory.GetData(Category_Code, NavigatorType.Current)
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Category_Code) > 0) Then
            Try
                Dim qry As String = "delete from TSPL_ITEM_CATEGORY where Category_Code='" + Category_Code + "'"
                isSaved = clsDBFuncationality.ExecuteNonQuery(qry, trans)

                qry = "delete from TSPL_ITEM_CATEGORY where Category_Code='" + Category_Code + "'"
                isSaved = isSaved AndAlso clsDBFuncationality.ExecuteNonQuery(qry, trans)

                If (isSaved) Then
                    trans.Commit()
                Else
                    trans.Rollback()
                End If
            Catch ex As Exception
                trans.Rollback()
                Throw New Exception(ex.Message)
            End Try
        End If
        Return isSaved
    End Function

