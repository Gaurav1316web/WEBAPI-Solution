    Public Shared Function SaveData(ByVal Category_Code As String, ByVal Arr As List(Of ClsItemCategory), ByVal trans As SqlTransaction) As Boolean
        Dim Category_Name As String = ""
        If (Arr IsNot Nothing AndAlso Arr.Count > 0) Then
            For Each obj As ClsItemCategory In Arr
                Dim coll As New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Category_Code", Category_Code)
                clsCommon.AddColumnsForChange(coll, "Category_Name", Category_Name)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ITEM_CATEGORY", OMInsertOrUpdate.Insert, "", trans)

            Next
        End If
        Return True
    End Function


    Public Shared Function CompleteRequition(ByVal Category_Code As String, ByVal strICode As String, ByVal LineNo As Integer) As Boolean
        Dim qry As String = "update TSPL_Item_Category set Category_Name ='tbCategoryName.text' where Category_Code='" + Category_Code + "' "
        Return clsDBFuncationality.ExecuteNonQuery(qry)
    End Function
End Class
