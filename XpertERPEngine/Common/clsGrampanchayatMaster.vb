Imports common
Imports System.Data
Imports System.Data.SqlClient

Public Class clsGrampanchayatMaster
#Region "Variables"
    Public code As String = Nothing
    Public name As String = Nothing
#End Region
    '----------------Code For Get Finder--------------------------------------------------------------------'
    Public Shared Function getFinder(ByVal whrcls As String, ByVal curcode As String, ByVal isButtonClicked As Boolean) As String
        Dim str As String = ""
        Dim qry As String = "select TSPL_GRAMPANCHAYAT_MASTER.GRAMPANCHAYAT_CODE as [Code] ,TSPL_GRAMPANCHAYAT_MASTER.GRAMPANCHAYAT_NAME as [Grampanchayat Name] ,TSPL_GRAMPANCHAYAT_MASTER.Created_By as [Created By] ,TSPL_GRAMPANCHAYAT_MASTER.Created_Date as [Created Date] ,TSPL_GRAMPANCHAYAT_MASTER.Modified_By as [Modified By] ,TSPL_GRAMPANCHAYAT_MASTER.Modified_Date as [Modified Date]  From TSPL_GRAMPANCHAYAT_MASTER  "
        str = clsCommon.ShowSelectForm("RGNFND@Grampanchayat@MAster", qry, "Code", whrcls, curcode, "Code", isButtonClicked)
        Return str
    End Function
    '----------------End of Code For Get Finder--------------------------------------------------------------'

    Public Shared Function SaveData(ByVal obj As clsGrampanchayatMaster, ByVal strCode As String) As Boolean
        Try

            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_GRAMPANCHAYAT_MASTER where GRAMPANCHAYAT_CODE='" & obj.code & "'")
                If ChkNewEntry = 0 Then
                    obj.code = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy"), clsDocType.GrampanchayatMaster, "", "")
                    If clsCommon.myLen(obj.code) <= 0 Then
                        Throw New Exception("Error in Grampanchayat Code Generation")
                    End If
                End If
            End If

            Dim coll As New Hashtable()
            Dim qry As String = "SELECT Count(*) FROM TSPL_GRAMPANCHAYAT_MASTER where GRAMPANCHAYAT_CODE= '" & obj.code & "'"
            Dim check As Integer = clsDBFuncationality.getSingleValue(qry)
            clsCommon.AddColumnsForChange(coll, "GRAMPANCHAYAT_NAME", obj.name)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))

            clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))
            If check > 0 Then
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_GRAMPANCHAYAT_MASTER", OMInsertOrUpdate.Update, "GRAMPANCHAYAT_CODE='" + obj.code + "'")
            Else
                clsCommon.AddColumnsForChange(coll, "GRAMPANCHAYAT_CODE", obj.code)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_GRAMPANCHAYAT_MASTER", OMInsertOrUpdate.Insert, "")
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return True
    End Function

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsGrampanchayatMaster
        Try
            Dim obj As clsGrampanchayatMaster = Nothing
            Dim qry As String = "select GRAMPANCHAYAT_CODE, GRAMPANCHAYAT_NAME from TSPL_GRAMPANCHAYAT_MASTER where 2=2"
            Select Case NavType
                Case NavigatorType.First
                    qry += " and GRAMPANCHAYAT_CODE = (select MIN(GRAMPANCHAYAT_CODE) from TSPL_GRAMPANCHAYAT_MASTER)"
                Case NavigatorType.Last
                    qry += " and GRAMPANCHAYAT_CODE = (select Max(GRAMPANCHAYAT_CODE) from TSPL_GRAMPANCHAYAT_MASTER)"
                Case NavigatorType.Next
                    qry += " and GRAMPANCHAYAT_CODE = (select Min(GRAMPANCHAYAT_CODE) from TSPL_GRAMPANCHAYAT_MASTER where  GRAMPANCHAYAT_CODE>'" + strCode + "')"
                Case NavigatorType.Previous
                    qry += " and GRAMPANCHAYAT_CODE = (select Max(GRAMPANCHAYAT_CODE) from TSPL_GRAMPANCHAYAT_MASTER where GRAMPANCHAYAT_CODE<'" + strCode + "')"
                Case NavigatorType.Current
                    qry += " and GRAMPANCHAYAT_CODE = '" + strCode + "'"

            End Select
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)


            If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
                obj = New clsGrampanchayatMaster()
                obj.code = clsCommon.myCstr(dt.Rows(0)("GRAMPANCHAYAT_CODE"))
                obj.name = clsCommon.myCstr(dt.Rows(0)("GRAMPANCHAYAT_NAME"))
            End If
            Return obj
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function

    Public Shared Function GetName(ByVal strCode As String) As String
        Dim qry As String = "Select GRAMPANCHAYAT_NAME from TSPL_GRAMPANCHAYAT_MASTER where GRAMPANCHAYAT_CODE='" + strCode + "'"
        Return clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry))
    End Function

End Class