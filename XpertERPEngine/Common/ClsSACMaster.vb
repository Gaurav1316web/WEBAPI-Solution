    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsVendorSubGroup
        Dim obj As clsVendorSubGroup = Nothing
        Dim qry As String = "select TSPL_VENDOR_SUB_GROUP.* from TSPL_VENDOR_SUB_GROUP   where 2=2 "
        Dim whrclas As String = ""
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code = (select MIN(Ven_Sub_Group_Code) from TSPL_VENDOR_SUB_GROUP WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code = (select Max(Ven_Sub_Group_Code) from TSPL_VENDOR_SUB_GROUP WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code = (select TOP 1 Ven_Sub_Group_Code from TSPL_VENDOR_SUB_GROUP WHERE 1=1 " + whrclas + " and Ven_Sub_Group_Code='" + strCode + "' )"
            Case NavigatorType.Next
                qry += " and TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code = (select Min(Ven_Sub_Group_Code) from TSPL_VENDOR_SUB_GROUP where Ven_Sub_Group_Code > '" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code = (select Max(Ven_Sub_Group_Code) from TSPL_VENDOR_SUB_GROUP where Ven_Sub_Group_Code < '" + strCode + "' " + whrclas + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New clsVendorSubGroup()
            obj.VendorSubCode = clsCommon.myCstr(dt.Rows(0)("Ven_Sub_Group_Code"))
            obj.Description = clsCommon.myCstr(dt.Rows(0)("SubGroup_Desc"))
        End If
        Return obj
    End Function

    Public Shared Function GetName(ByVal strCode As String) As String
        Return clsCommon.myCstr(clsDBFuncationality.getSingleValue("select SubGroup_Desc from TSPL_VENDOR_SUB_GROUP where Ven_Sub_Group_Code='" + strCode + "'"))
    End Function
    Public Shared Function getFinder(ByVal whrcls As String, ByVal curcode As String, ByVal isButtonClicked As Boolean) As String
        Dim str As String = ""
        Dim qry As String = "select TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code as Code,TSPL_VENDOR_SUB_GROUP.SubGroup_Desc as Description from TSPL_VENDOR_SUB_GROUP "
        str = clsCommon.ShowSelectForm("AreaFnd", qry, "Code", whrcls, curcode, "Code", isButtonClicked)
        Return str

    End Function
    Public Shared Function DeleteData(ByVal strCode As String) As Boolean
        Dim qry As String = ""
        Try
            qry = "Delete from TSPL_VENDOR_SUB_GROUP where TSPL_VENDOR_SUB_GROUP.Ven_Sub_Group_Code='" + strCode + "'"
            clsDBFuncationality.ExecuteNonQuery(qry)
        Catch err As Exception
            Throw New Exception(err.Message)
        End Try
        Return True
    End Function
End Class
