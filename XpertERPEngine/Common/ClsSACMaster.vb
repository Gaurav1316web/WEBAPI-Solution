Public Class clsItemRackbinMapping
#Region "Variables"
    Public Bin_Code As String = Nothing
    Public Description As String = Nothing
    Public Rack_Code As String = Nothing
    Public Location As String = Nothing
    Public Item_Code As String = Nothing
    Public Arr As List(Of clsItemRackbinMapping) = Nothing
#End Region

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsItemRackbinMapping
        Dim obj As New clsItemRackbinMapping
        Dim qry As String = "select TSPL_Item_Rack_Bin_Mapping.* from TSPL_Item_Rack_Bin_Mapping   where 2=2 "
        Dim whrclas As String = ""
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_Item_Rack_Bin_Mapping.Location = (select MIN(Location) from TSPL_Item_Rack_Bin_Mapping WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_Item_Rack_Bin_Mapping.Location = (select Max(Location) from TSPL_Item_Rack_Bin_Mapping WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_Item_Rack_Bin_Mapping.Location = (select TOP 1 Location from TSPL_Item_Rack_Bin_Mapping WHERE 1=1 " + whrclas + " and Location='" + strCode + "' )"
            Case NavigatorType.Next
                qry += " and TSPL_Item_Rack_Bin_Mapping.Location = (select Min(Location) from TSPL_Item_Rack_Bin_Mapping where Location > '" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_Item_Rack_Bin_Mapping.Location = (select Max(Location) from TSPL_Item_Rack_Bin_Mapping where Location < '" + strCode + "' " + whrclas + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj.Arr = New List(Of clsItemRackbinMapping)
            Dim objTr As clsItemRackbinMapping
            For Each dr As DataRow In dt.Rows
                objTr = New clsItemRackbinMapping
                objTr.Location = clsCommon.myCstr(dr("Location"))
                objTr.Rack_Code = clsCommon.myCstr(dr("Rack_Code"))
                objTr.Bin_Code = clsCommon.myCstr(dr("Bin_Code"))
                objTr.Item_Code = clsCommon.myCstr(dr("Item_Code"))
                obj.Location = clsCommon.myCstr(dr("Location"))
                obj.Arr.Add(objTr)
            Next


        End If
        Return obj
    End Function

    Public Function SaveData(ByVal strLocation As String, ByVal Arr As List(Of clsItemRackbinMapping), Optional ByVal trans As SqlTransaction = Nothing) As Boolean
        Dim qry As String = "delete from TSPL_Item_Rack_Bin_Mapping where Location ='" + strLocation + "'"
        clsDBFuncationality.ExecuteNonQuery(qry, trans)
        If (Arr IsNot Nothing AndAlso Arr.Count > 0) Then
            For Each obj As clsItemRackbinMapping In Arr
                Dim coll As New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Location", obj.Location)
                clsCommon.AddColumnsForChange(coll, "Item_Code", obj.Item_Code)
                clsCommon.AddColumnsForChange(coll, "Rack_Code", obj.Rack_Code)
                clsCommon.AddColumnsForChange(coll, "Bin_Code", obj.Bin_Code)

                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_Item_Rack_Bin_Mapping", OMInsertOrUpdate.Insert, "", trans)
            Next
        End If
        Return True
    End Function
End Class

