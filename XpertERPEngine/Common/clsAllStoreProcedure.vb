            strProcedureBody = "@TYPE TYPE_TSPL_HEADWISE_SALARY READONLY,@_COND VARCHAR(MAX),@STRQOUT VARCHAR(MAX) OUTPUT AS  DECLARE @PAY_PERIOD_CODE VARCHAR(MAX),@LOCATION_CODE VARCHAR(MAX),@DEVISION_CODE VARCHAR(MAX); DECLARE @str  VARCHAR(MAX); DECLARE @str1 VARCHAR(MAX); DECLARE @str2 VARCHAR(MAX); DECLARE @str3 VARCHAR(MAX); DECLARE @str4 VARCHAR(MAX); DECLARE @cond VARCHAR(MAX);DECLARE @condOuter VARCHAR(MAX); DECLARE @STRQ VARCHAR(MAX); DECLARE @OLD_PH_CODE VARCHAR(30); DECLARE @PH_CODE VARCHAR(30),@PH_NAME VARCHAR(50),@ISEARNING varchar(10);DECLARE @strStDTotal VARCHAR(MAX);" &
        " BEGIN " &
        " set @PAY_PERIOD_CODE= " &
        " (select '''' +  PAY_PERIOD_CODE + '''' + ',' from ( select distinct PAY_PERIOD_CODE from @TYPE) as t1 " &
        " for xml path('')) " &
        " if len(@PAY_PERIOD_CODE)>0 " &
        " begin " &
        " set @PAY_PERIOD_CODE= substring(@PAY_PERIOD_CODE,1,LEN(@PAY_PERIOD_CODE)-1) " &
        " End  " &
        " Else " &
        " set @PAY_PERIOD_CODE=''; " &
        " set @LOCATION_CODE= " &
        " (select '''' +  LOCATION_CODE + '''' + ',' from ( select distinct LOCATION_CODE from @TYPE " &
        " where LOCATION_CODE is not null) as t1 for xml path('')) " &
        " if len(@LOCATION_CODE)>0 " &
        " begin " &
        " set @LOCATION_CODE= substring(@LOCATION_CODE,1,LEN(@LOCATION_CODE)-1) " &
        " End " &
        " Else " &
        " set @LOCATION_CODE=''; " &
        " set @DEVISION_CODE= " &
        " (select '''' +  DEVISION_CODE + '''' + ',' from ( select distinct DEVISION_CODE from @TYPE " &
        " where DEVISION_CODE is not null) as t1 for xml path('')) " &
        " if len(@DEVISION_CODE)>0 " &
        " begin " &
        " set @DEVISION_CODE= substring(@DEVISION_CODE,1,LEN(@DEVISION_CODE)-1) " &
        " End " &
        " Else " &
        " set @DEVISION_CODE=''; " &
        " SET @str1 ='SELECT ACD.SALARY_GENERATION_CODE,ACD.EMP_CODE,ACD.PAY_HEAD_CODE,EMPLOYEE_NAME,FATHERS_NAME,[Working City],Birth_date,Joining_date,Designation,Department,LOCATION_DESC,DEVISION_NAME," &
        " BANK_NAME, Bank_Branch,Bank_Branch_Name,PAYMENT_MODE, ACD.PAYPERIOD_DAYS, ACD.PRESENT_DAYS, ACD.PAYABLE_DAYS," &
        " ACD.HOLIDAY_DAYS,ACD.WEEKLY_OFF_DAYS,ACD.LEAVE_DAYS ,PF_NO,ESI_NO,BANK_ACC_NO,RELIEVING_DATE,ACD.OT_HOURS, ';" &
        " SET @str2='SELECT SALARY_GENERATION_CODE,EMP_CODE AS EMP_CODE,EMPLOYEE_NAME,FATHERS_NAME AS [Father Name],[Working City],PF_NO AS [PF No],ESI_NO as [ESI No],BANK_ACC_NO as [Bank Acc No],Birth_date AS [Date of Birth],Joining_date as [Joining Date],CONVERT(VARCHAR,RELIEVING_DATE,103) as [Relieving Date]," &
        " Designation,Department,LOCATION_DESC AS Location,DEVISION_NAME AS Division,BANK_NAME as [Bank Name],Bank_Branch as [Bank Branch],Bank_Branch_Name as [Bank Branch Name],PAYMENT_MODE AS [Payment Mode],PAYPERIOD_DAYS AS [Month Days],PRESENT_DAYS As [Present Days]," &
        " PAYABLE_DAYS As [Payable Days],HOLIDAY_DAYS as [Holidays],WEEKLY_OFF_DAYS as [Week Off Days],LEAVE_DAYS as [Leave Days] ,';" &
        " SET @str3='';" &
        " SET @str4=' 0 +';" &
        " SET @OLD_PH_CODE='';" &
        " SET @strStDTotal=''; " &
        " SET @cond =''; " &
        " IF @PAY_PERIOD_CODE IS NULL  OR LEN(@PAY_PERIOD_CODE)=0" &
        " SET @cond =@cond;" &
        " Else " &
        " SET @cond =' AND T1.PAY_PERIOD_CODE in ( ' +  @PAY_PERIOD_CODE +')' ;" &
        " IF @LOCATION_CODE IS NULL  OR LEN(@LOCATION_CODE)=0" &
        " SET @cond =@cond;" &
        " Else " &
        " SET @cond =@cond + ' AND T1.LOCATION_CODE in ( ' +  @LOCATION_CODE +')' ;" &
        " IF @DEVISION_CODE IS NULL  OR LEN(@DEVISION_CODE)=0" &
        " SET @cond =@cond; " &
        " Else " &
        " SET @cond = @cond + ' AND T1.DEVISION_CODE in ( ' +  @DEVISION_CODE +')' ;" &
        " IF @_COND IS NULL  OR LEN(@_COND)=0" &
        " SET @condOuter =@_COND; " &
        " Else " &
        " SET @condOuter = 'And ' + @_COND  ;" &
        " create table #Temp_Table (PH_Code varchar(30),PH_Name Varchar(100),Is_Earning Varchar(5)) " &
        " declare @sqlstatement nvarchar(max) " &
        " set @sqlstatement = 'Insert into #Temp_Table (PH_Code,PH_Name,Is_Earning) SELECT PAY_HEAD_CODE,LOWER(PAY_HEAD_NAME) AS PAY_HEAD_NAME , " &
        " (CASE WHEN ISEARNING=1 THEN ''Yes'' ELSE ''No'' END) FROM TSPL_PAYHEAD_MASTER  WHERE PAY_HEAD_CODE IN (SELECT DISTINCT T1.PAY_HEAD_CODE FROM TSPL_GENERATE_SALARY_PAYHEADS T1 JOIN TSPL_GENERATE_SALARY T2 ON T1.SALARY_GENERATION_CODE=T2.SALARY_GENERATION_CODE  WHERE T1.ISHIDDENCOMPONENT=0 AND T1.ACTUAL_AMOUNT<>0  " &
        " AND T2.PAY_PERIOD_CODE in (' + @PAY_PERIOD_CODE + ')) " &
        " ORDER BY ISEARNING DESC,GROUP_SEQ' " &
        " exec(@sqlstatement) " &
        " DECLARE CursorName CURSOR FAST_FORWARD" &
        " FOR" &
        " select PH_Code,PH_Name,Is_Earning from #Temp_Table;" &
        " OPEN CursorName" &
        " FETCH NEXT FROM CursorName" &
        " INTO @PH_CODE,@PH_NAME,@ISEARNING" &
        " IF (@OLD_PH_CODE!=@PH_CODE)" &
        " BEGIN" &
        " IF @ISEARNING='Yes'" &
        " begin" &
        " SET @str1 = @str1 + 'CASE WHEN  ACD.PAY_HEAD_CODE ='''+ @PH_CODE +''' THEN acd.Payable_Amount else 0 END  AS ""s'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ;" &
        " SET @str2= @str2 + ' SUM(""s' + replace(LOWER(@PH_NAME),' ','_') +'"") AS ""'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
        " SET @strStDTotal=@strStDTotal + '(case when '''+  @ISEARNING +'''=''Yes'' then SUM(""s' + (replace(LOWER(@PH_NAME),' ','_')) +'"") else 0 end )+' ; " &
        " End " &
        " SET @OLD_PH_CODE=@PH_CODE;" &
        " End" &
        " WHILE @@FETCH_STATUS = 0" &
        " BEGIN" &
        " FETCH NEXT FROM CursorName" &
        " INTO @PH_CODE,@PH_NAME,@ISEARNING" &
        " IF (@OLD_PH_CODE!=@PH_CODE)" &
        " BEGIN " &
        " IF @ISEARNING='Yes'" &
        " begin" &
        " SET @str1 = @str1 + 'CASE WHEN  ACD.PAY_HEAD_CODE ='''+ @PH_CODE +''' THEN acd.Payable_Amount else 0 END  AS ""s'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
        " SET @str2= @str2 + ' SUM(""s' + replace(LOWER(@PH_NAME),' ','_') +'"") AS ""'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ;" &
        " SET @strStDTotal=@strStDTotal + '(case when '''+  @ISEARNING +'''=''Yes'' then SUM(""s' + (replace(LOWER(@PH_NAME),' ','_')) +'"") else 0 end )+' ; " &
        " End" &
        " SET @OLD_PH_CODE=@PH_CODE;" &
        " End" &
        " End" &
        " SET @str2=@str2 + left(@strStDTotal ,LEN(rtrim(@strStDTotal))-1) + ' AS ""Gross"" ,';" &
        " CLOSE CursorName" &
        " open CursorName" &
        " FETCH NEXT FROM CursorName" &
        " INTO @PH_CODE,@PH_NAME,@ISEARNING" &
        " IF (@OLD_PH_CODE!=@PH_CODE)" &
        " BEGIN" &
        " IF @ISEARNING='Yes'" &
        " begin" &
        " SET @str1 = @str1 + 'CASE WHEN  ACD.PAY_HEAD_CODE ='''+ @PH_CODE +''' THEN acd.Actual_Amount else 0 END  AS "" '+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
        " SET @str2= @str2 + ' SUM("" ' + replace(LOWER(@PH_NAME),' ','_') +'"") AS ""v'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
        " SET @str3=@str3 + '(case when '''+  @ISEARNING +'''=''Yes'' then SUM("" ' + (replace(LOWER(@PH_NAME),' ','_')) +'"") else 0 end )+' ; " &
        " SET @OLD_PH_CODE=@PH_CODE;" &
        " End " &
        " End" &
        " WHILE @@FETCH_STATUS = 0" &
        " BEGIN" &
        " FETCH NEXT FROM CursorName" &
        " INTO @PH_CODE,@PH_NAME,@ISEARNING" &
        " IF (@OLD_PH_CODE!=@PH_CODE)" &
        " BEGIN" &
        " IF @ISEARNING='Yes'" &
        " begin" &
        " SET @str1 = @str1 + 'CASE WHEN  ACD.PAY_HEAD_CODE ='''+ @PH_CODE +''' THEN acd.Actual_Amount else 0 END  AS "" '+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
        " SET @str2= @str2 + ' SUM("" ' + replace(LOWER(@PH_NAME),' ','_') +'"") AS ""v'+ replace(LOWER(@PH_NAME),' ','_') +'"",'   ; " &
