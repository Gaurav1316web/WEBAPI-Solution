    ' Ticket No : TEC/01/08/19-000975 By Prabhakar
    Public Shared Function CreateDeleteTableTriger(ByVal strTableName As String)
        Try
            Dim TriggerName As String = "Trg_" + strTableName + "_Send_To_Delete"
            Dim CreateAletr As String = Nothing
            If clsPostCreateTable.CheckTriggerExits(TriggerName, Nothing) = 0 Then
                CreateAletr = "Create "
            Else
                CreateAletr = "Alter "
            End If
            Dim strTableColumn As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue("DECLARE @colsSlot AS NVARCHAR(MAX),@query  AS NVARCHAR(MAX) SELECT   STUFF((SELECT distinct ',' +  QUOTENAME( COLUMN_NAME) as Description FROM INFORMATION_SCHEMA.COLUMNS where table_name='" + strTableName + "'  FOR XML PATH(''), TYPE ).value('.', 'NVARCHAR(MAX)') ,1,1,'')"))
            Dim qryTrig As String = "" & CreateAletr & "   TRIGGER " + TriggerName + " on [" + strTableName + "]  FOR DELETE  " + Environment.NewLine + _
                     " as " + Environment.NewLine + _
                     " INSERT INTO [" + strTableName + clsCommon.DeleteTablePostFix + "] " + Environment.NewLine + _
                     " ( " + Environment.NewLine + _
                     " " + strTableColumn + ", Delete_By,  Delete_On " + Environment.NewLine + _
                     " ) " + Environment.NewLine + _
                     " SELECT   " + strTableColumn + ",	CAST( SERVERPROPERTY('MachineName') AS VARCHAR(100)), GETDATE() FROM DELETED;" + Environment.NewLine
            clsDBFuncationality.ExecuteNonQuery(qryTrig)
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, "Error in Trigger")
        End Try
        Return True
    End Function
    Public Shared Function trg_TSPL_SD_SHIPMENT_DETAIL_Scheme() As String
        Dim qry As String = " Create  trigger [dbo].[trg_TSPL_SD_SHIPMENT_DETAIL_Scheme] on [dbo].[TSPL_SD_SHIPMENT_DETAIL] " & _
                            " for Insert  as  declare @Msg as varchar(max); " & _
                            " declare @Row_No as Integer;declare @Doc_No as varchar(30);declare @Scheme_code as varchar(30);declare @Item_Code varchar(50); " & _
                            " select @Scheme_code=coalesce(Scheme_Code,''),@Row_No=I.Line_No,@Doc_No=I.DOCUMENT_CODE,@Item_Code=I.Item_Code " & _
                            " from inserted I where 2=2 and len(coalesce(Scheme_Code,''))<=0 and Scheme_Item='Y'; " & _
                            " if len(@Scheme_code)<=0  " & _
                            " Begin " & _
                            " set @Msg ='Invalid Scheme Applied at: ' + 'Line No :' +@Row_No + ', Document Code:'+ @Doc_No + ', Item Code :' + @Item_Code + char(10)+ @Msg;" & _
                            " raiserror (@Msg,16,1); " & _
                            " End "
        Return qry
    End Function
