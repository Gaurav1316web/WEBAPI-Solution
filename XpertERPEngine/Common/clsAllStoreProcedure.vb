                              " ) AS T5 ON T1.EMP_CODE=T5.EMP_CODE AND T1.LEAVE_CODE=T5.LEAVE_CODE); " & _
                              " RETURN; " & _
                              " End "
            clsCommonFunctionality.CreateSQLFunctioin("TSPL_FUN_LEAVE_STATUS", strFunctionBody)

