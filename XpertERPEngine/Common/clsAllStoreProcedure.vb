            Dim qryType As String
            If clsPostCreateTable.CheckTypeExits("TYPE_TSPL_HEADWISE_SALARY", Nothing) = 0 Then
                qryType = "create TYPE TYPE_TSPL_HEADWISE_SALARY AS TABLE(" &
                      " [PAY_PERIOD_CODE] [varchar](30) NULL," &
                      " [LOCATION_CODE] [varchar](30) NULL,  " &
