            strProcedureBody = "( @Journal_No int, @Voucher_No varchar(30), @Voucher_Date datetime, @Detail_Line_No int, @Account_code varchar(50), @Account_Desc varchar(100) =NULL, @Amount decimal(18, 2) , @Description varchar(200) =null , @Reference varchar(200)  =null, @Posting_Date datetime, @Account_Type char(1), @Account_Group_Code varchar(12) , @Account_Seg_Code1 varchar(12) , @Account_Seg_Desc1 varchar(50) , @Account_Seg_Code2 varchar(12) , @Account_Seg_Desc2 varchar(50)  , @Account_Seg_Code3 varchar(12)  , @Account_Seg_Desc3 varchar(50)  , @Account_Seg_Code4 varchar(12)  , @Account_Seg_Desc4 varchar(50)  , @Account_Seg_Code5 varchar(12)  , @Account_Seg_Desc5 varchar(50)  , @Account_Seg_Code6 varchar(12) , @Account_Seg_Desc6 varchar(50) , @Account_Seg_Code7 varchar(12) , @Account_Seg_Desc7 varchar(50) , @Account_Seg_Code8 varchar(12) , @Account_Seg_Desc8 varchar(50) , @Account_Seg_Code9 varchar(12) , @Account_Seg_Desc9 varchar(50) , @Account_Seg_Code10 varchar(12)  , @Account_Seg_Desc10 varchar(50)  ) AS BEGIN insert into TSPL_JOURNAL_DETAILS_OP " &
                           " (Journal_No,Voucher_No,Voucher_Date,Detail_Line_No,Account_code,Account_Desc,Amount, Description,Reference,Posting_Date,Account_Type,Account_Group_Code,Account_Seg_Code1, Account_Seg_Desc1,Account_Seg_Code2,Account_Seg_Desc2,Account_Seg_Code3,Account_Seg_Desc3 , Account_Seg_Code4,Account_Seg_Desc4,Account_Seg_Code5,Account_Seg_Desc5,Account_Seg_Code6 , Account_Seg_Desc6,Account_Seg_Code7,Account_Seg_Desc7,Account_Seg_Code8,Account_Seg_Desc8," &
                           "  Account_Seg_Code9,Account_Seg_Desc9,Account_Seg_Code10,Account_Seg_Desc10) VALUES (@Journal_No,@Voucher_No,@Voucher_Date,@Detail_Line_No,@Account_code,@Account_Desc,@Amount," &
                           " @Description,@Reference,@Posting_Date,@Account_Type,@Account_Group_Code,@Account_Seg_Code1, @Account_Seg_Desc1,@Account_Seg_Code2,@Account_Seg_Desc2,@Account_Seg_Code3,@Account_Seg_Desc3 , @Account_Seg_Code4,@Account_Seg_Desc4,@Account_Seg_Code5,@Account_Seg_Desc5,@Account_Seg_Code6 , @Account_Seg_Desc6,@Account_Seg_Code7,@Account_Seg_Desc7,@Account_Seg_Code8,@Account_Seg_Desc8, @Account_Seg_Code9,@Account_Seg_Desc9,@Account_Seg_Code10,@Account_Seg_Desc10) END"
            clsCommonFunctionality.CreateStoreProcedure("sp_TSPL_JOURNAL_DETAILS_OP_INSERT", strProcedureBody)

            strProcedureBody = " (@CUT_OFF_DATE VARCHAR(15) ,  " + Environment.NewLine &
                                " @AS_ON_DATE VARCHAR(15),      " + Environment.NewLine &
                                " @REPORT_TYPE VARCHAR(15)='',      " + Environment.NewLine &
                                " @BUCKET_TYPE VARCHAR(15)='',       " + Environment.NewLine &
                                " @LOCATION VARCHAR(MAX)='',       " + Environment.NewLine &
                                " @ITEM VARCHAR(MAX)='',       " + Environment.NewLine &
                                " @FAT_SNF_TYPE VARCHAR(12)='',   " + Environment.NewLine &
                                " @BUCKET1 INT,       " + Environment.NewLine &
                                " @BUCKET2 INT,       " + Environment.NewLine &
                                " @BUCKET3 INT,       " + Environment.NewLine &
                                " @IS_LOCATION int =1)       " + Environment.NewLine &
                                " AS BEGIN       " + Environment.NewLine &
                                " DECLARE @QUERY NVARCHAR(MAX)=''        " + Environment.NewLine &
                                " SET @QUERY='  SELECT   1 AS TRANS_TYPE,TRANS_DATE =MAX(I.TRANS_DATE),I.Location_Code AS [Location Code],'''' as location_desc,I.Item_Code AS [Item Code],'''' AS [Item Desc],Stock_UOM,Opening=(SELECT CL_QTY FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM),(SELECT CL_FAT_KG FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM) AS OP_FAT,(SELECT CL_SNF_KG FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM) AS OP_SNF,0 AS [Qty(In)],0 AS [Qty(Out)],0 AS [FAT KG(In)],0 AS [SNF KG(In)],1 AS BASE_CONVERSION_FECTOR,1 AS CONVERSION_FECTOR,0 AS [FAT KG(Out)],0 AS [SNF KG(Out)],0 AS Outstanding,0 AS BALANCE_FAT,0 AS BALANCE_SNF INTO #TEMP_OP FROM TSPL_INV_MOVE_DL I       " + Environment.NewLine &
                                " WHERE  convert(DATE,(I.TRANS_DATE),103) <  convert(DATE,'''+@AS_ON_DATE+''',103) 	'+ (CASE WHEN @LOCATION='' THEN '' ELSE '	AND Location_Code IN (SELECT * FROM DBO.SPLIT_STRING('''+@LOCATION+''','','' )) ' END)+         " + Environment.NewLine &
                                " (CASE WHEN @ITEM='' THEN '' ELSE '	AND item_code IN (SELECT * FROM DBO.SPLIT_STRING('''+@ITEM+''','','' ) )' END)+ '   " + Environment.NewLine &
                                " GROUP BY I.Location_Code,I.Item_Code,Stock_UOM '+   " + Environment.NewLine &
                                " ' SELECT   0 AS TRANS_TYPE,TRANS_DATE =MAX(I.TRANS_DATE),I.Location_Code AS [Location Code],'''' as location_desc,I.Item_Code AS [Item Code],'''' AS [Item Desc],Stock_UOM,Opening=(SELECT CL_QTY FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM),(SELECT CL_FAT_KG FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM) AS OP_FAT,(SELECT CL_SNF_KG FROM TSPL_INV_MOVE_DL WHERE TRANS_DATE= MAX(I.TRANS_DATE) AND  Location_Code=I.Location_Code AND Item_Code=I.Item_Code AND Stock_UOM=I.Stock_UOM) AS OP_SNF,0 AS [Qty(In)],0 AS [Qty(Out)],0 AS [FAT KG(In)],0 AS [SNF KG(In)],1 AS BASE_CONVERSION_FECTOR,1 AS CONVERSION_FECTOR,0 AS [FAT KG(Out)],0 AS [SNF KG(Out)],0 AS Outstanding,0 AS BALANCE_FAT,0 AS BALANCE_SNF INTO #TEMP_OP2  FROM TSPL_INV_MOVE_DL I       " + Environment.NewLine &
                                " WHERE  convert(DATE,(I.TRANS_DATE),103) <convert(DATE,'''+@CUT_OFF_DATE+''',103) 	'+        " + Environment.NewLine &
                                " (CASE WHEN @LOCATION='' THEN '' ELSE '	AND I.Location_Code IN (SELECT * FROM DBO.SPLIT_STRING('''+@LOCATION+''','','' )) ' END)+   (CASE WHEN @ITEM='' THEN '' ELSE '	AND  I.item_code IN (SELECT * FROM DBO.SPLIT_STRING('''+@ITEM+''','','' ) )' END)+        " + Environment.NewLine &
                                " (CASE WHEN (CONVERT(DATE,@AS_ON_DATE,103)=CONVERT(DATE,@CUT_OFF_DATE,103)) THEN ' AND 1=0 ' ELSE '' END )+    " + Environment.NewLine &
                                " (CASE WHEN @LOCATION='' THEN ' and 1=2 ' ELSE  '' END)+  '   " + Environment.NewLine &
                                " GROUP BY I.Location_Code,I.Item_Code,Stock_UOM     " + Environment.NewLine &
                                " SELECT   1 AS TRANS_TYPE,       " + Environment.NewLine &
                                " [Date]=CONVERT(DATE,TRANS_DATE,103),       " + Environment.NewLine &
                                " [Location Code]=I.Location_Code,[Location Desc]=L.Location_Desc,[Item Code]=I.Item_Code,[Item Desc]=I.Item_Desc,[Stock UOM]    =Stock_UOM,Opening=SUM(CL_QTY-TRANS_QTY),OP_FAT=SUM(CL_FAT_KG-Fat_KG),OP_SNF=SUM(CL_SNF_KG-SNF_KG),[Qty(In)]=SUM(IN_QTY),[Qty(Out)]=SUM(Out_QTY),[FAT KG(In)]=SUM(In_Fat_KG)       " + Environment.NewLine &
                                " ,[SNF KG(In)]=SUM(In_SNF_KG),       " + Environment.NewLine &
                                " BASE_CONVERSION_FECTOR=(CASE WHEN ISNULL(BASE.CONVERSION_FACTOR,0)>0 THEN ISNULL(BASE.CONVERSION_FACTOR,0) ELSE 1 END) ,CONVERSION_FECTOR= (CASE WHEN ISNULL(U.CONVERSION_FACTOR,0)>0 THEN ISNULL(U.CONVERSION_FACTOR,0) ELSE 1 END) ,       " + Environment.NewLine &
                                " [FAT KG(Out)]=SUM(Out_Fat_KG),[SNF KG(Out)]=(SUM(Out_SNF_KG)),          " + Environment.NewLine &
                                " [Outstanding] = SUM((((isnull((CL_QTY - TRANS_QTY), 0)) + (isnull(IN_QTY, 0))) + (isnull(OUT_QTY, 0)))) ,    " + Environment.NewLine &
                                " [BALANCE_FAT] = SUM((((isnull((CL_FAT_KG - Fat_KG), 0)) + (isnull(In_Fat_KG, 0))) + (isnull(Out_Fat_KG, 0)))),    " + Environment.NewLine &
                                " [BALANCE_SNF] = SUM((((isnull((CL_SNF_KG - SNF_KG), 0)) + (isnull(In_SNF_KG, 0))) + (isnull(Out_SNF_KG, 0))))    " + Environment.NewLine &
                                " INTO #TEMP1       " + Environment.NewLine &
                                " FROM TSPL_INV_MOVE_DL I        " + Environment.NewLine &
                                " JOIN TSPL_LOCATION_MASTER L ON L.Location_Code=I.Location_Code        " + Environment.NewLine &
                                " JOIN TSPL_ITEM_MASTER IT ON IT.Item_Code=I.Item_Code        " + Environment.NewLine &
                                " LEFT JOIN TSPL_ITEM_UOM_DETAIL BASE ON BASE.ITEM_CODE=I.ITEM_CODE AND BASE.UOM_CODE=I.Stock_UOM        " + Environment.NewLine &
                                " LEFT JOIN TSPL_ITEM_UOM_DETAIL U ON U.ITEM_CODE=I.ITEM_CODE AND U.UOM_CODE=''KG''  " + Environment.NewLine &
                                " left join TSPL_ITEM_QC_PARAMETER_MASTER QC ON QC.Item_Code=I.Item_Code AND QC.Code=''PM00001''  " + Environment.NewLine &
                                " left join TSPL_ITEM_QC_PARAMETER_MASTER QC1 ON QC1.Item_Code=I.Item_Code AND QC1.Code=''PM00002''         " + Environment.NewLine &
                                " WHERE '+       " + Environment.NewLine &
                                " ' convert(DATE,TRANS_DATE,103) BETWEEN convert(DATE,'''+@CUT_OFF_DATE+''',103) AND convert(DATE,'''+@AS_ON_DATE+''',103) '+        " + Environment.NewLine &
                                " (CASE WHEN @LOCATION='' THEN '' ELSE '	AND I.Location_Code IN (SELECT * FROM DBO.SPLIT_STRING('''+@LOCATION+''','','' )) ' END)+         " + Environment.NewLine &
                                " (CASE WHEN @ITEM='' THEN '' ELSE '	AND I.item_code IN (SELECT * FROM DBO.SPLIT_STRING('''+@ITEM+''','','' ) )' END)+         " + Environment.NewLine &
                                " 'GROUP BY CONVERT(DATE,TRANS_DATE,103),I.Location_Code,L.Location_Desc,I.Item_Code,I.Item_Desc,Stock_UOM,BASE.Conversion_Factor,U.Conversion_Factor'+        " + Environment.NewLine &
                                " (CASE WHEN @FAT_SNF_TYPE='MILK' THEN ' HAVING (SUM(I.Fat_KG)!=0 OR SUM(I.SNF_KG)!=0 OR SUM(I.In_FAT_KG)!=0 OR SUM(I.In_SNF_KG)!=0  OR SUM(I.Out_FAT_KG)!=0 OR SUM(I.Out_SNF_KG)!=0 OR SUM(CL_FAT_KG-Fat_KG)!=0 OR SUM(CL_SNF_KG-SNF_KG)!=0 OR SUM(ISNULL(QC.Actual_Range,0))!=0  OR SUM(ISNULL(QC1.Actual_Range,0))!=0 ) ' WHEN @FAT_SNF_TYPE='OTHER' THEN '  HAVING (SUM(I.Fat_KG)=0 AND SUM(I.SNF_KG)=0 AND SUM(I.In_FAT_KG)=0 AND SUM(I.In_SNF_KG)=0  AND SUM(I.Out_FAT_KG)= 0 AND SUM(I.Out_SNF_KG)=0 and SUM(CL_FAT_KG-Fat_KG)=0 and SUM(CL_SNF_KG-SNF_KG)=0 AND SUM(ISNULL(QC.Actual_Range,0))=0 AND SUM(ISNULL(QC1.Actual_Range,0))=0 ) ' ELSE '' END )+ '       " + Environment.NewLine &
                                " SELECT * INTO #TEMP FROM #TEMP1      " + Environment.NewLine &
                                " UNION ALL       " + Environment.NewLine &
                                " select  1 AS TRANS_TYPE,CONVERT(DATE,punching_date,103) AS punching_date,location_code,'''' as location_desc,I.item_code,item_desc,uom,0 as op,0 AS OP_FAT,0 AS OP_SNF,qty as in_qty,0 as out_qty,Fat_KG as fat_kg_in,SNF_KG SNF_KG_in,1 AS BASE_CONVERSION_FECTOR,1 AS CONVERSION_FECTOR, 0 as fat_kg_out,0 as snf_kg_out,0 AS [Outstanding],0 AS BALANCE_FAT,0 AS BALANCE_SNF from TSPL_INVENTORY_MOVEMENT_WIN I left join TSPL_ITEM_QC_PARAMETER_MASTER QC ON QC.Item_Code=I.Item_Code AND QC.Code=''PM00001''  left join TSPL_ITEM_QC_PARAMETER_MASTER QC1 ON QC1.Item_Code=I.Item_Code AND QC1.Code=''PM00002''  where convert(DATE,punching_date,103) BETWEEN convert(DATE,'''+@CUT_OFF_DATE+''',103) AND convert(DATE,'''+@AS_ON_DATE+''',103) '+        " + Environment.NewLine &
                                " (CASE WHEN @LOCATION='' THEN '' ELSE '	AND Location_Code IN (SELECT * FROM DBO.SPLIT_STRING('''+@LOCATION+''','','' )) ' END)+         " + Environment.NewLine &
                                " (CASE WHEN @ITEM='' THEN '' ELSE '	AND I.item_code IN (SELECT * FROM DBO.SPLIT_STRING('''+@ITEM+''','','' ) )' END)+'  and inOut=''I'' '+       " + Environment.NewLine &
                                " (CASE WHEN @FAT_SNF_TYPE='MILK' THEN ' and 1=2 '  ELSE ' AND ISNULL(QC.Actual_Range,0)=0 and ISNULL(QC1.Actual_Range,0)=0 ' END )+'       " + Environment.NewLine &
                                " union all       " + Environment.NewLine &
                                " select  1 AS TRANS_TYPE,CONVERT(DATE,punching_date,103) AS punching_date,location_code,'''' as location_desc,I.item_code,item_desc,uom,0 as op,0 AS OP_FAT,0 AS OP_SNF,qty as in_qty,0 as out_qty,0 as fat_kg_in,0 SNF_KG_in,1 AS BASE_CONVERSION_FECTOR,1 AS CONVERSION_FECTOR, Fat_KG as fat_kg_out,SNF_KG as snf_kg_out,0 AS [Outstanding],0 AS BALANCE_FAT,0 AS BALANCE_SNF from TSPL_INVENTORY_MOVEMENT_WIN I left join TSPL_ITEM_QC_PARAMETER_MASTER QC ON QC.Item_Code=I.Item_Code AND QC.Code=''PM00001''  left join TSPL_ITEM_QC_PARAMETER_MASTER QC1 ON QC1.Item_Code=I.Item_Code AND QC1.Code=''PM00002''  where convert(DATE,punching_date,103) BETWEEN convert(DATE,'''+@CUT_OFF_DATE+''',103) AND convert(DATE,'''+@AS_ON_DATE+''',103) '+        " + Environment.NewLine &
                                " (CASE WHEN @LOCATION='' THEN '' ELSE '	AND Location_Code IN (SELECT * FROM DBO.SPLIT_STRING('''+@LOCATION+''','','' )) ' END)+         " + Environment.NewLine &
