            '' Created By Panch Raj for Inventory Summary
            strProcedureBody = " (@Item_Code varchar(50),@Location_Code varchar(12),@Trans_Date Date ,@Stock_UOM varchar(12))   as " &
                               " SET NOCOUNT ON" &
                               " declare @TRANSDATE Date, @IN_QTY numeric(18,2),@Out_QTY numeric(18,2),@TRANS_QTY numeric(18,2),@CL_QTY numeric(18,2),@AGEING_Flag int,@AGEING_QTY numeric(18,2);" &
                               " update TSPL_INV_MOVE_DL set AGEING_Flag=0 where Item_Code=@Item_Code and Location_Code=@Location_Code and Stock_UOM=@Stock_UOM and TRANS_DATE>=@Trans_Date ; " &
                               " DECLARE Cursor_UpdateAgeingQty CURSOR FAST_FORWARD FOR select TRANS_DATE,IN_QTY,Out_QTY,TRANS_QTY,CL_QTY,AGEING_Flag,AGEING_QTY " &
                               " from TSPL_INV_MOVE_DL where Item_Code=@Item_Code and Location_Code=@Location_Code and Stock_UOM=@Stock_UOM " &
                               " order by Item_Code,Location_Code,TRANS_DATE " &
                               " OPEN Cursor_UpdateAgeingQty " &
                               " WHILE @@FETCH_STATUS = 0 " &
                               " begin " &
                               " FETCH NEXT FROM Cursor_UpdateAgeingQty INTO @TRANSDATE,@IN_QTY,@Out_QTY,@TRANS_QTY,@CL_QTY,@AGEING_Flag,@AGEING_QTY " &
                               " update TSPL_INV_MOVE_DL set AGEING_Flag=(case when IN_QTY=0 then 0 else 1 end)," &
                               " AGEING_QTY=(case when IN_QTY=0 then 0 else coalesce((select coalesce(sum(Out_QTY),0) from TSPL_INV_MOVE_DL " &
                               " where  Item_Code=@Item_Code and Location_Code=@Location_Code and Stock_UOM=@Stock_UOM and TRANS_DATE<@TransDate and AGEING_Flag=0),0)+Out_QTY end) " &
                               " where Item_Code=@Item_Code and Location_Code=@Location_Code and Stock_UOM=@Stock_UOM and TRANS_DATE=@TransDate " &
                               " End " &
                               " CLOSE Cursor_UpdateAgeingQty" &
                               " DEALLOCATE Cursor_UpdateAgeingQty"
            clsCommonFunctionality.CreateStoreProcedure("SP_UpdateAgeingQty", strProcedureBody)
            strProcedureBody = " as " &
                               " SET NOCOUNT ON " &
                               " declare @Item_Code varchar(50),@Location_Code varchar(12),@Trans_Date Date ,@Stock_UOM varchar(12); " &
                               " DECLARE Cursor_UpdateAgeingQty_JOB CURSOR FAST_FORWARD FOR  " &
                               " select Item_Code,Location_Code,Stock_UOM,Trans_Date from (select Item_Code,Location_Code,Stock_UOM,cast(Punching_Date as date) as Trans_Date " &
                               " from TSPL_INVENTORY_MOVEMENT_WIN " &
                               " union all " &
                               " select Item_Code,Location_Code,Stock_UOM,cast(Punching_Date as date) as Trans_Date " &
                               " from TSPL_INVENTORY_MOVEMENT_NEW_WIN) Final order by Item_Code,Location_Code,Stock_UOM,Trans_Date " &
                               " declare @intFetch integer;  " &
                               " OPEN Cursor_UpdateAgeingQty_JOB " &
                               " FETCH NEXT FROM Cursor_UpdateAgeingQty_JOB INTO @Item_Code,@Location_Code,@Stock_UOM,@Trans_Date " &
                               " begin " &
                               " set @intFetch =@@FETCH_STATUS;  " &
                               " exec [dbo].[SP_UpdateAgeingQty] @Item_Code,@Location_Code,@Trans_Date,@Stock_UOM;" &
                               " End " &
                               " WHILE @intFetch <>-1  " &
                               " begin  FETCH NEXT FROM Cursor_UpdateAgeingQty_JOB INTO @Item_Code,@Location_Code,@Stock_UOM,@Trans_Date" &
                               " set @intFetch =@@FETCH_STATUS; " &
                               " exec [dbo].[SP_UpdateAgeingQty] @Item_Code,@Location_Code,@Trans_Date,@Stock_UOM;" &
                               " End " &
                               " CLOSE Cursor_UpdateAgeingQty_JOB " &
                               " DEALLOCATE Cursor_UpdateAgeingQty_JOB"
            clsCommonFunctionality.CreateStoreProcedure("SP_UpdateAgeingQty_JOB", strProcedureBody)
