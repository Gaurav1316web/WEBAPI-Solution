      "       begin  " &
    " update TSPL_PURCHASE_ACCOUNTS set Purchase_Class_Desc=@desc ,Inv_Control_Account=@invcontrol,Inv_Payable_Clearing=@invpayable,Adjustment_Account=@adjustacc,Assembly_Cost_Credit=@asscostcredit,Non_Stock_Clearing=@nonstockclearing,Transfer_Clearing =@transfer,Shipment_Clearing =@shipclearing,Disassembly_Expense=@dismexp,Physical_Inv_Adjustment=@Physicalinv, Credit_Debit_Note_Clearing=@Creditdebit,Reserve_Stock=@ReserveStock, WIP_Account=@WIPAccount,RM_Consumption=@RMConsumption,Other_1=@Other1,Other_2=@Other2,Created_By =@createdby,Created_Date =@createddate,Modify_By=@modifiedby,Modify_Date =@modifieddate,Comp_Code =@comp_code,Breakage_Gl_Account = @breakaglact,Is_IndentRequired=@indentrequired  where Purchase_Class_Code=@acc " &
