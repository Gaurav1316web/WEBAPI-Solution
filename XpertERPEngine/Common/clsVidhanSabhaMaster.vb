Imports common
Imports System.Data
Imports System.Data.SqlClient

Public Class clsVidhanSabhaMaster
#Region "Variables"
    Public code As String = Nothing
    Public name As String = Nothing
    Public namehindi As String = Nothing
#End Region
    '----------------Code For Get Finder--------------------------------------------------------------------'
    Public Shared Function getFinder(ByVal whrcls As String, ByVal curcode As String, ByVal isButtonClicked As Boolean) As String
        Dim str As String = ""
        Dim qry As String = "select TSPL_VIDHAN_SABHA_MASTER.VIDHAN_SABHA_CODE as [Code] ,TSPL_VIDHAN_SABHA_MASTER.VIDHAN_SABHA_NAME as [Vidhan Sabha Name] ,TSPL_VIDHAN_SABHA_MASTER.Created_By as [Created By] ,TSPL_VIDHAN_SABHA_MASTER.Created_Date as [Created Date] ,TSPL_VIDHAN_SABHA_MASTER.Modified_By as [Modified By] ,TSPL_VIDHAN_SABHA_MASTER.Modified_Date as [Modified Date]  From TSPL_VIDHAN_SABHA_MASTER  "
        str = clsCommon.ShowSelectForm("RGNFND@VidhanSabha@MAster", qry, "Code", whrcls, curcode, "Code", isButtonClicked)
        Return str
    End Function
    '----------------End of Code For Get Finder--------------------------------------------------------------'

    Public Shared Function SaveData(ByVal obj As clsVidhanSabhaMaster, ByVal strCode As String) As Boolean
        Try

            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_VIDHAN_SABHA_MASTER where VIDHAN_SABHA_CODE='" & obj.code & "'")
                If ChkNewEntry = 0 Then
                    obj.code = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy"), clsDocType.VidhanSabhaMaster, "", "")
                    If clsCommon.myLen(obj.code) <= 0 Then
                        Throw New Exception("Error in Vidhan Sabha Code Generation")
                    End If
                End If
            End If

            Dim coll As New Hashtable()
            Dim qry As String = "SELECT Count(*) FROM TSPL_VIDHAN_SABHA_MASTER where VIDHAN_SABHA_CODE= '" & obj.code & "'"
            Dim check As Integer = clsDBFuncationality.getSingleValue(qry)
            clsCommon.AddColumnsForChange(coll, "VIDHAN_SABHA_NAME", obj.name)
            clsCommon.AddColumnsForChange(coll, "VIDHAN_SABHA_NAME_HINDI", obj.namehindi, False, True)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))

            clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))
            If check > 0 Then
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_VIDHAN_SABHA_MASTER", OMInsertOrUpdate.Update, "VIDHAN_SABHA_CODE='" + obj.code + "'")
            Else
                clsCommon.AddColumnsForChange(coll, "VIDHAN_SABHA_CODE", obj.code)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_VIDHAN_SABHA_MASTER", OMInsertOrUpdate.Insert, "")
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return True
    End Function

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsVidhanSabhaMaster
        Try
            Dim obj As clsVidhanSabhaMaster = Nothing
            Dim qry As String = "select VIDHAN_SABHA_CODE, VIDHAN_SABHA_NAME from TSPL_VIDHAN_SABHA_MASTER where 2=2"
            Select Case NavType
                Case NavigatorType.First
                    qry += " and VIDHAN_SABHA_CODE = (select MIN(VIDHAN_SABHA_CODE) from TSPL_VIDHAN_SABHA_MASTER)"
                Case NavigatorType.Last
                    qry += " and VIDHAN_SABHA_CODE = (select Max(VIDHAN_SABHA_CODE) from TSPL_VIDHAN_SABHA_MASTER)"
                Case NavigatorType.Next
                    qry += " and VIDHAN_SABHA_CODE = (select Min(VIDHAN_SABHA_CODE) from TSPL_VIDHAN_SABHA_MASTER where  VIDHAN_SABHA_CODE>'" + strCode + "')"
                Case NavigatorType.Previous
                    qry += " and VIDHAN_SABHA_CODE = (select Max(VIDHAN_SABHA_CODE) from TSPL_VIDHAN_SABHA_MASTER where VIDHAN_SABHA_CODE<'" + strCode + "')"
                Case NavigatorType.Current
                    qry += " and VIDHAN_SABHA_CODE = '" + strCode + "'"

            End Select
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)


            If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
                obj = New clsVidhanSabhaMaster()
                obj.code = clsCommon.myCstr(dt.Rows(0)("VIDHAN_SABHA_CODE"))
                obj.name = clsCommon.myCstr(dt.Rows(0)("VIDHAN_SABHA_NAME"))
                obj.namehindi = clsCommon.myCstr(dt.Rows(0)("VIDHAN_SABHA_NAME_HINDI"))
            End If
            Return obj
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function

    Public Shared Function GetName(ByVal strCode As String) As String
        Dim qry As String = "Select VIDHAN_SABHA_NAME from TSPL_VIDHAN_SABHA_MASTER where VIDHAN_SABHA_CODE='" + strCode + "'"
        Return clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry))
    End Function

End Class