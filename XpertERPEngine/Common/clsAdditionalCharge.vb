                    qry += "KGS-AMT :" + objDosPrint.SetSpace(8, clsCommon.myCstr(clsCommon.myCdbl(dtDedcution.Rows(jj)("KgAmt"))), 8, DosPrintAlignment.Right, BlankSpacePosition.NA, "") + "     "
                    cntr += 1
                    If cntr = 7 Then
