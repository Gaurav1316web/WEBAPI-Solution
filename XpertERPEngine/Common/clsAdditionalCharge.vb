                    objT.Amt = clsCommon.myCdbl(dt.Rows(ii)("GrossAmt"))
                    If ReportType123 = 4 Then
                        objT.Amt = clsCommon.myCdbl(dt.Rows(ii)("GrossAmt1"))
                        objT.Amt1 = clsCommon.myCdbl(dt.Rows(ii)("GrossAmt"))
