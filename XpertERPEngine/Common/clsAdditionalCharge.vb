                    qry += "AVG RATE:" + objDosPrint.SetSpace(8, clsCommon.myCstr(clsCommon.myCdbl(dtDedcution.Rows(jj)("AvgRate"))), 8, DosPrintAlignment.Right, BlankSpacePosition.NA, "") + "     "
                    cntr += 1
