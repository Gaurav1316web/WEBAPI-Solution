                    qry += "NET AMT :" + objDosPrint.SetSpace(8, clsCommon.myCstr(clsCommon.myCdbl(dtDedcution.Rows(jj)("NetAmt"))), 8, DosPrintAlignment.Right, BlankSpacePosition.NA, "") + "     "
                    cntr += 1
