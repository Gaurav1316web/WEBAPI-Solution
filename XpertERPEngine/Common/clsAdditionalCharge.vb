                    qry += "LTS-AMT :" + objDosPrint.SetSpace(8, clsCommon.myCstr(clsCommon.myCdbl(dtDedcution.Rows(jj)("LtsAmt"))), 8, DosPrintAlignment.Right, BlankSpacePosition.NA, "") + "     "
                    cntr += 1
                    If cntr = 7 Then
