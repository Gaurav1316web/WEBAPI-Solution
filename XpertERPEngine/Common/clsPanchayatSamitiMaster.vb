Imports common
Imports System.Data
Imports System.Data.SqlClient

Public Class clsPanchayatSamitiMaster
#Region "Variables"
    Public code As String = Nothing
    Public name As String = Nothing
#End Region
    '----------------Code For Get Finder--------------------------------------------------------------------'
    Public Shared Function getFinder(ByVal whrcls As String, ByVal curcode As String, ByVal isButtonClicked As Boolean) As String
        Dim str As String = ""
        Dim qry As String = "select TSPL_PANCHAYAT_SAMITI_MASTER.PANCHAYAT_SAMITI_CODE as [Code] ,TSPL_PANCHAYAT_SAMITI_MASTER.PANCHAYAT_SAMITI_NAME as [Panchayat Samiti Name] ,TSPL_PANCHAYAT_SAMITI_MASTER.Created_By as [Created By] ,TSPL_PANCHAYAT_SAMITI_MASTER.Created_Date as [Created Date] ,TSPL_PANCHAYAT_SAMITI_MASTER.Modified_By as [Modified By] ,TSPL_PANCHAYAT_SAMITI_MASTER.Modified_Date as [Modified Date]  From TSPL_PANCHAYAT_SAMITI_MASTER  "
        str = clsCommon.ShowSelectForm("RGNFND@PanchayatSamiti@MAster", qry, "Code", whrcls, curcode, "Code", isButtonClicked)
        Return str
    End Function
    '----------------End of Code For Get Finder--------------------------------------------------------------'

    Public Shared Function SaveData(ByVal obj As clsPanchayatSamitiMaster, ByVal strCode As String) As Boolean
        Try

            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_PANCHAYAT_SAMITI_MASTER where PANCHAYAT_SAMITI_CODE='" & obj.code & "'")
                If ChkNewEntry = 0 Then
                    obj.code = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy"), clsDocType.PanchayatSamitiMaster, "", "")
                    If clsCommon.myLen(obj.code) <= 0 Then
                        Throw New Exception("Error in Panchayat Samiti Code Generation")
                    End If
                End If
            End If

            Dim coll As New Hashtable()
            Dim qry As String = "SELECT Count(*) FROM TSPL_PANCHAYAT_SAMITI_MASTER where PANCHAYAT_SAMITI_CODE= '" & obj.code & "'"
            Dim check As Integer = clsDBFuncationality.getSingleValue(qry)
            clsCommon.AddColumnsForChange(coll, "PANCHAYAT_SAMITI_NAME", obj.name)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))

            clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MMM/yyyy"))
            If check > 0 Then
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PANCHAYAT_SAMITI_MASTER", OMInsertOrUpdate.Update, "PANCHAYAT_SAMITI_CODE='" + obj.code + "'")
            Else
                clsCommon.AddColumnsForChange(coll, "PANCHAYAT_SAMITI_CODE", obj.code)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PANCHAYAT_SAMITI_MASTER", OMInsertOrUpdate.Insert, "")
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
        Return True
    End Function

    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsPanchayatSamitiMaster
        Try
            Dim obj As clsPanchayatSamitiMaster = Nothing
            Dim qry As String = "select PANCHAYAT_SAMITI_CODE, PANCHAYAT_SAMITI_NAME from TSPL_PANCHAYAT_SAMITI_MASTER where 2=2"
            Select Case NavType
                Case NavigatorType.First
                    qry += " and PANCHAYAT_SAMITI_CODE = (select MIN(PANCHAYAT_SAMITI_CODE) from TSPL_PANCHAYAT_SAMITI_MASTER)"
                Case NavigatorType.Last
                    qry += " and PANCHAYAT_SAMITI_CODE = (select Max(PANCHAYAT_SAMITI_CODE) from TSPL_PANCHAYAT_SAMITI_MASTER)"
                Case NavigatorType.Next
                    qry += " and PANCHAYAT_SAMITI_CODE = (select Min(PANCHAYAT_SAMITI_CODE) from TSPL_PANCHAYAT_SAMITI_MASTER where  PANCHAYAT_SAMITI_CODE>'" + strCode + "')"
                Case NavigatorType.Previous
                    qry += " and PANCHAYAT_SAMITI_CODE = (select Max(PANCHAYAT_SAMITI_CODE) from TSPL_PANCHAYAT_SAMITI_MASTER where PANCHAYAT_SAMITI_CODE<'" + strCode + "')"
                Case NavigatorType.Current
                    qry += " and PANCHAYAT_SAMITI_CODE = '" + strCode + "'"

            End Select
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)


            If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
                obj = New clsPanchayatSamitiMaster()
                obj.code = clsCommon.myCstr(dt.Rows(0)("PANCHAYAT_SAMITI_CODE"))
                obj.name = clsCommon.myCstr(dt.Rows(0)("PANCHAYAT_SAMITI_NAME"))
            End If
            Return obj
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function

    Public Shared Function GetName(ByVal strCode As String) As String
        Dim qry As String = "Select PANCHAYAT_SAMITI_NAME from TSPL_PANCHAYAT_SAMITI_MASTER where PANCHAYAT_SAMITI_CODE='" + strCode + "'"
        Return clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry))
    End Function

End Class