    Public Function SaveData(ByVal arr As List(Of clsVendorFormulaMapping), ByVal isNewEntry As String) As Boolean
        Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
        Dim qry As String
        Try
            If arr IsNot Nothing AndAlso arr.Count > 0 Then
                For Each obj As clsVendorFormulaMapping In arr
                    qry = "select top 1 DocCode from TSPL_VENDOR_FORMULA_MAPPING where DocCode='" + obj.DocCode + "' and posted=1"
                    Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                    If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                        Throw New Exception("Some posted vendor mapping found for Formula code :" + obj.Formulacode + "'")
                    End If

                    If isNewEntry = True Then
                        For Each StrVendor As String In obj.arrVendor
                            Dim qrycheck As String = "select TSPL_VENDOR_FORMULA_MAPPING.DocCode from TSPL_VENDOR_FORMULA_MAPPING"
                            qrycheck += " left outer join TSPL_VENDOR_FORMULA_MAPPING_DETAIL on TSPL_VENDOR_FORMULA_MAPPING_DETAIL.DocCode=TSPL_VENDOR_FORMULA_MAPPING.DocCode where TSPL_VENDOR_FORMULA_MAPPING_DETAIL.VendorCode='" + StrVendor + "' and convert(date,TSPL_VENDOR_FORMULA_MAPPING.DocDate,103)='" + clsCommon.GetPrintDate(obj.DocDate, "dd/MMM/yyyy") + "' and TSPL_VENDOR_FORMULA_MAPPING.FormulaCode='" + obj.Formulacode + "'"
                            Dim dt1 As DataTable = clsDBFuncationality.GetDataTable(qrycheck, tran)
                            If dt1 IsNot Nothing AndAlso dt1.Rows.Count > 0 Then
                                Throw New Exception("Vendor Mapping found for Formula code : " + obj.Formulacode + "' for date : " + clsCommon.myCDate(obj.DocDate) + "")
                            End If
                        Next


                    End If




                    qry = "delete from TSPL_VENDOR_FORMULA_MAPPING_Detail where DocCode='" + obj.DocCode + "'"
                    clsDBFuncationality.ExecuteNonQuery(qry, tran)
                    'For Each StrVendor As String In obj.arrVendor
                    Dim coll As New Hashtable()

                    clsCommon.AddColumnsForChange(coll, "FormulaCode", obj.Formulacode)
                    clsCommon.AddColumnsForChange(coll, "DocDate", clsCommon.GetPrintDate(obj.DocDate, "dd/MMM/yyyy hh:mm tt"))

                    If isNewEntry Then
                        clsCommon.AddColumnsForChange(coll, "DocCode", obj.DocCode)
                        clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                        clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(tran), "dd/MMM/yyyy hh:mm tt"))
                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_VENDOR_FORMULA_MAPPING", OMInsertOrUpdate.Insert, "", tran)
                    Else
                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_VENDOR_FORMULA_MAPPING", OMInsertOrUpdate.Update, "TSPL_VENDOR_FORMULA_MAPPING.DocCode='" + obj.DocCode + "'", tran)
                    End If

                    'Next
                    clsVendorFormulaMappingDetail.SaveData(arr, arrVendor, tran)
                Next
            End If
            tran.Commit()
        Catch ex As Exception
            tran.Rollback()
            Throw New Exception(ex.Message)
        End Try
        Return True
    End Function

    Public Function DeleteData(ByVal arr As List(Of clsVendorFormulaMapping)) As Boolean
        Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
