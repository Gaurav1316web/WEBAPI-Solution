    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType, ByVal trans As SqlTransaction) As clsVendorFormulaMapping
        Dim obj As clsVendorFormulaMapping = Nothing
        Dim qry As String = "select TSPL_VENDOR_FORMULA_MAPPING.DocCode,TSPL_VENDOR_FORMULA_MAPPING.DocDate,TSPL_VENDOR_FORMULA_MAPPING.VendorCode,TSPL_JW_FORMULA.Code,TSPL_JW_FORMULA.Formula,TSPL_JW_FORMULA.Structure_Code from TSPL_VENDOR_FORMULA_MAPPING "
        qry += " left outer join TSPL_JW_FORMULA on TSPL_JW_FORMULA.Code=TSPL_VENDOR_FORMULA_MAPPING.FormulaCode where 2=2"
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_VENDOR_FORMULA_MAPPING.DocCode = (select MIN(TSPL_VENDOR_FORMULA_MAPPING.DocCode) from TSPL_JW_FORMULA where 1=1 )"
            Case NavigatorType.Last
                qry += " and TSPL_VENDOR_FORMULA_MAPPING.DocCode = (select Max(TSPL_VENDOR_FORMULA_MAPPING.DocCode) from TSPL_JW_FORMULA where 1=1 )"
            Case NavigatorType.Next
                qry += " and TSPL_VENDOR_FORMULA_MAPPING.DocCode = (select Min(TSPL_VENDOR_FORMULA_MAPPING.DocCode) from TSPL_JW_FORMULA where Code>'" + strCode + "' )"
            Case NavigatorType.Previous
                qry += " and TSPL_VENDOR_FORMULA_MAPPING.DocCode = (select Max(TSPL_VENDOR_FORMULA_MAPPING.DocCode) from TSPL_JW_FORMULA where Code<'" + strCode + "')"
            Case NavigatorType.Current
                qry += " and TSPL_VENDOR_FORMULA_MAPPING.DocCode = '" + strCode + "'"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)

        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New clsVendorFormulaMapping()
            obj.DocCode = clsCommon.myCstr(dt.Rows(0)("DocCode"))
            obj.DocDate = clsCommon.myCstr(dt.Rows(0)("DocDate"))
            obj.Formulacode = clsCommon.myCstr(dt.Rows(0)("Code"))
            obj.Formula = clsCommon.myCstr(dt.Rows(0)("Formula"))
            obj.ItemStructure = clsCommon.myCstr(dt.Rows(0)("Structure_Code"))
            obj.VenderCode = clsCommon.myCstr(dt.Rows(0)("VendorCode"))


        End If
        Return obj
    End Function

