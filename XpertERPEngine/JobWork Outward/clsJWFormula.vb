Public Class clsJWFormulaSoln
    Public Type As Integer ''1-FAT,2-SNF
    Public EstFATKG As Decimal
    Public EstSNFKG As Decimal

    Public Shared Function CalculateEstimate(ByVal dtDocDate As DateTime, ByVal StrStructreCode As String, ByVal strLocationCode As String, ByVal FatKG As Decimal, ByVal SNFKg As Decimal) As clsJWFormulaSoln
        Return CalculateEstimate(dtDocDate, StrStructreCode, strLocationCode, FatKG, SNFKg, Nothing)
    End Function
    Public Shared Function CalculateEstimate(ByVal dtDocDate As DateTime, ByVal StrStructreCode As String, ByVal strLocationCode As String, ByVal FatKG As Decimal, ByVal SNFKg As Decimal, ByVal ArrQCParam As Dictionary(Of String, String)) As clsJWFormulaSoln
       

        Dim qry As String = "select top 1  FormulaCode from TSPL_VENDOR_FORMULA_MAPPING_DETAIL" + Environment.NewLine + _
        "left outer join TSPL_VENDOR_FORMULA_MAPPING on TSPL_VENDOR_FORMULA_MAPPING.DocCode=TSPL_VENDOR_FORMULA_MAPPING_DETAIL.DocCode" + Environment.NewLine + _
        "left outer join TSPL_JW_FORMULA on TSPL_JW_FORMULA.Code=TSPL_VENDOR_FORMULA_MAPPING.FormulaCode" + Environment.NewLine + _
        "where TSPL_VENDOR_FORMULA_MAPPING.Posted=1 and TSPL_VENDOR_FORMULA_MAPPING.DocDate <='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(dtDocDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_JW_FORMULA.Structure_Code in ('" + StrStructreCode + "')" + Environment.NewLine + _
        "and TSPL_VENDOR_FORMULA_MAPPING_DETAIL.VendorCode in (select Jobwork_Vendor from TSPL_LOCATION_MASTER where Location_Code ='" + strLocationCode + "') order by TSPL_VENDOR_FORMULA_MAPPING.DocDate desc"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            Dim strFormulaCode As String = clsCommon.myCstr(dt.Rows(0)("FormulaCode"))
            If clsCommon.myLen(strFormulaCode) > 0 Then
                Return CalculateFormula(strFormulaCode, FatKG, SNFKg, ArrQCParam)
            End If
        End If
        Return Nothing
    End Function

    Public Shared Function CalculateFormula(ByVal strFormulaCode As String, ByVal FatKG As Decimal, ByVal SNFKg As Decimal, ByVal ArrQCParam As Dictionary(Of String, String))
        Dim FATType As Boolean
        Dim SNFType As Boolean
        Dim obj As clsJWFormulaSoln = Nothing
        Dim qry As String = "select TSPL_JW_FORMULA.Formula, TSPL_JW_FORMULA_DETAILS.Parameter_Code,TSPL_JW_FORMULA_DETAILS.Value,TSPL_JW_PARAMETER_MASTER.Type,TSPL_PARAMETER_MASTER.Code as MainParameterCode from TSPL_JW_FORMULA_DETAILS " + Environment.NewLine + _
                "left outer join TSPL_JW_PARAMETER_MASTER on TSPL_JW_PARAMETER_MASTER.Code=TSPL_JW_FORMULA_DETAILS.Parameter_Code" + Environment.NewLine + _
                "left outer join TSPL_JW_FORMULA on TSPL_JW_FORMULA.code=TSPL_JW_FORMULA_DETAILS.Code" + Environment.NewLine + _
                "left outer join TSPL_PARAMETER_MASTER on TSPL_PARAMETER_MASTER.Code=TSPL_JW_FORMULA_DETAILS.Parameter_Code and TSPL_JW_PARAMETER_MASTER.Type='N'" + Environment.NewLine + _
                "where TSPL_JW_FORMULA_DETAILS.Code='" + strFormulaCode + "' and TSPL_JW_FORMULA.Formula   like  '%'+TSPL_JW_FORMULA_DETAILS.Parameter_Code+'%'"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            obj = New clsJWFormulaSoln()
            qry = clsCommon.myCstr(dt.Rows(0)("Formula"))
            For Each dr As DataRow In dt.Rows
                If clsCommon.CompairString(clsCommon.myCstr(dr("Type")), "F") = CompairStringResult.Equal Then
                    FATType = True
                    qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), clsCommon.myCstr(FatKG))
                ElseIf clsCommon.CompairString(clsCommon.myCstr(dr("Type")), "S") = CompairStringResult.Equal Then
                    SNFType = True
                    qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), clsCommon.myCstr(SNFKg))
                Else
                    If clsCommon.myLen(dr("MainParameterCode")) > 0 Then
                        ''BHA/22/10/18-000634 by balwinder on 24/10/2018
                        If ArrQCParam IsNot Nothing AndAlso ArrQCParam.Count > 0 Then
                            If ArrQCParam.ContainsKey(clsCommon.myCstr(dr("Parameter_Code"))) Then
                                qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), ArrQCParam.Item(clsCommon.myCstr(dr("Parameter_Code"))))
                            Else
                                qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), clsCommon.myCstr(dr("Value")))
                            End If
                        Else
                            qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), clsCommon.myCstr(dr("Value")))
                        End If
                    Else
                        qry = qry.Replace(clsCommon.myCstr(dr("Parameter_Code")), clsCommon.myCstr(dr("Value")))
                    End If
                End If
            Next
            qry = "select (" + qry + ") "
            If FATType AndAlso SNFType Then
                Throw New Exception("Formula - [" + strFormulaCode + "] has FAT And SNF both type parameters")
            ElseIf Not FATType AndAlso Not SNFType Then
                Throw New Exception("Formula - [" + strFormulaCode + "] has at least one FAT And SNF type parameters")
            Else
                If FATType Then
                    obj.Type = 1
                    Try
                        obj.EstFATKG = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry))
                    Catch ex As Exception
                    End Try
                ElseIf SNFType Then
                    obj.Type = 2
                    Try
                        obj.EstSNFKG = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry))
                    Catch ex As Exception
                    End Try
                Else
                    Throw New Exception("Formula - [" + strFormulaCode + "] something is wrong")
                End If
            End If
        End If
        Return obj
    End Function
End Class