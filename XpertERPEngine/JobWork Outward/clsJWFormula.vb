        Dim qry As String = "  select distinct TSPL_VENDOR_FORMULA_MAPPING.DocCode as [Code] ,TSPL_VENDOR_FORMULA_MAPPING.DocDate as [Date] ,TSPL_VENDOR_FORMULA_MAPPING.Formulacode as [Formula Code] ,TSPL_VENDOR_FORMULA_MAPPING.Created_By as [Created By] ,TSPL_VENDOR_FORMULA_MAPPING.Created_Date as [Created Date]   From TSPL_VENDOR_FORMULA_MAPPING   "
