    Public Shared Function SaveData(ByVal strCode As String, ByVal arr As List(Of clsCreateBIReportFilterDetails), ByVal trans As SqlTransaction) As Boolean
        Try
            Dim qry As String = "delete from TSPL_CREATE_BI_REPORT_FILTERS where Code='" + strCode + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            Dim isSaved As Boolean = True
            For Each objtr As clsCreateBIReportFilterDetails In arr
                Dim coll As New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Code", strCode)
                clsCommon.AddColumnsForChange(coll, "Is_Select", IIf(objtr.Is_Select, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Filter_Column", objtr.Filter_Column)
                clsCommon.AddColumnsForChange(coll, "Against_Filter", objtr.Against_Filter, True)
                clsCommon.AddColumnsForChange(coll, "Is_Date_Range", IIf(objtr.Is_Date_Range, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Is_Date_Type_Column", IIf(objtr.Is_Date_Type_Column, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Tree_Level", objtr.Tree_Level)
                clsCommon.AddColumnsForChange(coll, "Is_Show_Total", IIf(objtr.Is_Show_Total, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Is_Numeric_Type_Column", IIf(objtr.Is_Numeric_Type_Column, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Total_Formula", objtr.Total_Formula)
                clsCommon.AddColumnsForChange(coll, "Order_By", objtr.Order_By)
                clsCommon.AddColumnsForChange(coll, "Is_Order_Desc", IIf(objtr.Is_Order_Desc, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Figure_In", objtr.Figure_In)
                clsCommon.AddColumnsForChange(coll, "Chart_Column", IIf(objtr.Chart_Column, 1, 0))
                clsCommon.AddColumnsForChange(coll, "Chart_Row", IIf(objtr.Chart_Row, 1, 0))

                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_CREATE_BI_REPORT_FILTERS", OMInsertOrUpdate.Insert, "", trans)
            Next
            Return True
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function
End Class

