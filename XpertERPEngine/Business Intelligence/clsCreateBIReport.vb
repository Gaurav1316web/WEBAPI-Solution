    Public Function SaveData(ByVal obj As clsCreateBIReport, ByVal isNewEntry As Boolean) As Boolean
        Return SaveData(obj, isNewEntry, False)
    End Function

    Public Function SaveData(ByVal obj As clsCreateBIReport, ByVal isNewEntry As Boolean, ByVal isNewEntryAccordingToCode As Boolean) As Boolean
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim qry As String = ""
            Dim coll As New Hashtable()

            clsCommon.AddColumnsForChange(coll, "Description", obj.Description)
            clsCommon.AddColumnsForChange(coll, "Type", obj.Type)
            clsCommon.AddColumnsForChange(coll, "Qry", obj.Qry)
            clsCommon.AddColumnsForChange(coll, "Report_Module", obj.Report_Module, True)
            clsCommon.AddColumnsForChange(coll, "Chart_Type", obj.Chart_Type)

            clsCommon.AddColumnsForChange(coll, "Drill_Down_Type", obj.Drill_Down_Type)
            clsCommon.AddColumnsForChange(coll, "Drill_Down_Report", obj.Drill_Down_Report, True)
            clsCommon.AddColumnsForChange(coll, "Drill_Down_Filter", obj.Drill_Down_Filter, True)
            clsCommon.AddColumnsForChange(coll, "Drill_Down_Column", obj.Drill_Down_Column)
            clsCommon.AddColumnsForChange(coll, "Drill_Down_Transaction_Type", obj.Drill_Down_Transaction_Type)


            clsCommon.AddColumnsForChange(coll, "Chart_Combine_Mode", obj.Chart_Combine_Mode)
            clsCommon.AddColumnsForChange(coll, "Chart_Orientation", obj.Chart_Orientation)
            clsCommon.AddColumnsForChange(coll, "Chart_Label_Rotation", obj.Chart_Label_Rotation)
            clsCommon.AddColumnsForChange(coll, "Chart_Show_Label", IIf(obj.Chart_Show_Label, 1, 0))
            clsCommon.AddColumnsForChange(coll, "Chart_Show_Scroll", IIf(obj.Chart_Show_Scroll, 1, 0))

            clsCommon.AddColumnsForChange(coll, "Chart_Category_Member", obj.Chart_Category_Member)
            clsCommon.AddColumnsForChange(coll, "Chart_Series_Member", obj.Chart_Series_Member)
            clsCommon.AddColumnsForChange(coll, "Chart_Value_Member", obj.Chart_Value_Member)
            clsCommon.AddColumnsForChange(coll, "Is_Create_By_Developer", IIf(obj.Is_Create_By_Developer, 1, 0))
            clsCommon.AddColumnsForChange(coll, "is_For_Dashboard", IIf(obj.is_For_Dashboard, 1, 0))
            If obj.Layout Is Nothing Then
                clsCommon.AddColumnsForChange(coll, "Layout", Nothing, True)
            Else
                Dim reader As StreamReader = New StreamReader(obj.Layout)
                Dim strToSaveGridLayout As String = reader.ReadToEnd()
                clsCommon.AddColumnsForChange(coll, "Layout", strToSaveGridLayout)
                ''stuti regarding memory leakage
                reader.Close()
                reader.Dispose()
            End If
            clsCommon.AddColumnsForChange(coll, "Comp_Code", objCommonVar.CurrentCompanyCode)
            clsCommon.AddColumnsForChange(coll, "Modify_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modify_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy hh:mm tt"))

            If isNewEntryAccordingToCode Then
                qry = " select 1 from TSPL_CREATE_BI_REPORT where code='" + obj.Code + "'"
                Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
                If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                    isNewEntry = False
                Else
                    isNewEntry = True
                End If
            End If

            If isNewEntry Then
                If clsCommon.myLen(obj.Code) <= 0 Then
                    qry = " select max(Code) from TSPL_CREATE_BI_REPORT where code like 'BIRPT%'"
                    obj.Code = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, trans))
                    If clsCommon.myLen(obj.Code) > 0 Then
                        obj.Code = clsCommon.incval(obj.Code)
                    Else
                        obj.Code = "BIRPT000001"
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Code", obj.Code)
                clsCommon.AddColumnsForChange(coll, "Created_By", objCommonVar.CurrentUserCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MMM/yyyy hh:mm tt"))
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_CREATE_BI_REPORT", OMInsertOrUpdate.Insert, "", trans)
            Else
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_CREATE_BI_REPORT", OMInsertOrUpdate.Update, " code ='" + obj.Code + "'", trans)
            End If
            clsCreateBIReportFilterDetails.SaveData(obj.Code, obj.arr, trans)
            clsCreateBIReportInnerFilterDetails.SaveData(obj.Code, obj.arrInner, trans)

            If obj.is_For_Dashboard Then
                qry = "delete from TSPL_GROUP_PROGRAM_MAPPING where Program_Code='" + obj.Code + "'"
                clsDBFuncationality.ExecuteNonQuery(qry, trans)

                qry = "delete from TSPL_PROGRAM_MASTER where Program_Code='" + obj.Code + "'"
                clsDBFuncationality.ExecuteNonQuery(qry, trans)
            Else
                ProgramCodeNew.AddCustomLinks(obj.Code, obj.Description, obj.Report_Module, trans)
            End If
            trans.Commit()
        Catch ex As Exception
            trans.Rollback()
            Throw New Exception(ex.Message)
        End Try
        Return True
    End Function

    Public Shared Function GetName(ByVal strCode As String) As String
        Dim qry As String = "SELECT Description  FROM TSPL_CREATE_BI_REPORT where Code='" + strCode + "'"
        Return clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry))
    End Function
    Public Shared Function GetData(ByVal strCode As String, ByVal ShowAllReport As Boolean, ByVal NavType As NavigatorType) As clsCreateBIReport
        Dim qry As String = "select TSPL_CREATE_BI_REPORT.* from TSPL_CREATE_BI_REPORT  where 2=2"
        Dim whrclas As String = ""
        If Not ShowAllReport Then
            whrclas += " and TSPL_CREATE_BI_REPORT.Is_Create_By_Developer=0"
        End If

        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_CREATE_BI_REPORT.Code = (select MIN(Code) from TSPL_CREATE_BI_REPORT WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_CREATE_BI_REPORT.Code = (select Max(Code) from TSPL_CREATE_BI_REPORT WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_CREATE_BI_REPORT.Code = '" + strCode + "'  " + whrclas + ""
            Case NavigatorType.Next
                qry += " and TSPL_CREATE_BI_REPORT.Code = (select Min(Code) from TSPL_CREATE_BI_REPORT where  Code>'" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_CREATE_BI_REPORT.Code = (select Max(Code) from TSPL_CREATE_BI_REPORT where Code<'" + strCode + "' " + whrclas + ")"
        End Select
        Dim obj As clsCreateBIReport = Nothing
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        Dim Arr As List(Of clsCreateBIReport) = Nothing
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
            obj = New clsCreateBIReport()
            obj.Code = clsCommon.myCstr(dt.Rows(0)("Code"))
            obj.Description = clsCommon.myCstr(dt.Rows(0)("Description"))
            obj.Type = clsCommon.myCstr(dt.Rows(0)("Type"))
            obj.Qry = clsCommon.myCstr(dt.Rows(0)("Qry"))
            obj.Report_Module = clsCommon.myCstr(dt.Rows(0)("Report_Module"))
            obj.Chart_Type = clsCommon.myCstr(dt.Rows(0)("Chart_Type"))
            obj.Chart_Category_Member = clsCommon.myCstr(dt.Rows(0)("Chart_Category_Member"))
            obj.Chart_Series_Member = clsCommon.myCstr(dt.Rows(0)("Chart_Series_Member"))
            obj.Chart_Value_Member = clsCommon.myCstr(dt.Rows(0)("Chart_Value_Member"))
            obj.Is_Create_By_Developer = IIf(clsCommon.myCdbl(dt.Rows(0)("Is_Create_By_Developer")) = 1, True, False)
            obj.is_For_Dashboard = IIf(clsCommon.myCdbl(dt.Rows(0)("is_For_Dashboard")) = 1, True, False)

            obj.Chart_Combine_Mode = clsCommon.myCstr(dt.Rows(0)("Chart_Combine_Mode"))
            obj.Chart_Orientation = clsCommon.myCstr(dt.Rows(0)("Chart_Orientation"))
            obj.Chart_Label_Rotation = clsCommon.myCdbl(dt.Rows(0)("Chart_Label_Rotation"))
            obj.Chart_Show_Label = IIf(clsCommon.myCdbl(dt.Rows(0)("Chart_Show_Label")) = 1, True, False)
            obj.Chart_Show_Scroll = IIf(clsCommon.myCdbl(dt.Rows(0)("Chart_Show_Scroll")) = 1, True, False)

            obj.Drill_Down_Type = clsCommon.myCdbl(dt.Rows(0)("Drill_Down_Type"))
            obj.Drill_Down_Column = clsCommon.myCstr(dt.Rows(0)("Drill_Down_Column"))
            obj.Drill_Down_Transaction_Type = clsCommon.myCstr(dt.Rows(0)("Drill_Down_Transaction_Type"))
            obj.Drill_Down_Report = clsCommon.myCstr(dt.Rows(0)("Drill_Down_Report"))
            obj.Drill_Down_Filter = clsCommon.myCstr(dt.Rows(0)("Drill_Down_Filter"))
            

            Dim strGridLayout As String = clsCommon.myCstr(dt.Rows(0)("Layout"))
            Dim byteArray As Byte() = Encoding.ASCII.GetBytes(strGridLayout)
            obj.Layout = New MemoryStream(byteArray)

            obj.arr = New List(Of clsCreateBIReportFilterDetails)
            qry = "select TSPL_CREATE_BI_REPORT_FILTERS.*,TSPL_CREATE_BI_FILTER.Description AS Against_Filter_Name,TSPL_CREATE_BI_FILTER.Filter_Type as Against_Filter_Type,TSPL_CREATE_BI_FILTER.Tree_Level as Against_Filter_Max_Level  from TSPL_CREATE_BI_REPORT_FILTERS left outer join TSPL_CREATE_BI_FILTER on TSPL_CREATE_BI_FILTER.Code=TSPL_CREATE_BI_REPORT_FILTERS.Against_Filter where TSPL_CREATE_BI_REPORT_FILTERS.code='" + obj.Code + "'"
            Dim dt1 As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt1 IsNot Nothing AndAlso dt1.Rows.Count > 0 Then
                For Each dr As DataRow In dt1.Rows
                    Dim objtr As New clsCreateBIReportFilterDetails()
                    objtr.Code = clsCommon.myCstr(dr("Code"))
                    objtr.Filter_Column = clsCommon.myCstr(dr("Filter_Column"))
                    objtr.Against_Filter = clsCommon.myCstr(dr("Against_Filter"))
                    objtr.Against_Filter_Name = clsCommon.myCstr(dr("Against_Filter_Name"))

                    objtr.Against_Filter_Type = clsCommon.myCstr(dr("Against_Filter_Type"))
                    objtr.Against_Filter_Max_Level = clsCommon.myCdbl(dr("Against_Filter_Max_Level"))
                    objtr.Tree_Level = clsCommon.myCdbl(dr("Tree_Level"))
                    objtr.Order_By = clsCommon.myCdbl(dr("Order_By"))
                    objtr.Is_Order_Desc = IIf(clsCommon.myCdbl(dr("Is_Order_Desc")) = 1, True, False)
                    objtr.Figure_In = clsCommon.myCdbl(dr("Figure_In"))
                    objtr.Is_Select = IIf(clsCommon.myCdbl(dr("Is_Select")) = 1, True, False)
                    objtr.Is_Date_Range = IIf(clsCommon.myCdbl(dr("Is_Date_Range")) = 1, True, False)
                    objtr.Is_Date_Type_Column = IIf(clsCommon.myCdbl(dr("Is_Date_Type_Column")) = 1, True, False)

                    objtr.Is_Numeric_Type_Column = IIf(clsCommon.myCdbl(dr("Is_Numeric_Type_Column")) = 1, True, False)
                    objtr.Is_Show_Total = IIf(clsCommon.myCdbl(dr("Is_Show_Total")) = 1, True, False)
                    objtr.Total_Formula = clsCommon.myCstr(dr("Total_Formula"))

                    objtr.Chart_Column = IIf(clsCommon.myCdbl(dr("Chart_Column")) = 1, True, False)
                    objtr.Chart_Row = IIf(clsCommon.myCdbl(dr("Chart_Row")) = 1, True, False)

                    obj.arr.Add(objtr)
                Next
            End If

            qry = "select TSPL_CREATE_BI_REPORT_FILTERS_INNER.*,TSPL_CREATE_BI_FILTER.Description AS Against_Filter_Name,TSPL_CREATE_BI_FILTER.Filter_Type as Against_Filter_Type,TSPL_CREATE_BI_FILTER.Tree_Level as Against_Filter_Max_Level  from TSPL_CREATE_BI_REPORT_FILTERS_INNER left outer join TSPL_CREATE_BI_FILTER on TSPL_CREATE_BI_FILTER.Code=TSPL_CREATE_BI_REPORT_FILTERS_INNER.Against_Filter where TSPL_CREATE_BI_REPORT_FILTERS_INNER.code='" + obj.Code + "'"
            dt1 = clsDBFuncationality.GetDataTable(qry)
            If dt1 IsNot Nothing AndAlso dt1.Rows.Count > 0 Then
                obj.arrInner = New List(Of clsCreateBIReportInnerFilterDetails)
                For Each dr As DataRow In dt1.Rows
                    Dim objtr As New clsCreateBIReportInnerFilterDetails()
                    objtr.Code = clsCommon.myCstr(dr("Code"))
                    objtr.Filter_SNo = clsCommon.myCstr(dr("Filter_SNo"))
                    objtr.Table_Name = clsCommon.myCstr(dr("Table_Name"))
                    objtr.Column_Name = clsCommon.myCstr(dr("Column_Name"))
                    objtr.Operator_Name = clsCommon.myCstr(dr("Operator_Name"))
                    objtr.Against_Filter = clsCommon.myCstr(dr("Against_Filter"))
                    objtr.Against_Filter_Name = clsCommon.myCstr(dr("Against_Filter_Name"))
                    objtr.Against_Filter_Type = clsCommon.myCstr(dr("Against_Filter_Type"))
                    objtr.Against_Filter_Max_Level = clsCommon.myCdbl(dr("Against_Filter_Max_Level"))
                    objtr.Tree_Level = clsCommon.myCdbl(dr("Tree_Level"))
                    objtr.Is_Date_Range = IIf(clsCommon.myCdbl(dr("Is_Date_Range")) = 1, True, False)
                    objtr.Is_From_Date = IIf(clsCommon.myCdbl(dr("Is_From_Date")) = 1, True, False)
                    objtr.Is_To_Date = IIf(clsCommon.myCdbl(dr("Is_To_Date")) = 1, True, False)
                    obj.arrInner.Add(objtr)
                Next
            End If
        End If
        Return obj
    End Function

    Public Shared Function DeleteData(ByVal strDocNo As String) As Boolean
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim qry As String = "delete from TSPL_GROUP_PROGRAM_MAPPING where Program_Code='" + strDocNo + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "Delete from TSPL_PROGRAM_MASTER where Program_Code='" + strDocNo + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)


            qry = "Delete from TSPL_CREATE_BI_REPORT_FILTERS where Code='" + strDocNo + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "Delete from TSPL_CREATE_BI_REPORT where Code='" + strDocNo + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)
            trans.Commit()
        Catch ex As Exception
            trans.Rollback()
            Throw New Exception(ex.Message)
        End Try

        Return True
    End Function

End Class

