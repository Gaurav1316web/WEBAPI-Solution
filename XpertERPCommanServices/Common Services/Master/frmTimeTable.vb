    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        fndDocCode.MyReadOnly = True
        btnSave.Enabled = True
        btnDelete.Enabled = True
        isNewEntry = False
        Dim obj As New clsTimeTable()
        obj = clsTimeTable.GetData(strCode, NavTyep)
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Document_Code) > 0) Then
            fndDocCode.Value = obj.Document_Code
            txtDate.Text = clsCommon.GetPrintDate(obj.Document_Date, "dd/MM/yyyy")

            cmbDealer.SelectedValue = obj.Type
            tpBkgFrmTime.Value = clsCommon.GetPrintDate(obj.Order_From_Time, "hh:mm tt")
            tpBkgToTime.Value = clsCommon.GetPrintDate(obj.Order_To_Time, "hh:mm tt")
            tpPmtFrmTime.Value = clsCommon.GetPrintDate(obj.Payment_From_Time, "hh:mm tt")
            tpPmtToTime.Value = clsCommon.GetPrintDate(obj.Payment_To_Time, "hh:mm tt")
          
        End If

    End Sub

