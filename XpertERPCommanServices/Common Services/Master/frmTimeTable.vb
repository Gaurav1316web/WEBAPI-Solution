    Private Sub frmTimeTable_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        SetUserMgmtNew()
        LoadType()
        cmbDealer.SelectedValue = "Select"
        txtDate.Text = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy")
        tpBkgFrmTime.Value = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "hh:mm tt")
        tpBkgToTime.Value = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "hh:mm tt")
        tpPmtFrmTime.Value = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "hh:mm tt")
        tpPmtToTime.Value = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "hh:mm tt")
        
    End Sub

    Private Sub LoadType()
        Dim dt As DataTable = New DataTable
        dt.Columns.Add("Code", GetType(String))
        dt.Columns.Add("Name", GetType(String))

        Dim dr As DataRow = dt.NewRow()
        dr("Code") = ""
        dr("Name") = "Select"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "CNF"
        dr("Name") = "CNF"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "Distributer"
        dr("Name") = "Distributer"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "Retail"
        dr("Name") = "Retail"
        dt.Rows.Add(dr)

        cmbDealer.DataSource = dt
        cmbDealer.ValueMember = "Code"
        cmbDealer.DisplayMember = "Name"
    End Sub

    

    Private Sub fndDocCode__MYNavigator_1(sender As Object, e As EventArgs, NavType As NavigatorType) Handles fndDocCode._MYNavigator
        Try
