    Private Sub SaveBackGroundImage()
        Try
            Dim qry As String = ""
            If clsCommon.myLen(fndCompanyCode.Value) > 0 Then
                If BGImage.Image IsNot Nothing Then
                    Dim bm As New Bitmap(BGImage.Image)

                    Dim ms As New MemoryStream()
                    BGImage.Image.Save(ms, BGImage.Image.RawFormat)
                    If BGImage.Image.Width <= 1300 Then
                        clsCommon.MyMessageBoxShow(Me, "Image Width not match please increase width 1300 ", Me.Text)
                        Exit Sub
                    ElseIf BGImage.Image.Height <= "800" Then
                        clsCommon.MyMessageBoxShow(Me, "Image height not match please increase height 800 ", Me.Text)
                        Exit Sub
                    End If

                    Dim data As Byte() = ms.GetBuffer()
                    clsDBFuncationality.UpdateImage("BackgroundImage", data, "TSPL_COMPANY_MASTER", "Comp_Code='" + fndCompanyCode.Value + "'")
                    ''richa agarwal regarding memory leakage
                    ms.Close()
                    ms.Dispose()
                Else
                    clsDBFuncationality.ExecuteNonQuery("Update TSPL_COMPANY_MASTER set BackgroundImage=null where  Comp_Code='" + fndCompanyCode.Value + "'")
                End If
            End If

        Catch ex As Exception
            '  MsgBox(ex.Message.ToString())
        End Try
    End Sub
