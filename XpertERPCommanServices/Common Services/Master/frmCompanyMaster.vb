                If (clsCommon.myLen(dt.Rows(0)("Backgroundimage")) > 0) Then
                    Dim data As Byte() = DirectCast(dt.Rows(0)("Backgroundimage"), Byte())
                    Dim ms As New MemoryStream(data)
                    BGImage.Image = Image.FromStream(ms)
                    ms.Close()
                    ms.Dispose()

                End If
            End If

        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
