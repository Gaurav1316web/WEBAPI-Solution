    Private Sub chk_main_company_ToggleStateChanged(ByVal sender As System.Object, ByVal args As Telerik.WinControls.UI.StateChangedEventArgs) Handles chk_main_company.ToggleStateChanged
        Try
            If isInsideLoadData = True Then
                Return
            End If

            If chk_main_company.Checked Then
                Dim qry As String = "select count(*) from tspl_company_master where isnull(Is_Main_Company,'0')='1' and comp_code<>'" + fndCompanyCode.Value + "'"
                Dim check As Integer = clsDBFuncationality.getSingleValue(qry)

                If check > 0 Then
                    chk_main_company.Checked = False
                    Throw New Exception("There is already a main company exist.")
                End If

            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub


    Private Sub txtcust_code__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles txtcust_code._MYValidating
        Try
            txtcust_code.Value = clsCustomerMaster.getFinder("", txtcust_code.Value, isButtonClicked)

            If clsCommon.myLen(txtcust_code.Value) > 0 Then
                Dim qry As String = "select count(*) from tspl_company_master where cust_code='" + txtcust_code.Value + "' and comp_code<>'" + fndCompanyCode.Value + "'"
                Dim check As Integer = clsDBFuncationality.getSingleValue(qry)

                If check > 0 Then
                    txtcust_code.Value = ""
                    Throw New Exception("Selected customer already mapped with other company." + Environment.NewLine + "Select the other customer.")
                End If

                txtcust_name.Text = clsCommon.myCstr(clsDBFuncationality.getSingleValue("select customer_name from tspl_customer_master where cust_code='" + txtcust_code.Value + "'"))
            Else
                txtcust_code.Value = ""
                txtcust_name.Text = ""
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub





