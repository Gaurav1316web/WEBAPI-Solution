    Private Sub LoadImage()
        Try
            PictureBox1.Image = Nothing
            PictureBox2.Image = Nothing
            Dim qry As String = "select logo_Img,logo_Img2 from TSPL_COMPANY_MASTER where Comp_Code='" + fndCompanyCode.Value + "'"
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If (clsCommon.myLen(dt.Rows(0)("logo_Img")) > 0) Then
                    Dim data As Byte() = DirectCast(dt.Rows(0)("logo_Img"), Byte())
                    Dim ms As New MemoryStream(data)
                    PictureBox1.Image = Image.FromStream(ms)
                    ''PictureBox1.SizeMode = PictureBoxSizeMode.StretchImage

                    ''RICHA agarwal regarding memory leakage 
                    ms.Close()
                    ms.Dispose()

