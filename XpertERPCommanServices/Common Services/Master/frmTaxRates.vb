    Private Sub FrmTaxRates_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnAdd.Enabled Then
            savedata()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            deletedata()
        ElseIf e.Alt And e.KeyCode = Keys.C Then
            Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            reset()

        End If
    End Sub

    Private Sub findTaxAuthority__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles findTaxAuthority._MYValidating
        Dim qst As String = ""
        If GstApplicable And ShowOnlyActiveTaxRateGroup Then
            qst = "select count(*) from tspl_tax_master where TAX_code='" + findTaxAuthority.Value + "' and GSTActive=1 "
        Else
            qst = "select count(*) from tspl_tax_master where TAX_code='" + findTaxAuthority.Value + "'"
        End If
        Dim count As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qst))
        If count = 0 Then
            findTaxAuthority.MyReadOnly = False
        Else
            findTaxAuthority.MyReadOnly = True
        End If

        If findTaxAuthority.MyReadOnly OrElse isButtonClicked Then
            'Dim qry As String = "select TAX_code as 'TaxAuthority',Tax_Code_Desc as 'Description' from tspl_tax_master"
            'findTaxAuthority.Value = clsCommon.ShowSelectForm("frmTaxAuty", qry, "TaxAuthority", "", findTaxAuthority.Value, "TAX_code", isButtonClicked)
            Dim strwhrcls As String = ""
            If GstApplicable And ShowOnlyActiveTaxRateGroup Then
                strwhrcls = " GSTActive=1"
            End If
            findTaxAuthority.Value = clsTaxMaster.getFinder(strwhrcls, findTaxAuthority.Value, isButtonClicked)
            LoadData()
        End If
    End Sub

    Private Sub findTaxAuthority__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavType As common.NavigatorType) Handles findTaxAuthority._MYNavigator
        Dim strwhrcls As String = ""
        Dim strwhrcls2 As String = ""
        Dim qst As String = "select TAX_code as 'Tax Authority',Tax_Code_Desc as 'Description' from tspl_tax_master where 2=2 "
        If GstApplicable And ShowOnlyActiveTaxRateGroup Then
            strwhrcls = " and GSTActive=1 "
            strwhrcls2 = " where GSTActive=1"
        End If
        Select Case NavType
            Case NavigatorType.Current
                qst += " and tspl_tax_master .TAX_code in ('" + findTaxAuthority.Value + "') " + strwhrcls + ""
            Case NavigatorType.Next
                qst += " and tspl_tax_master .TAX_code in (select min(TAX_code) from tspl_tax_master where TAX_code  >'" + findTaxAuthority.Value + "'  " + strwhrcls + ")"
            Case NavigatorType.First
                qst += " and tspl_tax_master .TAX_code in (select MIN(TAX_code) from tspl_tax_master  " + strwhrcls2 + " )"

            Case NavigatorType.Last
                qst += " and tspl_tax_master .TAX_code in (select Max(TAX_code) from tspl_tax_master " + strwhrcls2 + ")"
            Case NavigatorType.Previous
                qst += " and tspl_tax_master .TAX_code in (select Max(TAX_code) from tspl_tax_master where TAX_code  <'" + findTaxAuthority.Value + "' " + strwhrcls + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            findTaxAuthority.Value = clsCommon.myCstr(dt.Rows(0)("Tax Authority"))
        End If
        LoadData()
    End Sub
