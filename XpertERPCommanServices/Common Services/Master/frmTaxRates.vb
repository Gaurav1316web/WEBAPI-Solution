    Private Sub fillTransactionType()
        Dim dataTableTransType As New DataTable()
        dataTableTransType.Columns.Add("TransDesc")
        dataTableTransType.Columns.Add("TransValue")
        dataTableTransType.Rows.Add("Sales", "S")
        dataTableTransType.Rows.Add("Purchase", "P")
        dataTableTransType.Rows.Add("Transfer", "T")
        dataTableTransType.Rows.Add("HR And Payroll", "H")
        ddlTransType.DisplayMember = "TransDesc"
        ddlTransType.ValueMember = "TransValue"
        ddlTransType.DataSource = dataTableTransType
        ddlTransType.SelectedValue = "S"
    End Sub
    Private Sub reset()
        findTaxAuthority.Value = ""
        findTaxAuthority.MyReadOnly = False
        ddlTransType.SelectedValue = "S"
        btnAdd.Text = "Save"
        btnAdd.Enabled = True
        gvTaxRates.DataSource = Nothing
        gvTaxRates.Rows.Clear()
    End Sub
    Private Sub fillControls()
        gvTaxRates.DataSource = Nothing
        gvTaxRates.Rows.Clear()
        sql = "select " + tableName + ".Tax_Rate_Code," + tableName + ".Tax_Rate_Desc," + tableName + ".Tax_Rate," + tableName + ".GL_Account_Code,TSPL_GL_ACCOUNTS.Description as GLAccountName," & tableName & "._Type ," & tableName & ".GSTActive FROM  " + tableName + " left outer join TSPL_GL_ACCOUNTS on TSPL_GL_ACCOUNTS.Account_Code=" + tableName + ".GL_Account_Code  where " + tableName + ".Tax_Code='" + findTaxAuthority.Value + "' and " + tableName + ".Tax_Type='" + ddlTransType.SelectedValue + "'"
        ds = connectSql.RunSQLReturnDS(sql)
        For Each drow As DataRow In ds.Tables(0).Rows
            gvTaxRates.Rows.Add(drow(1).ToString(), drow(2).ToString(), drow(1).ToString(), clsCommon.myCstr(drow("GL_Account_Code")), clsCommon.myCstr(drow("GLAccountName")), clsCommon.myCstr(drow("_Type")))
        Next
        chkIsGLReadonly.Checked = True
        If clsCommon.CompairString(clsCommon.myCstr(ddlTransType.SelectedValue), "S") = CompairStringResult.Equal Then
            chkIsGLReadonly.Checked = False
        ElseIf clsCommon.CompairString(clsCommon.myCstr(ddlTransType.SelectedValue), "P") = CompairStringResult.Equal Then
            sql = "select Tax_Recoverable from tspl_tax_master where Tax_Code='" + findTaxAuthority.Value + "'"
            If clsCommon.CompairString(clsCommon.myCstr(clsDBFuncationality.getSingleValue(sql)), "Y") = CompairStringResult.Equal Then
                chkIsGLReadonly.Checked = False
            End If
        End If
        If ds.Tables(0).Rows.Count > 0 Then
            If clsCommon.myCdbl(ds.Tables(0).Rows(0)("GSTActive")) = 1 Then
                chkGSTActive.Checked = True
            Else
                chkGSTActive.Checked = False
            End If
        End If


        If (gvTaxRates.Rows.Count <> 0) Then
            btnAdd.Text = "Update"
            btnDelete.Enabled = True
            btnAdd.Enabled = True
        Else
            btnAdd.Text = "Save"
            btnAdd.Enabled = True
            btnDelete.Enabled = False
            'If userCode <> "ADMIN" Then
            '    If funSetUserAccess() = False Then Exit Sub
            'End If
        End If
    End Sub
    Function validate1(ByVal trans As SqlTransaction) As Boolean
        sql = "select TAX_code from tspl_tax_master where Tax_Code='" + findTaxAuthority.Value + "'"
        dr = clsDBFuncationality.GetDataTable(sql, trans)
        If dr.Rows Is Nothing AndAlso dr.Rows.Count <= 0 Then
            common.clsCommon.MyMessageBoxShow("Tax Autority is not valid.")
            findTaxAuthority.Focus()
            Return False
        End If
        ''richa agarwal 12 Nov,2016
        If clsCommon.CompairString(clsCommon.myCstr(findTaxAuthority.Value).ToUpper(), "WCT") = CompairStringResult.Equal Then
            Dim dbltaxrate As Integer = 0
            For i As Integer = 0 To gvTaxRates.Rows.Count - 1
                If clsCommon.myLen(gvTaxRates.Rows(i).Cells(0).Value) <> 0 Then
                    dbltaxrate = clsCommon.myCdbl(gvTaxRates.Rows(i).Cells(1).Value)
                    If dbltaxrate >= 0 Then
                        common.clsCommon.MyMessageBoxShow("Tax rate must be in -ve for WCT type.")
                        Return False
                    End If
                End If
            Next
        End If
        ''--------
        Return True
    End Function
