    Private Sub fndID__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavigatorType As common.NavigatorType) Handles fndID._MYNavigator
        Dim qst As String = "Select Channel_category_id as [Channel Category Id],channel_category_name[Channel Category Name] from TSPL_CHANNEL_CATEGORY_MASTER where  2=2 "
        Select Case NavigatorType
            Case NavigatorType.Current
                '  qst += "and assign_to='" + txtassign.Value + "' "
                ' qst += "and job_code in ('" + txtcode1.Value + "')"
            Case NavigatorType.Next
                qst += "and Channel_category_id in (select min(Channel_category_id) from TSPL_CHANNEL_CATEGORY_MASTER where Channel_category_id>'" + fndID.Value + "'   ) "
            Case NavigatorType.First
                qst += "and Channel_category_id in (select MIN(Channel_category_id) from TSPL_CHANNEL_CATEGORY_MASTER  )"
            Case NavigatorType.Last
                qst += "and Channel_category_id in (select Max(Channel_category_id) from TSPL_CHANNEL_CATEGORY_MASTER  )"
            Case NavigatorType.Previous
                qst += "and Channel_category_id in (select max(Channel_category_id) from TSPL_CHANNEL_CATEGORY_MASTER where Channel_category_id<'" + fndID.Value + "'   )"
        End Select
        ' fun_gridfill()
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndID.Value = clsCommon.myCstr(dt.Rows(0)("Channel Category Id"))

        End If
        'TextChanged()
        If fndID.Value IsNot Nothing Then
            rdbtndelete.Enabled = True
        Else
            rdbtndelete.Enabled = False

        End If
        text_changed()
        fndID_Leave()

    End Sub
