            fndID.Value = clsCommon.ShowSelectForm("POProject3", qry, "ChannelCategoryId", "", fndID.Value, "", isButtonClicked)
            ' rdtxtgroupdesc.Text = clsDBFuncationality.getSingleValue("Select group_desc from tspl_vendor_group where ven_group_code='" + fndgroupcode.Value + "'")
