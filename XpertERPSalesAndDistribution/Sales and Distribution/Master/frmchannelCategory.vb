    Sub text_changed()
        Try
            Dim query As String = "Select Channel_category_id from tspl_channel_category_master where channel_category_id ='" + fndID.Value.Trim() + "'"
            Dim dr As DataTable
            dr = clsDBFuncationality.GetDataTable(query)
            Dim value As String = String.Empty
            If dr IsNot Nothing AndAlso dr.Rows.Count > 0 Then
                value = dr.Rows(0)(0).ToString()
            End If
            If (value <> "") Then
                funfill()
                rdbtnsave.Text = "Update"
                rdbtnsave.Enabled = True
                rdbtndelete.Enabled = True
                rdtxtcategoryname1.Enabled = True
                rdbtndelete.Enabled = True
            Else
                rdbtndelete.Enabled = False
                rdbtnsave.Text = "Save"
                rdbtnsave.Enabled = True
                rdtxtcategoryname1.Text = ""
                rdtxtcategoryname1.Enabled = True
            End If
            'If userCode <> "ADMIN" Then
            '    If funSetUserAccess() = False Then Exit Sub
            'End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try

    End Sub
    ' This function is used to retrive data text_changed of finder.
    Public Sub funfill()
        Try
            Dim query As String = " Select Channel_category_id,channel_category_name from tspl_channel_category_master where channel_category_id ='" + fndID.Value.Trim() + "'"
            dr = clsDBFuncationality.GetDataTable(query)

            If dr IsNot Nothing AndAlso dr.Rows.Count > 0 Then
                fndID.Value = dr.Rows(0)(0).ToString().Trim()
                rdtxtcategoryname1.Text = dr.Rows(0)(1).ToString()
                rdbtnsave.Text = "Update"
                rdbtndelete.Enabled = True
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub
    Sub fndID_Leave()
        If fndID.Value <> "" Then
            rdtxtcategoryname1.Enabled = True
            rdbtnsave.Enabled = True
            rdbtnclose.Enabled = True
        End If
    End Sub

