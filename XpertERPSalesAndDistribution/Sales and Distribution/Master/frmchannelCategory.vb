    ' This event is Used for Import Data from excel sheet to database.
    Private Sub rdmenuimport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rdmenuimport.Click
        Dim dgv As New RadGridView
        Me.Controls.Add(dgv)
        If transportSql.importExcel(dgv, "Channel Category Id", "Channel Category Name") Then
            Dim trans As SqlTransaction = Nothing
            Try
                connectSql.OpenConnection()
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()
                For Each dgrv As GridViewRowInfo In dgv.Rows

                    Dim strchannelcategoryid As String = clsCommon.myCstr(dgrv.Cells(0).Value)
                    If clsCommon.myLen(strchannelcategoryid) > 12 Then
                        Throw New Exception("Check the length of channel category id")
                    End If

                    Dim strchannelcategoryname As String = clsCommon.myCstr(dgrv.Cells(1).Value)
                    If clsCommon.myLen(strchannelcategoryname) > 50 Then
                        Throw New Exception("Check the length of channel category name")
                    End If

                    If String.IsNullOrEmpty(strchannelcategoryid) Or clsCommon.myLen(strchannelcategoryid) > 12 Then
                        Throw New Exception("Channel Category Id has some incorrect values")
                    End If

                    Dim sql1 As String = "select count(*)from tspl_channel_category_master where channel_category_id='" + strchannelcategoryid + "'"
                    Dim i As Integer = CInt(connectSql.RunScalar(trans, sql1))
                    If (i = 0) Then
                        Dim query As String = "insert into tspl_channel_category_master values('" + strchannelcategoryid + "','" + strchannelcategoryname + "','" + userCode + "','" + connectSql.serverDate(trans) + "','" + userCode + "','" + connectSql.serverDate(trans) + "','" + companyCode + "')"
                        connectSql.RunSqlTransaction(trans, query)
                    Else
                        Dim query1 As String = "update tspl_channel_category_master set channel_category_name ='" + strchannelcategoryname + "' where channel_category_id='" + strchannelcategoryid + "' "
                        connectSql.RunSqlTransaction(trans, query1)
                    End If
                Next
                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transferred Completed", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)


            End Try
        End If
        Me.Controls.Remove(dgv)
    End Sub
