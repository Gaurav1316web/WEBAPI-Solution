#Region "Import/Export"
    Private Sub MenuImport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MenuImport.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        If transportSql.importExcel(gv, "CUST_CATEGORY_CODE", "CUST_CATEGORY_DESC", "Price_Code", "Price_Code_Desc", "Route_No", "Route_Desc", "Price Code Non-Excise", "Price Code Non-Excise Description") Then
            Dim trans As SqlTransaction = Nothing
            Try
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()
                For Each grow As GridViewRowInfo In gv.Rows
                    Dim strCustCode As String
                    Dim strCustDesc As String
                    Dim strPCode As String
                    ' Dim strPCodeDesc As String
                    Dim strRouteId As String
                    Dim strRouteDesc As String
                    If String.IsNullOrEmpty(clsCommon.myCstr(grow.Cells(0).Value)) Then
                        Throw New Exception("Customer Category can not be blank")
                    ElseIf clsCommon.myLen(grow.Cells(0).Value) > 12 Then
                        Throw New Exception("Customer Category cannot be greater than 12 length.")
                    Else
                        strCustCode = clsCommon.myCstr(grow.Cells(0).Value)
                    End If

                    If clsCommon.myLen(grow.Cells(1).Value) > 50 Then
                        Throw New Exception("Customer Category Description cannot be greater than 50 length.")
                    Else
                        strCustDesc = clsCommon.myCstr(grow.Cells(1).Value)
                    End If

                    If String.IsNullOrEmpty(clsCommon.myCstr(grow.Cells(2).Value)) Then
                        Throw New Exception("Price Code cannot be blank")
                    ElseIf clsCommon.myLen(grow.Cells(2).Value) > 12 Then
                        Throw New Exception("Price Code cannot be greater than 12 length.")
                    Else
                        strPCode = clsCommon.myCstr(grow.Cells(2).Value)
                    End If

                    If clsCommon.myLen(grow.Cells(3).Value) > 100 Then
                        Throw New Exception("Price Code Description cannot be greater than 100 length.")
                    Else
                        strRouteDesc = clsCommon.myCstr(grow.Cells(3).Value)
                    End If

                    If clsCommon.myLen(grow.Cells(4).Value) > 12 Then
                        Throw New Exception("Route Id cannot be greater than 12 length.")
                    Else
                        strRouteId = clsCommon.myCstr(grow.Cells(4).Value)
                    End If

                    If clsCommon.myLen(grow.Cells(5).Value) > 50 Then
                        Throw New Exception("Route Description cannot be greater than 50 length.")
                    Else
                        strRouteDesc = (grow.Cells(5).Value)
                    End If

                    Dim strPriceCodeNon As String = clsCommon.myCstr(grow.Cells(6).Value)
                    Dim strPriceCodeNonDesc As String = clsCommon.myCstr(grow.Cells(7).Value)
                    Dim Datee As String = clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans))
                    Dim sql1 As String = "select COUNT(*) from TSPL_CUSTOMER_CATEGORY_MASTER  where CUST_CATEGORY_CODE='" + strCustCode + "'"
                    Dim i As Integer = CInt(clsDBFuncationality.getSingleValue(sql1, trans))
                    If (i = 0) Then
                        connectSql.RunSpTransaction(trans, "sp_tspl_Customer_Category_Master_insert", New SqlParameter("@CustCategoryCode", strCustCode), New SqlParameter("@CustCategoryDesc", strCustDesc), New SqlParameter("@PriceCode", strPCode), New SqlParameter("@PriceCodeDesc", strRouteDesc), New SqlParameter("@RouteId", strRouteId), New SqlParameter("@RouteDesc", strRouteDesc), New SqlParameter("@CreatedBy", userCode), New SqlParameter("@CreatedDate", Datee), New SqlParameter("@ModifiedBy", userCode), New SqlParameter("@ModifiedDate", Datee), New SqlParameter("@CompCode", companyCode), New SqlParameter("@PriceCodeNon", strPriceCodeNon), New SqlParameter("@PriceCodeDescNon", strPriceCodeNonDesc), New SqlParameter("@ShelfLife", ""))
                    Else
                        connectSql.RunSpTransaction(trans, "sp_tspl_Customer_Category_Master_update", New SqlParameter("@CustCategoryCode", strCustCode), New SqlParameter("@CustCategoryDesc", strCustDesc), New SqlParameter("@PriceCode", strPCode), New SqlParameter("@PriceCodeDesc", strRouteDesc), New SqlParameter("@RouteId", strRouteId), New SqlParameter("@RouteDesc", strRouteDesc), New SqlParameter("@CreatedBy", userCode), New SqlParameter("@CreatedDate", Datee), New SqlParameter("@ModifiedBy", userCode), New SqlParameter("@ModifiedDate", Datee), New SqlParameter("@CompCode", companyCode), New SqlParameter("@PriceCodeNon", strPriceCodeNon), New SqlParameter("@PriceCodeDescNon", strPriceCodeNonDesc), New SqlParameter("@ShelfLife", ""))
                    End If
                Next
                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)

            End Try

        End If
        Me.Controls.Remove(gv)
    End Sub

