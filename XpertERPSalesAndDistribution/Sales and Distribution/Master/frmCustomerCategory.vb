    Private Sub fndCustomerId__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavType As common.NavigatorType) Handles fndCustomerId._MYNavigator
        Dim qst As String = "select Cust_Category_Code as [Customer Category Code],Cust_Category_Desc as [Customer Code Description] from tspl_Customer_Category_Master where 2=2  "
        Select Case NavType
            Case NavigatorType.Current
                qst += " and tspl_Customer_Category_Master .Cust_Category_Code in ('" + fndCustomerId.Value + "')"
            Case NavigatorType.Next
                qst += " and tspl_Customer_Category_Master .Cust_Category_Code in (select min(Cust_Category_Code ) from tspl_Customer_Category_Master where tspl_Customer_Category_Master.Cust_Category_Code   >'" + fndCustomerId.Value + "')"
            Case NavigatorType.First
                qst += " and tspl_Customer_Category_Master .Cust_Category_Code in (select MIN(Cust_Category_Code ) from tspl_Customer_Category_Master)"

            Case NavigatorType.Last
                qst += " and tspl_Customer_Category_Master .Cust_Category_Code in (select Max(Cust_Category_Code ) from tspl_Customer_Category_Master)"
            Case NavigatorType.Previous
                qst += " and tspl_Customer_Category_Master .Cust_Category_Code in (select Max(Cust_Category_Code ) from tspl_Customer_Category_Master where tspl_Customer_Category_Master.Cust_Category_Code   <'" + fndCustomerId.Value + "')"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndCustomerId.Value = clsCommon.myCstr(dt.Rows(0)("Customer Category Code"))
            txtCustomerDesc.Text = clsCommon.myCstr(dt.Rows(0)("Customer Code Description"))
        End If
        LoadData()
    End Sub

