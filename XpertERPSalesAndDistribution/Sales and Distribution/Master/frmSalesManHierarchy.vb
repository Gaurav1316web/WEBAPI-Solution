    Sub DeleteData()
        If clsCommon.myLen(fndSalesmancode.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow("You Cannot Delete Record")
            Exit Sub
        End If
        '' Code Added By Abhishek as on 19/10/2012 11:29 am  For Check If Exist SettlementCode in TSPL_TRANSFER_HEAD,TSPL_SHIPMENT_MASTER then Don't Delete
        Dim SalesemenCode As String
        Dim SalesemenCode1 As String
        SalesemenCode = clsDBFuncationality.getSingleValue(" select Route_No  from TSPL_TRANSFER_HEAD  where Route_No ='" & fndSalesmancode.Value & "'")
        SalesemenCode1 = clsDBFuncationality.getSingleValue(" select Route_No  from TSPL_SHIPMENT_MASTER where Route_No='" & fndSalesmancode.Value & "'")
        If clsCommon.myLen(SalesemenCode) > 0 Or clsCommon.myLen(SalesemenCode1) > 0 Then
            common.clsCommon.MyMessageBoxShow("This record can't be deleted.It is used in another process")
            Exit Sub
        End If
        '' Code Ends 

        If myMessages.deleteConfirm() Then
            funDelete()
        Else

        End If


    End Sub

