    Private Sub Import_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles Import.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        If transportSql.importExcel(gv, "Salesman code", "HOS", "TDM", "ADC", "CE", "HOS StartDate", "TDM StartDate", "ADC StartDate", "CE StartDate") Then
            Dim trans As SqlTransaction = Nothing
            Try
                connectSql.OpenConnection()
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()

                For Each grow As GridViewRowInfo In gv.Rows
                    Dim strcode As String = clsCommon.myCstr(grow.Cells(0).Value)
                    If clsCommon.myLen(strcode) > 12 Then
                        Throw New Exception("Check the length of 'Code'.")
                    End If
                    ''richa agarwal
                    ' Dim acc1 As String = "SELECT count(*)  FROM [dbo].[TSPL_ROUTE_MASTER] where route_no='" + strcode + "'"
                    Dim acc1 As String = "SELECT count(*)  FROM [dbo].[TSPL_EMPLOYEE_MASTER] where EMP_CODE='" + strcode + "' and Emp_type ='EMP01'"
                    Dim no1 As Integer = CInt(connectSql.RunScalar(trans, acc1))
                    If no1 = 0 Then
                        Throw New Exception("This  " + strcode + "  Salesman Code does not exist")
                    End If



                    Dim strhos As String = clsCommon.myCstr(grow.Cells("HOS").Value)
                    Dim LS1DATE As String = clsCommon.GetPrintDate(clsCommon.myCstr(grow.Cells("HOS StartDate").Value), "dd/MM/yyyy")
                    Dim LS2DATE As String = clsCommon.GetPrintDate(clsCommon.myCstr(grow.Cells("TDM StartDate").Value), "dd/MM/yyyy")
                    Dim LS3DATE As String = clsCommon.GetPrintDate(clsCommon.myCstr(grow.Cells("ADC StartDate").Value), "dd/MM/yyyy")
                    Dim LS4DATE As String = clsCommon.GetPrintDate(clsCommon.myCstr(grow.Cells("CE StartDate").Value), "dd/MM/yyyy")
                    If clsCommon.myLen(strhos) > 12 Then
                        Throw New Exception("Check the length of 'HOS'.")
                    End If
                    Dim acc2 As String = "SELECT count(*)  FROM [dbo].[TSPL_employee_master] where emp_code='" + strhos + "'"
                    Dim no2 As Integer = CInt(connectSql.RunScalar(trans, acc2))
                    If no2 = 0 Then
                        Throw New Exception("This  " + strhos + "   Code does not exist")
                    End If

                    Dim strtdm As String = clsCommon.myCstr(grow.Cells("TDM").Value)
                    If clsCommon.myLen(strtdm) > 12 Then
                        Throw New Exception("Check the length of 'TDM'.")
                    End If
                    Dim acc3 As String = "SELECT count(*)  FROM [dbo].[TSPL_employee_master] where emp_code='" + strtdm + "'"
                    Dim no3 As Integer = CInt(connectSql.RunScalar(trans, acc3))
                    If no3 = 0 Then
                        Throw New Exception("This  " + strtdm + "   Code does not exist")
                    End If


                    Dim stradc As String = clsCommon.myCstr(grow.Cells("ADC").Value)
                    If clsCommon.myLen(stradc) > 12 Then
                        Throw New Exception("Check the length of 'ADC'.")
                    End If
                    Dim acc4 As String = "SELECT count(*)  FROM [dbo].[TSPL_employee_master] where emp_code='" + stradc + "'"
                    Dim no4 As Integer = CInt(connectSql.RunScalar(trans, acc4))
                    If no4 = 0 Then
                        Throw New Exception("This  " + stradc + "   Code does not exist")
                    End If


                    Dim strce As String = clsCommon.myCstr(grow.Cells("CE").Value)
                    If clsCommon.myLen(strce) > 12 Then
                        Throw New Exception("Check the length of 'TDM'.")
                    End If
                    Dim acc5 As String = "SELECT count(*)  FROM [dbo].[TSPL_employee_master] where emp_code='" + strce + "'"
                    Dim no5 As Integer = CInt(connectSql.RunScalar(trans, acc5))
                    If no5 = 0 Then
                        Throw New Exception("This  " + strce + "   Code does not exist")
                    End If

                    Dim createddate As String = CDate(connectSql.serverDate(trans)).ToString("dd/MM/yyyy ")
                    Dim modifydate As String = CDate(connectSql.serverDate(trans)).ToString("dd/MM/yyyy ")
                    'Dim createddate As String = (clsCommon.GETSERVERDATE).ToString("dd/MM/yyyy")
                    'Dim modifydate As String = (clsCommon.GETSERVERDATE).ToString("dd/MM/yyyy")
                    Dim commision As Decimal = 0
                    Dim type As String = ""
                    ' Dim SalesName As String = connectSql.RunScalar(trans, "SELECT TSPL_ROUTE_MASTER.Employee_Name FROM TSPL_ROUTE_MASTER  where Route_No='" + strcode + "' ")
                    Dim SalesName As String = connectSql.RunScalar(trans, "SELECT TSPL_EMPLOYEE_MASTER.Emp_Name FROM TSPL_EMPLOYEE_MASTER  where EMP_CODE='" + strcode + "' ")
                    ''=====================
                    Dim sql1 As String = "select count(*) from TSPL_SALESMAN_MAPPING where salesman_code='" + strcode + "' "
                    Dim i As Integer = CInt(connectSql.RunScalar(trans, sql1))
                    If (i = 0) Then
                        Dim Sql As String = "insert into TSPL_SALESMAN_MAPPING(salesman_code,salesman_name,commission_rate,type,level1_code,level2_code,level3_code,level4_code,created_by,created_date,modify_by,modify_date,comp_code,L1SDATE,L2SDATE,L3SDATE,L4SDATE) values ('" + strcode.ToString() + "', '" + SalesName + "', '" + clsCommon.myCstr(commision) + "','" + clsCommon.myCstr(type) + "','" + clsCommon.myCstr(strhos) + "','" + clsCommon.myCstr(strtdm) + "', '" + clsCommon.myCstr(stradc) + "','" + clsCommon.myCstr(strce) + "','" + userCode + "' ,'" + createddate + "','" + userCode + "', '" + modifydate + "', '" + companyCode + "' ,Convert(date,'" + LS1DATE + "', 103),COnvert(Date,'" + LS2DATE + "', 103),COnvert(Date,'" + LS3DATE + "', 103),COnvert(Date, '" + LS4DATE + "', 103))"
                        connectSql.RunSqlTransaction(trans, Sql)
                    Else
                        Dim sql As String = "update TSPL_SALESMAN_MAPPING set salesman_name='" + clsCommon.myCstr(SalesName) + "',commission_rate='" + clsCommon.myCstr(commision) + "',type='" + clsCommon.myCstr(type) + "',level1_code='" + clsCommon.myCstr(strhos) + "',level2_code='" + clsCommon.myCstr(strtdm) + "',level3_code='" + clsCommon.myCstr(stradc) + "',level4_code='" + clsCommon.myCstr(strce) + "',modify_by='" + userCode + "',modify_date='" + modifydate + "',comp_code='" + companyCode + "' ,L1SDATE=Convert(Date,'" + LS1DATE + "', 103) ,L2SDATE=Convert(Date,'" + LS2DATE + "', 103),L3SDATE=COnvert(date,'" + LS3DATE + "', 103),L4SDATE=Convert(Date,'" + LS4DATE + "', 103) where salesman_code = '" + strcode + "' "
                        connectSql.RunSqlTransaction(trans, sql)
                    End If
                Next
                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
8:          Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()

                myMessages.myExceptions(ex)
            End Try

        End If
        Me.Controls.Remove(gv)
    End Sub



    Private Sub FrmSalesManHierarchy_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnSave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.P AndAlso MyBase.isPostFlag Then
            'PostData() 
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            DeleteData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.C Then
            Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funReset()
        End If
    End Sub

