                qst += "and EMP_CODE in (select min(EMP_CODE) from TSPL_EMPLOYEE_MASTER where EMP_CODE>'" + fndSalesmancode.Value + "'  and Emp_type ='EMP01'   ) "
            Case NavigatorType.First
                qst += "and EMP_CODE in (select MIN(EMP_CODE) from TSPL_EMPLOYEE_MASTER where Emp_type ='EMP01'   )"
            Case NavigatorType.Last
                qst += "and EMP_CODE in (select Max(EMP_CODE) from TSPL_EMPLOYEE_MASTER where Emp_type ='EMP01'   )"
            Case NavigatorType.Previous
                qst += "and EMP_CODE in (select max(EMP_CODE) from TSPL_EMPLOYEE_MASTER where EMP_CODE<'" + fndSalesmancode.Value + "' and Emp_type ='EMP01'    )"
        End Select
        ' fun_gridfill()
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndSalesmancode.Value = clsCommon.myCstr(dt.Rows(0)("EMP_CODE"))
            txtSalesmanName.Text = clsCommon.myCstr(dt.Rows(0)("Emp_Name"))
        End If
        'TextChanged()
        If fndSalesmancode.Value IsNot Nothing Then
            btnDelete.Enabled = True
        Else
            btnDelete.Enabled = False

        End If
        fndSalesmancode_TextChanged()
    End Sub
End Class
