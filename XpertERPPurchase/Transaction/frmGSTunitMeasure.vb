    Sub funReset()
        isNewEntry = True
        txtCode1.MyReadOnly = False
        txtCode1.Value = Nothing
        txtCode1.Focus()
        txtName1.Text = ""
        btnSave1.Text = "Save"
        btnSave1.Enabled = True
        btnDelete1.Enabled = False
    End Sub
    Private Sub btnSave1_Click(sender As Object, e As EventArgs) Handles btnSave1.Click
        If clsCommon.myLen(txtCode1.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow("Please Enter PO  Code.")
            txtCode1.Focus()
            Exit Sub
        End If
        If clsCommon.myLen(txtName1.Text) <= 0 Then
            common.clsCommon.MyMessageBoxShow("Please select Vendor.")
            txtName1.Focus()
            Exit Sub
        End If
        Save()
    End Sub
    Function AllowToSave() As Boolean
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso clsCommon.myLen(txtCode1.Value) <= 0 Then
            myMessages.blankValue("Code")
            txtCode1.Focus()
            Return False
            'End If
        ElseIf clsCommon.myLen(txtCode1.Value) > 30 Then
            clsCommon.MyMessageBoxShow("Code Max Length should be 30")
            txtCode1.Focus()
            Return False
        ElseIf clsCommon.myLen(txtName1.Text) <= 0 Then
            myMessages.blankValue("Description")
            txtName1.Focus()
            Return False
        End If
        Return True
    End Function
    Public Sub Save()
        Try
            If AllowToSave() Then


                Dim obj As New clsUnitMaster()
                obj.Code = txtCode1.Value
                obj.Description = txtName1.Text

                If clsCommon.myLen(txtCode1.Value) > 0 Then
                    Dim sqlqry As String = "select Code, Description from TSPL_EINVOICE_UOM "
                    'Dim sqlqry As String = " Update TSPL_EINVOICE_UOM Set Code ='" & clsCommon.myCstr(txtCode1.Value) & "'  where Code='" + txtCode1.Value + "'"
                    clsDBFuncationality.ExecuteNonQuery(sqlqry)
                End If
                If clsCommon.myLen(txtCode1.Value) > 0 Then
                    'Dim sqlqry As String = "select Code as code, Description as Description from TSPL_EINVOICE_UOM "
                    Dim qry As String = "insert into Code,Description  into TSPL_EINVOICE_UOM values('" + txtCode1.Value + "') "
                    'Dim sqlqry As String = " Update TSPL_EINVOICE_UOM Set Code ='" & clsCommon.myCstr(txtCode1.Value) & "'  where Code='" + txtCode1.Value + "'"
                    clsDBFuncationality.ExecuteNonQuery(qry)
                End If
                btnSave1.Text = "Save"
                btnDelete.Enabled = True
            Else
                btnSave1.Text = "Save"
                btnDelete.Enabled = False
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub
    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        txtCode1.MyReadOnly = True
        btnSave1.Enabled = True
        btnDelete.Enabled = True
        isNewEntry = False
        Dim obj As New clsUnitMaster()
        obj = clsUnitMaster.GetData(strCode, NavTyep)
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Code) > 0) Then
            'funReset()
            isNewEntry = False
            btnSave1.Text = "Update"
            btnDelete.Enabled = True
            txtCode1.Value = obj.Code
            txtName1.Text = obj.Description
        End If
    End Sub

