    Private Sub btnSave1_Click(sender As Object, e As EventArgs) Handles btnSave1.Click
        If clsCommon.myLen(txtcode1.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "Please Enter  Code.", Me.Text)
            lblcode.Focus()
            Exit Sub
        End If
        If clsCommon.myLen(txtName1.Text) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "Please select Name", Me.Text)
            txtName1.Focus()
            Exit Sub
        End If
        Try
            If AllowToSave() Then
                Dim isNewEntry As Boolean = False
                Dim trans As SqlTransaction = Nothing
                Dim obj As New clsGstunitMeasure()
                obj.Code = txtcode1.Value
                obj.Description = txtName1.Text

                If clsCommon.myLen(txtcode1.Value) > 0 Then
                    Dim sqlqry As String = "select Code, Description from TSPL_EINVOICE_UOM where Code='" + obj.Code + "'"
                    Dim dt As DataTable = clsDBFuncationality.GetDataTable(sqlqry)
                    If dt.Rows.Count > 0 Then
                        isNewEntry = False
                    Else
                        isNewEntry = True
                    End If
                End If
                clsGstunitMeasure.SaveData(obj, isNewEntry, trans)
                common.clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                btnSave1.Text = "Save"
                btnDelete1.Enabled = True
            Else
                btnSave1.Text = "Save"
                btnDelete1.Enabled = False
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub
    Function AllowToSave() As Boolean
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso clsCommon.myLen(txtcode1.Value) <= 0 Then
            myMessages.blankValue(Me, "Code", Me.Text)
            lblcode.Focus()
            Return False
            'End If
        ElseIf clsCommon.myLen(txtcode1.Value) > 30 Then
            clsCommon.MyMessageBoxShow(Me, "Code Max Length should be 30", Me.Text)
            lblcode.Focus()
            Return False
        ElseIf clsCommon.myLen(txtName1.Text) <= 0 Then
            myMessages.blankValue(Me, "Description", Me.Text)
            txtName1.Focus()
            Return False
        End If
        Return True
    End Function
