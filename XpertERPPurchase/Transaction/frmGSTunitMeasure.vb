    Public Shared Function GetData(ByVal strCode As String, ByVal NavType As NavigatorType) As clsUnitMaster
        Dim obj As clsUnitMaster = Nothing
        Dim qry As String = "select TSPL_COST_CENTER_UNIT_MASTER.* from TSPL_COST_CENTER_UNIT_MASTER   where 2=2 "
        Dim whrclas As String = ""
        Select Case NavType
            Case NavigatorType.First
                qry += " and TSPL_COST_CENTER_UNIT_MASTER.Code = (select MIN(Code) from TSPL_COST_CENTER_UNIT_MASTER WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Last
                qry += " and TSPL_COST_CENTER_UNIT_MASTER.Code = (select Max(Code) from TSPL_COST_CENTER_UNIT_MASTER WHERE 1=1 " + whrclas + " )"
            Case NavigatorType.Current
                qry += " and TSPL_COST_CENTER_UNIT_MASTER.Code = (select TOP 1 Code from TSPL_COST_CENTER_UNIT_MASTER WHERE 1=1 " + whrclas + " and Code='" + strCode + "' )"
            Case NavigatorType.Next
                qry += " and TSPL_COST_CENTER_UNIT_MASTER.Code = (select Min(Code) from TSPL_COST_CENTER_UNIT_MASTER where Code > '" + strCode + "' " + whrclas + ")"
            Case NavigatorType.Previous
                qry += " and TSPL_COST_CENTER_UNIT_MASTER.Code = (select Max(Code) from TSPL_COST_CENTER_UNIT_MASTER where Code < '" + strCode + "' " + whrclas + ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        'If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then
        '    obj = New clsUnitMaster()
        '    obj.Code = clsCommon.myCstr(dt.Rows(0)("Code"))
        '    obj.Description = clsCommon.myCstr(dt.Rows(0)("Description"))

        'End If
        Return obj
    End Function

