    Private Sub txtCode1__MYValidating(sender As Object, e As EventArgs, isButtonClicked As Boolean) Handles txtcode1._MYValidating
        Dim str As String = "select count(*) from TSPL_EINVOICE_UOM where Code ='" + txtcode1.Value + "' "
        Dim no As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(str))
        If no = 0 AndAlso isButtonClicked = False Then
            txtcode1.MyReadOnly = False
        Else
            txtcode1.MyReadOnly = True
        End If
        If txtcode1.MyReadOnly OrElse isButtonClicked Then
            txtcode1.Value = clsGstunitMeasure.getFinder("", txtcode1.Value, isButtonClicked)
            If txtcode1.Value <> "" Then
                LoadData(txtcode1.Value, NavigatorType.Current)
            Else
                funReset()
            End If
        End If

    End Sub

    Private Sub txtCode1__MYNavigator(sender As Object, e As EventArgs, NavType As NavigatorType) Handles txtcode1._MYNavigator
        Try
            LoadData(txtcode1.Value, NavType)
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub

