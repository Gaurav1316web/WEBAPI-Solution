    Private Sub txtcostcenter__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles txtcostcenter._MYValidating
        Dim Qry As String = "select  CostCenter_Code , Description  from TSPL_COST_CENTRE_GROUP_MASTER "
        txtcostcenter.Value = clsCommon.ShowSelectForm("ccgrpfin", Qry, "CostCenter_Code", "", txtcostcenter.Value, "CostCenter_Code", isButtonClicked)
        If clsCommon.myLen(txtcostcenter.Value) > 0 Then
            lblCostDesp.Text = clsDBFuncationality.getSingleValue("Select Description from TSPL_COST_CENTRE_GROUP_MASTER Where CostCenter_Code='" + txtcostcenter.Value + "' ")
        Else
            lblCostDesp.Text = ""
        End If
    End Sub

    Private Sub FrmCostCentreFinancial_KeyDown(ByVal sender As Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles Me.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnSave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            DeleteData()
        ElseIf e.Alt And e.KeyCode = Keys.C Then
            funClose()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funReset()
        End If
    End Sub

    Private Sub FrmCostCentreFinancial_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load
        SetUserMgmtNew()
        EnableHirerachyCostCentre = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.EnableHirerachyCostCentre, clsFixedParameterCode.EnableHirerachyCostCentre, Nothing))
        funReset()
        ButtonToolTip.SetToolTip(btnSave, "Press Alt+S for Save/Update Transaction")
        ButtonToolTip.SetToolTip(btnDelete, "Press Alt+D for Delete Transaction")
        ButtonToolTip.SetToolTip(btnClose, "Press Alt+C Close the Window")
        ButtonToolTip.SetToolTip(rdbtnreset, "Press Alt+N for New Transaction")
    End Sub
    Private Sub SetUserMgmtNew()
        ''MyBase.SetUserMgmt(clsUserMgtCode.CostCentreFinancial)
        If Not (MyBase.isReadFlag) Then
            Throw New Exception("Permission Denied")

        End If
        btnSave.Visible = MyBase.isModifyFlag

        If btnSave.Visible = True Then
            rmExport.Enabled = True
            rmImport.Enabled = True
        Else
            rmExport.Enabled = False
            rmImport.Enabled = False
        End If

        btnDelete.Visible = MyBase.isDeleteFlag
    End Sub
    Function AllowToSave() As Boolean
        btnSave.Focus()
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso clsCommon.myLen(fndCode.Value) <= 0 Then
            myMessages.blankValue("Code")
            fndCode.Focus()
            Return False
        ElseIf clsCommon.myLen(txtdescription.Text) <= 0 Then
            myMessages.blankValue("Description")
            txtdescription.Focus()
            Return False
            '==============update by preeti gupta against ticket no[BM00000009038]
            'ElseIf clsCommon.myLen(txtcostcenter.Value) <= 0 Then
            '    myMessages.blankValue("Cost center group")
            '    txtcostcenter.Focus()
            '    Return False
        ElseIf clsCommon.myLen(TxtHirerachyLevel.Value) <= 0 Then
            myMessages.blankValue("Hirerachy level")
            TxtHirerachyLevel.Focus()
            Return False
        End If
        If clsCommon.myLen(txtcostcenter.Value) > 0 Then
            Dim qry As String = "select count(*) As Row from TSPL_COST_CENTRE_GROUP_MASTER where CostCenter_Code='" + txtcostcenter.Value + "'"
            Dim check As Integer = clsDBFuncationality.getSingleValue(qry)
            If check <= 0 Then
                clsCommon.MyMessageBoxShow("'" & clsCommon.myCstr(txtcostcenter.Value) & "' code does not exists.First create cost centre group stores entry")
                txtcostcenter.Focus()
                Return False
            End If
        End If
        If EnableHirerachyCostCentre = 0 Then
            If clsCommon.myLen(TxtHirerachyLevel.Value) > 0 Then
                If clsCommon.CompairString(LblLevel.Text, "1") <> CompairStringResult.Equal AndAlso clsCommon.myLen(TxtCostCentreLevel.Value) <= 0 Then
                    myMessages.blankValue("Cost centre level")
                    TxtCostCentreLevel.Focus()
                    Return False
                End If
            End If
        Else
            If clsCommon.CompairString(LblLevel.Text, "1") <> CompairStringResult.Equal Then
                Dim Count As Integer = 0
                For ii As Integer = 0 To gv1.RowCount - 1
                    If (clsCommon.myCBool(gv1.Rows(ii).Cells(colCostLSelect).Value)) Then
                        Count += 1
                        Exit For
                    End If
                Next
                If Count = 0 Then
                    clsCommon.MyMessageBoxShow(Me, "Please Select Cost Centre Level", Me.Text)
                    Return False
                End If
            End If
        End If
        Return True
    End Function
    Private Sub DeleteData()
        Try
            If (deleteConfirm()) Then
                If (ClsCostCentreFinancial.DeleteData(fndCode.Value)) Then
                    common.clsCommon.MyMessageBoxShow(Me, "Data Deleted Successfully ", Me.Text)
                    funReset()
                End If
            End If
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Sub funReset()
        If EnableHirerachyCostCentre = 1 Then
            MyLabel2.Visible = False
            TxtCostCentreLevel.Visible = False
            LblCostCentre.Visible = False
            RadGroupBox1.Visible = True
            gv1.Visible = True
            gv1.DataSource = Nothing
        Else
            MyLabel2.Visible = True
            TxtCostCentreLevel.Visible = True
            LblCostCentre.Visible = True
            RadGroupBox1.Visible = False
            gv1.Visible = False
        End If
        isNewEntry = True
        fndCode.MyReadOnly = False
        fndCode.Value = Nothing
        fndCode.Focus()
        txtdescription.Text = ""
        txtcostcenter.Value = ""
        lblCostDesp.Text = ""
        TxtCostCentreLevel.Value = ""
        LblCostCentre.Text = ""
        TxtHirerachyLevel.Value = ""
        LblHirerachy.Text = ""
        LblLevel.Text = ""
        btnSave.Text = "Save"
        btnSave.Enabled = True
        btnDelete.Enabled = False
        LoadBlankGridDetail()
    End Sub
    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        LoadBlankGridDetail()
        Dim obj As New ClsCostCentreFinancial()
        obj = ClsCostCentreFinancial.GetData(strCode, NavTyep)
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Cost_Center_Fin_Code) > 0) Then
            funReset()
            isNewEntry = False
            btnSave.Text = "Update"
            fndCode.Value = obj.Cost_Center_Fin_Code
            txtdescription.Text = obj.Cost_Center_Fin_Name
            txtcostcenter.Value = obj.Cost_Center_Group
            If clsCommon.myLen(txtcostcenter.Value) > 0 Then
                lblCostDesp.Text = clsDBFuncationality.getSingleValue("select Description from TSPL_COST_CENTRE_GROUP_MASTER where CostCenter_Code='" + clsCommon.myCstr(txtcostcenter.Value) + "'")
            Else
                lblCostDesp.Text = ""
            End If
            TxtHirerachyLevel.Value = obj.Hirerachy_Level_Code
            If clsCommon.myLen(TxtHirerachyLevel.Value) > 0 Then
                LblHirerachy.Text = clsDBFuncationality.getSingleValue("select ISNULL( Description,'') AS Description from TSPL_HIRERACHY_LEVEL_MASTER where Hirerachy_Code='" + clsCommon.myCstr(TxtHirerachyLevel.Value) + "'")
                LblLevel.Text = clsDBFuncationality.getSingleValue("select ISNULL(Level,'') AS Level from TSPL_HIRERACHY_LEVEL_MASTER where Hirerachy_Code='" + clsCommon.myCstr(TxtHirerachyLevel.Value) + "'")
            Else
                LblHirerachy.Text = ""
                LblLevel.Text = ""
            End If
            If EnableHirerachyCostCentre = 0 Then
                TxtCostCentreLevel.Value = obj.Cost_Centre_Fin_Level_Code
                If clsCommon.myLen(TxtCostCentreLevel.Value) > 0 Then
                    LblCostCentre.Text = clsDBFuncationality.getSingleValue("select Cost_Center_Fin_Name from TSPL_COST_CENTRE_FINANCIAL where Cost_Center_Fin_Code='" + clsCommon.myCstr(TxtCostCentreLevel.Value) + "'")
                Else
                    LblCostCentre.Text = ""
                End If
            Else
                If obj.Arr IsNot Nothing AndAlso obj.Arr.Count > 0 Then
                    For Each objTr As ClsCostCentreFinancialDetail In obj.Arr
                        If clsCommon.myLen(clsCommon.myCstr(objTr.COST_CENTRE_HIRERACHY_CODE)) > 0 Then

                            gv1.Rows.AddNew()
                            gv1.Rows(gv1.Rows.Count - 1).Cells(colCostLSelect).Value = objTr.FLAG
                            gv1.Rows(gv1.Rows.Count - 1).Cells(COST_CENTRE_HIRERACHY_CODE).Value = clsCommon.myCstr(objTr.COST_CENTRE_HIRERACHY_CODE)
                            gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE1).Value = clsCommon.myCstr(objTr.HIRERACHY_LEVEL_CODE1)
                            gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE2).Value = clsCommon.myCstr(objTr.HIRERACHY_LEVEL_CODE2)
                            gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE3).Value = clsCommon.myCstr(objTr.HIRERACHY_LEVEL_CODE3)
                            gv1.Rows(gv1.Rows.Count - 1).Cells(colHirerachyLevel).Value = clsCommon.myCstr(objTr.HIRERACHY_LEVEL)

                        End If
                    Next
                End If
            End If
            btnSave.Enabled = True
            btnDelete.Enabled = True
            fndCode.MyReadOnly = True
            RefreshHeaderText()
        End If

    End Sub
    Public Sub SaveData()
        If AllowToSave() Then
            Dim obj As New ClsCostCentreFinancial()
            obj.Cost_Center_Fin_Code = fndCode.Value
            obj.Cost_Center_Fin_Name = txtdescription.Text
            obj.Cost_Center_Group = txtcostcenter.Value
            obj.Hirerachy_Level_Code = TxtHirerachyLevel.Value
            obj.Hirerachy_Level = LblLevel.Text
            obj.EnableHirerachyCostCentre = EnableHirerachyCostCentre
            If EnableHirerachyCostCentre = 0 Then
                obj.Cost_Centre_Fin_Level_Code = TxtCostCentreLevel.Value
            Else
                If clsCommon.CompairString(LblLevel.Text, "1") = CompairStringResult.Equal Then
                    obj.Arr = New List(Of ClsCostCentreFinancialDetail)
                    Dim objTr As New ClsCostCentreFinancialDetail()
                    objTr.COST_CENTRE_HIRERACHY_CODE = ""
                    objTr.HIRERACHY_LEVEL_CODE1 = ""
                    objTr.HIRERACHY_LEVEL_CODE2 = ""
                    objTr.HIRERACHY_LEVEL_CODE3 = ""
                    objTr.HIRERACHY_LEVEL = clsCommon.myCstr(LblLevel.Text)
                    obj.Arr.Add(objTr)
                Else
                    obj.Arr = New List(Of ClsCostCentreFinancialDetail)
                    For ii As Integer = 0 To gv1.RowCount - 1
                        Dim objTr As New ClsCostCentreFinancialDetail()
                        If (clsCommon.myCBool(gv1.Rows(ii).Cells(colCostLSelect).Value)) Then

                            If clsCommon.CompairString(clsCommon.myCstr(LblLevel.Text), "2") = CompairStringResult.Equal Then
                                objTr.HIRERACHY_LEVEL_CODE1 = clsCommon.myCstr(gv1.Rows(ii).Cells(COST_CENTRE_HIRERACHY_CODE).Value)
                            End If
                            If clsCommon.CompairString(clsCommon.myCstr(LblLevel.Text), "3") = CompairStringResult.Equal Then
                                objTr.HIRERACHY_LEVEL_CODE1 = clsCommon.myCstr(gv1.Rows(ii).Cells(HIRERACHY_LEVEL_CODE1).Value)
                                objTr.HIRERACHY_LEVEL_CODE2 = clsCommon.myCstr(gv1.Rows(ii).Cells(COST_CENTRE_HIRERACHY_CODE).Value)
                            End If
                            If clsCommon.CompairString(clsCommon.myCstr(LblLevel.Text), "4") = CompairStringResult.Equal Then
                                objTr.HIRERACHY_LEVEL_CODE1 = clsCommon.myCstr(gv1.Rows(ii).Cells(HIRERACHY_LEVEL_CODE1).Value)
                                objTr.HIRERACHY_LEVEL_CODE2 = clsCommon.myCstr(gv1.Rows(ii).Cells(HIRERACHY_LEVEL_CODE2).Value)
                                objTr.HIRERACHY_LEVEL_CODE3 = clsCommon.myCstr(gv1.Rows(ii).Cells(COST_CENTRE_HIRERACHY_CODE).Value)
                            End If
                            objTr.HIRERACHY_LEVEL = clsCommon.myCstr(LblLevel.Text)

                            obj.Arr.Add(objTr)
                        End If
                    Next
                End If
            End If
            If (ClsCostCentreFinancial.SaveData(obj, isNewEntry)) Then
                common.clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                LoadData(obj.Cost_Center_Fin_Code, NavigatorType.Current)
            End If

        End If
    End Sub
    Sub funClose()
        Me.Close()
        GC.Collect()
    End Sub
    Private Sub rmImport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmImport.Click
        Dim gv As New RadGridView()
