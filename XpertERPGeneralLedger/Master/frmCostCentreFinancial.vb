                    '    clsCommon.AddColumnsForChange(coll, "Hirerachy_Level", obj.Hirerachy_Level)

                    '    clsCommonFunctionality.UpdateDataTable(coll, "TSPL_COST_CENTRE_FINANCIAL_DETAIL", OMInsertOrUpdate.Insert, "TSPL_COST_CENTRE_FINANCIAL_DETAIL.Cost_Center_Fin_Code='" + obj.Cost_Center_Fin_Code + "' ", trans)
