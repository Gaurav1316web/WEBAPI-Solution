    Sub RefreshHeaderText()
        If clsCommon.myLen(LblLevel.Text) > 0 Then
            Dim dt As DataTable = clsDBFuncationality.GetDataTable("select Description from TSPL_HIRERACHY_LEVEL_MASTER where Level<'" + clsCommon.myCstr(clsCommon.myCdbl(LblLevel.Text)) + "' order by level desc")
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If dt.Rows.Count > 0 Then
                    gv1.Columns(COST_CENTRE_HIRERACHY_CODE).HeaderText = clsCommon.myCstr(dt.Rows(0)("Description"))
                    If dt.Rows.Count > 1 Then
                        gv1.Columns(HIRERACHY_LEVEL_CODE1).HeaderText = clsCommon.myCstr(dt.Rows(1)("Description"))
                        If dt.Rows.Count > 2 Then
                            gv1.Columns(HIRERACHY_LEVEL_CODE2).HeaderText = clsCommon.myCstr(dt.Rows(2)("Description"))
                            If dt.Rows.Count > 3 Then
                                gv1.Columns(HIRERACHY_LEVEL_CODE3).HeaderText = clsCommon.myCstr(dt.Rows(3)("Description"))
                            End If
                        Else
                            gv1.Columns(HIRERACHY_LEVEL_CODE2).IsVisible = False
                            gv1.Columns(HIRERACHY_LEVEL_CODE3).IsVisible = False
                        End If
                    Else
                        gv1.Columns(HIRERACHY_LEVEL_CODE1).IsVisible = False
                        gv1.Columns(HIRERACHY_LEVEL_CODE2).IsVisible = False
                        gv1.Columns(HIRERACHY_LEVEL_CODE3).IsVisible = False
                    End If
                Else
                    RadGroupBox1.Visible = False
                End If
            Else
                RadGroupBox1.Visible = False
            End If
        End If
    End Sub

End Class
