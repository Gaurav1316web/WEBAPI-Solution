                            Throw New Exception("'" & clsCommon.myCstr(strHirerachyCode) & "' code does not exists at line no. " + clsCommon.myCstr(linno) + ".First create hirerachy level entry")
                        End If
                    Else
                        Throw New Exception("Please fill hirerachy level at line no. " + clsCommon.myCstr(linno))
                    End If
                    obj.Hirerachy_Level_Code = strHirerachyCode
