    Private Sub TxtHirerachyLevel__MYValidating(sender As Object, e As EventArgs, isButtonClicked As Boolean) Handles TxtHirerachyLevel._MYValidating
        TxtCostCentreLevel.Value = ""
        LblCostCentre.Text = ""
