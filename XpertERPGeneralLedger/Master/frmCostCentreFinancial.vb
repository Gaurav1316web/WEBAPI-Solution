                    If strCode.Length <= 0 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("Cost Center Fin Code can not be blank at line no. " + clsCommon.myCstr(linno) + ".")
                    ElseIf strCode.Length > 30 Then
