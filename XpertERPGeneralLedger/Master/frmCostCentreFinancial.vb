        If clsCommon.myLen(TxtHirerachyLevel.Value) > 0 Then
            LblHirerachy.Text = clsDBFuncationality.getSingleValue("Select ISNULL(Description,'') AS Desp from TSPL_HIRERACHY_LEVEL_MASTER Where HIRERACHY_CODE='" + TxtHirerachyLevel.Value + "' ")
            LblLevel.Text = clsDBFuncationality.getSingleValue("Select ISNULL(Level,'') AS Level from TSPL_HIRERACHY_LEVEL_MASTER Where HIRERACHY_CODE='" + TxtHirerachyLevel.Value + "' ")
            Dim Level As String = clsCommon.myCstr(clsCommon.myCdbl(LblLevel.Text) - 1)
            If EnableHirerachyCostCentre = 1 Then
                If clsCommon.CompairString(LblLevel.Text, "1") <> CompairStringResult.Equal Then
                    BindCostCentreLevel(Level)
                End If
            End If
        Else
            LblHirerachy.Text = ""
            LblLevel.Text = ""
        End If
    End Sub

    Private Sub TxtCostCentreLevel__MYValidating(sender As Object, e As EventArgs, isButtonClicked As Boolean) Handles TxtCostCentreLevel._MYValidating
        TxtCostCentreLevel.Value = ClsCostCentreFinancial.getFinder(" Hirerachy_Level = '" + clsCommon.myCstr(clsCommon.myCdbl(LblLevel.Text) - 1) + "' AND Cost_Center_Fin_Code <> '" + clsCommon.myCstr(fndCode.Value) + "'", TxtCostCentreLevel.Value, isButtonClicked)
        If clsCommon.myLen(TxtCostCentreLevel.Value) > 0 Then
            LblCostCentre.Text = clsDBFuncationality.getSingleValue("Select Cost_Center_Fin_Name from TSPL_COST_CENTRE_FINANCIAL Where Cost_Center_Fin_Code='" + TxtCostCentreLevel.Value + "' ")
        Else
            LblCostCentre.Text = ""
        End If
    End Sub

    Sub BindCostCentreLevel(ByVal Hirerachy_Level As String)
        Try
            LoadBlankGridDetail()
            Dim qry As String = Nothing
            qry = "SELECT CAST(0 as bit) as Sel,COST_CENTRE_HIRERACHY_CODE,HIRERACHY_LEVEL_CODE1,HIRERACHY_LEVEL_CODE2,HIRERACHY_LEVEL_CODE3" & _
                " ,HIRERACHY_LEVEL FROM TSPL_COST_CENTRE_HIRERACHY_DETAIL WHERE HIRERACHY_LEVEL='" + Hirerachy_Level + "' "

            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, Nothing)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                For Each dr As DataRow In dt.Rows
                    gv1.Rows.AddNew()

                    gv1.Rows(gv1.Rows.Count - 1).Cells(colCostLSelect).Value = dr("SEL")
                    gv1.Rows(gv1.Rows.Count - 1).Cells(COST_CENTRE_HIRERACHY_CODE).Value = clsCommon.myCstr(dr("COST_CENTRE_HIRERACHY_CODE"))
                    gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE1).Value = clsCommon.myCstr(dr("HIRERACHY_LEVEL_CODE1"))
                    gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE2).Value = clsCommon.myCstr(dr("HIRERACHY_LEVEL_CODE2"))
                    gv1.Rows(gv1.Rows.Count - 1).Cells(HIRERACHY_LEVEL_CODE3).Value = clsCommon.myCstr(dr("HIRERACHY_LEVEL_CODE3"))
                    gv1.Rows(gv1.Rows.Count - 1).Cells(colHirerachyLevel).Value = clsCommon.myCdbl(dr("HIRERACHY_LEVEL"))

                Next
            Else
                gv1.DataSource = Nothing
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Sub
