    '' Anubhooti 12-Dec-2014 (Auto Code Generation From Sub Account)
    Public Function GetGLMainCode(ByVal StrSubAcc As String, ByVal trans As SqlTransaction) As String

        If clsCommon.myLen(StrSubAcc) <= 0 Then
            Throw New Exception("Please enter Sub Account")
        End If
        Dim qry As String = ""
        Dim DigitLen As String = ""
        Dim strRetCode As String = ""
        Dim strLocatinSegmentCode As String = ""
        If clsCommon.myLen(StrSubAcc) > 0 Then
            Dim qry1 As String = "Select COUNT(*) AS Row FROM TSPL_ACCOUNT_MAIN_GL_ACCOUNT WHERE ISNULL(Sub_Group_Code,'') = '" + StrSubAcc + "'"
            Dim SubAccSeries As Double = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry1, trans))
            Dim SeriesLength As Integer = clsCommon.myCdbl(clsCommon.myLen(SubAccSeries))
            If SubAccSeries = 0 Then
                SubAccSeries = 1
            Else
                SubAccSeries = 1 + SubAccSeries
            End If
            strRetCode = clsCommon.myCstr(StrSubAcc.ToUpper() + clsCommon.myCdbl(SubAccSeries))

            Dim flag As Boolean = True
            While flag ''By Balwinder on 20/03/2020
                qry = "Select Main_GL_Account FROM TSPL_ACCOUNT_MAIN_GL_ACCOUNT where Main_GL_Account='" + strRetCode + "' "
                qry = clsDBFuncationality.getSingleValue(qry)
                If clsCommon.myLen(qry) > 0 Then
                    strRetCode = clsCommon.incval(strRetCode, True)
                    flag = True
                Else
                    flag = False
                End If
            End While

        End If
        Return strRetCode
    End Function
    Function PwdOpen() As Boolean
        Dim qry As String = Nothing
        Dim count As Integer = 0
        qry = "select count(*) from tspl_gl_accounts where account_seg_code1='" & fndaccgp.Value & "'"
        count = clsDBFuncationality.getSingleValue(qry)
        If count > 0 Then
            Dim frm As New FrmPWD(Nothing)
            frm.strType = clsFixedParameterType.PwdOpenOnMainGLAccountAfterSave
            frm.strCode = clsFixedParameterCode.PwdOpenOnMainGLAccountAfterSave
            frm.ShowDialog()
            If frm.isPasswordCorrect Then
                Return True
            Else
                Return False
                'btnsave.Visible = True
            End If
        Else
            Return True
        End If

    End Function
