    Private Sub DeleteData()
        Try
            If (deleteConfirm()) Then
                If (clsMainGLAccount.DeleteData(fndaccgp.Value)) Then
                    common.clsCommon.MyMessageBoxShow(Me, "Data Deleted Successfully ", Me.Text)
                    funReset()
                End If
            End If
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Sub funReset()
        chkIsControlAcct.Enabled = True
        isNewEntry = True
        '' Anubhooti 12-Dec-2014 
        If clsCommon.CompairString(IsAutoCodeSettingsON, "1") = CompairStringResult.Equal Then
            fndaccgp.MyReadOnly = True
        Else
            fndaccgp.MyReadOnly = False
        End If
        chkIsControlAcct.Checked = False
        fndaccgp.Value = Nothing
        fndaccgp.Focus()
        txtdes.Text = ""
        txtSubGroup.Text = ""
        btnsave.Text = "Save"
        btnsave.Enabled = True
        btndelete.Enabled = False
        txtSubGroup.Value = ""
        lblSubGroup.Text = ""
    End Sub
    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)

        Dim obj As New clsMainGLAccount()
        obj = clsMainGLAccount.GetData(strCode, NavTyep)
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Main_GL_Account) > 0) Then
            funReset()
            isNewEntry = False
            btnsave.Text = "Update"
            fndaccgp.Value = clsCommon.myCstr(obj.Main_GL_Account)
            txtdes.Text = clsCommon.myCstr(obj.Main_GL_Account_Desc)
            txtSubGroup.Value = obj.Sub_Group_Code
            Dim isUsed As Boolean = clsMainGLAccount.IsMainGLaccountUsedOrNot(obj.Main_GL_Account) 'clsCommon.myCdbl(clsDBFuncationality.getSingleValue("select count(*)  from TSPL_GL_ACCOUNTS where Account_Seg_Code1='" & fndaccgp.Value & "'"))
            If isUsed = True Then
                chkIsControlAcct.Enabled = False
            Else
                chkIsControlAcct.Enabled = True
            End If
            chkIsControlAcct.Checked = IIf(obj.IsControlAcct = 1, True, False)
            lblSubGroup.Text = clsCommon.myCstr(clsDBFuncationality.getSingleValue("select Account_Sub_Group_Desc from TSPL_ACCOUNT_SUB_GROUPS where Account_Sub_Group_Code='" + txtSubGroup.Value + "'"))

            btnsave.Enabled = True
            btndelete.Enabled = True
            fndaccgp.MyReadOnly = True
        End If

    End Sub
    Public Sub SaveData()
        Try
            Dim AutoGLMainAccCode As String
            If AllowToSave() Then

                If MyBase.isModifyonPasswordFlag Then
                    If clsPasswordCheckForMasters.CheckMasterPwd(clsUserMgtCode.AccountGLMainAccount, clsCommon.myCstr(objCommonVar.CurrentCompanyCode)) Then
                    Else
                        Return
                    End If
                End If
                Dim obj As New clsMainGLAccount()
                '' Anubhooti 12-Dec-2014 
                If clsCommon.CompairString(IsAutoCodeSettingsON, "1") = CompairStringResult.Equal Then
                    If isNewEntry = True Then
                        If clsCommon.myLen(clsCommon.myCstr(txtSubGroup.Value)) > 0 Then
                            AutoGLMainAccCode = GetGLMainCode(clsCommon.myCstr(txtSubGroup.Value), Nothing)
                            If clsCommon.myLen(AutoGLMainAccCode) > 0 Then
                                fndaccgp.Value = clsCommon.myCstr(AutoGLMainAccCode)
                            End If
                        End If
                    End If
                Else
                    fndaccgp.Value = clsCommon.myCstr(fndaccgp.Value)
                End If
                obj.Main_GL_Account = clsCommon.myCstr(fndaccgp.Value)
                obj.Main_GL_Account_Desc = clsCommon.myCstr(txtdes.Text)
                obj.Sub_Group_Code = txtSubGroup.Value
                obj.IsControlAcct = IIf(chkIsControlAcct.Checked, 1, 0)
                If (clsMainGLAccount.SaveData(obj, isNewEntry)) Then
                    common.clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                    LoadData(obj.Main_GL_Account, NavigatorType.Current)
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub

    Sub funClose()
        Me.Close()
        GC.Collect()
    End Sub
