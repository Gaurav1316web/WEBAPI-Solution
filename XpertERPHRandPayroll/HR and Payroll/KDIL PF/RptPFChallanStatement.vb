        Qry += "  AugustAcc22,MAX(isnull(JuneAcc22,0)) as JuneAcc22,MAX(isnull(JulyAcc22,0))as JulyAcc22,MAX(isnull(SeptemberAcc22,0)) as SeptemberAcc22,MAX(ISNULL( OctoberAcc22,0)) as  OctoberAcc22,MAX(isnull(NovemberAcc22,0)) as NovemberAcc22,MAX(isnull(JanuaryAcc22,0)) as  JanuaryAcc22, MAX(isnull(FebruaryAcc22,0)) as FebruaryAcc22,MAX(ISNULL( MarchAcc22,0)) as MarchAcc22,MAX(isnull(DecemberAcc22,0)) as DecemberAcc22,max(April_Date)as April_Date ,max(May_Date)as May_Date,max(June_Date)as June_Date, max(July_Date)as July_Date ,MAX( August_Date)as August_Date,max(September_Date)as September_Date,max(October_Date )as October_Date, max(November_Date)as November_Date,max(January_Date)as January_Date, max(February_Date)as February_Date ,MAX( March_Date)as March_Date,max(December_Date)as December_Date"
        Qry += ",sum(isnull(AprilPFEmp,0))as AprilPFEmp,sum(isnull(MayPFEmp,0))as MayPFEmp,sum(isnull(JunePFEmp,0))as JunePFEmp,sum(isnull( JulyPFEmp,0))as JulyPFEmp,sum(isnull( AugustPFEmp,0))as AugustPFEmp ,sum(isnull(SeptemberPFEmp,0))as  SeptemberPFEmp,sum(isnull(OctoberPFEmp,0))as OctoberPFEmp,sum(isnull(NovemberPFEmp,0))as NovemberPFEmp,sum(isnull(JanuaryPFEmp,0))as JanuaryPFEmp ,sum(isnull( FebruaryPFEmp,0))as FebruaryPFEmp ,sum(isnull( MarchPFEmp,0))as"
        Qry += " MarchPFEmp,sum(isnull(DecemberPFEmp,0)) as DecemberPFEmp,Max(Location) as Location,(Location_Code) as Location_Code ,max(Location_Address)  as Location_Address,max(PF_No) as PF_No  from(select * from(select * from (select * from (select * from(select * from (select * from (select * from(select * from (select * from (select  EMP_CODE,ACTUAL_AMOUNT+(ACTUAL_AMOUNT - pension_fund )as dd,(Acc01+ ACTUAL_AMOUNT)as Acc01 ,ADMIN_AMT_AC02 as Acc02,HEAD_VALUE ,pension_fund  as Acc10,EDLI_AMT_AC21 AS Acc21,ADMIN_EDLI_AMT_AC22 as Acc22,Comp_Name,add1,add2,"
