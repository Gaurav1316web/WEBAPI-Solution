(SeptemberAcc02,0)+isnull(SeptemberAcc10,0)+"
        Qry += " isnull(SeptemberAcc21,0)+isnull(SeptemberAcc22,0)) as TotalSeptember,(isnull(OctoberAcc01,0)+isnull(OctoberAcc02,0)+isnull(OctoberAcc10,0)+isnull(OctoberAcc21,0)+isnull(OctoberAcc22,0)) as TotalOctober,(isnull(NovemberAcc01,0)+isnull(NovemberAcc02,0)+isnull(NovemberAcc10,0)+isnull(NovemberAcc21,0)+isnull(NovemberAcc22,0)) as TotalNovember,(isnull(DecemberAcc01,0)+isnull(DecemberAcc02,0)+isnull(DecemberAcc10,0)+isnull(DecemberAcc21,0)+isnull(DecemberAcc22,0)) as TotalDecember, (isnull(JanuaryAcc01,0)+isnull(JanuaryAcc02,0)+isnull(JanuaryAcc10,0)+isnull(JanuaryAcc21,0)+isnull(JanuaryAcc22,0)) as TotalJanuary,(isnull(FebruaryAcc01,0)+isnull(FebruaryAcc02,0)+isnull(FebruaryAcc10,0)+isnull(FebruaryAcc21,0)+isnull(FebruaryAcc22,0)) as TotalFebruary,(isnull(MarchAcc01,0)+isnull(MarchAcc02,0)+isnull(MarchAcc10,0)+isnull(MarchAcc21,0)+isnull(MarchAcc22,0)) as TotalMarch"
