        str += " [EMPEPF_PER] as 'Employee EPF Share(%)',[EMPEPF_MAX] as 'Max EPF Amount',[EMPEPF_ROUNDOFF_YPE] as 'Employee EPF Round Off Type', "
        str += " [OC] as 'Other Charges(OC)', OTH_ROUNDOFF_YPE as 'Other Charges Round off type',[OC_MAX] as 'Max of Other Charges(OC)' from TSPL_PF_RULE_MASTER"
