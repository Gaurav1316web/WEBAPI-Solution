                        Throw New Exception("Max amount of ACEPF can not be blank or incorrect.")
                    End If
                    obj.EMPEPF_MAX = strCode

                    strCode = clsCommon.myCstr(grow.Cells(14).Value)
                    If strCode.Length >= 2 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("Employee EPF Round Off Type can not be blank or incorrect.")
                    End If
                    obj.EMPEPF_ROUNDOFF_YPE = strCode

                    strCode = clsCommon.myCstr(grow.Cells(15).Value)
                    If strCode.Length > 10 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("Other Charges(OC) can not be blank or incorrect.")
