                    strCode = clsCommon.myCstr(grow.Cells(11).Value)
                    If strCode.Length > 10 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("Max of ACEDLI can not be blank or incorrect.")
                    End If
