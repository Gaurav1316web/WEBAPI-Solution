                    strCode = clsCommon.myCstr(grow.Cells(8).Value)
                    If strCode.Length > 10 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("EDLI Paid by Company can not be blank or incorrect.")
                    End If
                    obj.COEDLI_PER = strCode

                    strCode = clsCommon.myCstr(grow.Cells(9).Value)
                    If strCode.Length > 10 Or (String.IsNullOrEmpty(strCode)) Then
                        Throw New Exception("Max of EDLI can not be blank or incorrect.")
