    Private Function GetItemType(Optional ByVal istype As Boolean = False) As DataTable
        Dim dt As New DataTable()
        If istype = True Then
            dt.Columns.Add("Code", GetType(String))

            Dim dr As DataRow = dt.NewRow()
            dr("Code") = "New"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "Refurnished"
            dt.Rows.Add(dr)
        Else
            dt.Columns.Add("Code", GetType(String))

            Dim dr As DataRow = dt.NewRow()
            dr("Code") = "Yes"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "No"
            dt.Rows.Add(dr)
        End If

        Return dt
    End Function

