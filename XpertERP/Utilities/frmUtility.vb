    Private Sub btnRecreateShipmentJE_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnRecreateShipmentJE.Click
        Dim dt As New DataTable()
        Try
            ''for trans tyep='ALL' nor mal shipment
            clsDBFuncationality.ExecuteNonQuery("delete from TEMP_DELETE_SHIPMENT")

            Dim counter As Integer = 0

            Dim qry As String = "insert into TEMP_DELETE_SHIPMENT "
            qry += " select TSPL_SD_SHIPMENT_HEAD.Document_Code,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_SD_SHIPMENT_HEAD left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_SD_SHIPMENT_HEAD.Document_Code and TSPL_JOURNAL_MASTER.Source_Code='SD-SH' where TSPL_SD_SHIPMENT_HEAD.Status=1 and TSPL_SD_SHIPMENT_HEAD.trans_type='ALL'"
            clsDBFuncationality.ExecuteNonQuery(qry)

            qry = "select * from TEMP_DELETE_SHIPMENT where shipment_no not in (select shipment_no from TEMP_CREATE_SHIPMENT)"
            dt = clsDBFuncationality.GetDataTable(qry)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If common.clsCommon.MyMessageBoxShow("Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " Shipments", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    For Each dr As DataRow In dt.Rows
                        Dim strShipmentNo As String = clsCommon.myCstr(dr("shipment_no"))
                        Dim strVoucherNo As String = clsCommon.myCstr(dr("voucher_no"))


                        If clsUtility.ReCreateShipment(strShipmentNo, strVoucherNo) Then
                            counter += 1
                        End If
                    Next
                End If
            End If

            If counter > 0 Then
                common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
            Else
                common.clsCommon.MyMessageBoxShow("No record found.", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        Finally
            dt = Nothing
        End Try

    End Sub

    Private Sub RecreateSaleReturnGL()
        Dim dt As New DataTable()
        Try
            Dim counter As Integer = 0
            clsDBFuncationality.ExecuteNonQuery("delete from TEMP_DELETE_SALE_RETURN")

            Dim qry As String = "insert into TEMP_DELETE_SALE_RETURN "
            qry += "select TSPL_SD_SALE_RETURN_HEAD.document_code,TSPL_JOURNAL_MASTER.voucher_no,TSPL_Customer_Invoice_Head.document_no as AR_NO from TSPL_SD_SALE_RETURN_HEAD left outer join TSPL_Customer_Invoice_Head on TSPL_Customer_Invoice_Head.against_sale_return_no=tspl_sd_sale_return_head.document_code left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.source_doc_no=tspl_customer_invoice_head.document_no where TSPL_SD_SALE_RETURN_HEAD.status=1 and TSPL_SD_SALE_RETURN_HEAD.trans_type='ALL'"
            clsDBFuncationality.ExecuteNonQuery(qry)

            qry = "select * from TEMP_DELETE_SALE_RETURN where SR_NO not in (select sr_no from TEMP_CREATE_SALE_RETURN)"
            dt = clsDBFuncationality.GetDataTable(qry)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If common.clsCommon.MyMessageBoxShow("Recreate journal entry for " + clsCommon.myCstr(dt.Rows.Count) + Environment.NewLine + " of Sale Return.", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    For Each dr As DataRow In dt.Rows
                        Dim strReturnNo As String = clsCommon.myCstr(dr("sr_no"))
                        Dim strVoucherNo As String = clsCommon.myCstr(dr("voucher_no"))
                        Dim strAR_Inv_No As String = clsCommon.myCstr(dr("AR_Invoice_No"))

                        If clsUtility.ReCreateSaleReturn(strReturnNo, strVoucherNo, strAR_Inv_No) Then
                            counter += 1
                        End If
                    Next
                End If
            End If

            If counter > 0 Then
                common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
            Else
                common.clsCommon.MyMessageBoxShow("No record found.", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        Finally
            dt = Nothing
        End Try
    End Sub

    Private Sub btnRecreateSRJE_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnRecreateSRJE.Click
        RecreateSaleReturnGL()
    End Sub

    Private Sub RadButton2_Click(ByVal sender As System.Object, ByVal e As System.EventArgs)
        Dim qry As String = "select DocNo from xxx_sale_invoice where DocNo not in (select DocNo from xxx_sale_invoice_Complete)"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            If common.clsCommon.MyMessageBoxShow("Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " Sale Invoice", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                For Each dr As DataRow In dt.Rows
                    Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                    Try
                        Dim strInvoiceNo As String = clsCommon.myCstr(dr("DocNo"))
                        qry = "delete from TSPL_JOURNAL_DETAILS where TSPL_JOURNAL_DETAILS.Voucher_No in (select Voucher_No from TSPL_JOURNAL_MASTER where TSPL_JOURNAL_MASTER.Source_Code='SD-IN' and TSPL_JOURNAL_MASTER.Source_Doc_No='" + strInvoiceNo + "')"
                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                        qry = "delete from TSPL_JOURNAL_MASTER where TSPL_JOURNAL_MASTER.Source_Code='SD-IN' and TSPL_JOURNAL_MASTER.Source_Doc_No='" + strInvoiceNo + "'"
                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                        If (clsSaleHead.CreateJournalEntry(strInvoiceNo, trans)) Then
                            qry = "insert into xxx_sale_invoice_Complete values('" + strInvoiceNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)
                            trans.Commit()
                        Else
                            trans.Rollback()
                        End If
                    Catch ex As Exception
                        trans.Rollback()
                    End Try
                Next
                common.clsCommon.MyMessageBoxShow("Task Completed", Me.Text)
            End If
        End If
    End Sub

    Private Sub btnRecereateInventoryMovementAndItemLocationDetail_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnRecereateInventoryMovementAndItemLocationDetail.Click
        If clsCommon.MyMessageBoxShow("Do you want to Recreate inventory movement and item location details", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
            Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
            Try
                Dim qry As String = "delete from TSPL_INVENTORY_MOVEMENT"
                clsDBFuncationality.ExecuteNonQuery(qry, trans)

                qry = " insert into TSPL_INVENTORY_MOVEMENT   " + Environment.NewLine
                qry += " select  Trans_Type, InOut, Location_Code , Item_Code, Item_Desc, Qty, UOM, Source_Doc_No, Source_Doc_Date, Entry_Date, Basic_Cost, Rec_Cost, Add_Cost, Net_Cost,  Created_By, Comp_Code, ItemType, Punching_Date, MRP, Batch_No from (" + Environment.NewLine
                qry += " select '' as Trans_Id, 'Sale Return' as Trans_Type,'I' as InOut,TSPL_SALE_RETURN_HEAD.Location as Location_Code ,TSPL_SALE_RETURN_DETAIL.Item_Code as Item_Code,TSPL_SALE_RETURN_DETAIL.Item_Desc as Item_Desc,TSPL_SALE_RETURN_DETAIL.Actual_Return_Qty as Qty,TSPL_SALE_RETURN_DETAIL.Unit_code as UOM,TSPL_SALE_RETURN_DETAIL.Sale_Return_No as Source_Doc_No,CONVERT(varchar, TSPL_SALE_RETURN_HEAD.Sale_Return_Date,103) as Source_Doc_Date,CONVERT(varchar, TSPL_SALE_RETURN_HEAD.Sale_Return_Date,103) as Entry_Date,0 as Basic_Cost,0 as Rec_Cost,0 as Add_Cost,0 as Net_Cost,TSPL_SALE_RETURN_HEAD.Created_By as Created_By,TSPL_SALE_RETURN_HEAD.Comp_Code as  Comp_Code,'FM' as ItemType,TSPL_SALE_RETURN_HEAD.Sale_Return_Date as Punching_Date,TSPL_SALE_RETURN_DETAIL.MRP_Amt as MRP,'' as Batch_No" + Environment.NewLine
                qry += " from TSPL_SALE_RETURN_DETAIL " + Environment.NewLine
                qry += " left outer join TSPL_SALE_RETURN_HEAD on TSPL_SALE_RETURN_HEAD.Sale_Return_No=TSPL_SALE_RETURN_DETAIL.Sale_Return_No" + Environment.NewLine
                qry += " where  TSPL_SALE_RETURN_HEAD.Is_Post='Y'" + Environment.NewLine
                qry += " UNION ALL" + Environment.NewLine
                qry += " select '' as Trans_Id, 'Sale Return' as Trans_Type,'I' as InOut,TSPL_SALE_RETURN_INTER_HEAD.Location as Location_Code ,TSPL_SALE_RETURN_INTER_DETAIL.Item_Code as Item_Code,TSPL_SALE_RETURN_INTER_DETAIL.Item_Desc as Item_Desc,TSPL_SALE_RETURN_INTER_DETAIL.Qty as Qty,TSPL_SALE_RETURN_INTER_DETAIL.Unit_code as UOM,TSPL_SALE_RETURN_INTER_DETAIL.Document_No as Source_Doc_No,CONVERT(varchar, TSPL_SALE_RETURN_INTER_HEAD.Document_Date,103) as Source_Doc_Date,CONVERT(varchar, TSPL_SALE_RETURN_INTER_HEAD.Document_Date,103) as Entry_Date,0 as Basic_Cost,0 as Rec_Cost,0 as Add_Cost,0 as Net_Cost,TSPL_SALE_RETURN_INTER_HEAD.Created_By as Created_By,TSPL_SALE_RETURN_INTER_HEAD.Comp_Code as  Comp_Code,'FM' as ItemType,TSPL_SALE_RETURN_INTER_HEAD.Document_Date as Punching_Date,TSPL_SALE_RETURN_INTER_DETAIL.MRP_Amt as MRP,'' as Batch_No" + Environment.NewLine
                qry += " from TSPL_SALE_RETURN_INTER_DETAIL " + Environment.NewLine
                qry += " left outer join TSPL_SALE_RETURN_INTER_HEAD on TSPL_SALE_RETURN_INTER_HEAD.Document_No=TSPL_SALE_RETURN_INTER_DETAIL.Document_No" + Environment.NewLine
                qry += " where  TSPL_SALE_RETURN_INTER_HEAD.Is_Post=1" + Environment.NewLine
                qry += " UNION ALL" + Environment.NewLine
                qry += " select '' as Trans_Id, TSPL_RGP_HEAD.Doc_Type as Trans_Type,'O' as InOut,TSPL_RGP_HEAD.Location as Location_Code ,TSPL_RGP_DETAIL.Item_Code as Item_Code,TSPL_RGP_DETAIL.Item_Desc as Item_Desc,TSPL_RGP_DETAIL.RGP_Qty as Qty,TSPL_RGP_DETAIL.Unit_code as UOM,TSPL_RGP_DETAIL.RGP_No as Source_Doc_No,CONVERT(varchar, TSPL_RGP_HEAD.RGP_Date,103) as Source_Doc_Date,CONVERT(varchar, TSPL_RGP_HEAD.RGP_Date,103) as Entry_Date,0 as Basic_Cost,0 as Rec_Cost,0 as Add_Cost,0 as Net_Cost,TSPL_RGP_HEAD.Created_By as Created_By,TSPL_RGP_HEAD.Comp_Code as  Comp_Code,'OT' as ItemType,TSPL_RGP_HEAD.RGP_Date as Punching_Date,0 as MRP,'' as Batch_No" + Environment.NewLine
                qry += " from TSPL_RGP_DETAIL " + Environment.NewLine
                qry += " left outer join TSPL_RGP_HEAD on TSPL_RGP_HEAD.RGP_No=TSPL_RGP_DETAIL.RGP_No" + Environment.NewLine
                qry += " where  TSPL_RGP_HEAD.Status=1 and isnull(TSPL_RGP_HEAD.Is_Non_Inventory,0)=0 " + Environment.NewLine
                qry += " union all" + Environment.NewLine
                qry += " --For Transfer " + Environment.NewLine
                qry += " select '' as Trans_Id, 'Transfer' as Trans_Type, 'O'  as InOut,TSPL_TRANSFER_HEAD.From_Location as Location_Code ,TSPL_TRANSFER_DETAIL.Item_Code as Item_Code,TSPL_TRANSFER_DETAIL.Item_Desc as Item_Desc," + Environment.NewLine
                qry += " case when Transfer_Type='LO' then TSPL_TRANSFER_DETAIL.Item_Qty else TSPL_TRANSFER_DETAIL.LoadIn_Qty end as Qty,TSPL_TRANSFER_DETAIL.Uom as UOM,TSPL_TRANSFER_DETAIL.Transfer_No as Source_Doc_No,CONVERT(varchar, TSPL_TRANSFER_HEAD.EntryDateTime,103) as Source_Doc_Date,CONVERT(varchar, TSPL_TRANSFER_HEAD.EntryDateTime,103) as Entry_Date,0 as Basic_Cost,0 as Rec_Cost,0 as Add_Cost,0 as Net_Cost,TSPL_TRANSFER_HEAD.Created_By as Created_By,TSPL_TRANSFER_HEAD.Comp_Code as  Comp_Code,'FM' as ItemType,TSPL_TRANSFER_HEAD.EntryDateTime as Punching_Date,TSPL_TRANSFER_DETAIL.MRP as MRP,'' as Batch_No" + Environment.NewLine
                qry += " from TSPL_TRANSFER_DETAIL " + Environment.NewLine
                qry += " left outer join TSPL_TRANSFER_HEAD on TSPL_TRANSFER_HEAD.Transfer_No=TSPL_TRANSFER_DETAIL.Transfer_No" + Environment.NewLine
