        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEAssemblyDeassembly", tran)
            qry = "select TSPL_PROD_ASSEMBLIES.CODE,TSPL_JOURNAL_MASTER.Voucher_No,TSPL_PROD_ASSEMBLIES.TRANSACTION_TYPE from TSPL_PROD_ASSEMBLIES" + Environment.NewLine +
        "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PROD_ASSEMBLIES.CODE and TSPL_JOURNAL_MASTER.Source_Code='PP-AD'" + Environment.NewLine +
        "where TSPL_PROD_ASSEMBLIES.Posted=1 and TSPL_PROD_ASSEMBLIES.ASSEMBLY_DATE>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_PROD_ASSEMBLIES.ASSEMBLY_DATE<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' "
            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PROD_ASSEMBLIES.LOCATION_CODE in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            qry = "select * into Temp_PEAssemblyDeassembly from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEAssemblyDeassembly order by  CODE"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("CODE"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    clsAssembliesDis.PostData(strDocNo, False, tran, strVoucherNo)
                Else
                    clsAssembliesDis.UnpostData(strDocNo, clsCommon.myCstr(dr("TRANSACTION_TYPE")), tran)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

    Sub PEPurchaseIssue(ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean)
        Dim qry As String
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEPurchaseIssue", tran)
            qry = "select TSPL_IssueReturn_HEAD.Doc_No,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_IssueReturn_HEAD" + Environment.NewLine +
        "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_IssueReturn_HEAD.Doc_No and TSPL_JOURNAL_MASTER.Source_Code in ('PU-TC','PU-IS','PU-RE','PU-TF')" + Environment.NewLine +
        "where TSPL_IssueReturn_HEAD.Doc_Type='Issue' and TSPL_IssueReturn_HEAD.Status=1 and TSPL_IssueReturn_HEAD.Doc_Date>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_IssueReturn_HEAD.Doc_Date<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "'"

            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_IssueReturn_HEAD.From_Location in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            qry = "select * into Temp_PEPurchaseIssue from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEPurchaseIssue order by  Doc_No"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("Doc_No"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    clsIssueReturnHead.PostData(strDocNo, strVoucherNo, tran)
                Else
                    clsIssueReturnHead.ReverseAndUnpost(strDocNo, tran)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
