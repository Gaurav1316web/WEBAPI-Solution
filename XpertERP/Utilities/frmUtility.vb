                                        Throw New Exception("Please set default Pro Data of Deduction Master")
                                    End If
                                    If clsCommon.myLen(dtDed.Rows(0)("GL_Account_Code")) <= 0 Then
                                        Throw New Exception("Please set gl Account for Deduction Code :" + clsCommon.myCstr(dtDed.Rows(0)("code")))
                                    End If
                                    qry = clsCommon.myCstr(dtDed.Rows(0)("GL_Account_Code"))
                                    qry = clsERPFuncationality.ChangeGLAccountLocationSegment(qry, strLoc_Seg_Code, True, trans)
                                    Dim AccDr() As String = {qry, -1 * Math.Round(((dblAmt)), 2, MidpointRounding.ToEven)}
                                    ArryDeductionGLAC.Add(AccDr)

                                    clsJournalMaster.FunGrnlEntryWithTrans(strLoc_Seg_Code, True, trans, dtDocDate, "Total Deduction Against Farmer Payment Process No ( " & strDocNo & ")", "MP-DE", "MP Deduction", strDocNo, "", "", "", "", objCommonVar.CurrentUserCode, objCommonVar.CurrentCompanyCode, ArryDeductionGLAC)
                                End If
                                trans.Commit()
                                clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate journal entry " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                            Catch ex As Exception
                                trans.Rollback()
                                strErro += "Farmer Payment Process No- " + strDocNo + " Exception -" + ex.Message + Environment.NewLine
                            End Try

                        Next
                    Catch ex As Exception
                    Finally
                        clsCommon.ProgressBarPercentHide()
                    End Try
                    If clsCommon.myLen(strErro) > 0 Then
                        common.clsCommon.MyMessageBoxShow(strErro, Me.Text)
                    Else
                        common.clsCommon.MyMessageBoxShow("Task Completed", Me.Text)
                    End If
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try
    End Sub

