    Private Sub RadButton8_Click(sender As Object, e As EventArgs) Handles RadButton8.Click
        Dim qry As String = "select * from Temp_Sale where JVNo not in (select JVNo from Temp_Sale_Done)"
        Dim strERROR As String = ""
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            If common.clsCommon.MyMessageBoxShow("Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " ", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                Try
                    clsCommon.ProgressBarPercentShow()
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                        Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("InvNo"))
                        Dim strARNo As String = clsCommon.myCstr(dt.Rows(ii)("ARNo"))
                        Dim strJVNo As String = clsCommon.myCstr(dt.Rows(ii)("JVNo"))
                        Try
                            qry = "delete from TSPL_JOURNAL_DETAILS where TSPL_JOURNAL_DETAILS.Voucher_No in ('" + strJVNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_JOURNAL_MASTER where TSPL_JOURNAL_MASTER.Source_Code='AR-IN' and TSPL_JOURNAL_MASTER.Voucher_No='" + strJVNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Customer_Invoice_Detail where Document_No in ('" + strARNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Customer_Invoice_Head where Document_No = '" + strARNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            Dim obj As clsPSInvoiceHead = clsPSInvoiceHead.GetData(strDocNo, NavigatorType.Current, "", trans)

                            If clsPSInvoiceHead.createARInvoice(obj, trans, strARNo, strJVNo, clsCommon.myCstr(dt.Rows(ii)("Form_ID"))) Then
                                qry = "insert into Temp_Sale_Done values('" + strJVNo + "')"
                                clsDBFuncationality.ExecuteNonQuery(qry, trans)
                                trans.Commit()
                            Else
                                trans.Rollback()
                            End If



                            'Dim obj As clsCustomerInvoiceHead = clsCustomerInvoiceHead.GetData(clsCommon.myCstr(dt.Rows(ii)("ARNo")), trans)
                            'If (clsCustomerInvoiceHead.CreateGLEntryForAllCases(obj, trans, False, clsCommon.myCstr(dt.Rows(ii)("Form_ID")), strJVNo)) Then
                            '    qry = "insert into Temp_Sale_Done values('" + strJVNo + "')"
                            '    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                            '    trans.Commit()
                            'Else
                            '    trans.Rollback()
                            'End If
                            clsCommon.ProgressBarPercentUpdate(ii * 100 / dt.Rows.Count - 1, "Recreate journal entry " + clsCommon.myCstr(dt.Rows.Count - 1) + "/" + clsCommon.myCstr(ii))
                        Catch ex As Exception
                            trans.Rollback()
                            strERROR += "Invoice No-" + strDocNo + ",AR No- " + strARNo + " JV No-" + strJVNo + " Error " + ex.Message + ""
                        End Try
                    Next
                Catch ex As Exception
                Finally
                    clsCommon.ProgressBarPercentHide()
                End Try
                If clsCommon.myLen(strERROR) > 0 Then
                    clsCommon.MyMessageBoxShow(strERROR, Me.Text)
                Else
                    common.clsCommon.MyMessageBoxShow("Task Completed", Me.Text)
                End If

            End If
        End If
    End Sub

    Private Sub RadButton9_Click(sender As Object, e As EventArgs) Handles RadButton9.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim currentdate As Date = Date.Today
        If transportSql.importExcel(gv, "InvNo", "ARNo", "JVNo") Then
            Try
                clsDBFuncationality.ExecuteNonQuery("drop table Temp_Sale")
            Catch ex As Exception
            End Try
            Try
                clsDBFuncationality.ExecuteNonQuery("drop table Temp_Sale_Done")
            Catch ex As Exception
            End Try
            clsDBFuncationality.ExecuteNonQuery("create table Temp_Sale( InvNo varchar(50) not null, ARNo varchar(50) not null, JVNo varchar(50) not null, Form_ID varchar(50) not null )")
            clsDBFuncationality.ExecuteNonQuery("create table Temp_Sale_Done( JVNo varchar(50) not null)")
            Dim trans As SqlTransaction = Nothing
            Try
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()
                'Dim jj As Integer = 1
                For Each grow As GridViewRowInfo In gv.Rows
                    'If jj > 10 Then
                    '    Exit For
                    'Else
                    '    jj += 1
                    'End If

                    Dim strInvNo As String = clsCommon.myCstr(grow.Cells(0).Value)
                    Dim strARNo As String = clsCommon.myCstr(grow.Cells(1).Value)
                    Dim strJVNo As String = clsCommon.myCstr(grow.Cells(2).Value)
                    If clsCommon.myLen(strInvNo) > 0 AndAlso clsCommon.myLen(strARNo) > 0 AndAlso clsCommon.myLen(strJVNo) > 0 Then
                        Dim Qry As String = "INSERT Into Temp_Sale (InvNo,ARNo,JVNo,Form_ID) values('" + strInvNo + "','" + strARNo + "', '" + strJVNo + "','')"
                        clsDBFuncationality.ExecuteNonQuery(Qry, trans)
                    End If
                Next
                clsDBFuncationality.ExecuteNonQuery("update Temp_Sale set Form_ID= (select case when Trans_Type='FS' then 'FreshSaleInvoice' else case when Trans_Type='MCC' then '' else case when Trans_Type='PS' then '' else '' end end end from TSPL_SD_SALE_INVOICE_HEAD where TSPL_SD_SALE_INVOICE_HEAD.Document_Code=Temp_Sale.InvNo)", trans)
                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)
            Finally
                Me.Controls.Remove(gv)
            End Try
        End If
    End Sub






