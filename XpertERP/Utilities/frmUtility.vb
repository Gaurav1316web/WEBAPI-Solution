                        QryInsert = "insert into TEMP_DELETED_DAIRYReceipt_DayWise "
                        QryInsert += "select ShipmentNo,ShipmentVoucherNo,InvoiceNo,ARInvoiceNo,ARVoucherNo,ShipmentDate,Document_Type,OrderColumn,Location_Code from (" & qry1 & ") Rev"
                        clsDBFuncationality.ExecuteNonQuery(QryInsert)

                        ''----------------delete doc and recreate doc

                        qry = "select * from TEMP_DELETED_DAIRYReceipt_DayWise where DocumentNo not in (select DocumentNo from TEMP_UNPOSTED_DAIRYReceipt_DayWise) order by  Document_date,DOCUMENTnO "
                        dt = New DataTable()
                        dt = clsDBFuncationality.GetDataTable(qry)

                        Dim trans As SqlTransaction = Nothing
                        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                            flag = False
                            trans = clsDBFuncationality.GetTransactin()
                            clsCommon.ProgressBarPercentShow()
                            For ii As Integer = 0 To dt.Rows.Count - 1
                                Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("DocumentNo"))
                                Dim strShipmentJVNo As String = clsCommon.myCstr(dt.Rows(ii)("Shipment_JV_NO"))
                                Dim strInvoiceNo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No"))
                                Dim strInvoiceARNo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No_AR_NO"))
                                Dim strInvoiceARJENo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No_AR_JV_NO"))
                                Dim strShipmentDate As Date = clsCommon.GetPrintDate(dt.Rows(ii)("Document_date"), "dd/MMM/yyyy")
                                Dim strDocType As String = clsCommon.myCstr(dt.Rows(ii)("Document_Type"))
                                Dim strOrderColumn As String = clsCommon.myCstr(dt.Rows(ii)("OrderColumn"))
                                Dim strLocation_Code As String = clsCommon.myCstr(dt.Rows(ii)("Location_Code"))
                                Try
                                    If clsCommon.CompairString(strDocType, "S") = CompairStringResult.Equal Then
                                        ''Shipment
                                        qry = "Delete from TSPL_JOURNAL_DETAILS where voucher_no='" + strShipmentJVNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                                        qry = "Delete from TSPL_JOURNAL_MASTER where voucher_no='" + strShipmentJVNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                                        '--Invoice
                                        qry = "Delete from TSPL_JOURNAL_DETAILS where voucher_no='" + strInvoiceARJENo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                                        qry = "Delete from TSPL_JOURNAL_MASTER where voucher_no='" + strInvoiceARJENo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                                        clsDBFuncationality.ExecuteNonQuery("update tspl_batch_item set Against_Inv_Movement_Trans_Id=null where Document_Code='" & strDocNo & "'", trans)
                                        clsDBFuncationality.ExecuteNonQuery("Delete from TSPL_INVENTORY_MOVEMENT where Source_Doc_No='" & strDocNo & "'", trans)


                                        qry = "Delete from TSPL_Customer_Invoice_Detail where document_no='" + strInvoiceARNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)

                                        qry = "Delete from TSPL_Customer_Invoice_Head where document_no='" + strInvoiceARNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)
                                    ElseIf clsCommon.CompairString(strDocType, "U") = CompairStringResult.Equal Then
                                        clsDSSalesReturnHead.ReverseAndUnpost(strDocNo, trans, True)
                                    ElseIf clsCommon.CompairString(strDocType, "T") = CompairStringResult.Equal Then
                                        clsTransferDCC.ReverseAndUnpost(strDocNo, True, trans, False)
                                    ElseIf clsCommon.CompairString(strDocType, "D") = CompairStringResult.Equal Then
                                        clsAssembliesDis.UnpostData(strDocNo, "Disassembly", trans)
                                    ElseIf clsCommon.CompairString(strDocType, "W") = CompairStringResult.Equal Then
                                        clsWreckageBooking.UnpostData(strDocNo, clsUserMgtCode.frmWreckageBooking, trans)
                                    Else
                                        Throw New Exception("Wrong Document Type [" + strDocType + "]")
                                    End If

                                    clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_UNPOSTED_DAIRYReceipt_DayWise values('" & strDocNo & "','" & strShipmentJVNo & "','" & strInvoiceNo & "','" & strInvoiceARNo & "','" & strInvoiceARJENo & "','" & clsCommon.GetPrintDate(dt.Rows(ii)("Document_date"), "dd/MMM/yyyy") & "','" + strDocType + "','" + strOrderColumn + "','" + strLocation_Code + "')", trans)

                                Catch ex As Exception
                                    strErro += "Delete Dairy Shipment  - " + strDocNo + " Exception -" + ex.Message + Environment.NewLine
                                End Try
                                clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Unpost Document for " & clsCommon.GetPrintDate(strfromDate, "dd/MMM/yyyy") & "   " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                            Next

                            If clsCommon.myLen(strErro) > 0 Then
                                trans.Rollback()
                                Throw New Exception(strErro)
                            Else
                                trans.Commit()
                            End If
                            clsCommon.ProgressBarPercentHide()
                        End If
                        clsCommon.ProgressBarPercentShow()
                        Try
Recreate:
                            'qry = "select * from TEMP_UNPOSTED_DAIRYReceipt_DayWise where DocumentNo not in (select DocumentNo from TEMP_CREATED_DAIRYReceipt_DayWise) order by Location_Code,Document_date,OrderColumn,DOCUMENTnO "
                            qry = "select (case when TEMP_UNPOSTED_DAIRYReceipt_DayWise.Document_Type='S' then TEMP_UNPOSTED_DAIRYReceipt_DayWise.Invoice_No else (case when TEMP_UNPOSTED_DAIRYReceipt_DayWise.Document_Type='U' then TSPL_SD_SALE_RETURN_HEAD.Against_Invoice_No else TEMP_UNPOSTED_DAIRYReceipt_DayWise.DocumentNo end ) end) as DOCUMENTNoForOrder,(case when TEMP_UNPOSTED_DAIRYReceipt_DayWise.Document_Type='U' then convert(date, TSPL_SD_SALE_INVOICE_HEAD.Document_Date,103) else TEMP_UNPOSTED_DAIRYReceipt_DayWise.Document_date end) as Document_dateForOrder,TEMP_UNPOSTED_DAIRYReceipt_DayWise.* " + Environment.NewLine +
                            " From TEMP_UNPOSTED_DAIRYReceipt_DayWise " + Environment.NewLine +
                            " left outer join TSPL_SD_SALE_RETURN_HEAD on TSPL_SD_SALE_RETURN_HEAD.DOCUMENT_CODE=TEMP_UNPOSTED_DAIRYReceipt_DayWise.DocumentNo " + Environment.NewLine +
                            " left outer join TSPL_SD_SALE_INVOICE_HEAD on TSPL_SD_SALE_INVOICE_HEAD.DOCUMENT_CODE=TSPL_SD_SALE_RETURN_HEAD.Against_Invoice_No " + Environment.NewLine +
                            " where DocumentNo not in (select DocumentNo from TEMP_CREATED_DAIRYReceipt_DayWise) order by Location_Code,Document_dateForOrder,OrderColumn,DOCUMENTNoForOrder "
                            dt = New DataTable()
                            dt = clsDBFuncationality.GetDataTable(qry)
                            strErro = ""
                            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                                If flag Then
                                    If Not common.clsCommon.MyMessageBoxShow("Recreate Dairy Shipment/Sale/Transfer " + clsCommon.myCstr(dt.Rows.Count), Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                                        clsCommon.ProgressBarPercentHide()
                                        Exit Sub
                                    End If
                                End If
                                For ii As Integer = 0 To dt.Rows.Count - 1
                                    Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("DocumentNo"))
                                    Dim strShipmentJVNo As String = clsCommon.myCstr(dt.Rows(ii)("Shipment_JV_NO"))
                                    Dim strInvoiceNo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No"))
                                    Dim strInvoiceARNo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No_AR_NO"))
                                    Dim strInvoiceARJENo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No_AR_JV_NO"))
                                    Dim strDocType As String = clsCommon.myCstr(dt.Rows(ii)("Document_Type"))
                                    trans = clsDBFuncationality.GetTransactin()
                                    Try
                                        If clsCommon.CompairString(strDocType, "S") = CompairStringResult.Equal Then
                                            Dim obj As clsPSShipmentHead = clsPSShipmentHead.GetData(strDocNo, NavigatorType.Current, trans, True)
                                            Dim ExtraWhrForAvg As String = ""
                                            If Not MyCheckBox11.Checked Then
                                                ExtraWhrForAvg = "  and 2= case when Trans_Type='Transfer' and InOut='I' then 1 else 2 end  "
                                            End If
                                            clsPSShipmentHead.UpdateInventoryMovement(obj, trans, True, True, IIf(MyDateTimePicker5.Checked, MyDateTimePicker5.Value, Nothing), ExtraWhrForAvg)
                                            clsPSShipmentHead.CreateJournalEntry(strDocNo, trans, strShipmentJVNo)
                                            Dim objINV As clsPSInvoiceHead = clsPSInvoiceHead.GetData(strInvoiceNo, NavigatorType.Current, "", trans)
                                            clsPSInvoiceHead.createARInvoice(objINV, trans, strInvoiceARNo, strInvoiceARJENo, clsUserMgtCode.frmSaleDispatchDairy, True)
                                        ElseIf clsCommon.CompairString(strDocType, "U") = CompairStringResult.Equal Then
                                            clsDSSalesReturnHead.PostData(clsUserMgtCode.frmSaleReturndairy, strDocNo, trans, strInvoiceARNo, strInvoiceARJENo, True)
                                        ElseIf clsCommon.CompairString(strDocType, "T") = CompairStringResult.Equal Then
                                            clsTransferDCC.postTransfer(MyCheckBox10.Checked, trans, strDocNo, ProvisionAllow, strShipmentJVNo)
                                        ElseIf clsCommon.CompairString(strDocType, "D") = CompairStringResult.Equal Then
                                            clsAssembliesDis.PostData(strDocNo, False, trans, strShipmentJVNo, True)
                                        ElseIf clsCommon.CompairString(strDocType, "W") = CompairStringResult.Equal Then
                                            clsWreckageBooking.PostData(clsUserMgtCode.frmWreckageBooking, strDocNo, "", False, trans, strShipmentJVNo)
                                        Else
                                            Throw New Exception("Wrong Document Type [" + strDocType + "]")
                                        End If
                                        clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_CREATED_DAIRYReceipt_DayWise values('" & strDocNo & "')", trans)
                                        trans.Commit()
                                    Catch ex As Exception
                                        trans.Rollback()
                                        If ex.Message.Contains("deadlocked") Then
                                            Throw New Exception(ex.Message)
                                        Else
                                            strErro += "Recreate Dairy Shipment  - " + strDocNo + " Exception -" + ex.Message + Environment.NewLine
                                        End If
                                    End Try
                                    clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate Document for date " & clsCommon.GetPrintDate(strfromDate, "dd/MMM/yyyy") & "  " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                                Next
                            End If
                        Catch ex As Exception
                            If ex.Message.Contains("deadlocked") Then
                                clsCommon.ProgressBarPercentUpdate(0, "Collision occured. Please Waiting it will be auto start ...")
                                System.Threading.Thread.Sleep(60000)
                                flag = False
                                GoTo Recreate
                            End If
                        End Try
                        clsCommon.ProgressBarPercentHide()
                        strfromDate = strfromDate.AddDays(1)
                    Next
                End If
            End If
            If clsCommon.myLen(strErro) > 0 Then
                common.clsCommon.MyMessageBoxShow(strErro, Me.Text)
            Else
                common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub

