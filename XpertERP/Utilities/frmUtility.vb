    Sub DeleteTranasctionTable(ByVal isHeadTable As Boolean, ByVal tran As SqlTransaction, ByVal strTillDate As String, ByRef STRXT As String)
        Dim qry As String = "    len(TSPL_TABLE_METADATA.Document_No_Column)>0 and (len(TSPL_TABLE_METADATA.Parent_Table)>0 or len(TSPL_TABLE_METADATA.Document_Date_Column)>0) and not ( TSPL_TABLE_METADATA.TABLE_NAME   like ('%Cancel%') or TSPL_TABLE_METADATA.TABLE_NAME   like ('%Hist%') or TSPL_TABLE_METADATA.TABLE_NAME   like ('TEMP%') or TSPL_TABLE_METADATA.TABLE_NAME   like ('%XXX%')  or TSPL_TABLE_METADATA.TABLE_NAME   like ('%_SYNC%')  or TSPL_TABLE_METADATA.TABLE_NAME   like ('%_Delete_Data%')   )"
        If isHeadTable Then
            qry += " and len(isnull( TSPL_TABLE_METADATA.Parent_Table,'')) <= 0"
        Else
            qry += " and len(isnull( TSPL_TABLE_METADATA.Parent_Table,'')) > 0"
        End If
        Dim dt As DataTable = GetTransactionTable(qry, "TSPL_TABLE_METADATA.SNO desc", tran)
        For ii As Integer = 0 To dt.Rows.Count - 1
            clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, IIf(isHeadTable, "Header Table ", "Detail Table") + "[" + clsCommon.myCstr(dt.Rows(ii)("TABLE_NAME")) + "]" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
            qry = "delete from " + clsCommon.myCstr(dt.Rows(ii)("TABLE_NAME"))
            If clsCommon.myLen(dt.Rows(ii)("Parent_Table")) > 0 Then
                qry += " where " + clsCommon.myCstr(dt.Rows(ii)("Document_No_Column")) + " in (select  " + clsCommon.myCstr(dt.Rows(ii)("Parent_Document_No_Column")) + " from  " + clsCommon.myCstr(dt.Rows(ii)("Parent_Table")) + " where " + clsCommon.myCstr(dt.Rows(ii)("Parent_Document_Date_Column")) + " <='" + strTillDate + "' )"
            Else
                qry += " where " + clsCommon.myCstr(dt.Rows(ii)("Document_Date_Column")) + " <='" + strTillDate + "'"
            End If
            Try
                clsDBFuncationality.ExecuteNonQuery(qry, tran)
                If clsCommon.myLen(tran.Connection) <= 0 Then
                    Throw New Exception("Error in " + dt.Rows(ii)("TABLE_NAME"))
                End If

            Catch ex As Exception
                STRXT += ex.Message
            End Try
        Next
    End Sub

    Sub DropTableWithDropContraint(ByVal strTableName As String, ByVal tran As SqlTransaction)
line1:
        Try
            clsDBFuncationality.ExecuteNonQuery("truncate table """ + strTableName + """", tran)
        Catch ex As Exception
            If ex.Message.Contains("because it is being referenced by a FOREIGN KEY constraint") Then
                Dim qry As String = "SELECT  obj.name AS FK_NAME, " + Environment.NewLine +
    "sch.name AS [schema_name]," + Environment.NewLine +
    "tab1.name AS [table]," + Environment.NewLine +
    "col1.name AS [column]," + Environment.NewLine +
    "tab2.name AS [referenced_table]," + Environment.NewLine +
    "col2.name AS [referenced_column]" + Environment.NewLine +
"FROM sys.foreign_key_columns fkc" + Environment.NewLine +
"INNER JOIN sys.objects obj" + Environment.NewLine +
 "   ON obj.object_id = fkc.constraint_object_id" + Environment.NewLine +
"INNER JOIN sys.tables tab1" + Environment.NewLine +
"    ON tab1.object_id = fkc.parent_object_id" + Environment.NewLine +
"INNER JOIN sys.schemas sch" + Environment.NewLine +
"    ON tab1.schema_id = sch.schema_id" + Environment.NewLine +
"INNER JOIN sys.columns col1" + Environment.NewLine +
 "   ON col1.column_id = parent_column_id AND col1.object_id = tab1.object_id" + Environment.NewLine +
"INNER JOIN sys.tables tab2" + Environment.NewLine +
 "   ON tab2.object_id = fkc.referenced_object_id" + Environment.NewLine +
" INNER JOIN sys.columns col2" + Environment.NewLine +
    "ON col2.column_id = referenced_column_id AND col2.object_id = tab2.object_id" + Environment.NewLine +
    " Where tab2.name='" + strTableName + "'"
                Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
                If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                    For Each dr As DataRow In dt.Rows
                        clsDBFuncationality.ExecuteNonQuery("Alter table " + clsCommon.myCstr(dr("table")) + " drop constraint " + clsCommon.myCstr(dr("FK_NAME")), tran)
                    Next
                    GoTo line1
                Else
                    Throw New Exception("Error in table " + strTableName)
                End If
            Else
                Throw New Exception(strTableName + " - " + ex.Message)
            End If
        End Try
    End Sub

