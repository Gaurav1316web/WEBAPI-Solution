                            Dim dtDocDate As Date = clsCommon.myCDate(dt.Rows(ii)("To_Date"))
                            Dim dblAmt As Decimal = clsCommon.myCstr(dt.Rows(ii)("Incentive_Amount"))
                            Try
                                Dim ArryIncentiveGLAC As ArrayList = New ArrayList()
                                If dblAmt > 0 Then
                                    Dim strFarmerCode As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue("select top 1 Farmer_Code  from TSPL_MP_PAY_PROCESS_DETAIL where doc_no='" + strDocNo + "'", trans))
                                    If clsCommon.myLen(qry) <= 0 Then
                                        Throw New Exception("MP not found for Farmer Payment process No [" + strDocNo + "]")
                                    End If

                                    qry = "select Incentive_Account from TSPL_MP_MASTER where MP_Code='" + strFarmerCode + "'"
                                    qry = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, trans))
                                    If clsCommon.myLen(qry) <= 0 Then
                                        Throw New Exception("Please set Incentive Account form MP " + strFarmerCode)
                                    End If
                                    qry = clsERPFuncationality.ChangeGLAccountLocationSegment(qry, strLoc_Seg_Code, True, trans)
                                    Dim AccDr() As String = {qry, Math.Round(((dblAmt)), 2, MidpointRounding.ToEven)}
                                    ArryIncentiveGLAC.Add(AccDr)


                                    Dim DisCCodeForArAdj As String = clsFixedParameter.GetData(clsFixedParameterType.DiscountCodeForMPAdj, clsFixedParameterCode.DiscountCodeForMPAdj, trans)
