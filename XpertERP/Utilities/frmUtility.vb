    Private Sub RadButton53_Click(sender As Object, e As EventArgs) Handles RadButton53.Click
        Dim qry As String = ""
        Dim dt As New DataTable()
        Try
            qry = "select * from TEMP_DELETE_PR where Doc_No not in (select Doc_No from TEMP_CREATE_PR)"
            dt = New DataTable()
            dt = clsDBFuncationality.GetDataTable(qry)
            Dim strErro As String = ""
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If common.clsCommon.MyMessageBoxShow(Me, "Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " PR", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    clsCommon.ProgressBarPercentShow()
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("Doc_No"))
                        Dim strAPInvVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("Voucher_No"))
                        Dim strAPInvNo As String = clsCommon.myCstr(dt.Rows(ii)("AP_Invoice_No"))
                        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                        Try

                            ''By Balwinder Becuase it is getting reduce at the time of Return Post function
                            qry = "update TSPL_VENDOR_INVOICE_HEAD set Balance_Amt=Balance_Amt + (select (isnull( Document_Total,0)+isnull(TDS_Actual_Amount,0)) as ReturnAmt  from TSPL_VENDOR_INVOICE_HEAD where Against_PurchaseReturn_No='" + strDocNo + "' and TSPL_VENDOR_INVOICE_HEAD.Document_Type='D') where Against_POInvoice_No  in ( select Against_PI from TSPL_PR_HEAD where PR_No='" + strDocNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_VENDOR_INVOICE_HEAD set Posting_Date=null where Against_PurchaseReturn_No in ('" + strDocNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "Delete from TSPL_REMITTANCE WHERE Document_No in ('" + strDocNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Inventory_Movement where Trans_Type='Purchase Return' and Source_Doc_No in ('" + strDocNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_PR_HEAD set Status=0 where PR_No in ('" + strDocNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)





                            clsPurchasReturnHead.PostData(clsUserMgtCode.mbtnPurchaseReturn, strDocNo, trans, "", strAPInvVoucherNo, strAPInvNo, True)

                            clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_CREATE_PR values('" + strDocNo + "')", trans)
                            trans.Commit()
                        Catch ex As Exception
                            trans.Rollback()
                            strErro += "PR No - " + strDocNo + "AP Invoice No - " + strAPInvNo + " Voucher No - " + strAPInvVoucherNo + "  Exception -" + ex.Message + Environment.NewLine
                        End Try
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate journal entry " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                    Next
                    clsCommon.ProgressBarPercentHide()
                End If
                If clsCommon.myLen(strErro) > 0 Then
                    common.clsCommon.MyMessageBoxShow(Me, strErro, Me.Text)
                Else
                    common.clsCommon.MyMessageBoxShow(Me, "Task completed", Me.Text)
                End If
            End If

        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub

