    Sub EnableDisableInvSummarySetting()
        Dim qry As String = ""
        Try

            qry = "select count(*) from TSPL_INV_MOVE_DL"
            Dim tot As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry))
            If tot > 0 Then
                chkInvSummary.Enabled = False
                chkFatSNFControl.Enabled = False
                chkCheckBalInvSummary.Enabled = False
                chkItemwiseFatSNFControl.Checked = False
            Else
                chkInvSummary.Enabled = True
                chkFatSNFControl.Enabled = True
                chkCheckBalInvSummary.Enabled = True
                chkItemwiseFatSNFControl.Checked = True
            End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Sub
    Sub LoadInvSummarySetting()
        Try
            chkInvSummary.Checked = If(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.UpdateInventorySummaryTable, clsFixedParameterCode.UpdateInventorySummaryTable, Nothing)) = 1, True, False)
            chkFatSNFControl.Checked = If(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.FatSNFStockControl, clsFixedParameterCode.FatSNFStockControl, Nothing)) = 1, True, False)
            chkCheckBalInvSummary.Checked = If(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.CheckBalanceFromInvMoveSummry, clsFixedParameterCode.CheckBalanceFromInvMoveSummry, Nothing)) = 1, True, False)
            chkItemwiseFatSNFControl.Checked = If(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.ItemwiseFatSNFStockControl, clsFixedParameterCode.ItemwiseFatSNFStockControl, Nothing)) = 1, True, False)
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Sub

    Private Sub btnUpdateInvSetting_Click(sender As Object, e As EventArgs) Handles btnUpdateInvSetting.Click
        Try

            clsCommon.ProgressBarShow()
            Dim qry As String

            qry = "select count(*) from TSPL_INV_MOVE_DL"
            Dim tot As Decimal = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry))
            If tot > 0 AndAlso txtMultItem.arrValueMember Is Nothing AndAlso txtMultiLoc.arrValueMember Is Nothing Then
                Throw New Exception("Inventory Summary is already Updated")
            ElseIf txtMultItem.arrValueMember IsNot Nothing And txtMultItem.arrValueMember.Count > 0 AndAlso txtMultiLoc.arrValueMember IsNot Nothing And txtMultiLoc.arrValueMember.Count > 0 Then
                Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin
                Try
                    qry = "select top 1 * from TSPL_INVENTORY_MOVEMENT_NEW_WIN  with (TABLOCKX)"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "select top 1 * from TSPL_INVENTORY_MOVEMENT_WIN with (TABLOCKX)"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                    '' check pending GIT Data
                    qry = "select count(*) as total from View_STOCK_DATA_GIT"
                    tot = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry, trans))
                    If tot > 0 Then
                        Throw New Exception("Run Inventory Summary Update Job/Procedure to update pending GIT Data!!")
                    End If

                    qry = "delete from  TSPL_INV_MOVE_DL where Item_Code in (" & clsCommon.GetMulcallString(txtMultItem.arrValueMember) & ") and Location_Code in (" & clsCommon.GetMulcallString(txtMultiLoc.arrValueMember) & ")"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                    qry = "delete from TSPL_INV_MOVE_TRANS_DL where Item_Code in (" & clsCommon.GetMulcallString(txtMultItem.arrValueMember) & ") and Location_Code in (" & clsCommon.GetMulcallString(txtMultiLoc.arrValueMember) & ")"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                    clsInventoryMovement.InsertIntoGITTable(False, txtMultItem.arrValueMember, txtMultiLoc.arrValueMember, trans)
                    clsInventoryMovement.UpdateInvSummaryData("", trans)
                    trans.Commit()
                Catch ex As Exception
                    trans.Rollback()
                    clsCommon.MyMessageBoxShow(ex.Message)
                End Try

                '' CREATE TABLE
                'clsCreateAllTables.CreateInventorySummaryTables()
                'qry = "truncate TABLE TSPL_INVENTORY_MOVEMENT_NEW_WIN"
                'clsDBFuncationality.ExecuteNonQuery(qry)

                'qry = "truncate TABLE TSPL_INVENTORY_MOVEMENT_WIN"
                'clsDBFuncationality.ExecuteNonQuery(qry)

                'clsCompanyMaster.UpdateInventorySummarySetting(If(chkInvSummary.Checked, "1", "0"), If(chkFatSNFControl.Checked, "1", "0"), If(chkCheckBalInvSummary.Checked, "1", "0"), If(chkItemwiseFatSNFControl.Checked, "1", "0"))
                EnableDisableInvSummarySetting()
                LoadInvSummarySetting()
            Else
                qry = "drop table TSPL_INV_MOVE_DL"
                clsDBFuncationality.ExecuteNonQuery(qry)
                qry = "DROP TABLE TSPL_INV_MOVE_TRANS_DL"
                clsDBFuncationality.ExecuteNonQuery(qry)
                '' CREATE TABLE
                XpertERPEngineFine.clsCreateAllTable.CreateInventorySummaryTables()
                qry = "truncate TABLE TSPL_INVENTORY_MOVEMENT_NEW_WIN"
                clsDBFuncationality.ExecuteNonQuery(qry)

                qry = "truncate TABLE TSPL_INVENTORY_MOVEMENT_WIN"
                clsDBFuncationality.ExecuteNonQuery(qry)

                clsCompanyMaster.UpdateInventorySummarySetting(If(chkInvSummary.Checked, "1", "0"), If(chkFatSNFControl.Checked, "1", "0"), If(chkCheckBalInvSummary.Checked, "1", "0"), If(chkItemwiseFatSNFControl.Checked, "1", "0"))
                EnableDisableInvSummarySetting()
                LoadInvSummarySetting()
            End If

            clsCommon.ProgressBarHide()
            clsCommon.MyMessageBoxShow("Setting Updated Successfully")
        Catch ex As Exception
            clsCommon.ProgressBarHide()
            clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub

