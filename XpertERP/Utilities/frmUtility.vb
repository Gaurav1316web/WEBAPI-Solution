    Private Sub RadButton256_Click(sender As Object, e As EventArgs) Handles RadButton256.Click
        Try
            If TxtMultiSelectFinder9.arrValueMember Is Nothing OrElse TxtMultiSelectFinder9.arrValueMember.Count <= 0 Then
                Throw New Exception("Please select At least One Document To unpost")
            End If
            Dim StrAllException As String = ""
            For ii As Integer = 0 To TxtMultiSelectFinder9.arrValueMember.Count - 1
                Try
                    Dim qry As String = "select Bom_code,Item_Code,Unit_Code,Quantity from TSPL_PP_BATCH_ORDER_BOM_DETAIL where Batch_Code='" + TxtMultiSelectFinder9.arrValueMember(ii) + "'"
                    Dim dtBOMCode As DataTable = clsDBFuncationality.GetDataTable(qry)
                    Dim strMainBOMCode As String = clsCommon.myCstr(dtBOMCode.Rows(0)("Bom_code"))
                    Dim strMainItemCode As String = clsCommon.myCstr(dtBOMCode.Rows(0)("Item_Code"))
                    Dim strMainItemUOM As String = clsCommon.myCstr(dtBOMCode.Rows(0)("Unit_Code"))
                    Dim strMainItemQty As Decimal = clsCommon.myCdbl(dtBOMCode.Rows(0)("Quantity"))

                    qry = "select * from (" + Environment.NewLine + _
                    "select Revision_No, 'xxx' as History_No,BOM_CODE,PROD_QUANTITY,Prod_Item_Unit_Code from TSPL_PP_BOM_HEAD where bom_code='" + strMainBOMCode + "'" + Environment.NewLine + _
                    "union all " + Environment.NewLine + _
                    "select Revision_No,History_No,BOM_CODE,PROD_QUANTITY,Prod_Item_Unit_Code from TSPL_PP_BOM_HEAD_HISTORY  where bom_code='" + strMainBOMCode + "'" + Environment.NewLine + _
                    ")xx order by Revision_No desc"
                    Dim dtHis As DataTable = clsDBFuncationality.GetDataTable(qry)
                    If dtHis IsNot Nothing AndAlso dtHis.Rows.Count > 0 Then
                        Dim isFound As Boolean = False
                        Dim revisionNo As String = ""
                        For Each drHist As DataRow In dtHis.Rows
                            Dim convFact As Decimal = 1
                            If Not clsCommon.CompairString(strMainItemUOM, clsCommon.myCstr(drHist("Prod_Item_Unit_Code"))) = CompairStringResult.Equal Then
                                convFact = clsItemMaster.GetConvertionFactor(strMainItemCode, strMainItemUOM, Nothing) / clsItemMaster.GetConvertionFactor(strMainItemCode, clsCommon.myCstr(drHist("Prod_Item_Unit_Code")), Nothing)
                            End If

                            qry = "select Item_Code,unit_code,sum(Quantity*ri) as Quantity  from (" + Environment.NewLine + _
                            "select Item_Code,unit_code,Quantity,1 as RI from TSPL_PP_BATCH_ORDER_RAW_ITEM_DETAIL where Batch_Code='" + TxtMultiSelectFinder9.arrValueMember(ii) + "'" + Environment.NewLine + _
                            "union all" + Environment.NewLine
                            If clsCommon.CompairString(clsCommon.myCstr(drHist("History_No")), "xxx") = CompairStringResult.Equal Then
                                qry += "select ITEM_CODE,UNIT_CODE," + clsCommon.myCstr(convFact) + "*((Quantity*(100+isnull(ProcessLossPer,0))/100)/" + clsCommon.myCstr(clsCommon.myCdbl(drHist("PROD_QUANTITY"))) + "*" + clsCommon.myCstr(strMainItemQty) + ") as Quantity, -1 as RI from TSPL_PP_BOM_ITEM_DETAIL where BOM_CODE='" + strMainBOMCode + "'" + Environment.NewLine
                            Else
                                qry += "select ITEM_CODE,UNIT_CODE, " + clsCommon.myCstr(convFact) + "*((Quantity*(100+isnull(ProcessLossPer,0))/100)/" + clsCommon.myCstr(clsCommon.myCdbl(drHist("PROD_QUANTITY"))) + "*" + clsCommon.myCstr(strMainItemQty) + ") as Quantity, -1 as RI from TSPL_PP_BOM_ITEM_DETAIL_HISTORY where BOM_CODE='" + strMainBOMCode + "' and History_No='" + clsCommon.myCstr(drHist("History_No")) + "'"
                            End If
                            qry += ")x group by Item_Code,unit_code having  ABS(cast(sum(Quantity*ri) as decimal(18,2))) > 0.1"
                            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
                            If dt Is Nothing OrElse dt.Rows.Count <= 0 Then
                                revisionNo = clsCommon.myCstr(drHist("Revision_No"))
                                isFound = True
                                Exit For
                            End If
                        Next
                        If isFound Then
                            qry = "update TSPL_PP_BATCH_ORDER_BOM_DETAIL set BOM_Revision_No='" + revisionNo + "' where  Batch_Code='" + TxtMultiSelectFinder9.arrValueMember(ii) + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry)
                        Else
                            Throw New Exception("Revision No not found")
                        End If
                    End If
                Catch ex As Exception
                    StrAllException += "Error In Batch Order no [" + TxtMultiSelectFinder9.arrValueMember(ii) + "]" + ex.Message + Environment.NewLine
                End Try
            Next
            If clsCommon.myLen(StrAllException) > 0 Then
                clsCommon.MyMessageBoxShow(StrAllException, Me.Text)
            Else
                clsCommon.MyMessageBoxShow("Successfully reverse and unposted", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try
    End Sub

