    Function isPendingTEMP_CREATED_DAIRYReceipt_DayWise() As Boolean
        Dim qry As String = "select DocumentNo from TEMP_UNPOSTED_DAIRYReceipt_DayWise where DocumentNo not in (select DocumentNo from TEMP_CREATED_DAIRYReceipt_DayWise)"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)

        qry = "select DocumentNo from TEMP_UNPOSTED_DAIRYReceipt_DayWise"
        Dim dt1 As DataTable = clsDBFuncationality.GetDataTable(qry)
        Dim flag As Boolean = False
        If dt1 IsNot Nothing AndAlso dt1.Rows.Count > 0 Then
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                flag = True
            End If
        End If
        Return flag
    End Function
