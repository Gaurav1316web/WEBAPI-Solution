                        Dim strInvoiceARJENo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No_AR_JV_NO"))
                        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                        Try

                            '--Invoice
                            qry = "Delete from TSPL_JOURNAL_DETAILS where voucher_no='" + strInvoiceARJENo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "Delete from TSPL_JOURNAL_MASTER where voucher_no='" + strInvoiceARJENo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "Delete from TSPL_Customer_Invoice_Detail where document_no='" + strInvoiceARNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "Delete from TSPL_Customer_Invoice_Head where document_no='" + strInvoiceARNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)


                            Dim objINV As clsPSInvoiceHead = clsPSInvoiceHead.GetData(strInvoiceNo, NavigatorType.Current, "", trans, True)
                            clsPSInvoiceHead.createARInvoice(objINV, trans, strInvoiceARNo, strInvoiceARJENo, clsUserMgtCode.frmSaleDispatchDairy, True)


                            clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_CREATED_DAIRY values('" & strDocNo & "')", trans)
                            trans.Commit()
                        Catch ex As Exception
                            trans.Rollback()
                            strErro += "Recreate Dairy Shipment  - " + strDocNo + " Exception -" + ex.Message + Environment.NewLine
                        End Try
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate Document " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                    Next
                    clsCommon.ProgressBarPercentHide()
                    If clsCommon.myLen(strErro) > 0 Then
                        common.clsCommon.MyMessageBoxShow(strErro, Me.Text)
                    Else
                        common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
                    End If
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub
    Private Sub RadButton226_Click(sender As Object, e As EventArgs) Handles RadButton226.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim currentdate As Date = Date.Today
        If transportSql.importExcel(gv, "Production issue no", "Item Code", "Old Location", "New Location") Then
            Dim trans As SqlTransaction = Nothing
            Try
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()
                Dim ii As Integer = 1
                Try
                    For Each grow As GridViewRowInfo In gv.Rows
                        Dim strIssueNo As String = clsCommon.myCstr(grow.Cells("Production issue no").Value)
                        Dim strBatchNo As String
                        Dim strItemCode As String = clsCommon.myCstr(grow.Cells("Item Code").Value)
                        Dim strOldLocation As String = clsCommon.myCstr(grow.Cells("Old Location").Value)
                        Dim strLocation As String = clsCommon.myCstr(grow.Cells("New Location").Value)
                        Dim qry As String
                        If clsCommon.myLen(strIssueNo) > 0 Then
                            qry = "select Batch_Code from TSPL_PP_ISSUE_HEAD where Issue_Code='" + strIssueNo + "'"
                            strBatchNo = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, trans))
                            If clsCommon.myLen(strBatchNo) <= 0 Then
                                Throw New Exception("Batch No no found for Issue No " + strIssueNo)
                            End If
                            qry = "select Location_Code from TSPL_LOCATION_MASTER where Location_Code='" + strLocation + "'"
                            strLocation = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, trans))
                            If clsCommon.myLen(strLocation) <= 0 Then
                                Throw New Exception("Invalid New Location Code " + clsCommon.myCstr(grow.Cells("New Location").Value))
                            End If

                            qry = "select Item_Code from TSPL_ITEM_MASTER where Item_Code='" + strItemCode + "'"
                            strItemCode = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, trans))
                            If clsCommon.myLen(strItemCode) <= 0 Then
                                Throw New Exception("Invalid Item Code " + clsCommon.myCstr(grow.Cells("Item Code").Value))
                            End If

                            qry = "update TSPL_PP_ISSUE_ITEM_DETAIL set From_SubLocation_YN=1,From_Loaction_Code='" + strLocation + "'  where  Item_Code='" + strItemCode + "' and isnull(From_Loaction_Code,'')='" + strOldLocation + "' and Issue_Code in (select Issue_Code from TSPL_PP_ISSUE_HEAD where Batch_Code='" + strBatchNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_PP_ISSUE_QC_DETAIL set From_Location_Code='" + strLocation + "'  where  Item_Code='" + strItemCode + "' and isnull( From_Location_Code,'')='" + strOldLocation + "' and Issue_Code in (select Issue_Code from TSPL_PP_ISSUE_HEAD where Batch_Code='" + strBatchNo + "') "
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_INVENTORY_MOVEMENT set Location_Code='" + strLocation + "' where  Trans_Type='PP_ISSUE' and InOut='O' and Item_Code='" + strItemCode + "' and isnull(Location_Code,'')='" + strOldLocation + "' and Source_Doc_No in (select Issue_Code from TSPL_PP_ISSUE_HEAD where Batch_Code='" + strBatchNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_INVENTORY_MOVEMENT_NEW set Location_Code='" + strLocation + "' where  Trans_Type='PP_ISSUE' and InOut='O' and Item_Code='" + strItemCode + "' and isnull(Location_Code,'')='" + strOldLocation + "' and Source_Doc_No in (select Issue_Code from TSPL_PP_ISSUE_HEAD where Batch_Code='" + strBatchNo + "') "
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_PP_SP_ISSUE_ITEM_DETAIL set From_Loaction_Code='" + strLocation + "' where Item_Code='" + strItemCode + "' and isnull(From_Loaction_Code,'')='" + strOldLocation + "' and STAGE_PROCESS_CODE in (select STAGE_PROCESS_CODE from TSPL_PP_STAGE_PROCESS_HEAD where Main_Batch_Code='" + strBatchNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "update TSPL_PP_PE_ISSUE_ITEM_DETAIL set  From_Loaction_Code='" + strLocation + "' where Item_Code='" + strItemCode + "' and isnull(From_Loaction_Code,'')='" + strOldLocation + "' and PROD_ENTRY_CODE in (select PROD_ENTRY_CODE from TSPL_PP_PRODUCTION_ENTRY where Batch_Code in ('" + strBatchNo + "'))"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                        End If
                    Next
                Catch ex As Exception
                    Throw New Exception("Error at Row No " + clsCommon.myCstr(ii) + Environment.NewLine + ex.Message)
                End Try

                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)
            Finally
                Me.Controls.Remove(gv)
            End Try
        End If
    End Sub

