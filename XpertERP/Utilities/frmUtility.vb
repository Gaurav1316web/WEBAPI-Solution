                        If MyCheckBox15.Checked Then
                            qry += " select  TSPL_WRECKAGE_ENTRY.WRECKAGE_ENTRY_CODE as ShipmentNo,TSPL_WRECKAGE_ENTRY.PROD_DATE as ShipmentDate,TSPL_JOURNAL_MASTER.Voucher_No as  ShipmentVoucherNo,'' as InvoiceNo,'' as ARInvoiceNo, '' as ARVoucherNo,'' as [Customer Code], '' as Customer,'W' as Document_Type,'F' as OrderColumn, TSPL_WRECKAGE_ENTRY.LOCATION_CODE  as Location_Code 
From TSPL_WRECKAGE_ENTRY
Left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_WRECKAGE_ENTRY.WRECKAGE_ENTRY_CODE and TSPL_JOURNAL_MASTER.Source_Code='PP-WR'
where TSPL_WRECKAGE_ENTRY.POSTED=1 and  convert(date,TSPL_WRECKAGE_ENTRY.PROD_DATE,103)='" + clsCommon.GetPrintDate(strfromDate, "dd/MMM/yyyy") + "' "
                            If TxtMultiSelectFinder14.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder14.arrValueMember.Count > 0 Then
                                qry += " And TSPL_WRECKAGE_ENTRY.LOCATION_CODE in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder14.arrValueMember) + ")"
                            End If
                        End If

