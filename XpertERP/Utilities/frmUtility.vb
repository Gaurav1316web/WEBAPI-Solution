    Private Sub RadButton6_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles RadButton6.Click
        Dim STRXT As String = ""
        Dim frm As New FrmPWD(Nothing)
        frm.strCode = clsFixedParameterCode.BlankDatabase
        frm.strType = clsFixedParameterType.BlankDatabase
        frm.ShowDialog()
        If frm.isPasswordCorrect Then
            If clsCommon.MyMessageBoxShow("Do you want to delete all records of Transaction Table", Me.Text, MessageBoxButtons.YesNo, RadMessageIcon.Question) = System.Windows.Forms.DialogResult.Yes Then
                Dim setting1 As String = clsFixedParameter.GetData(clsFixedParameterType.UpdateInventorySummaryTable, clsFixedParameterCode.UpdateInventorySummaryTable, Nothing)
                Dim setting2 As String = clsFixedParameter.GetData(clsFixedParameterType.FatSNFStockControl, clsFixedParameterCode.FatSNFStockControl, Nothing)

                Dim dt As DataTable = GetTransactionTable("", "")
                'Dim arrTable As New List(Of String)
                'arrTable.Add("TSPL_JOURNAL_MASTER")
                Try
                    clsCommon.ProgressBarPercentShow()

                    clsFixedParameter.UpdateData(clsFixedParameterType.UpdateInventorySummaryTable, clsFixedParameterCode.UpdateInventorySummaryTable, "0", Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.FatSNFStockControl, clsFixedParameterCode.FatSNFStockControl, "0", Nothing)
                    EnableDisableTrigger(False, Nothing)
                    Dim ii As Integer = 0
                    For Each row As DataRow In dt.Rows
                        clsCommon.ProgressBarPercentUpdate((((ii + 1) * 100) / dt.Rows.Count), "Progress-" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count) + " Table-" + clsCommon.myCstr(row.Item("TABLE_NAME")))
                        'clsCommon.ProgressBarPercentUpdate((((ii + 1) * 100) / arrTable.Count), "Progress-" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(arrTable.Count) + " Table-" + clsCommon.myCstr(arrTable(ii)))
                        Try
                            DropTableWithDropContraint(row.Item("TABLE_NAME"), Nothing)
                        Catch ex As Exception
                            STRXT += ex.Message
                        End Try
                        ii += 1
                    Next

                    clsDBFuncationality.ExecuteNonQuery(" update TSPL_DOCPREFIX_MASTER set Next_Number=1")
                    EnableDisableTrigger(True, Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.UpdateInventorySummaryTable, clsFixedParameterCode.UpdateInventorySummaryTable, setting1, Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.FatSNFStockControl, clsFixedParameterCode.FatSNFStockControl, setting2, Nothing)
                    If clsCommon.myLen(STRXT) > 0 Then
                        clsCommon.ProgressBarPercentHide()
                        clsCommon.MyMessageBoxShow("Some table are not cleared " + Environment.NewLine + STRXT, Me.Text)
                    Else

                        clsCommon.ProgressBarPercentHide()
                        clsCreateAllTables.CreateAllTable()
                        clsCommon.MyMessageBoxShow("Transaction data blanked successfully", Me.Text)
                    End If
                Catch ex As Exception
                    clsCommon.ProgressBarPercentHide()
                    clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
                End Try
            End If
        End If
    End Sub

    Function GetTransactionTable(ByVal Whr As String, ByVal ordBy As String) As DataTable
        Return GetTransactionTable(Whr, ordBy, Nothing)
    End Function
    Function GetTransactionTable(ByVal Whr As String, ByVal ordBy As String, ByVal tran As SqlTransaction) As DataTable
        Dim qry As String = "select TSPL_TABLE_METADATA.TABLE_NAME,TSPL_TABLE_METADATA.Document_No_Column,TSPL_TABLE_METADATA.Document_Date_Column,TSPL_TABLE_METADATA.Parent_Table,Parent.Document_No_Column as Parent_Document_No_Column,Parent.Document_Date_Column as Parent_Document_Date_Column from TSPL_TABLE_METADATA left outer join TSPL_TABLE_METADATA as Parent on Parent.TABLE_NAME=TSPL_TABLE_METADATA.Parent_Table where TSPL_TABLE_METADATA.type = 'T' "
        If clsCommon.myLen(Whr) > 0 Then
            qry += " and " + Whr
        End If
        If clsCommon.myLen(ordBy) > 0 Then
            qry += " order by " + ordBy
        End If
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        Return dt
    End Function



