    Private Sub RadButton270_Click(sender As Object, e As EventArgs) Handles RadButton270.Click
        Try
            If clsCommon.GetDateWithEndTime(MyDateTimePicker2.Value) > clsCommon.GetDateWithEndTime(MyDateTimePicker1.Value) Then
                Throw New Exception("From Date cannot be more than to date")
            End If
            If TxtMultiSelectFinder10.arrValueMember Is Nothing OrElse TxtMultiSelectFinder10.arrValueMember.Count <= 0 Then
                Throw New Exception("Please select at least one location")
            End If
            If Not MyCheckBox5.Checked And Not MyCheckBox4.Checked And Not chkCanSale.Checked And Not chkBulkSale.Checked Then
                Throw New Exception("Please select at least one document type")
            End If

            Dim dt As DataTable = clsDBFuncationality.GetDataTable("select * from ExplodeDates('" + clsCommon.GetPrintDate(MyDateTimePicker2.Value, "dd/MMM/yyyy") + "','" + clsCommon.GetPrintDate(MyDateTimePicker1.Value, "dd/MMM/yyyy") + "')")
            clsCommon.ProgressBarPercentShow()
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                Dim settTankerDispatchAvgFATSNFPer As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.TankerDispatchAvgFATSNFPer, clsFixedParameterCode.TankerDispatchAvgFATSNFPer, Nothing)) = 1)
                For ii As Integer = 0 To dt.Rows.Count - 1
                    Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
                    Try
                        Dim intSettingType As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, tran))
                        clsFixedParameter.UpdateData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, "0", tran)

                        Dim settConsiderUnpostedDocForBalance As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, tran))
                        clsFixedParameter.UpdateData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, "0", tran)
                        Dim flag As Boolean = False
                        Dim dtWIP As Date = clsCommon.myCDate(dt.Rows(ii)("thedate"))
                        Dim qry As String = "select * from (" + Environment.NewLine
                        If MyCheckBox5.Checked Then
                            qry += "select MCC_CODE as Loc_code,Chalan_NO as DocNo,Dispatch_Date as DocDate,'Dispatch' as Trans from TSPL_MCC_Dispatch_Challan where TSPL_MCC_Dispatch_Challan.isPosted=1 and convert(date,dispatch_date,103)='" + clsCommon.GetPrintDate(dtWIP, "dd/MMM/yyyy") + "' and MCC_CODE in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder10.arrValueMember) + ")" + Environment.NewLine
                            flag = True
                        End If
                        If MyCheckBox4.Checked Then
                            If flag Then
                                qry += "union all" + Environment.NewLine
                            End If
                            qry += "select MainLocationCode as Loc_code,Adjustment_No as DocNo, Adjustment_Date as DocDate,'Adjstment' as Trans  from TSPL_ADJUSTMENT_HEADER where adjustment_type='FLG' and posted='Y' and MainLocationCode in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder10.arrValueMember) + ") and convert(date,Adjustment_Date,103)='" + clsCommon.GetPrintDate(dtWIP, "dd/MMM/yyyy") + "'" + Environment.NewLine
                            flag = True
                        End If
                        If chkCanSale.Checked Then
                            If flag Then
                                qry += "union all" + Environment.NewLine
                            End If
                            qry += "select Location_code as Loc_code,Document_No as DocNo,Document_date as DocDate,'CanSale' as Trans from TSPL_CANSALE_INVOICE_HEAD where  posted=1 and Location_code in ( " + clsCommon.GetMulcallString(TxtMultiSelectFinder10.arrValueMember) + " ) and convert(date,Document_date,103)='" + clsCommon.GetPrintDate(dtWIP, "dd/MMM/yyyy") + " '" + Environment.NewLine
                            flag = True
                        End If
                        If chkBulkSale.Checked Then
                            If flag Then
                                qry += "union all" + Environment.NewLine
                            End If
                            qry += "select TSPL_Dispatch_BulkSale.Location_Code as Loc_code,TSPL_Dispatch_BulkSale.Document_No as DocNo,TSPL_Dispatch_BulkSale.Document_Date as DocDate,'BulkSale' as Trans from TSPL_Dispatch_BulkSale where  TSPL_Dispatch_BulkSale.Posted=1 and TSPL_Dispatch_BulkSale.Location_Code in ( " + clsCommon.GetMulcallString(TxtMultiSelectFinder10.arrValueMember) + " ) and convert(date,TSPL_Dispatch_BulkSale.Document_Date,103)='" + clsCommon.GetPrintDate(dtWIP, "dd/MMM/yyyy") + " '" + Environment.NewLine
                        End If

                        qry += ")x order by Loc_code,DocDate"
                        Dim dtDoc As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                        Dim arrBulkSaleDoc As New ArrayList()
                        For Each dr As DataRow In dtDoc.Rows
                            If clsCommon.CompairString(clsCommon.myCstr(dr("Trans")), "BulkSale") = CompairStringResult.Equal Then
                                arrBulkSaleDoc.Add(clsCommon.myCstr(dr("DocNo")))
                            End If
                        Next
                        For Each dr As DataRow In dtDoc.Rows
                            If clsCommon.CompairString(clsCommon.myCstr(dr("Trans")), "Dispatch") = CompairStringResult.Equal Then
                                DispathToTansferInCorrectionWithDoc(clsCommon.myCstr(dr("DocNo")), settTankerDispatchAvgFATSNFPer, tran)
                            ElseIf clsCommon.CompairString(clsCommon.myCstr(dr("Trans")), "Adjstment") = CompairStringResult.Equal Then
                                AdjstmentCorrection(clsCommon.myCstr(dr("DocNo")), clsCommon.myCstr(dr("Loc_code")), clsCommon.myCDate(dr("DocDate")), settTankerDispatchAvgFATSNFPer, tran)
                            ElseIf clsCommon.CompairString(clsCommon.myCstr(dr("Trans")), "CanSale") = CompairStringResult.Equal Then
                                CanSaleCorrection(clsCommon.myCstr(dr("DocNo")), tran)
                            ElseIf clsCommon.CompairString(clsCommon.myCstr(dr("Trans")), "BulkSale") = CompairStringResult.Equal Then
                                BulkSaleCorrection(clsCommon.myCstr(dr("DocNo")), tran, arrBulkSaleDoc)
                            Else
                                Throw New Exception("Wrong Document Transaciton [" + clsCommon.myCstr(dr("Trans")) + "] ")
                            End If
                        Next
                        clsDBFuncationality.ExecuteNonQuery("Delete from TEMP_Full_TankerDispatch", tran)
                        Dim coll As New Hashtable()
                        clsCommon.AddColumnsForChange(coll, "FromDate", clsCommon.GetPrintDate(dtWIP.AddDays(1), "dd/MMM/yyyy"))
                        clsCommon.AddColumnsForChange(coll, "ToDate", clsCommon.GetPrintDate(MyDateTimePicker1.Value, "dd/MMM/yyyy"))
                        clsCommonFunctionality.UpdateDataTable(coll, "TEMP_Full_TankerDispatch", OMInsertOrUpdate.Insert, "", tran)
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count) + "[" + clsCommon.GetPrintDate(dtWIP, "dd/MM/yyyy") + "]")
                        clsDBFuncationality.ExecuteNonQuery("Delete from TEMP_Full_TankerDispatch_Loc", tran)
                        clsDBFuncationality.ExecuteNonQuery("Delete from TEMP_Full_TankerDispatch_Item", tran)
                        For Each Str As String In TxtMultiSelectFinder10.arrValueMember
                            coll = New Hashtable()
                            clsCommon.AddColumnsForChange(coll, "Location_Code", Str)
                            clsCommonFunctionality.UpdateDataTable(coll, "TEMP_Full_TankerDispatch_Loc", OMInsertOrUpdate.Insert, "", tran)
                        Next
                        For Each Str As String In TxtMultiSelectFinder11.arrValueMember
                            coll = New Hashtable()
                            clsCommon.AddColumnsForChange(coll, "Item_Code", Str)
                            clsCommonFunctionality.UpdateDataTable(coll, "TEMP_Full_TankerDispatch_Item", OMInsertOrUpdate.Insert, "", tran)
                        Next
                        clsFixedParameter.UpdateData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, clsCommon.myCstr(intSettingType), tran)
                        clsFixedParameter.UpdateData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, clsCommon.myCstr(settConsiderUnpostedDocForBalance), tran)
                        tran.Commit()
                    Catch ex As Exception
                        tran.Rollback()
                        clsCommon.ProgressBarPercentHide()
                        Throw New Exception(ex.Message)
                    End Try
                Next
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow("Task Completed", Me.Text)
            Else
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow("No Document Found Completed", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        Finally
            LoadFullTankerDispatch()
        End Try
    End Sub

    Sub DispathToTansferInCorrectionWithDoc(ByVal strDocNo As String, ByVal settTankerDispatchAvgFATSNFPer As Boolean, ByVal trans As SqlTransaction)
        Dim qry As String = "select Chalan_NO,Dispatch_Date,MCC_Code,MCC_Name,Tanker_Dispatch_To,Mcc_Or_Plant_Code,Tanker_No,(select Voucher_No from TSPL_JOURNAL_MASTER     where Source_Doc_No =Chalan_NO and Source_Code='DI-CH') as Voucher_No,TSPL_MILK_TRANSFER_IN.Receipt_Challan_No as TranferIn_Doc_No,(select Voucher_No from TSPL_JOURNAL_MASTER where Source_Doc_No =TSPL_MILK_TRANSFER_IN.Receipt_Challan_No and Source_Code='MT-IN') as TranferIn_Voucher_No,TSPL_ADJUSTMENT_HEADER.Adjustment_No " + Environment.NewLine + _
        "from TSPL_MCC_Dispatch_Challan" + Environment.NewLine + _
        "left join TSPL_MILK_TRANSFER_IN on TSPL_MILK_TRANSFER_IN.Dispatch_Challan_No=TSPL_MCC_Dispatch_Challan.Chalan_NO " + Environment.NewLine + _
        "left join TSPL_ADJUSTMENT_HEADER on TSPL_ADJUSTMENT_HEADER.Against_Tanker_Dispatch_Doc_No=TSPL_MCC_Dispatch_Challan.Chalan_NO " + Environment.NewLine + _
        "where TSPL_MCC_Dispatch_Challan.isPosted = 1" + Environment.NewLine + _
        "and 2=(case when TSPL_MILK_TRANSFER_IN.Receipt_Challan_No is null then 2 else case when TSPL_MILK_TRANSFER_IN.isPosted=1 then 2 else 1 end end)" + Environment.NewLine + _
        "and Chalan_NO='" + strDocNo + "'"
        If TxtMultiSelectFinder11.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder11.arrValueMember.Count > 0 Then
            qry += " and exists ( select 1 from TSPL_MCC_DISPATCH_CHALLAN_DETAIL where TSPL_MCC_DISPATCH_CHALLAN_DETAIL.Chalan_No=TSPL_MCC_Dispatch_Challan.Chalan_NO and TSPL_MCC_DISPATCH_CHALLAN_DETAIL.Qty_Kg>0 and item_code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder11.arrValueMember) + "))"
        End If
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                DispathToTansferInCorrection(strDocNo, clsCommon.myCstr(dr("Voucher_No")), clsCommon.myCstr(dr("Adjustment_No")), clsCommon.myCstr(dr("TranferIn_Doc_No")), clsCommon.myCstr(dr("TranferIn_Voucher_No")), settTankerDispatchAvgFATSNFPer, trans)
            Next
        End If
    End Sub

    Sub AdjstmentCorrection(ByVal strDocNo As String, ByVal strLocCode As String, ByVal TranDate As DateTime, ByVal settTankerDispatchAvgFATSNFPer As Boolean, ByVal trans As SqlTransaction)
        If settTankerDispatchAvgFATSNFPer Then
            Dim ItemCostZeroOnStoreAdjForTypeFlushing = IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.ItemCostZeroOnStoreAdjForTypeFlushing, clsFixedParameterCode.ItemCostZeroOnStoreAdjForTypeFlushing, trans)) = 0, False, True)

            Dim qry As String
            Dim flag As Boolean = True
            Dim dt As DataTable

            While flag
                qry = "select chalan_No from TSPL_MCC_Dispatch_Challan where  Dispatch_Date='" + clsCommon.GetPrintDate(TranDate, "dd/MMM/yyyy hh:mm tt") + "' and MCC_Code='" + strLocCode + "'"
                dt = clsDBFuncationality.GetDataTable(qry, trans)
                If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                    TranDate = TranDate.AddMinutes(-1)
                    qry = "update TSPL_ADJUSTMENT_HEADER set EntryDateTime='" + clsCommon.GetPrintDate(TranDate, "dd/MMM/yyyy hh:mm tt") + "',Adjustment_Date='" + clsCommon.GetPrintDate(TranDate, "dd/MMM/yyyy hh:mm tt") + "' where Adjustment_No='" + strDocNo + "'"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                Else
                    flag = False
                End If
            End While

            dt = clsDBFuncationality.GetDataTable("select Adjustment_Line_No,item_code,unit_code, FAT_Pers,SNF_Pers,FAT_KG,SNF_KG,fat_Rate,snf_rate,Fat_Amt,SNF_Amt,Item_Quantity,Item_Cost from TSPL_ADJUSTMENT_DETAIL where Adjustment_No='" + strDocNo + "'", trans)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                For Each dr As DataRow In dt.Rows
                    Dim calQty As Decimal = clsCommon.myCdbl(dr("Item_Quantity"))
                    Dim objMCT As MIlkComponentType = GetAvgCost(True, "MI", clsCommon.myCstr(dr("item_code")), strLocCode, 1, clsCommon.myCstr(dr("unit_code")), 1, 1, TranDate, TranDate, False, trans, strDocNo)
                    Dim calFATKg As Decimal = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(dr("item_code")), clsCommon.myCstr(dr("unit_code")), calQty, objMCT.FAT_Per, trans)
                    Dim calSNFKg As Decimal = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(dr("item_code")), clsCommon.myCstr(dr("unit_code")), calQty, objMCT.SNF_Per, trans)
                    Dim calFatAmt As Decimal = Math.Round(objMCT.FAT_Cost * calFATKg, 2, MidpointRounding.ToEven)
                    Dim calSNFAmt As Decimal = Math.Round(objMCT.SNF_Cost * calSNFKg, 2, MidpointRounding.ToEven)
                    Dim calAmt As Decimal = calFatAmt + calSNFAmt
                    Dim dclRate As Decimal = 0
                    If Not calQty = 0 Then
                        dclRate = calAmt / calQty
                    End If

                    Dim coll = New Hashtable()
                    If ItemCostZeroOnStoreAdjForTypeFlushing Then
                        clsCommon.AddColumnsForChange(coll, "FAT_Pers", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_Pers", 0)
                        clsCommon.AddColumnsForChange(coll, "FAT_KG", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_KG", 0)
                        clsCommon.AddColumnsForChange(coll, "fat_Rate", 0)
                        clsCommon.AddColumnsForChange(coll, "snf_Rate", 0)
                        clsCommon.AddColumnsForChange(coll, "fat_Amt", 0)
                        clsCommon.AddColumnsForChange(coll, "snf_Amt", 0)
                        clsCommon.AddColumnsForChange(coll, "Item_Cost", 0)
                        clsCommon.AddColumnsForChange(coll, "Unit_Cost", 0)
                    Else
                        clsCommon.AddColumnsForChange(coll, "FAT_Pers", objMCT.FAT_Per)
                        clsCommon.AddColumnsForChange(coll, "SNF_Pers", objMCT.SNF_Per)
                        clsCommon.AddColumnsForChange(coll, "FAT_KG", calFATKg)
                        clsCommon.AddColumnsForChange(coll, "SNF_KG", calSNFKg)
                        clsCommon.AddColumnsForChange(coll, "fat_Rate", objMCT.FAT_Cost)
                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", objMCT.SNF_Cost)
                        clsCommon.AddColumnsForChange(coll, "Fat_Amt", calFatAmt)
                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", calSNFAmt)
                        clsCommon.AddColumnsForChange(coll, "Item_Cost", calAmt)
                        clsCommon.AddColumnsForChange(coll, "Unit_Cost", dclRate)
                    End If

                    clsCommonFunctionality.UpdateDataTable(coll, "TSPL_ADJUSTMENT_DETAIL", OMInsertOrUpdate.Update, "Adjustment_Line_No='" + clsCommon.myCstr(clsCommon.myCdbl(dr("Adjustment_Line_No"))) + "' and Adjustment_No='" + strDocNo + "' and item_code='" + clsCommon.myCstr(dr("item_code")) + "'", trans)

                    coll = New Hashtable()
                    If ItemCostZeroOnStoreAdjForTypeFlushing Then
                        clsCommon.AddColumnsForChange(coll, "Basic_cost", 0)
                        clsCommon.AddColumnsForChange(coll, "Fat_Per", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_Per", 0)
                        clsCommon.AddColumnsForChange(coll, "FAT_KG", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_KG", 0)
                        clsCommon.AddColumnsForChange(coll, "Fat_Rate", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", 0)
                        clsCommon.AddColumnsForChange(coll, "Fat_Amt", 0)
                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", 0)
                        clsCommon.AddColumnsForChange(coll, "Avg_Cost", 0)
                        clsCommon.AddColumnsForChange(coll, "FIFO_Cost", 0)
                        clsCommon.AddColumnsForChange(coll, "LIFO_Cost", 0)
                    Else
                        clsCommon.AddColumnsForChange(coll, "Basic_cost", dclRate)
                        clsCommon.AddColumnsForChange(coll, "Fat_Per", objMCT.FAT_Per)
                        clsCommon.AddColumnsForChange(coll, "SNF_Per", objMCT.SNF_Per)
                        clsCommon.AddColumnsForChange(coll, "FAT_KG", calFATKg)
                        clsCommon.AddColumnsForChange(coll, "SNF_KG", calSNFKg)
                        clsCommon.AddColumnsForChange(coll, "Fat_Rate", objMCT.FAT_Cost)
                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", objMCT.SNF_Cost)
                        clsCommon.AddColumnsForChange(coll, "Fat_Amt", calFatAmt)
                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", calSNFAmt)
                        clsCommon.AddColumnsForChange(coll, "Avg_Cost", calAmt)
                        clsCommon.AddColumnsForChange(coll, "FIFO_Cost", calAmt)
                        clsCommon.AddColumnsForChange(coll, "LIFO_Cost", calAmt)
                    End If
                    clsCommonFunctionality.UpdateDataTable(coll, "TSPL_INVENTORY_MOVEMENT_NEW", OMInsertOrUpdate.Update, "Trans_Type='IC-AD' and Source_Doc_No='" + strDocNo + "' and Item_Code='" + clsCommon.myCstr(dr("item_code")) + "'", trans)
                Next
            End If

            Dim strVoucherNo As String = clsDBFuncationality.getSingleValue("select voucher_no from TSPL_JOURNAL_MASTER where TSPL_JOURNAL_MASTER.Source_Doc_No='" + strDocNo + "' and TSPL_JOURNAL_MASTER.Source_Code='IC-AD' ", trans)
            Dim strAdjustmentType As String = ClsAdjustments.GetTransactionType(strDocNo, trans)
            Dim obj As New ClsAdjustments
            obj = obj.GetData(strDocNo, strAdjustmentType, NavigatorType.Current, trans)
            ClsAdjustments.CreateJE(obj, strAdjustmentType, trans, strVoucherNo)
        End If
    End Sub

