    Private Sub btnUpdateInventoryAndItemLocation_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnUpdateInventoryAndItemLocation.Click
        If common.clsCommon.MyMessageBoxShow("Update MRP in Inventory and Item Location stock" + Environment.NewLine + "Are you sure.", Me.Text, MessageBoxButtons.YesNo, RadMessageIcon.Question) = System.Windows.Forms.DialogResult.No Then
            Exit Sub
        End If
        Dim qry As String = ""
        Try
            qry = " ALTER TABLE TSPL_ITEM_LOCATION_DETAILS"
            qry += " DROP CONSTRAINT PK_ITEM_LOCATION_DETAILS"
            clsDBFuncationality.ExecuteNonQuery(qry)
        Catch ex As Exception

        End Try

        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            clsCommon.ProgressBarShow()


            '----------------------For Updation of MRP In inventory Movement for  LOAD OUT TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.MRP_Amt"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, MRP_Amt from TSPL_SHIPMENT_DETAILS "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_SHIPMENT_DETAILS.Shipment_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_SHIPMENT_DETAILS.Item_Code and tspl_Inventory_movement.UOM=TSPL_SHIPMENT_DETAILS.Unit_code"
            qry += " where tspl_Inventory_movement.Trans_Type='Load Out'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)


            '----------------------For Updation of MRP In inventory Movement for TRANSFER TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.MRP"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, TSPL_transfer_DETAIL.MRP from TSPL_transfer_DETAIL "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_transfer_DETAIL.transfer_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_transfer_DETAIL.Item_Code and tspl_Inventory_movement.UOM=TSPL_transfer_DETAIL.Uom"
            qry += " where tspl_Inventory_movement.Trans_Type='Transfer'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)


            '----------------------For Updation of MRP In inventory Movement for SRN TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.MRP"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, TSPL_srn_DETAIL.MRP from TSPL_SRN_DETAIL "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_SRN_DETAIL.SRN_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_SRN_DETAIL.Item_Code and tspl_Inventory_movement.UOM=TSPL_SRN_DETAIL.Unit_code"
            qry += " where tspl_Inventory_movement.Trans_Type='SRN'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)


            '----------------------For Updation of MRP In inventory Movement for Purchase return TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.MRP"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, TSPL_PR_DETAIL.MRP from TSPL_pr_DETAIL "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_pr_DETAIL.PR_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_PR_DETAIL.Item_Code and tspl_Inventory_movement.UOM=TSPL_PR_DETAIL.Unit_code"
            qry += " where tspl_Inventory_movement.Trans_Type='Purchase Return'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)


            '----------------------For Updation of MRP In inventory Movement for Sale return intercompany TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.mrp_amt"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, TSPL_SALE_RETURN_INTER_DETAIL.MRP_Amt from TSPL_SALE_RETURN_INTER_DETAIL "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_SALE_RETURN_INTER_DETAIL.Document_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_SALE_RETURN_INTER_DETAIL.Item_Code and tspl_Inventory_movement.UOM=TSPL_SALE_RETURN_INTER_DETAIL.Unit_code"
            qry += " where tspl_Inventory_movement.Trans_Type='Sale Return'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)



            '----------------------For Updation of MRP In inventory Movement for Sale return  TYPE TRANSACTIONS
            qry = " update tspl_Inventory_movement set tspl_Inventory_movement.MRP=xxx.mrp_amt"
            qry += " from tspl_Inventory_movement inner join("
            qry += " select tspl_Inventory_movement.Trans_Id, TSPL_SALE_RETURN_DETAIL.MRP_Amt from TSPL_SALE_RETURN_DETAIL "
            qry += " inner join tspl_Inventory_movement on tspl_Inventory_movement.Source_Doc_No=  TSPL_SALE_RETURN_DETAIL.Sale_Return_No"
            qry += " and tspl_Inventory_movement.Item_Code=TSPL_SALE_RETURN_DETAIL.Item_Code and tspl_Inventory_movement.UOM=TSPL_SALE_RETURN_DETAIL.Unit_code"
            qry += " where tspl_Inventory_movement.Trans_Type='Sale Return'"
            qry += " )xxx on xxx.Trans_Id=tspl_Inventory_movement.Trans_Id "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)




            '--step 1
            qry = " delete from TSPL_ITEM_LOCATION_DETAILS where ItemType in ('FT','FM','E')"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)
            '--End of step 1 


            '--step 2
            qry = " select * from TSPL_INVENTORY_MOVEMENT where Trans_Type='SRN' and ItemType='E' "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)
            '--End of step 2 



            '--step 3
            qry = " update   TSPL_INVENTORY_MOVEMENT set UOM=(case when UOM='FB' then 'EB' else case when UOM='FC' then 'EC' else UOM end end) "
            qry += " where Trans_Type='SRN' and ItemType='E' "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)
            '--End of step 3 



            '--step 4
            qry = " insert into TSPL_ITEM_LOCATION_DETAILS (Item_Code,Item_Desc,Location_Code,Location_Desc,Item_Qty,Amount,Created_By,Created_Date,Modify_By,Modify_Date,Comp_code,MRP,MFG_Date,Batch_No,Expiry_Date,ItemType) "
            '--Run to show Preview for Items to be inserted and change comp_Code according to company Code
            qry += " select xxxx.Item_Code,TSPL_ITEM_MASTER.Item_Desc,xxxx.Location_Code,TSPL_LOCATION_MASTER.Location_Desc,xxxx.Qty,xxxx.qty*TSPL_ITEM_MASTER.Cost as Amt,'ADMIN' as created_By,'17/09/2012' as created_Date,'ADMIN' as Modify_By,'17/09/2012' as Modify_Date,'Demo' as Comp_Code,xxxx.MRP,"
            qry += " (select top 1 MFG_Date from  TSPL_ADJUSTMENT_DETAIL where TSPL_ADJUSTMENT_DETAIL.Item_Code=xxxx.Item_Code and Batch_No='B1') as MFG_Date,'B1' as BatchNo,(select top 1 Expiry_Date from  TSPL_ADJUSTMENT_DETAIL where TSPL_ADJUSTMENT_DETAIL.Item_Code=xxxx.Item_Code and Batch_No='B1') as Expiry_Date,"
            qry += " ItemType"
            qry += " from ("
            qry += " select  Item_Code,Location_Code,MRP,sum(Qty * case when InOut='I' then 1 else -1 end )as Qty,'FT' as ItemType from ("
            qry += " select  TSPL_INVENTORY_MOVEMENT.Item_Code,TSPL_INVENTORY_MOVEMENT.Location_Code,CONVERT(decimal(18,2), TSPL_INVENTORY_MOVEMENT.Qty/TSPL_ITEM_UOM_DETAIL.Conversion_Factor) as Qty,CONVERT(decimal(18,2), TSPL_INVENTORY_MOVEMENT.MRP*TSPL_ITEM_UOM_DETAIL.Conversion_Factor) as MRP,InOut,TSPL_INVENTORY_MOVEMENT.Trans_Id,TSPL_INVENTORY_MOVEMENT.UOM,TSPL_ITEM_UOM_DETAIL.UOM_Code,TSPL_INVENTORY_MOVEMENT.ItemType"
            qry += " from TSPL_INVENTORY_MOVEMENT "
            qry += " left outer join TSPL_ITEM_UOM_DETAIL on  TSPL_ITEM_UOM_DETAIL.Item_Code=TSPL_INVENTORY_MOVEMENT.Item_Code and TSPL_ITEM_UOM_DETAIL.UOM_Code=TSPL_INVENTORY_MOVEMENT.UOM"
            qry += " where TSPL_INVENTORY_MOVEMENT.ItemType in ('FT','FM','E') "
            qry += " )xxx"
            qry += " group by Item_Code,Location_Code,MRP "
            qry += " )xxxx"
            qry += " left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=xxxx.Item_Code"
            qry += " left outer join TSPL_LOCATION_MASTER on TSPL_LOCATION_MASTER.Location_Code=xxxx.Location_Code"
            '--End of Run if show Preview Items to be inserted 
            clsDBFuncationality.ExecuteNonQuery(qry, trans)
            '--End of step 4


            trans.Commit()
            clsCommon.ProgressBarHide()
            common.clsCommon.MyMessageBoxShow("Successfully Updated", Me.Text)
        Catch ex As Exception
            trans.Rollback()
            clsCommon.ProgressBarHide()
            common.clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        Finally
            clsCommon.ProgressBarHide()
        End Try
    End Sub

    Private Sub txtShipment__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles txtShipment._MYValidating
        Dim qry As String = "select Shipment_No as Code,[No of Invoices] from("
        qry += " select Shipment_No,SUM(1) as [No of Invoices] from TSPL_SALE_INVOICE_HEAD group by Shipment_No having SUM(1)>1"
        qry += " union all "
        qry += " select Shipment_No,0 as [No of Invoices] from TSPL_SHIPMENT_MASTER where not exists (select 1 from TSPL_SALE_INVOICE_HEAD where TSPL_SALE_INVOICE_HEAD.Shipment_No=TSPL_SHIPMENT_MASTER.Shipment_No)"
        qry += ")xxx"
        txtShipment.Value = clsCommon.ShowSelectForm("UTISHIP", qry, "Code", "", txtShipment.Value, "", isButtonClicked)
        gvShipment.DataSource = Nothing
        gvShipment.Rows.Clear()
        gvShipment.Columns.Clear()
        If clsCommon.myLen(txtShipment.Value) > 0 Then
            qry = "select Sale_Invoice_No AS [Invoice No] from TSPL_SALE_INVOICE_HEAD where Shipment_No='" + txtShipment.Value + "'"
            gvShipment.DataSource = clsDBFuncationality.GetDataTable(qry)

            gvShipment.Columns(0).ReadOnly = True
            gvShipment.Columns(0).Width = 250
            gvShipment.AllowAddNewRow = False
            gvShipment.ShowGroupPanel = False
            gvShipment.AllowColumnReorder = True
            gvShipment.AllowRowReorder = False
            gvShipment.EnableSorting = False
            gvShipment.AddNewRowPosition = Telerik.WinControls.UI.SystemRowPosition.Bottom
            gvShipment.MasterTemplate.ShowRowHeaderColumn = False
            gvShipment.TableElement.TableHeaderHeight = 20
        End If

    End Sub

    Private Sub btnDeleteShipment_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnDeleteShipment.Click
        If common.clsCommon.MyMessageBoxShow("Delete the Shipment and it's Sale Invoices." + Environment.NewLine + "Are you sure", Me.Text, MessageBoxButtons.YesNo, RadMessageIcon.Question) = System.Windows.Forms.DialogResult.No Then
            Exit Sub
        End If

        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim arr As List(Of String) = New List(Of String)

            For ii As Integer = 0 To gvShipment.Rows.Count - 1
                arr.Add(clsCommon.myCstr(gvShipment.Rows(ii).Cells(0).Value))
            Next
            clsSaleHead.ReverseSaleAndShipment(txtShipment.Value, arr, True, trans, True)

            trans.Commit()
            common.clsCommon.MyMessageBoxShow("Successfully Deleted ", Me.Text)

            txtShipment.Value = ""
            gvShipment.DataSource = Nothing
            gvShipment.Rows.Clear()
            gvShipment.Columns.Clear()
        Catch ex As Exception
            trans.Rollback()
            common.clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try

    End Sub

