    Private Sub RadButton129_Click(sender As Object, e As EventArgs) Handles RadButton129.Click
        Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            ''get setting value
            ''Transfer Entry On Inventory Control Account
            Dim JeOnInvcontroTransfer As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.TransferEntryOnInvCtrlAccount, clsFixedParameterCode.TransferEntryOnInvCtrlAccount, tran))
            'Ticket No-BHA/01/03/19-000831,Consider Purchase Accounting setting
            Dim isPurchaseAccounting As Boolean = IIf(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.AllowPurchaseAccounting, clsFixedParameterCode.AllowPurchaseAccounting, tran)) = 1, True, False)

            Dim qry As String = "DISABLE TRIGGER dbo.TRG_JD_FiscaYearEndNoUpdateNoDelete ON dbo.TSPL_JOURNAL_DETAILS"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
            '' change by Panch Raj against ticket No: UDL/27/04/18-000137
            qry = " update tspl_journal_details set Reco_Control_Account='S' from (" & Environment.NewLine +
                  " select Final.Document_Code,JE.Voucher_No,JE.SOURCE_DOC_NO,JE.Segment_code,Final.Code as Trans_Code,Final.Name as Trans_Name," & Environment.NewLine +
                  " (Final.Sales_Acc_No+'-'+JE.Segment_code) as Sales_Account FROM TSPL_JOURNAL_MASTER JE " & Environment.NewLine +
                  " INNER JOIN ( " & Environment.NewLine +
                  " SELECT  xxx.Code,  xxx.Name,xxx.Document_Code,xxx.JE_SOURCE_DOC_NO,xxx.Sales_Account,GLA.account_Seg_Code1 as Sales_Acc_No  FROM ( " & Environment.NewLine +
                  " SELECT DISTINCT 'SD' As Code , 'General Sale' As Name,SDH.Document_Code,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Account  " & Environment.NewLine +
                  " From TSPL_SD_SALE_INVOICE_DETAIL SDD " & Environment.NewLine +
                  " LEFT join  TSPL_SD_SALE_INVOICE_HEAD SDH on SDD.DOCUMENT_CODE=SDH.Document_Code " & Environment.NewLine +
                  " left join TSPL_Customer_Invoice_Head ARH on SDH.Document_Code=ARH.Against_Sale_No " & Environment.NewLine +
                  " LEFT JOIN TSPL_ITEM_MASTER Item on SDD.Item_Code=Item.Item_Code " & Environment.NewLine +
                  " LEFT JOIN TSPL_SALES_ACCOUNTS SAC ON Item.Sale_Class_Code=SAC.Sales_Class_Code " & Environment.NewLine +
                  " Where SDH.Trans_Type='ALL'  AND SDH.STATUS=1 " & Environment.NewLine +
                  " UNION ALL " & Environment.NewLine +
                  " SELECT DISTINCT SDH.Trans_Type+ISNULL(SDH.Document_Type,'')  As Code ,CASE  WHEN SDH.Trans_Type ='CSA' THEN 'CSA Sale'  " & Environment.NewLine +
                  " WHEN SDH.Trans_Type ='EXP' AND SDH.Document_Type ='EX' THEN 'Export Sale'  " & Environment.NewLine +
                  " WHEN SDH.Trans_Type ='FS' THEN 'Fresh Sale'   WHEN SDH.Trans_Type ='MCC' THEN 'MCC Sale'  WHEN SDH.Trans_Type ='PS' THEN 'Product Sale'  " & Environment.NewLine +
                  " WHEN SDH.Trans_Type ='EXP' " & Environment.NewLine +
                  " AND ARH.Document_Type ='MT' THEN 'Merchant Trade'  End  As Name,SDH.Document_Code,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Account " & Environment.NewLine +
                  " FROM TSPL_SD_SALE_INVOICE_DETAIL SDD " & Environment.NewLine +
                  " LEFT join  TSPL_SD_SALE_INVOICE_HEAD SDH on SDD.DOCUMENT_CODE=SDH.Document_Code " & Environment.NewLine +
                  " left join TSPL_Customer_Invoice_Head ARH on SDH.Document_Code=ARH.Against_Sale_No " & Environment.NewLine +
                  " LEFT JOIN TSPL_ITEM_MASTER Item on SDD.Item_Code=Item.Item_Code " & Environment.NewLine +
                  " LEFT JOIN TSPL_SALES_ACCOUNTS SAC ON Item.Sale_Class_Code=SAC.Sales_Class_Code " & Environment.NewLine +
                  " Where SDH.Trans_Type <>'ALL'  AND SDH.Status=1 " & Environment.NewLine +
                  " union all " & Environment.NewLine +
                  " select distinct 'CSA' as Code,'CSA Sale' as Name,SDH.DOC_CODE,SDH.DOC_CODE AS JE_SOURCE_DOC_NO,SAC.GSOC_Acct  " & Environment.NewLine +
                  " from  tspl_csa_transfer_head  SDH " & Environment.NewLine +
                  " left join tspl_customer_master Cust on SDH.Cust_Code=Cust.Cust_Code " & Environment.NewLine +
                  " LEFT JOIN Tspl_Customer_account_Set SAC ON Cust.Cust_Account=SAC.Cust_Account " & Environment.NewLine +
                  " where SDH.Status=1 " & Environment.NewLine +
                  " UNION ALL " & Environment.NewLine +
                  " SELECT DISTINCT 'BS'  As Code ,'Bulk Sale' As Name ,SDH.Document_No,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Account " & Environment.NewLine +
                  " FROM TSPL_INVOICE_DETAIL_BULKSALE SDD " & Environment.NewLine +
                  " LEFT join   TSPL_INVOICE_MASTER_BULKSALE SDH on SDD.Document_No=SDH.Document_No " & Environment.NewLine +
                  " left join TSPL_Customer_Invoice_Head ARH on SDH.Document_No=ARH.Against_Sale_No " & Environment.NewLine +
                  " LEFT JOIN TSPL_ITEM_MASTER Item on SDD.Item_Code=Item.Item_Code " & Environment.NewLine +
                  " LEFT JOIN TSPL_SALES_ACCOUNTS SAC ON Item.Sale_Class_Code=SAC.Sales_Class_Code WHERE SDH.Posted=1 " & Environment.NewLine +
                  " /*UNION ALL " & Environment.NewLine +
                  " SELECT DISTINCT 'BST'  As Code ,'Bulk Sale Trade' As Name  FROM TSPL_INVOICE_MASTER_BULKSALE  */ " & Environment.NewLine +
                  " UNION ALL " & Environment.NewLine +
                  " Select DISTINCT 'SS'  As Code ,'Misc Sale' As Name ,SDH.invoice_No AS Document_No,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Account " & Environment.NewLine +
                  " FROM TSPL_SCRAPINVOICE_DETAIL SDD " & Environment.NewLine +
                  " LEFT join  TSPL_SCRAPINVOICE_HEAD SDH on SDD.invoice_No=SDH.invoice_No " & Environment.NewLine +
                  " left join TSPL_Customer_Invoice_Head ARH on SDH.invoice_No=ARH.AgainstScrap " & Environment.NewLine +
                  " LEFT JOIN TSPL_ITEM_MASTER Item on SDD.Item_Code=Item.Item_Code " & Environment.NewLine +
                  " LEFT JOIN TSPL_SALES_ACCOUNTS SAC ON Item.Sale_Class_Code=SAC.Sales_Class_Code WHERE SDH.ispost=1 " & Environment.NewLine +
                  " UNION ALL " & Environment.NewLine +
                  " Select DISTINCT 'MS-SR'  As Code ,'Misc Sale Return' As Name ,SDH.Document_No AS Document_No,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Account " & Environment.NewLine +
                  " FROM TSPL_SCRAPSALE_DETAIL_RETURN SDD " & Environment.NewLine +
                  " LEFT join  TSPL_SCRAPSALE_HEAD_RETURN SDH on SDD.Document_No=SDH.Document_No " & Environment.NewLine +
                  " left join TSPL_Customer_Invoice_Head ARH on SDH.Document_No=ARH.AgainstScrapReturn " & Environment.NewLine +
                  " LEFT JOIN TSPL_ITEM_MASTER Item on SDD.Item_Code=Item.Item_Code " & Environment.NewLine +
                  " LEFT JOIN TSPL_SALES_ACCOUNTS SAC ON Item.Sale_Class_Code=SAC.Sales_Class_Code WHERE SDH.ispost=1 " & Environment.NewLine +
                  " UNION ALL " & Environment.NewLine +
                  " SELECT DISTINCT 'BSR'  As Code ,'Bulk Sale Return' As Name,SDH.Document_No,ARH.Document_No AS JE_SOURCE_DOC_NO,SAC.Sales_Return_Account " & Environment.NewLine +
