    Private Sub RadButton5_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles RadButton5.Click
        Dim frm As New FrmPWD(Nothing)
        frm.strCode = clsFixedParameterCode.BlankDatabase
        frm.strType = clsFixedParameterType.BlankDatabase
        frm.ShowDialog()
        If frm.isPasswordCorrect Then
            If clsCommon.MyMessageBoxShow("Do you want to blank Database", Me.Text, MessageBoxButtons.YesNo, RadMessageIcon.Question) = System.Windows.Forms.DialogResult.Yes Then
                Dim qry As String = "EXEC sp_MSforeachtable @command1= "" ALTER TABLE ? NOCHECK CONSTRAINT ALL """
                clsDBFuncationality.ExecuteNonQuery(qry)
                Dim isTaskCompleted As Boolean = False
                Dim dt As DataTable
                clsCommon.ProgressBarPercentShow()
                Try
                    While Not isTaskCompleted
                        qry = GetQryForBlankDatabase(" p.[Rows] >0 ")
                        clsCommon.ProgressBarPercentUpdate(0, "Fatching Tables having records")
                        dt = clsDBFuncationality.GetDataTable(qry)
                        If dt Is Nothing OrElse dt.Rows.Count = 0 Then
                            isTaskCompleted = True
                        Else
                            For ii As Integer = 0 To dt.Rows.Count - 1
                                clsCommon.ProgressBarPercentUpdate((((ii + 1) * 100) / dt.Rows.Count), "Progress-" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count) + " Table-" + clsCommon.myCstr(dt.Rows(ii)("TableName")) + " Rows-" + clsCommon.myCstr(dt.Rows(ii)("NoOfRows")))
                                Try
                                    qry = "truncate table """ + clsCommon.myCstr(dt.Rows(ii)("TableName")) + """"
                                    clsDBFuncationality.ExecuteNonQuery(qry)
                                Catch ex As Exception
                                    Try
                                        qry = "delete TOP (1000) from """ + clsCommon.myCstr(dt.Rows(ii)("TableName")) + """"
                                        clsDBFuncationality.ExecuteNonQuery(qry)
                                    Catch ex1 As Exception
                                        Dim MSG As String = "AAAA"
                                    End Try
                                End Try
                            Next
                        End If
                    End While
                    clsCommon.ProgressBarPercentHide()

                    qry = "EXEC sp_MSforeachtable @command1= "" ALTER TABLE ? CHECK CONSTRAINT ALL"""
                    clsDBFuncationality.ExecuteNonQuery(qry)

                Catch ex As Exception
                    clsCommon.ProgressBarPercentHide()
                    clsCommon.MyMessageBoxShow("Plese try again." + Environment.NewLine + ex.Message, Me.Text)
                    Exit Sub
                End Try

                Try
                    ''for reset identity to 1 of all tables
                    clsCommon.ProgressBarPercentShow()
                    qry = GetQryForBlankDatabase("")
                    dt = clsDBFuncationality.GetDataTable(qry)
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        clsCommon.ProgressBarPercentUpdate((((ii + 1) * 100) / dt.Rows.Count), "Progress-" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count) + " Table-" + clsCommon.myCstr(dt.Rows(ii)("TableName")) + " Rows-" + clsCommon.myCstr(dt.Rows(ii)("NoOfRows")))
                        Try
                            qry = "truncate table """ + clsCommon.myCstr(dt.Rows(ii)("TableName")) + """"
                            clsDBFuncationality.ExecuteNonQuery(qry)
                        Catch ex As Exception
                        End Try
                    Next
                    clsCommon.ProgressBarPercentHide()
                Catch ex As Exception
                    clsCommon.ProgressBarPercentHide()
                    clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
                    Exit Sub
                End Try


                If isTaskCompleted Then
                    clsCommon.MyMessageBoxShow("Database blanked successfully", Me.Text)
                    ' Ticket No : TEC/17/06/19-000538 By Prabhakar
                    InsertStateOfIndia()
                    ' Ticket No : TEC/24/06/19-000565 By Prabhakar
                    InsertWeightUomMaster() ' 
                    clsFixedParameter.UpdateData(clsFixedParameterType.AllowItemCostMandatoryForStockingUnit, clsFixedParameterCode.AllowItemCostMandatoryForStockingUnit, "1", Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.CalculateTaxRatefromItemwsieTaxOnSale, clsFixedParameterCode.CalculateTaxRatefromItemwsieTaxOnSale, "1", Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.PurchaseModulePickFixTaxRate, clsFixedParameterCode.PurchaseModulePickFixTaxRate, "1", Nothing)
                    clsFixedParameter.UpdateData(clsFixedParameterType.AllowItemConversionAutomation, clsFixedParameterCode.AllowItemConversionAutomation, "1", Nothing)
                    ' AllowItemConversionAutomation
                Else
                    clsCommon.MyMessageBoxShow("Plese try again.", Me.Text)
                End If
            End If
        End If
    End Sub

