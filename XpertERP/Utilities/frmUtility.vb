    Private Sub RadButton65_Click(sender As Object, e As EventArgs) Handles RadButton65.Click
        clsCommon.ProgressBarPercentShow()
        Try
            Dim qry As String = "select MCC_Code,MCC_NAME from TSPL_MCC_MASTER "
            Dim arrMCC As ArrayList = clsCommon.ShowMultipleSelectForm("REdds222", qry, "MCC_Code", "MCC_NAME", Nothing, Nothing)
            If arrMCC Is Nothing OrElse arrMCC.Count <= 0 Then
                Exit Sub
            End If

            qry = "select Trans_Id,Source_Doc_No,Qty, UOM,Stock_Qty, Stock_UOM,Fat_Per,Fat_KG,Fat_Rate,Fat_Amt,SNF_Per, SNF_KG,SNF_Rate,SNF_Amt from tspl_inventory_movement_New where Location_Code in (" + clsCommon.GetMulcallString(arrMCC) + ") and Trans_Type='MCC-MSRN'  "
            Dim dtInvenory As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dtInvenory IsNot Nothing AndAlso dtInvenory.Rows.Count > 0 Then
                Dim i As Integer = 0
                For Each drInvenotry As DataRow In dtInvenory.Rows
                    Try
                        i += 1
                        qry = "select * from TSPL_MILK_SRN_DETAIL where doc_code='" + clsCommon.myCstr(drInvenotry("Source_Doc_No")) + "'"
                        Dim dtSRN As DataTable = clsDBFuncationality.GetDataTable(qry)
                        If dtSRN IsNot Nothing AndAlso dtSRN.Rows.Count > 0 Then
                            Dim arr As New clsFatSnfRateCalculator
                            Dim dtMilkPrice As DataTable = clsDBFuncationality.GetDataTable("select * from TSPL_MILK_PRICE_MASTER where Price_Code= (select Distinct Price_Code from tspl_Fat_SNf_Uploader_Master where code='" + clsCommon.myCstr(dtSRN.Rows(0)("Price_Code")) + "')")
                            If dtMilkPrice IsNot Nothing AndAlso dtMilkPrice.Rows.Count > 0 Then
                                If objCommonVar.ApplyStdFATSNFRate Then
                                    arr = clsFatSnfRateCalculator.CalculateStdFATSNFRate(clsCommon.myCdbl(dtSRN.Rows(0)("QTY")), clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Fat_Pers")), clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("SNF_Pers")), clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Ratio")), clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Snf_Ratio")), clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Milk_Rate")), clsCommon.myCdbl(drInvenotry("Fat_Per")), clsCommon.myCdbl(drInvenotry("SNF_Per")))
                                Else
                                    If clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Fat_Pers")) = clsCommon.myCdbl(dtSRN.Rows(0)("FAT_PER")) And clsCommon.myCdbl(dtMilkPrice.Rows(0).Item("Snf_Pers")) = clsCommon.myCdbl(dtSRN.Rows(0)("SNF_PER")) Then
                                        arr = clsFatSnfRateCalculator.CalculateInonSamePercentage(clsCommon.myCdbl(dtSRN.Rows(0)("QTY")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Fat_Pers")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("SNF_Pers")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Ratio")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Snf_Ratio")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Milk_Rate")))
                                    Else
                                        Try
                                            arr = clsFatSnfRateCalculator.CalculateIn(clsCommon.myCdbl(dtSRN.Rows(0)("QTY")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Fat_Pers")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("SNF_Pers")), clsCommon.myCdbl(dtSRN.Rows(0)("FAT_PER")), clsCommon.myCdbl(dtSRN.Rows(0)("SNF_PER")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Milk_Rate")), clsCommon.myCdbl(dtSRN.Rows(0)("RATE")))
                                        Catch ex As Exception
                                            If ex.Message.Contains("Same equation repeated") Then
                                                arr = clsFatSnfRateCalculator.CalculateInonSamePercentage(clsCommon.myCdbl(dtSRN.Rows(0)("QTY")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Fat_Pers")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("SNF_Pers")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Ratio")), clsCommon.myCstr(dtMilkPrice.Rows(0).Item("Snf_Ratio")), clsCommon.myCdbl(dtSRN.Rows(0)("RATE")))
                                                If clsCommon.myCdbl(drInvenotry("FAT_KG")) <> 0 Then
                                                    arr.fatR = arr.FatAmt / clsCommon.myCdbl(drInvenotry("FAT_KG"))
                                                End If
                                                If clsCommon.myCdbl(drInvenotry("SNF_KG")) <> 0 Then
                                                    arr.snfR = arr.snfAmt / clsCommon.myCdbl(drInvenotry("SNF_KG"))
                                                End If
                                            Else
                                                Throw New Exception(ex.Message)
                                            End If
                                        End Try
                                    End If
                                End If

                                Dim coll As New Hashtable()
                                clsCommon.AddColumnsForChange(coll, "Fat_Rate", arr.fatR)
                                clsCommon.AddColumnsForChange(coll, "SNF_Rate", arr.snfR)
                                clsCommon.AddColumnsForChange(coll, "Fat_Amt", arr.FatAmt)
                                clsCommon.AddColumnsForChange(coll, "SNF_Amt", arr.snfAmt)
                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_INVENTORY_MOVEMENT_new", OMInsertOrUpdate.Update, "Trans_Id='" + clsCommon.myCstr(drInvenotry("Trans_Id")) + "' and Source_Doc_No='" + clsCommon.myCstr(drInvenotry("Source_Doc_No")) + "'", Nothing)
                            End If
                            dtMilkPrice = Nothing
                            arr = Nothing
                            dtSRN = Nothing
                        End If
                    Catch ex As Exception
                        clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
                    End Try
                    clsCommon.ProgressBarPercentUpdate(((i + 1) * 100) / dtInvenory.Rows.Count, " " + clsCommon.myCstr(i + 1) + "/" + clsCommon.myCstr(dtInvenory.Rows.Count))
                Next
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow("Updated Successfully.")
            End If
        Catch ex As Exception
            clsCommon.ProgressBarPercentHide()
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try
    End Sub

