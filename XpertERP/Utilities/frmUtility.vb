                'Dim SNF_Per As Decimal = clsCommon.myCdbl(drInv.Item("SNF_Per"))
                Dim Fat_KG As Decimal = clsCommon.myCdbl(drInv.Item("Fat_KG"))
                Dim SNF_KG As Decimal = clsCommon.myCdbl(drInv.Item("SNF_KG"))
                Dim Source_Doc_No As String = clsCommon.myCstr(drInv.Item("Source_Doc_No"))
                Dim Source_Doc_Date As Date = clsCommon.myCDate(drInv.Item("Source_Doc_Date"))
                Dim Posting_Date As Date = clsCommon.myCDate(drInv.Item("Posting_Date"))


                clsCommon.ProgressBarPercentUpdate((dt.Rows.IndexOf(drInv) + 1) * 100 / dt.Rows.Count, "Update Inventory Out Cost " + clsCommon.myCstr(dt.Rows.IndexOf(drInv) + 1) + ": TransId/Source Doc No: " & Trans_Id & " /" & Source_Doc_No & "Out of " + clsCommon.myCstr(dt.Rows.Count))
                Dim coll As New Hashtable()
                If Trans_Id = 31579 Then
                    clsCommon.MyMessageBoxShow(Trans_Id)
                End If
                Dim objCost As New MIlkComponentType
                objCost = clsInventoryMovementNew.GetAvgCost("MI", Item_Code, Location_Code, Qty, UOM, Fat_KG, SNF_KG, Source_Doc_Date, Posting_Date, False, Nothing, Source_Doc_No, Trans_Id)
                obj.Fat_Rate = Math.Round(objCost.FAT_Cost / IIf(Fat_KG <= 0, 1, Fat_KG), 2)
                obj.SNF_Rate = Math.Round(objCost.SNF_Cost / IIf(SNF_KG <= 0, 1, SNF_KG), 2)
                obj.Fat_Amt = Math.Round(objCost.FAT_Cost, 2)
                obj.SNF_Amt = Math.Round(objCost.SNF_Cost, 2)
                coll = New Hashtable()
                clsCommon.AddColumnsForChange(coll, "Fat_Rate", obj.Fat_Rate)
                clsCommon.AddColumnsForChange(coll, "SNF_Rate", obj.SNF_Rate)
                clsCommon.AddColumnsForChange(coll, "Fat_Amt", obj.Fat_Amt)
                clsCommon.AddColumnsForChange(coll, "SNF_Amt", obj.SNF_Amt)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_INVENTORY_MOVEMENT_NEW", OMInsertOrUpdate.Update, "TSPL_INVENTORY_MOVEMENT_NEW.Trans_Id='" & Trans_Id & "' and TSPL_INVENTORY_MOVEMENT_NEW.Item_Code='" & Item_Code & "' and Source_Doc_No='" & Source_Doc_No & "'", Nothing)
                '' update in doc
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_INVENTORY_MOVEMENT_NEW", OMInsertOrUpdate.Update, "TSPL_INVENTORY_MOVEMENT_NEW.InOut='I' and TSPL_INVENTORY_MOVEMENT_NEW.Item_Code='" & Item_Code & "' and Source_Doc_No='" & Source_Doc_No & "'", Nothing)
            Next

        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        Finally
            clsCommon.ProgressBarPercentHide()
        End Try

