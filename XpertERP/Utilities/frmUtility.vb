    Private Sub btnUpdateAvgCost_Click(sender As Object, e As EventArgs) Handles btnUpdateAvgCost.Click
        Dim Avg_cost As Double = 0
        Try
            Dim isApplyCostOnPostDate As Boolean = IIf(clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.ApplyCostingOnPostedDate, clsFixedParameterCode.ApplyCostingOnPostedDate, Nothing)) = 1, True, False)
            Dim dtItem As DataTable = clsDBFuncationality.GetDataTable("select TEMP_DELETE_ITEM_COST.Item_Code,TSPL_ITEM_MASTER.Product_Type from TEMP_DELETE_ITEM_COST left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TEMP_DELETE_ITEM_COST.Item_Code where TEMP_DELETE_ITEM_COST.Item_Code not in (select Item_Code from TEMP_CREATE_ITEM_COST )")
            If dtItem IsNot Nothing AndAlso dtItem.Rows.Count > 0 Then
                clsCommon.ProgressBarPercentShow()
                For kk As Integer = 0 To dtItem.Rows.Count - 1
                    clsCommon.ProgressBarPercentUpdate(0, " Processing " & (kk + 1) & "  / " & clsCommon.myCstr(dtItem.Rows.Count) & "Item(s).Current Item " + clsCommon.myCstr(dtItem.Rows(kk)("Item_Code")))
                    Dim strTABLENAME As String = "TSPL_INVENTORY_MOVEMENT"
                    If clsCommon.CompairString(clsCommon.myCstr(dtItem.Rows(kk)("Product_Type")), "MI") = CompairStringResult.Equal Then
                        strTABLENAME = "TSPL_INVENTORY_MOVEMENT_NEW"
                    End If
                    Dim arrLocation As New List(Of String)
                    Dim dt As DataTable = clsDBFuncationality.GetDataTable("select * from " + strTABLENAME + " where  InOut='O' and stock_qty>0  and item_code ='" + clsCommon.myCstr(dtItem.Rows(kk)("Item_Code")) + "' and Trans_Type not in ('Sale Return','Prod-Issue','Production','IC-AD','SRN-RET','StockConversion','PP_ISSUE','PP_STDN','PP_STD-FQC','PROD_ENTRY','PRD_STG_PROC') and cast(Punching_Date as Date)>='" & clsCommon.GetPrintDate(dtpAvgCostDate.Value, "dd-MMM-yyyy") & "' order by Punching_Date")
                    Dim whrExta As String = " and Trans_Type not in ('Sale Return','Prod-Issue','Production', 'SRN-RET','StockConversion','PP_ISSUE','PP_STDN','PP_STD-FQC','PROD_ENTRY','PRD_STG_PROC') "
                    If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                        For i As Integer = 0 To dt.Rows.Count - 1
                            Try
                                If dt.Rows(i).Item("Source_Doc_No") = "BD/402/16-17/000010" Then
                                    MsgBox("30744")
                                End If

                                If Not arrLocation.Contains(clsCommon.myCstr(dt.Rows(i)("Location_Code"))) Then
                                    arrLocation.Add(clsCommon.myCstr(dt.Rows(i)("Location_Code")))
                                    clsInventoryMovement.UpdateSeconds("Punching_Date", strTABLENAME, clsCommon.myCstr(dt.Rows(i)("Item_Code")), clsCommon.myCstr(dt.Rows(i)("Location_Code")), clsCommon.GetPrintDate(dtpAvgCostDate.Value, "dd-MMM-yyyy"), Nothing)
                                End If
                                If clsCommon.CompairString(clsCommon.myCstr(dtItem.Rows(kk)("Product_Type")), "MI") = CompairStringResult.Equal Then
                                    Dim objCost As MIlkComponentType = clsInventoryMovementNew.GetAvgCost(whrExta, clsCommon.myCstr(dtItem.Rows(kk)("Product_Type")), clsCommon.myCstr(dt.Rows(i)("Item_Code")), clsCommon.myCstr(dt.Rows(i)("Location_Code")), clsCommon.myCdbl(dt.Rows(i)("Stock_Qty")), clsCommon.myCstr(dt.Rows(i)("Stock_UOM")), 1, 1, clsCommon.myCDate(dt.Rows(i)("Punching_Date")), clsCommon.myCDate(dt.Rows(i)("Posting_Date")), False, Nothing, clsCommon.myCstr(dt.Rows(i)("Source_Doc_No")), clsCommon.myCdbl(dt.Rows(i)("Trans_Id")))
                                    If objCost IsNot Nothing Then
                                        Dim coll As New Hashtable()
                                        clsCommon.AddColumnsForChange(coll, "FAT_Rate", objCost.FAT_Cost)
                                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", objCost.SNF_Cost)
                                        Dim FATAmt As Decimal = objCost.FAT_Cost * clsCommon.myCdbl(dt.Rows(i)("Fat_KG"))
                                        Dim SNFAmt As Decimal = objCost.SNF_Cost * clsCommon.myCdbl(dt.Rows(i)("SNF_KG"))
                                        clsCommon.AddColumnsForChange(coll, "FAT_Amt", FATAmt)
                                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", SNFAmt)
                                        clsCommon.AddColumnsForChange(coll, "AVG_cost", FATAmt + SNFAmt)
                                        clsCommonFunctionality.UpdateDataTable(coll, strTABLENAME, OMInsertOrUpdate.Update, "trans_id='" & clsCommon.myCstr(dt.Rows(i)("Trans_Id")) & "' and Trans_Type='" & dt.Rows(i)("Trans_Type") & "' and InOut='" & dt.Rows(i)("InOut") & "' and Source_Doc_No='" & dt.Rows(i)("Source_Doc_No") & "' and Location_Code = '" & dt.Rows(i)("Location_Code") & "'")
                                    End If
                                Else
                                    Avg_cost = GetCost(EnumCostingMethod.Averege, clsCommon.myCstr(dt.Rows(i)("Item_Code")), clsCommon.myCstr(dt.Rows(i)("Location_Code")), clsCommon.myCdbl(dt.Rows(i)("Stock_Qty")), clsCommon.myCDate(dt.Rows(i)("Punching_Date")), clsCommon.myCDate(dt.Rows(i)("Posting_Date")), False, Nothing, strTABLENAME, clsCommon.myCstr(dt.Rows(i)("Trans_Id")), clsCommon.myCstr(dt.Rows(i)("Source_Doc_No")), whrExta)
                                    clsDBFuncationality.ExecuteNonQuery("Update " + strTABLENAME + " set AVG_cost=" & clsCommon.myCstr(Avg_cost) & " where trans_id='" & clsCommon.myCstr(dt.Rows(i)("Trans_Id")) & "' and Trans_Type='" & dt.Rows(i)("Trans_Type") & "' and InOut='" & dt.Rows(i)("InOut") & "' and Source_Doc_No='" & dt.Rows(i)("Source_Doc_No") & "' and Location_Code = '" & dt.Rows(i)("Location_Code") & "'")
                                End If




                                If clsCommon.CompairString(clsCommon.myCstr(dt.Rows(i)("Trans_Type")), "FS-SH") = CompairStringResult.Equal Then
                                    '' UPDATE RETURN DOCS AVG AGAINST this DISPATCH
                                    Dim qry1 As String = "UPDATE TSPL_INVENTORY_MOVEMENT SET Avg_Cost=" & Avg_cost & ",Basic_Cost=case when qty<=0 then 0 else " & Avg_cost & "/qty end, Net_Cost=" & Avg_cost & " FROM (" &
                                    " select RETD.DOCUMENT_CODE,RETD.Item_Code,RETD.Unit_code,RETD.Invoice_Code,INV.Against_Shipment_No,INV.Document_Date AS INV_DATE,SHIP.Document_Date AS SHIP_DATE from TSPL_SD_SALE_RETURN_DETAIL RETD " &
                                    " inner join TSPL_SD_SALE_RETURN_HEAD RET on RETD.DOCUMENT_CODE=RET.Document_Code " &
                                    " LEFT JOIN TSPL_SD_SALE_INVOICE_DETAIL INVD ON INVD.DOCUMENT_CODE=RETD.Invoice_Code AND INVD.Item_Code=RETD.Item_Code AND INVD.Unit_code=RETD.Unit_code AND INVD.Line_No=RETD.Line_No " &
                                    " LEFT JOIN TSPL_SD_SALE_INVOICE_HEAD INV ON RETD.Invoice_Code=INV.Document_Code " &
                                    " LEFT JOIN TSPL_SD_SHIPMENT_HEAD SHIP ON INV.Against_Shipment_No=SHIP.Document_Code " &
                                    " WHERE SHIP.Document_Code='" & clsCommon.myCstr(dt.Rows(i)("Source_Doc_No")) & "' AND RETD.Item_Code='" & clsCommon.myCstr(dt.Rows(i)("Item_Code")) & "' AND RETD.Unit_code='" & clsCommon.myCstr(dt.Rows(i)("Uom")) & "') AS RET " &
                                    " WHERE TSPL_INVENTORY_MOVEMENT.Source_Doc_No=RET.DOCUMENT_CODE AND TSPL_INVENTORY_MOVEMENT.Item_Code=RET.Item_Code AND TSPL_INVENTORY_MOVEMENT.UOM=RET.Unit_code"
                                    clsDBFuncationality.ExecuteNonQuery(qry1)
                                End If

                                If clsCommon.CompairString(clsCommon.myCstr(dt.Rows(i)("Trans_Type")), "DispatchBS") = CompairStringResult.Equal Then
                                    '' UPDATE RETURN DOCS AVG AGAINST this DISPATCH
                                    Dim qry1 As String = " update TSPL_INVENTORY_MOVEMENT_NEW set Avg_Cost=Final.Disp_AvgCost,Fat_Rate=Final.Fat_Rate,Fat_Amt=Final.Fat_Amt," &
                                    " SNF_Rate = Final.SNF_Rate, SNF_Amt = Final.SNF_Amt, Fat_Per = Final.Fat_Per, SNF_Per = Final.SNF_Per, " &
                                    " Fat_KG = Final.Fat_KG, SNF_KG = Final.SNF_KG, Net_Cost = Final.Disp_AvgCost, Basic_Cost = Final.Disp_AvgCost / Qty " &
                                    " from ( " &
                                    " select InV.Source_Doc_No,InV.Item_Code,InV.Avg_Cost,InV2.Source_Doc_No as DispatchNo,InV2.Item_Code as Disp_Item_Code,InV2.Avg_Cost as Disp_AvgCost, " &
                                    " InV2.Fat_Rate,InV2.Fat_Amt,InV2.SNF_Rate,InV2.SNF_Amt,InV2.Fat_Per,InV2.SNF_Per,InV2.Fat_KG,InV2.SNF_KG from TSPL_SALE_RETURN_DETAIL_BULKSALE BSR " &
                                    " left join( SELECT * FROM TSPL_INVENTORY_MOVEMENT_NEW WHERE Trans_Type= 'SaleReturnBS')  as InV on BSR.Document_No=InV.Source_Doc_No " &
                                    " left join( SELECT * FROM TSPL_INVENTORY_MOVEMENT_NEW WHERE Trans_Type= 'DispatchBS')  as InV2 on BSR.Dispatch_Code=InV2.Source_Doc_No " &
                                    " )  as Final where TSPL_INVENTORY_MOVEMENT_NEW.Trans_Type='SaleReturnBS' and Final.Source_Doc_No='" & clsCommon.myCstr(dt.Rows(i)("Source_Doc_No")) & "' " &
                                    " and TSPL_INVENTORY_MOVEMENT_NEW.Source_Doc_No=Final.Source_Doc_No and TSPL_INVENTORY_MOVEMENT_NEW.Item_Code=Final.Item_Code"
                                    clsDBFuncationality.ExecuteNonQuery(qry1)
                                End If

                                If clsCommon.CompairString(clsCommon.myCstr(dt.Rows(i)("Trans_Type")), "Transfer") = CompairStringResult.Equal Then
                                    ''Because Transfer in should be same and transfer out movement cost.
                                    Dim dtTranIn As DataTable = clsDBFuncationality.GetDataTable("select * from TSPL_INVENTORY_MOVEMENT where Source_Doc_No='" + clsCommon.myCstr(dt.Rows(i)("Source_Doc_No")) + "' and item_code='" + clsCommon.myCstr(dt.Rows(i)("Item_Code")) + "' and InOut='I' and Trans_Type='Transfer'")
                                    If dtTranIn IsNot Nothing AndAlso dtTranIn.Rows.Count > 0 Then
                                        For Each dr As DataRow In dtTranIn.Rows
                                            clsDBFuncationality.ExecuteNonQuery(" Update " + strTABLENAME + " set AVG_cost=" & clsCommon.myCstr(Avg_cost) & " where trans_id='" & clsCommon.myCstr(dr("Trans_Id")) & "' and Trans_Type='" & clsCommon.myCstr(dr("Trans_Type")) & "' and InOut='" & clsCommon.myCstr(dr("InOut")) & "' and Source_Doc_No='" & clsCommon.myCstr(dr("Source_Doc_No")) & "' and Location_Code = '" & clsCommon.myCstr(dr("Location_Code")) & "'")
                                        Next
                                    End If
                                End If
                                clsCommon.ProgressBarPercentUpdate(((i + 1) * 100) / dt.Rows.Count, " Processing " & (kk + 1) & "  / " & clsCommon.myCstr(dtItem.Rows.Count) & "Item(s).Current Item " + clsCommon.myCstr(dt.Rows(i)("item_code")) + " Transaction " + clsCommon.myCstr(i + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                            Catch ex As Exception
                            End Try
                        Next
                    End If
                    Dim qry As String = "insert into TEMP_CREATE_ITEM_COST values ('" + clsCommon.myCstr(dtItem.Rows(kk)("Item_Code")) + "')"
                    clsDBFuncationality.ExecuteNonQuery(qry)
                Next
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow(Me, "Updated Successfully.", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.ProgressBarPercentHide()
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub


    Public Shared Function GetCost(ByVal CostMethod As EnumCostingMethod, ByVal strICode As String, ByVal strLocation As String, ByVal dblqty As Double, ByVal dtDocumentDate As DateTime, ByVal dtPostingDate As DateTime, ByVal isApplyCostOnPostDate As Boolean, ByVal trans As SqlTransaction, ByVal tableName As String, ByVal CurrTransID As String, ByVal strSource_Doc_No As String, ByVal whrExta As String) As Double
        Dim dblRetCost As Double = 0
        If Not CostMethod = EnumCostingMethod.NA AndAlso dblqty > 0 Then
            Dim strSymbolCost As String = " >= "
            If CostMethod = EnumCostingMethod.LIFO Then
                strSymbolCost = " <= "
            End If
            If clsCommon.CompairString(CurrTransID, "1588727") = CompairStringResult.Equal Then
                Dim x As Integer = 1
            End If

            Dim strDateColumn As String = " Punching_Date "
            Dim strDateForCheck As String = clsCommon.GetPrintDate(dtDocumentDate, "dd/MMM/yyyy hh:mm:ss tt")
            If isApplyCostOnPostDate Then
                strDateColumn = " Posting_Date "
                strDateForCheck = clsCommon.GetPrintDate(dtPostingDate, "dd/MMM/yyyy hh:mm:ss tt")
            End If
            Dim qry As String
            qry = " select  case when Amt>0 and Qty>0  then abs((Amt/Qty)*" + clsCommon.myCstr(dblqty) + ") else Last_Rate*" & clsCommon.myCstr(dblqty) & " end as AvgCost from( "
            qry += " select  sum(Amt * RI) as Amt,sum(Qty * RI) as Qty,max(Last_Rate) as Last_Rate from(" + Environment.NewLine
            qry += " select Stock_Qty as Qty,(Avg_Cost) as Amt,case when InOut='O' then -1 else 1 end as RI,(select top 1 Basic_Cost as Last_Rate from " & tableName & " where Item_Code='" + strICode + "' and Location_Code='" + strLocation + "' and  " + strDateColumn + " < '" + strDateForCheck + "' and Trans_Id <>'" + CurrTransID + "' and Source_Doc_No<>'" + strSource_Doc_No + "' and InOut='I' and Basic_Cost>0 order by Trans_Id) as Last_Rate from " & tableName & " where Item_Code='" + strICode + "' and Location_Code='" + strLocation + "' and  " + strDateColumn + " < '" + strDateForCheck + "' and Trans_Id <>'" + CurrTransID + "' and Source_Doc_No<>'" + strSource_Doc_No + "' " + whrExta + Environment.NewLine
            qry += " )xxx )xxxx" + Environment.NewLine
            dblRetCost = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qry, trans))
        End If
        Dim rate As Decimal = 0
        rate = dblRetCost / dblqty
        If rate > 50 Then
            'clsCommon.MyMessageBoxShow(rate)
        End If
        Return dblRetCost
    End Function

