    Sub AssemblyDeassemblyCreateDocs(ByVal isJVOnly As Boolean)
        Try
            Dim settPickCostFromItemMaster As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.PickCostFromItemMaster, clsFixedParameterCode.PickCostFromItemMaster, Nothing)) = 1)
            Dim qry As String = "select TEMP_Assembly_Deassambly.*,TSPL_PROD_ASSEMBLIES.TRANSACTION_TYPE,TSPL_PROD_ASSEMBLIES.Main_Item_Code,TSPL_PROD_ASSEMBLIES.QUANTITY,TSPL_PROD_ASSEMBLIES.BUILD_ITEM_UNIT_CODE,TSPL_PROD_ASSEMBLIES.ASSEMBLY_DATE from TEMP_Assembly_Deassambly left outer join TSPL_PROD_ASSEMBLIES on TSPL_PROD_ASSEMBLIES.CODE=TEMP_Assembly_Deassambly.DocumentNo where TEMP_Assembly_Deassambly.Status is null order by TSPL_PROD_ASSEMBLIES.ASSEMBLY_DATE"
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If clsCommon.MyMessageBoxShow("Pending Document [" + clsCommon.myCstr(dt.Rows.Count) + "] Found" + Environment.NewLine + "Continue...", Me.Text, MessageBoxButtons.YesNo, WinControls.RadMessageIcon.Question) = System.Windows.Forms.DialogResult.Yes Then
                    Try
                        clsCommon.ProgressBarPercentShow()
                        For ii As Integer = 0 To dt.Rows.Count - 1
                            Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("DocumentNo"))
                            Dim dtDocDate As DateTime = clsCommon.myCDate(dt.Rows(ii)("ASSEMBLY_DATE"))
                            Dim strTransType As String = clsCommon.myCstr(dt.Rows(ii)("TRANSACTION_TYPE"))
                            Dim strVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("VoucherNo"))
                            Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                            Dim collStatus As New Hashtable()
                            Try
                                If isJVOnly Then
                                    If clsCommon.myLen(strVoucherNo) > 0 Then
                                        qry = "delete from TSPL_JOURNAL_DETAILS where Voucher_No ='" + strVoucherNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)
                                        qry = "delete from TSPL_JOURNAL_MASTER where Voucher_No ='" + strVoucherNo + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, trans)
                                    End If
                                    clsAssembliesDis.JournalEntryWIP(trans, strDocNo, strVoucherNo)
                                Else
                                    clsAssembliesDis.UnpostData(strDocNo, strTransType, trans)
                                    If settPickCostFromItemMaster Then
                                        Dim coll As Hashtable
                                        Dim dblAmt As Decimal
                                        qry = "select TSPL_ITEM_MASTER.Product_Type,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.LINE_NO,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.CONSM_ITEM_CODE,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.FAT_KG,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.SNF_KG,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.CONSM_ITEM_UNIT_CODE,TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.CONSM_QUANTITY " + Environment.NewLine +
                                    "from TSPL_PROD_ASSEMBLIES_ITEM_DETAIL" + Environment.NewLine +
                                    "left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.CONSM_ITEM_CODE" + Environment.NewLine +
                                    "where ASSEMBLY_CODE='" + strDocNo + "'"
                                        Dim dtI As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
                                        If dtI IsNot Nothing AndAlso dtI.Rows.Count > 0 Then
                                            For Each drI As DataRow In dtI.Rows
                                                coll = New Hashtable()
                                                If clsCommon.CompairString(clsCommon.myCstr(drI("Product_Type")), "MI") = CompairStringResult.Equal Then
                                                    Dim objQCPAR As clsItemMasterQCParameter = clsItemMasterQCParameter.GetStandardFATSNFRate(clsCommon.myCstr(drI("CONSM_ITEM_CODE")), trans)
                                                    If objQCPAR.FATRate <= 0 Then
                                                        Throw New Exception("Define FAT Rate Of Item " + clsCommon.myCstr(drI("CONSM_ITEM_CODE")))
                                                    End If
                                                    If objQCPAR.SNFRate <= 0 Then
                                                        Throw New Exception("Define SNF Rate Of Item " + clsCommon.myCstr(drI("CONSM_ITEM_CODE")))
                                                    End If
                                                    clsCommon.AddColumnsForChange(coll, "FAT_Rate", objQCPAR.FATRate)
                                                    clsCommon.AddColumnsForChange(coll, "SNF_Rate", objQCPAR.SNFRate)
                                                    clsCommon.AddColumnsForChange(coll, "Item_Amount", ((objQCPAR.FATRate * clsCommon.myCdbl(drI("FAT_KG"))) + (objQCPAR.SNFRate * clsCommon.myCdbl(drI("SNF_KG")))))
                                                Else
                                                    dblAmt = clsItemUOMDetails.GetItemUOMCost(dtDocDate, clsCommon.myCstr(drI("CONSM_ITEM_CODE")), clsCommon.myCstr(drI("CONSM_ITEM_UNIT_CODE")), trans) * clsCommon.myCdbl(drI("CONSM_QUANTITY"))
                                                    clsCommon.AddColumnsForChange(coll, "Item_Amount", dblAmt)
                                                End If
                                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PROD_ASSEMBLIES_ITEM_DETAIL", OMInsertOrUpdate.Update, "TSPL_PROD_ASSEMBLIES_ITEM_DETAIL.ASSEMBLY_CODE='" + strDocNo + "' and LINE_NO='" + clsCommon.myCstr(drI("LINE_NO")) + "' and CONSM_ITEM_CODE='" + clsCommon.myCstr(drI("CONSM_ITEM_CODE")) + "'", trans)
                                            Next
                                        End If
                                        coll = New Hashtable()
                                        dblAmt = clsItemUOMDetails.GetItemUOMCost(dtDocDate, clsCommon.myCstr(dt.Rows(ii)("Main_Item_Code")), clsCommon.myCstr(dt.Rows(ii)("BUILD_ITEM_UNIT_CODE")), trans) * clsCommon.myCdbl(dt.Rows(ii)("QUANTITY"))
                                        clsCommon.AddColumnsForChange(coll, "DISASSEMBLY_COST", dblAmt)
                                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PROD_ASSEMBLIES", OMInsertOrUpdate.Update, "CODE='" + strDocNo + "'", trans)
                                    End If
                                    clsAssembliesDis.PostData(strDocNo, True, trans, strVoucherNo)
                                End If
                                clsCommon.AddColumnsForChange(collStatus, "Status", 1)
                                clsCommon.AddColumnsForChange(collStatus, "ERROR", Nothing, True)
                                clsCommonFunctionality.UpdateDataTable(collStatus, "TEMP_Assembly_Deassambly", OMInsertOrUpdate.Update, "DocumentNo='" + strDocNo + "'", trans)
                                trans.Commit()
                            Catch ex As Exception
                                trans.Rollback()
                                collStatus = New Hashtable()
                                If clsCommon.myLen(ex.Message) > 5000 Then
                                    clsCommon.AddColumnsForChange(collStatus, "ERROR", ex.Message.Substring(0, 4999))
                                Else
                                    clsCommon.AddColumnsForChange(collStatus, "ERROR", ex.Message)
                                End If
                                clsCommonFunctionality.UpdateDataTable(collStatus, "TEMP_Assembly_Deassambly", OMInsertOrUpdate.Update, "DocumentNo='" + strDocNo + "'")
