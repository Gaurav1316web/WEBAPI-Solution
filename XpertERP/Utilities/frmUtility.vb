    Private Sub RadButton203_Click(sender As Object, e As EventArgs) Handles RadButton203.Click
        Dim qry As String = ""
        Dim dt As New DataTable()
        Try
            qry = "select * from TEMP_Delete_MCCMateialSaleReturn where Doc_No not in (select Doc_No from TEMP_Created_MCCMateialSaleReturn)"
            dt = New DataTable()
            dt = clsDBFuncationality.GetDataTable(qry)
            Dim strErro As String = ""
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If common.clsCommon.MyMessageBoxShow("Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " TR", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    clsCommon.ProgressBarPercentShow()
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("Doc_No"))
                        Dim strARNo As String = clsCommon.myCstr(dt.Rows(ii)("AR_No"))
                        Dim strVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("Voucher_No"))
                        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                        Try

                            ' Invoice
                            qry = "delete from TSPL_JOURNAL_DETAILS where TSPL_JOURNAL_DETAILS.Voucher_No in ('" + strVoucherNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_JOURNAL_MASTER where TSPL_JOURNAL_MASTER.Source_Code='AR-IN' and TSPL_JOURNAL_MASTER.Voucher_No='" + strVoucherNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Customer_Invoice_Detail where Document_No in ('" + strARNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Customer_Invoice_Head where Document_No = '" + strARNo + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            Dim obj As clsMccMaterialSaleReturn = clsMccMaterialSaleReturn.GetData(strDocNo, NavigatorType.Current, trans)
                            clsMccMaterialSaleReturn.UpdateInventoryMovement(obj, trans, True)
                            clsMccMaterialSaleReturn.createARInvoice(obj, trans, strARNo, strVoucherNo, "")

                            clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_Created_MCCMateialSaleReturn values('" + strDocNo + "')", trans)
                            trans.Commit()
                        Catch ex As Exception
                            trans.Rollback()
                            strErro += "TR No - " + strDocNo + " Voucher No - " + strVoucherNo + "  Exception -" + ex.Message + Environment.NewLine
                        End Try
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate journal entry " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                    Next
                    clsCommon.ProgressBarPercentHide()
                    common.clsCommon.MyMessageBoxShow("Successfully Updated", Me.Text)
                End If
                If clsCommon.myLen(strErro) > 0 Then
                    common.clsCommon.MyMessageBoxShow(strErro, Me.Text)
                Else
                    common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub

    Sub PEStageProcess(ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean, ByVal BatchCodeToProcess As String)
        Dim qry As String
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEStageProcess", tran)
            qry = "select TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_CODE,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_PP_STAGE_PROCESS_HEAD" + Environment.NewLine +
      "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_CODE  and TSPL_JOURNAL_MASTER.Source_Code='PR-SP'" + Environment.NewLine +
      " left outer join TSPL_PP_BATCH_ORDER_HEAD on TSPL_PP_BATCH_ORDER_HEAD.Batch_Code =TSPL_PP_STAGE_PROCESS_HEAD.Main_Batch_Code " & Environment.NewLine &
      "where TSPL_PP_STAGE_PROCESS_HEAD.Posted=1 and TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_DATE>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_DATE<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' "
            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PP_BATCH_ORDER_HEAD.Location_Code in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            If TxtMultiSelectFinder12.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder12.arrValueMember.Count > 0 Then
                qry += " and exists (select 1 from TSPL_PP_SP_ISSUE_ITEM_DETAIL where TSPL_PP_SP_ISSUE_ITEM_DETAIL.STAGE_PROCESS_CODE=TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_CODE and TSPL_PP_SP_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))"
            End If
            qry = "select * into Temp_PEStageProcess from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEStageProcess where 2=2 "
        If clsCommon.myLen(BatchCodeToProcess) > 0 Then
            qry += " and exists (select 1 from TSPL_PP_STAGE_PROCESS_HEAD where TSPL_PP_STAGE_PROCESS_HEAD.main_Batch_code='" + BatchCodeToProcess + "' and TSPL_PP_STAGE_PROCESS_HEAD.STAGE_PROCESS_CODE=Temp_PEStageProcess.STAGE_PROCESS_CODE)"
        End If
        qry += " order by  STAGE_PROCESS_CODE"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("STAGE_PROCESS_CODE"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    Dim obj As clsProcessProductionStageProcess = clsProcessProductionStageProcess.GetData(strDocNo, NavigatorType.Current, "", tran)
                    clsProcessProductionStageProcess.SaveData(False, obj, tran)
                    clsProcessProductionStageProcess.PostData(clsUserMgtCode.frmProcessProductionStageProcess, strDocNo, "", tran, strVoucherNo)
                    clsDBFuncationality.ExecuteNonQuery("Delete from Temp_PEStageProcess where STAGE_PROCESS_CODE='" + strDocNo + "' ", tran)
                Else
                    clsProcessProductionStageProcess.UnpostData(strDocNo, clsUserMgtCode.frmProcessProductionStageProcess, tran)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

