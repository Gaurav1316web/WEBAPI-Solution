            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If clsCommon.MyMessageBoxShow("Pending Document [" + clsCommon.myCstr(dt.Rows.Count) + "] Found" + Environment.NewLine + "Continue...", Me.Text, MessageBoxButtons.YesNo, WinControls.RadMessageIcon.Question) = System.Windows.Forms.DialogResult.Yes Then
                    Try
                        clsCommon.ProgressBarPercentShow()
                        For ii As Integer = 0 To dt.Rows.Count - 1
                            Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("DocumentNo"))
                            Dim strTransType As String = clsCommon.myCstr(dt.Rows(ii)("Transfer_Type"))
                            Dim strVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("VoucherNo"))
                            Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                            Dim collStatus As New Hashtable()
                            Try
                                clsTransferDCC.ReverseAndUnpost(strDocNo, True, trans)
                                clsTransferDCC.postTransfer(trans, strDocNo, ProvisionAllow, strVoucherNo)
                                clsCommon.AddColumnsForChange(collStatus, "Status", 1)
                                clsCommon.AddColumnsForChange(collStatus, "ERROR", Nothing, True)
                                clsCommonFunctionality.UpdateDataTable(collStatus, "TEMP_TransferDoc", OMInsertOrUpdate.Update, "DocumentNo='" + strDocNo + "'", trans)
                                trans.Commit()
                            Catch ex As Exception
                                trans.Rollback()
                                collStatus = New Hashtable()
                                If clsCommon.myLen(ex.Message) > 5000 Then
                                    clsCommon.AddColumnsForChange(collStatus, "ERROR", ex.Message.Substring(0, 4999))
                                Else
                                    clsCommon.AddColumnsForChange(collStatus, "ERROR", ex.Message)
                                End If
                                clsCommonFunctionality.UpdateDataTable(collStatus, "TEMP_TransferDoc", OMInsertOrUpdate.Update, "DocumentNo='" + strDocNo + "'")
                            End Try
                            clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Step [1]" + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                        Next
                        clsCommon.ProgressBarPercentHide()
                        'End If

                    Catch ex As Exception
                        clsCommon.ProgressBarPercentHide()
                        clsCommon.MyMessageBoxShow(ex.Message)
                    End Try
                    qry = "select * from TEMP_TransferDoc where Status is null"
                    dt = clsDBFuncationality.GetDataTable(qry)
                    If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                        If clsCommon.MyMessageBoxShow("Problem in " + clsCommon.myCstr(dt.Rows.Count) + " transaction" + Environment.NewLine + "Do you want to export to excel", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                            transportSql.ExporttoExcelWithoutFilter("select * from TEMP_TransferDoc where [status] is null and  error is not null", "", "", Me)
                        End If
                    Else
                        clsCommon.MyMessageBoxShow("Task completed", Me.Text)
                    End If
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try
