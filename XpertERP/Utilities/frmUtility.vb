    Private Sub RadButton75_Click(sender As Object, e As EventArgs) Handles RadButton75.Click
        Dim qry As String = ""
        Dim dt As New DataTable()
        Try
            Dim settTankerDispatchAvgFATSNFPer As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.TankerDispatchAvgFATSNFPer, clsFixedParameterCode.TankerDispatchAvgFATSNFPer, Nothing)) = 1)
            qry = "select * from TEMP_DELETED_MCCTankerDispatch_To_TranferIn left outer join tspl_mcc_dispatch_challan on tspl_mcc_dispatch_challan.chalan_no=TEMP_DELETED_MCCTankerDispatch_To_TranferIn.doc_No where Doc_No not in (select Doc_No from TEMP_CREATED_MCCTankerDispatch_To_TranferIn) order by tspl_mcc_dispatch_challan.dispatch_date"
            dt = New DataTable()
            dt = clsDBFuncationality.GetDataTable(qry)
            Dim strErro As String = ""
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                If common.clsCommon.MyMessageBoxShow("Recalculate cost of " + clsCommon.myCstr(dt.Rows.Count) + " Document From Tanker Dispatch To Milk Transfer In", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    clsCommon.ProgressBarPercentShow()
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("Doc_No"))
                        Dim strVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("Voucher_No"))
                        Dim strTransferInDocNo As String = clsCommon.myCstr(dt.Rows(ii)("TranferIn_Doc_No"))
                        Dim strTransferInVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("TranferIn_Voucher_No"))
                        Dim strDiffAdjustmentNo As String = clsCommon.myCstr(dt.Rows(ii)("Diff_AdjustmentNo"))
                        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                        Try
                            Dim settIsConsiderOutTypeDocForBalance As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, trans))
                            clsFixedParameter.UpdateData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, "0", trans)

                            Dim settConsiderUnpostedDocForBalance As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, trans))
                            clsFixedParameter.UpdateData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, "0", trans)


                            DispathToTansferInCorrection(strDocNo, strVoucherNo, strDiffAdjustmentNo, strTransferInDocNo, strTransferInVoucherNo, settTankerDispatchAvgFATSNFPer, trans)

                            clsFixedParameter.UpdateData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, clsCommon.myCstr(settIsConsiderOutTypeDocForBalance), trans)
                            clsFixedParameter.UpdateData(clsFixedParameterType.ConsiderUnpostedDocForBalance, clsFixedParameterCode.ConsiderUnpostedDocForBalance, clsCommon.myCstr(settConsiderUnpostedDocForBalance), trans)
                            trans.Commit()
                        Catch ex As Exception
                            trans.Rollback()
                            strErro += "Tanker Dispatch No - " + strDocNo + " Voucher No - " + strVoucherNo + " Exception -" + ex.Message + Environment.NewLine
                        End Try
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recalculate cost " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                    Next
                    clsCommon.ProgressBarPercentHide()
                    If clsCommon.myLen(strErro) > 0 Then
                        common.clsCommon.MyMessageBoxShow(strErro, Me.Text)
                    Else
                        common.clsCommon.MyMessageBoxShow("Task completed", Me.Text)
                    End If
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub

    Sub DispathToTansferInCorrection(ByVal strDocNo As String, ByVal strVoucherNo As String, ByVal strDiffAdjustmentNo As String, ByVal strTransferInDocNo As String, ByVal strTransferInVoucherNo As String, ByVal settTankerDispatchAvgFATSNFPer As Boolean, ByVal trans As SqlTransaction)
        If settTankerDispatchAvgFATSNFPer Then
            DispathToTansferInCorrectionAutoFATSNF(strDocNo, strVoucherNo, strDiffAdjustmentNo, strTransferInDocNo, strTransferInVoucherNo, trans)
        Else
            DispathToTansferInCorrectionManualFATSNF(strDocNo, strVoucherNo, strDiffAdjustmentNo, strTransferInDocNo, strTransferInVoucherNo, trans)
        End If
    End Sub
    Sub DispathToTansferInCorrectionAutoFATSNF(ByVal strDocNo As String, ByVal strVoucherNo As String, ByVal strDiffAdjustmentNo As String, ByVal strTransferInDocNo As String, ByVal strTransferInVoucherNo As String, ByVal trans As SqlTransaction)
        Try
            Dim obj As clsMccDispatch = clsMccDispatch.getData(strDocNo, NavigatorType.Current, trans)
            ''To Correct Reject Location out milk
            Dim qry As String
            Dim dt As DataTable = Nothing
            qry = "delete from TSPL_INVENTORY_MOVEMENT_new where Source_Doc_No='" + obj.Chalan_NO + "' and Trans_Type='DispChallan'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "delete from TSPL_INVENTORY_MOVEMENT where Source_Doc_No='" + obj.Chalan_NO + "' and Trans_Type='DispChallan'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            Dim arr As New List(Of clsMCCDispatchDetail)
            For ii As Integer = 0 To obj.arr.Count - 1
                If obj.arr(ii).Qty_KG > 0 Then
                    Dim objtr As New clsMCCDispatchDetail
                    objtr.Chamber_No = obj.arr(ii).Chamber_No
                    objtr.Item_Code = obj.arr(ii).Item_Code
                    objtr.Item_UOM = obj.arr(ii).Item_UOM
                    objtr.Qty_KG = obj.arr(ii).Qty_KG
                    arr.Add(objtr)
                End If
            Next
            Dim dtSummary As New DataTable
            Dim objMCT As New MIlkComponentType
            Dim ArrSilo As List(Of clsMCCDispatchSiloWise) = clsMCCDispatchSiloWise.InventoryMovementAvgFATSNF(obj.Chalan_NO, obj.Dispatch_Date, arr, obj.MCC_Code, obj.Mcc_Or_Plant_Code, obj.Rejected_Only, trans, IIf(MyDateTimePicker3.Checked, MyDateTimePicker3.Value, Nothing), dtSummary, True)
            Dim coll As New Hashtable()
            If ArrSilo IsNot Nothing AndAlso ArrSilo.Count > 0 Then
                clsDBFuncationality.ExecuteNonQuery("Delete from TSPL_MCC_Dispatch_Silo_Wise where Challan_No='" + obj.Chalan_NO + "'", trans)
                clsMCCDispatchSiloWise.SaveData(obj.Chalan_NO, ArrSilo, trans)
                clsMccDispatch.CreateInvMovementSiloWise(obj.Chalan_NO, obj.Dispatch_Date, obj.MCC_Code, obj.Mcc_Or_Plant_Code, trans)

                Dim calFatAmt As Decimal = 0
                Dim calSNFAmt As Decimal = 0
                Dim calAmt As Decimal = 0
                Dim calFATKg As Decimal = 0
                Dim calSNFKg As Decimal = 0
                Dim calQty As Decimal = 0

                For Each drSumm As DataRow In dtSummary.Rows
                    For Each objtr As clsMCCDispatchDetail In obj.arr
                        If clsCommon.CompairString(objtr.Chamber_No, clsCommon.myCstr(drSumm("Chamber_No"))) = CompairStringResult.Equal Then
                            coll = New Hashtable()
                            qry = "Update TSPL_Mcc_Dispatch_Chalan_Parameter_Detail set Param_Field_Value='" + clsCommon.myCstr(Math.Round(clsCommon.myCdbl(drSumm("Fat_Per")), 2, MidpointRounding.ToEven)) + "' where Chalan_NO='" + obj.Chalan_NO + "' and Param_Type='FAT' and SNO='" + clsCommon.myCstr(objtr.SNo) + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)
                            qry = "Update TSPL_Mcc_Dispatch_Chalan_Parameter_Detail set Param_Field_Value='" + clsCommon.myCstr(Math.Round(clsCommon.myCdbl(drSumm("SNF_Per")), 2, MidpointRounding.ToEven)) + "'  where Chalan_NO='" + obj.Chalan_NO + "' and Param_Type='SNF' and SNO='" + clsCommon.myCstr(objtr.SNo) + "'"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)
                            clsCommon.AddColumnsForChange(coll, "FAT_KG", Math.Round(clsCommon.myCdbl(drSumm("Fat_KG")), 3, MidpointRounding.ToEven))
                            clsCommon.AddColumnsForChange(coll, "SNF_KG", Math.Round(clsCommon.myCdbl(drSumm("SNF_KG")), 3, MidpointRounding.ToEven))

                            calFATKg += Math.Round(clsCommon.myCdbl(drSumm("Fat_KG")), 3, MidpointRounding.ToEven)
                            calSNFKg += Math.Round(clsCommon.myCdbl(drSumm("SNF_KG")), 3, MidpointRounding.ToEven)
                            calQty += Math.Round(clsCommon.myCdbl(drSumm("Qty")), 2, MidpointRounding.ToEven)

                            clsCommon.AddColumnsForChange(coll, "FAT_RATE", Math.Round(clsCommon.myCdbl(drSumm("Fat_Rate")), 2, MidpointRounding.ToEven))
                            clsCommon.AddColumnsForChange(coll, "SNF_RATE", Math.Round(clsCommon.myCdbl(drSumm("SNF_Rate")), 2, MidpointRounding.ToEven))
                            clsCommon.AddColumnsForChange(coll, "Amount", Math.Round(clsCommon.myCdbl(drSumm("Amount")), 2, MidpointRounding.ToEven))
                            calFatAmt += Math.Round(clsCommon.myCdbl(drSumm("Fat_Amt")), 2, MidpointRounding.ToEven)
                            calSNFAmt += Math.Round(clsCommon.myCdbl(drSumm("SNF_Amt")), 2, MidpointRounding.ToEven)
                            calAmt += Math.Round((calFatAmt + calSNFAmt), 2, MidpointRounding.ToEven)
                            clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MCC_DISPATCH_CHALLAN_DETAIL", OMInsertOrUpdate.Update, "chalan_no='" + obj.Chalan_NO + "' and Chamber_No='" + clsCommon.myCstr(objtr.Chamber_No) + "'", trans)

                            coll = New Hashtable()
                            clsCommon.AddColumnsForChange(coll, "fat_per", Math.Round(clsCommon.myCdbl(drSumm("Fat_Per")), 10, MidpointRounding.ToEven))
                            clsCommon.AddColumnsForChange(coll, "snf_Per", Math.Round(clsCommon.myCdbl(drSumm("SNF_Per")), 10, MidpointRounding.ToEven))
                            clsCommonFunctionality.UpdateDataTable(coll, "TSPL_Gate_Entry_Chember_Details", OMInsertOrUpdate.Update, " GE_Code in (select Gate_Entry_No from tspl_gate_entry_details where Challan_No='" + obj.Chalan_NO + "') and chamber_desc='" + clsCommon.myCstr(objtr.Chamber_Description) + "'", trans)

                            coll = New Hashtable()
                            clsCommon.AddColumnsForChange(coll, "fat_per", Math.Round(clsCommon.myCdbl(drSumm("Fat_Per")), 10, MidpointRounding.ToEven))
                            clsCommon.AddColumnsForChange(coll, "snf_Per", Math.Round(clsCommon.myCdbl(drSumm("SNF_Per")), 10, MidpointRounding.ToEven))
                            clsCommonFunctionality.UpdateDataTable(coll, "TSPL_Weighment_Chember_Details", OMInsertOrUpdate.Update, "  weighment_no in (  select Weighment_No From tspl_weighment_detail   where  Challan_No='" + obj.Chalan_NO + "') and chamber_desc ='" + clsCommon.myCstr(objtr.Chamber_Description) + "'", trans)
                        End If
                    Next
                Next
                If calFATKg = 0 Then
                    objMCT.FAT_Cost = 0
                Else
                    objMCT.FAT_Cost = Math.Round(calFatAmt / calFATKg, 2, MidpointRounding.ToEven)
                End If
                If calFATKg = 0 Then
                    objMCT.SNF_Cost = 0
                Else
                    objMCT.SNF_Cost = Math.Round(calSNFAmt / calSNFKg, 2, MidpointRounding.ToEven)
                End If

                If calQty = 0 Then
                    objMCT.FAT_Per = 0
                    objMCT.SNF_Per = 0
                Else
                    objMCT.FAT_Per = Math.Round(calFATKg * 100 / calQty, 2, MidpointRounding.ToEven)
                    objMCT.SNF_Per = Math.Round(calSNFKg * 100 / calQty, 2, MidpointRounding.ToEven)
                End If

                coll = New Hashtable()
                clsCommon.AddColumnsForChange(coll, "FAT_RATE", objMCT.FAT_Cost)
                clsCommon.AddColumnsForChange(coll, "SNF_RATE", objMCT.SNF_Cost)
                clsCommon.AddColumnsForChange(coll, "FAT_KG", calFATKg)
                clsCommon.AddColumnsForChange(coll, "SNF_KG", calSNFKg)
                clsCommon.AddColumnsForChange(coll, "Amount", calAmt)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MCC_Dispatch_Challan", OMInsertOrUpdate.Update, "chalan_no='" + obj.Chalan_NO + "'", trans)


                coll = New Hashtable()
                clsCommon.AddColumnsForChange(coll, "fat_per", objMCT.FAT_Per)
                clsCommon.AddColumnsForChange(coll, "snf_Per", objMCT.SNF_Per)
                clsCommonFunctionality.UpdateDataTable(coll, "tspl_gate_entry_details", OMInsertOrUpdate.Update, "Challan_No='" + obj.Chalan_NO + "'", trans)

                coll = New Hashtable()
                clsCommon.AddColumnsForChange(coll, "fat_per", objMCT.FAT_Per)
                clsCommon.AddColumnsForChange(coll, "snf_Per", objMCT.SNF_Per)
                clsCommon.AddColumnsForChange(coll, "FAT_RATE", objMCT.FAT_Cost)
                clsCommon.AddColumnsForChange(coll, "SNF_RATE", objMCT.SNF_Cost)
                clsCommon.AddColumnsForChange(coll, "FAT_KG", calFATKg)
                clsCommon.AddColumnsForChange(coll, "SNF_KG", calSNFKg)
                clsCommon.AddColumnsForChange(coll, "FAT_Value", calFatAmt)
                clsCommon.AddColumnsForChange(coll, "SNF_Value", calSNFAmt)
                clsCommon.AddColumnsForChange(coll, "Amount", calAmt)
                clsCommonFunctionality.UpdateDataTable(coll, "tspl_weighment_detail", OMInsertOrUpdate.Update, "Challan_No='" + obj.Chalan_NO + "'", trans)
            End If

            If obj IsNot Nothing AndAlso obj.arr IsNot Nothing AndAlso obj.arr.Count > 0 Then
                If clsCommon.myLen(strDiffAdjustmentNo) > 0 Then
                    qry = "Delete from TSPL_JOURNAL_DETAILS where Voucher_No in (select Voucher_No from TSPL_JOURNAL_MASTER where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') )"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_JOURNAL_MASTER where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') "
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_INVENTORY_MOVEMENT_NEW where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') "
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_ADJUSTMENT_DETAIL where adjustment_no in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "')"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_ADJUSTMENT_HEADER where adjustment_no in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "')"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                End If

                obj = clsMccDispatch.getData(strDocNo, NavigatorType.Current, trans)
                clsMccDispatch.CreateTransferOutJE(obj, strVoucherNo, trans)

                If clsCommon.myLen(strTransferInDocNo) > 0 Then
                    Dim objTI As clsMilkTransferIn = clsMilkTransferIn.getData(strTransferInDocNo, NavigatorType.Current, trans)
                    qry = "update TSPL_INVENTORY_MOVEMENT_NEW set Fat_Rate='" + clsCommon.myCstr(objMCT.FAT_Cost) + "',SNF_Rate='" + clsCommon.myCstr(objMCT.SNF_Cost) + "',Fat_Amt=convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + "),SNF_Amt=convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + "),Avg_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + ")),FIFO_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + ")) ,LIFO_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + "))  where Trans_Type='MilkTransferIn' and Source_Doc_No='" + strTransferInDocNo + "'"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                    clsMilkTransferIn.CreateTransferInJE(objTI, strTransferInVoucherNo, trans)
                    If clsCommon.myLen(strDiffAdjustmentNo) > 0 Then
                        Dim DoNotCreateAdjustmentonMilkTransferInGL As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.DoNotCreateAdjustmentonMilkTransferInGL, clsFixedParameterCode.DoNotCreateAdjustmentonMilkTransferInGL, trans))
                        If DoNotCreateAdjustmentonMilkTransferInGL = 0 Then
                            ClsAdjustments.CreateMilkTransferAdjustmentDoc(obj, objTI, trans)
                        End If
                    End If
                End If
                clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_CREATED_MCCTankerDispatch_To_TranferIn values('" + strDocNo + "')", trans)
            Else
                Throw New Exception("chamber wise Data not found")
            End If
        Catch ex As Exception
            Throw New Exception("Tanker Dispatch No - " + strDocNo + " Voucher No - " + strVoucherNo + " Exception -" + ex.Message + Environment.NewLine)
        End Try
    End Sub

    Sub DispathToTansferInCorrectionManualFATSNF(ByVal strDocNo As String, ByVal strVoucherNo As String, ByVal strDiffAdjustmentNo As String, ByVal strTransferInDocNo As String, ByVal strTransferInVoucherNo As String, ByVal trans As SqlTransaction)
        Try
            Dim obj As clsMccDispatch = clsMccDispatch.getData(strDocNo, NavigatorType.Current, trans)
            Dim qry As String
            Dim dt As DataTable = Nothing
            If obj IsNot Nothing AndAlso obj.arr IsNot Nothing AndAlso obj.arr.Count > 0 Then
                If clsCommon.myLen(strDiffAdjustmentNo) > 0 Then
                    qry = "Delete from TSPL_JOURNAL_DETAILS where Voucher_No in (select Voucher_No from TSPL_JOURNAL_MASTER where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') )"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_JOURNAL_MASTER where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') "
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_INVENTORY_MOVEMENT_NEW where Source_Doc_No in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "') "
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_ADJUSTMENT_DETAIL where adjustment_no in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "')"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)

                    qry = "delete from TSPL_ADJUSTMENT_HEADER where adjustment_no in (select Adjustment_No from TSPL_ADJUSTMENT_HEADER  where Against_Tanker_Dispatch_Doc_No='" + strDocNo + "')"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                End If

                Dim dtNew As DateTime = New Date(obj.Dispatch_Date.Year, obj.Dispatch_Date.Month, obj.Dispatch_Date.Day, 23, 59, 59)
                Dim objMCT As MIlkComponentType = GetAvgCost(obj.Rejected_Only, 2, True, "MI", obj.arr(0).Item_Code, obj.MCC_Code, 1, obj.arr(0).Item_UOM, 1, 1, dtNew, dtNew, False, trans, obj.Chalan_NO)
                ''Dispatch Head Table
                Dim calFatAmt As Decimal = 0
                Dim calSNFAmt As Decimal = 0
                Dim calAmt As Decimal = 0
                Dim calFATKg As Decimal = 0
                Dim calSNFKg As Decimal = 0
                Dim calQty As Decimal = 0
                Dim coll As New Hashtable()
                ''Dispatch Detail Table
                For Each objtr As clsMCCDispatchDetail In obj.arr
                    If objtr.Qty_KG > 0 Then
                        coll = New Hashtable()
                        clsCommon.AddColumnsForChange(coll, "FAT_RATE", objMCT.FAT_Cost)
                        clsCommon.AddColumnsForChange(coll, "SNF_RATE", objMCT.SNF_Cost)
                        clsCommon.AddColumnsForChange(coll, "Amount", Math.Round((objtr.FAT_KG * objMCT.FAT_Cost) + (objtr.SNF_KG * objMCT.SNF_Cost), 2, MidpointRounding.ToEven))
                        calFatAmt += Math.Round((objtr.FAT_KG * objMCT.FAT_Cost), 2, MidpointRounding.ToEven)
                        calSNFAmt += Math.Round((objtr.SNF_KG * objMCT.SNF_Cost), 2, MidpointRounding.ToEven)
                        calAmt += Math.Round((calFatAmt + calSNFAmt), 2, MidpointRounding.ToEven)
                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MCC_DISPATCH_CHALLAN_DETAIL", OMInsertOrUpdate.Update, "chalan_no='" + obj.Chalan_NO + "' and Chamber_No='" + clsCommon.myCstr(objtr.Chamber_No) + "'", trans)
                    End If
                Next

                coll = New Hashtable()
                clsCommon.AddColumnsForChange(coll, "FAT_RATE", objMCT.FAT_Cost)
                clsCommon.AddColumnsForChange(coll, "SNF_RATE", objMCT.SNF_Cost)
                clsCommon.AddColumnsForChange(coll, "Amount", calAmt)
                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_MCC_Dispatch_Challan", OMInsertOrUpdate.Update, "chalan_no='" + obj.Chalan_NO + "'", trans)

                ''Dispatch Inventory movement
                qry = "select Stock_Qty,Location_Code from TSPL_INVENTORY_MOVEMENT_NEW where Source_Doc_No='" + strDocNo + "' and Trans_Type='DispChallan'"
                Dim dtDisInvMov As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
                If dtDisInvMov IsNot Nothing AndAlso dtDisInvMov.Rows.Count > 0 Then
                    Dim TotQty As Decimal = 0
                    For Each drInvMov As DataRow In dtDisInvMov.Rows
                        TotQty += clsCommon.myCdbl(drInvMov("Stock_Qty"))
                    Next
                    For Each drInvMov As DataRow In dtDisInvMov.Rows
                        Dim dclRatio As Decimal = clsCommon.myCdbl(drInvMov("Stock_Qty")) / TotQty
                        coll = New Hashtable()
                        clsCommon.AddColumnsForChange(coll, "Fat_Rate", objMCT.FAT_Cost)
                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", objMCT.SNF_Cost)
                        clsCommon.AddColumnsForChange(coll, "Fat_Amt", Math.Round((calFatAmt * dclRatio), 2, MidpointRounding.ToEven))
                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", Math.Round((calSNFAmt * dclRatio), 2, MidpointRounding.ToEven))
                        clsCommon.AddColumnsForChange(coll, "Avg_Cost", Math.Round((calAmt * dclRatio), 2, MidpointRounding.ToEven))
                        clsCommon.AddColumnsForChange(coll, "FIFO_Cost", Math.Round((calAmt * dclRatio), 2, MidpointRounding.ToEven))
                        clsCommon.AddColumnsForChange(coll, "LIFO_Cost", Math.Round((calAmt * dclRatio), 2, MidpointRounding.ToEven))
                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_INVENTORY_MOVEMENT_NEW", OMInsertOrUpdate.Update, "Trans_Type='DispChallan' and Source_Doc_No='" + strDocNo + "' and Location_Code='" + clsCommon.myCstr(drInvMov("Location_Code")) + "'", trans)
                    Next
                End If
                ''End of Dispatch Inventory movement

                obj = clsMccDispatch.getData(strDocNo, NavigatorType.Current, trans)
                clsMccDispatch.CreateTransferOutJE(obj, strVoucherNo, trans)

                If clsCommon.myLen(strTransferInDocNo) > 0 Then
                    Dim objTI As clsMilkTransferIn = clsMilkTransferIn.getData(strTransferInDocNo, NavigatorType.Current, trans)
                    qry = "update TSPL_INVENTORY_MOVEMENT_NEW set Fat_Rate='" + clsCommon.myCstr(objMCT.FAT_Cost) + "',SNF_Rate='" + clsCommon.myCstr(objMCT.SNF_Cost) + "',Fat_Amt=convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + "),SNF_Amt=convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + "),Avg_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + ")),FIFO_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + ")) ,LIFO_Cost=(convert(decimal(18,2), Fat_KG*" + clsCommon.myCstr(objMCT.FAT_Cost) + ")+convert(decimal(18,2), SNF_KG*" + clsCommon.myCstr(objMCT.SNF_Cost) + "))  where Trans_Type='MilkTransferIn' and Source_Doc_No='" + strTransferInDocNo + "'"
                    clsDBFuncationality.ExecuteNonQuery(qry, trans)
                    clsMilkTransferIn.CreateTransferInJE(objTI, strTransferInVoucherNo, trans)
                    If clsCommon.myLen(strDiffAdjustmentNo) > 0 Then
                        Dim DoNotCreateAdjustmentonMilkTransferInGL As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.DoNotCreateAdjustmentonMilkTransferInGL, clsFixedParameterCode.DoNotCreateAdjustmentonMilkTransferInGL, trans))
                        If DoNotCreateAdjustmentonMilkTransferInGL = 0 Then
                            ClsAdjustments.CreateMilkTransferAdjustmentDoc(obj, objTI, trans)
                        End If
                    End If
                End If
                clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_CREATED_MCCTankerDispatch_To_TranferIn values('" + strDocNo + "')", trans)
            Else
                Throw New Exception("chamber wise Data not found")
            End If
        Catch ex As Exception
            Throw New Exception("Tanker Dispatch No - " + strDocNo + " Voucher No - " + strVoucherNo + " Exception -" + ex.Message + Environment.NewLine)
        End Try
    End Sub

    Private Shared Function GetAvgCost(ByVal Product_Type As String, ByVal Item_Code As String, ByVal strLocation As String, ByVal dblQty As Decimal, ByVal Unit_Code As String, ByVal dblFATqty As Double, ByVal dblSNFqty As Double, ByVal dtDocumentDate As DateTime, ByVal dtPostingDate As DateTime, ByVal isApplyCostOnPostDate As Boolean, ByVal trans As SqlTransaction, Optional ByVal Current_Doc_Code As String = "", Optional ByVal Trans_Id As Integer = 0) As MIlkComponentType
        Return GetAvgCost(False, Product_Type, Item_Code, strLocation, dblQty, Unit_Code, dblFATqty, dblSNFqty, dtDocumentDate, dtPostingDate, isApplyCostOnPostDate, trans, Current_Doc_Code, Trans_Id)
    End Function
    Private Shared Function GetAvgCost(ByVal isAfter1Aug2017 As Boolean, ByVal Product_Type As String, ByVal Item_Code As String, ByVal strLocation As String, ByVal dblQty As Decimal, ByVal Unit_Code As String, ByVal dblFATqty As Double, ByVal dblSNFqty As Double, ByVal dtDocumentDate As DateTime, ByVal dtPostingDate As DateTime, ByVal isApplyCostOnPostDate As Boolean, ByVal trans As SqlTransaction, Optional ByVal Current_Doc_Code As String = "", Optional ByVal Trans_Id As Integer = 0) As MIlkComponentType
        Return GetAvgCost(2, isAfter1Aug2017, Product_Type, Item_Code, strLocation, dblQty, Unit_Code, dblFATqty, dblSNFqty, dtDocumentDate, dtPostingDate, isApplyCostOnPostDate, trans, Current_Doc_Code, Trans_Id)
    End Function
    Private Shared Function GetAvgCost(ByVal FATSNFPerDecimalPlaces As Integer, ByVal isAfter1Aug2017 As Boolean, ByVal Product_Type As String, ByVal Item_Code As String, ByVal strLocation As String, ByVal dblQty As Decimal, ByVal Unit_Code As String, ByVal dblFATqty As Double, ByVal dblSNFqty As Double, ByVal dtDocumentDate As DateTime, ByVal dtPostingDate As DateTime, ByVal isApplyCostOnPostDate As Boolean, ByVal trans As SqlTransaction, Optional ByVal Current_Doc_Code As String = "", Optional ByVal Trans_Id As Integer = 0) As MIlkComponentType
        Return GetAvgCost(False, FATSNFPerDecimalPlaces, isAfter1Aug2017, Product_Type, Item_Code, strLocation, dblQty, Unit_Code, dblFATqty, dblSNFqty, dtDocumentDate, dtPostingDate, isApplyCostOnPostDate, trans, Current_Doc_Code, Trans_Id)
    End Function
    Private Shared Function GetAvgCost(ByVal IsRejectOnly As Boolean, ByVal FATSNFPerDecimalPlaces As Integer, ByVal isAfter1Aug2017 As Boolean, ByVal Product_Type As String, ByVal Item_Code As String, ByVal strLocation As String, ByVal dblQty As Decimal, ByVal Unit_Code As String, ByVal dblFATqty As Double, ByVal dblSNFqty As Double, ByVal dtDocumentDate As DateTime, ByVal dtPostingDate As DateTime, ByVal isApplyCostOnPostDate As Boolean, ByVal trans As SqlTransaction, Optional ByVal Current_Doc_Code As String = "", Optional ByVal Trans_Id As Integer = 0) As MIlkComponentType
        Dim obj As New MIlkComponentType
        Try
            Dim dblRetCost As Double = 0
            Dim strSymbolCost As String = " >= "

            Dim strDateColumn As String = " Punching_Date "
            Dim strDateForCheck As String = clsCommon.GetPrintDate(dtDocumentDate, "dd/MMM/yyyy hh:mm:ss tt")
            If isApplyCostOnPostDate Then
                strDateColumn = " Posting_Date "
                strDateForCheck = clsCommon.GetPrintDate(dtPostingDate, "dd/MMM/yyyy hh:mm:ss tt")
            End If

            Dim qry As String = ""

            Dim cond_TransId As String = ""
            If Trans_Id > 0 Then
                cond_TransId = " and  TSPL_INVENTORY_MOVEMENT_new.Trans_id<'" & Trans_Id & "'"
            End If
            If clsCommon.myLen(Product_Type) <= 0 Then
                Product_Type = clsItemMaster.GetItemProductType(Item_Code, trans)
            End If
            If clsCommon.CompairString(Product_Type, "MI") = CompairStringResult.Equal Then
                qry = "select (case when (Fat_Amt*SNF_Amt<0 or Fat_KG*SNF_KG<0 or Fat_Amt<=0 or Fat_KG<=0) then Last_Fat_Rate else Fat_Amt/Fat_KG end)*" + clsCommon.myCstr(dblFATqty) + " as Avg_Fat_Cost" + Environment.NewLine +
                    ",(case when (Fat_Amt*SNF_Amt<0 or Fat_KG*SNF_KG<0 or SNF_Amt<=0 or SNF_KG<=0) then Last_SNF_Rate else SNF_Amt/SNF_KG end)*" + clsCommon.myCstr(dblSNFqty) + " as Avg_SNF_Cost " + Environment.NewLine +
                    ",(case when (Fat_Amt*SNF_Amt<0 or Fat_KG*SNF_KG<0 or SNF_Amt<=0 or SNF_KG<=0 or Stock_Qty<=0) then Last_FAT_Per else Fat_KG*100/Stock_Qty end) as FAT_Per " +
                    ",(case when (Fat_Amt*SNF_Amt<0 or Fat_KG*SNF_KG<0 or SNF_Amt<=0 or SNF_KG<=0 or Stock_Qty<=0) then Last_SNF_Per else SNF_KG*100/Stock_Qty end) as SNF_Per " +
                  " from( select  sum(Stock_Qty*RI) as Stock_Qty, sum(Fat_Amt * RI) as Fat_Amt,sum(Fat_KG * RI) as Fat_KG,sum(SNF_Amt * RI) as SNF_Amt,sum(SNF_KG * RI) as SNF_KG  " + Environment.NewLine +
                  ",isnull((select top 1 Fat_Rate from TSPL_INVENTORY_MOVEMENT_NEW where Item_Code='" + Item_Code + "' and (Location_Code='" + strLocation + "' or main_location='" + strLocation + "') and  " + strDateColumn + " < '" + strDateForCheck + "' and Source_Doc_No<>'" + Current_Doc_Code + "' and InOut='I' and Fat_Rate>0  order by " + strDateColumn + " desc ),0) as Last_Fat_Rate" + Environment.NewLine +
                  ",isnull((select top 1 SNF_Rate from TSPL_INVENTORY_MOVEMENT_NEW where Item_Code='" + Item_Code + "' and (Location_Code='" + strLocation + "' or main_location='" + strLocation + "') and  " + strDateColumn + " < '" + strDateForCheck + "' and Source_Doc_No<>'" + Current_Doc_Code + "' and InOut='I' and SNF_Rate>0 order by " + strDateColumn + " desc ),0) as Last_SNF_Rate " + Environment.NewLine +
                  ",isnull((select top 1 Fat_Per from TSPL_INVENTORY_MOVEMENT_NEW where Item_Code='" + Item_Code + "' and (Location_Code='" + strLocation + "' or main_location='" + strLocation + "') and  " + strDateColumn + " < '" + strDateForCheck + "' and Source_Doc_No<>'" + Current_Doc_Code + "' and InOut='I' and Fat_Rate>0  order by " + strDateColumn + " desc ),0) as Last_Fat_Per" + Environment.NewLine +
                  ",isnull((select top 1 SNF_Per from TSPL_INVENTORY_MOVEMENT_NEW where Item_Code='" + Item_Code + "' and (Location_Code='" + strLocation + "' or main_location='" + strLocation + "') and  " + strDateColumn + " < '" + strDateForCheck + "' and Source_Doc_No<>'" + Current_Doc_Code + "' and InOut='I' and SNF_Rate>0 order by " + strDateColumn + " desc ),0) as Last_SNF_Per " + Environment.NewLine +
                  " from(" + Environment.NewLine +
                  " select cast(Fat_KG as numeric(18,2)) as Fat_KG ,cast((case when Fat_Amt<=0 then 0 else Fat_Amt end) as numeric(18,2)) as Fat_Amt,cast(SNF_KG as numeric(18,2)) as SNF_KG ," &
                  " cast((case when SNF_Amt<=0 then 0 else SNF_Amt  end) as numeric(18,2)) as SNF_Amt,case when InOut='O' then -1 else 1 end as RI,Stock_Qty from TSPL_INVENTORY_MOVEMENT_new left outer join TSPL_Location_MASTER on TSPL_Location_MASTER.Location_Code=TSPL_INVENTORY_MOVEMENT_NEW.Location_Code where Item_Code='" & Item_Code & "' and ( TSPL_INVENTORY_MOVEMENT_NEW.Location_Code='" + strLocation + "' or TSPL_INVENTORY_MOVEMENT_NEW.main_location='" + strLocation + "' )"
                If isAfter1Aug2017 Then
                    qry += " and  " + strDateColumn + " >= '01/Aug/2017 00:00:00 AM'"
                End If
                If IsRejectOnly Then
                    qry += " and TSPL_Location_MASTER.Rejected_Type='Y'"
                Else
                    qry += " and TSPL_Location_MASTER.Rejected_Type='N'"
                End If
                qry += " and  " + strDateColumn + " <= '" + strDateForCheck + "' and Source_Doc_No not in ('" & Current_Doc_Code & "') " & cond_TransId & "  " + Environment.NewLine +
                      " )xxx )xxxx"
                Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, trans)
                If dt.Rows.Count > 0 Then
                    obj.FAT_Cost = Math.Round(clsCommon.myCdbl(dt.Rows(0).Item("Avg_Fat_Cost")), 2)
                    obj.SNF_Cost = Math.Round(clsCommon.myCdbl(dt.Rows(0).Item("Avg_SNF_Cost")), 2)
                    Dim intDP As Integer = 100
                    If FATSNFPerDecimalPlaces = 3 Then
                        intDP = 1000
                    End If
                    obj.FAT_Per = Math.Truncate(clsCommon.myCdbl(dt.Rows(0).Item("FAT_Per")) * intDP) / intDP
                    obj.SNF_Per = Math.Truncate(clsCommon.myCdbl(dt.Rows(0).Item("SNF_Per")) * intDP) / intDP
                End If
            ElseIf clsCommon.CompairString(Product_Type, "MP") = CompairStringResult.Equal Then
                Dim Stock_Qty As Decimal = 0
                Stock_Qty = dblQty * clsItemMaster.GetConvertionFactor(Item_Code, Unit_Code, trans)
                Dim AvgCost As Decimal = clsInventoryMovement.GetCost(EnumCostingMethod.Averege, Item_Code, strLocation, Stock_Qty, dtDocumentDate, dtPostingDate, True, trans)
                Dim avgRate As Decimal = AvgCost / IIf((dblFATqty + dblSNFqty) <= 0, 1, (dblFATqty + dblSNFqty))
                obj.FAT_Cost = avgRate * dblFATqty
                obj.SNF_Cost = avgRate * dblSNFqty
            Else
                Dim Stock_Qty As Decimal = 0
                Stock_Qty = dblQty * clsItemMaster.GetConvertionFactor(Item_Code, Unit_Code, trans)
                Dim AvgCost As Decimal = clsInventoryMovement.GetCost(EnumCostingMethod.Averege, Item_Code, strLocation, Stock_Qty, dtDocumentDate, dtPostingDate, True, trans)
                obj.FAT_Cost = AvgCost * 2 / 3
                obj.SNF_Cost = AvgCost / 3
            End If

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try

        Return obj
    End Function

