    Private Sub OpenPort()
        Try
            Dim obj As clsPortSetting = clsPortSetting.getData(IIf(chkEkoProMachine.IsChecked, 0, 1), CboMachine.Text)
            If obj Is Nothing Then
                Throw New Exception("No setting found for device")
            End If
            objSerial.isShowUtility = True
            objSerial.BaudRate = obj.baud_rate
            objSerial.Parity = obj.parity
            objSerial.PortName = cboComPort.Text
            objSerial.StopBits = obj.stop_bits
            objSerial.DataBits = obj.data_bits
            objSerial.isEkoProMachine = chkEkoProMachine.IsChecked
            objSerial.isWeighingMachine = chkWeighingMachine.IsChecked
            objSerial._LblFat = Nothing
            objSerial._LblSNF = Nothing
            objSerial._LblWeight = Nothing
            objSerial._TextBox = txtHyperTerminal
            objSerial._MachineCode = CboMachine.SelectedValue
            objSerial.MachineName = clsPortSetting.getMachineMakePrefix(CboMachine.Text, IIf(chkEkoProMachine.IsChecked, 0, 1))
            objSerial.DataForm = obj.Data_Form
            
            objSerial.OpenPort()
            'End If
        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Sub

