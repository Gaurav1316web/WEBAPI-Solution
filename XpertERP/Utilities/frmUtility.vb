    Private Sub RadButton200_Click(sender As Object, e As EventArgs) Handles RadButton200.Click
        Try
            Dim ProvisionAllow As Boolean = clsCommon.myCBool(IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.PROVISIONENTRYONSTOCKTRANSFER, clsFixedParameterCode.PROVISIONENTRYONSTOCKTRANSFER, Nothing)) = 1, True, False))
