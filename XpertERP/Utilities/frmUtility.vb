                    objDocSeq.UpdateARInvoice(clsCommon.myCstr(dt.Rows(ii)("ARNo")), clsCommon.myCstr(dt.Rows(ii)("NewARNo")), tran)
                    objDocSeq.UpdateJournalEntry(clsCommon.myCstr(dt.Rows(ii)("VoucherNo")), clsCommon.myCstr(dt.Rows(ii)("NewVoucherNo")), tran)
                Next
            End If
            clsCommon.ProgressBarPercentUpdate(0, "(4/4)Updating Sale Return")
            dt = clsDBFuncationality.GetDataTable("select * from [1SALEProblem_Ret]", tran)
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
