                    objDocSeq.UpdateJournalEntry(clsCommon.myCstr(dt.Rows(ii)("VoucherNo")), clsCommon.myCstr(dt.Rows(ii)("NewVoucherNo")), tran)
                Next
            End If
            'Throw New Exception("Balwinder singh premi")
            tran.Commit()
            clsCommon.ProgressBarPercentHide()
            clsCommon.MyMessageBoxShow("Task completed", Me.Text)
        Catch ex As Exception
