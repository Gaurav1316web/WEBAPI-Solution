    Private Sub RadButton167_Click(sender As Object, e As EventArgs) Handles RadButton167.Click
        Dim flag As Boolean = True
        Try
            If clsCommon.GetDateWithEndTime(txtFullProductionFromDate.Value) > clsCommon.GetDateWithEndTime(txtFullProductionToDate.Value) Then
                Throw New Exception("From Date cannot be more than to date")
            End If
            clsCommon.ProgressBarPercentShow()
            ExecuteInvWin()
            Dim dt As DataTable = clsDBFuncationality.GetDataTable("select * from ExplodeDates('" + clsCommon.GetPrintDate(txtFullProductionFromDate.Value, "dd/MMM/yyyy") + "','" + clsCommon.GetPrintDate(txtFullProductionToDate.Value, "dd/MMM/yyyy") + "')")
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                For ii As Integer = 0 To dt.Rows.Count - 1
                    Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
                    clsFixedParameter.UpdateFixedParameter(clsFixedParameterType.FATSNFRate, clsFixedParameterCode.FATSNFRate, txtFPFATRate.Value, txtFPSNFRate.Value, tran)

                    Dim intSettingType As Integer = clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.IsConsiderOutTypeDocForBalance, clsFixedParameterCode.IsConsiderOutTypeDocForBalance, tran))
                    Try
                        If chkDoNotConsiderOutTypeDocForBalance.Checked Then
                            clsDBFuncationality.ExecuteNonQuery("Update TSPL_FIXED_PARAMETER set Description='0' where Type='" + clsFixedParameterType.IsConsiderOutTypeDocForBalance + "' and Code='" + clsFixedParameterCode.IsConsiderOutTypeDocForBalance + "'", tran)
                        End If
                        Dim dtWIP As Date = clsCommon.myCDate(dt.Rows(ii)("thedate"))
                        EnableDisableFinancialTrigger(False, tran)
                        '------------------For Unpost
                        PEPurchaseIssue(dtWIP, tran, False)
                        PEItemIssue(False, dtWIP, tran, False, "")
                        PEStandard(dtWIP, tran, False, "")
                        PEStandardFinalQC(dtWIP, tran, False, "")
                        PEItemIssue(True, dtWIP, tran, False, "")
                        PEStageProcess(dtWIP, tran, False, "")
                        PEProductionEntry(dtWIP, tran, False, "")
                        PEAssemblyDeassembly(dtWIP, tran, False)


                        '------------------For Post
                        PEPurchaseIssue(dtWIP, tran, True)
                        Dim qry As String = "select distinct Batch_Code from Temp_PEItemIssue order by Batch_Code"
                        Dim dtBatch As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                        If dtBatch IsNot Nothing AndAlso dtBatch.Rows.Count > 0 Then
                            For Each dr As DataRow In dtBatch.Rows
                                PEItemIssue(False, dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                                PEStandard(dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                                PEStandardFinalQC(dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                            Next
                        End If
                        PEStandard(dtWIP, tran, True, "")
                        PEStandardFinalQC(dtWIP, tran, True, "")

                        qry = "select distinct Batch_Code from Temp_PEItemIssueFG order by Batch_Code"
                        dtBatch = clsDBFuncationality.GetDataTable(qry, tran)
                        If dtBatch IsNot Nothing AndAlso dtBatch.Rows.Count > 0 Then
                            For Each dr As DataRow In dtBatch.Rows
                                PEItemIssue(True, dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                                PEStageProcess(dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                                PEProductionEntry(dtWIP, tran, True, clsCommon.myCstr(dr("Batch_Code")))
                            Next
                        End If
                        PEStageProcess(dtWIP, tran, True, "")
                        PEProductionEntry(dtWIP, tran, True, "")

                        PEAssemblyDeassembly(dtWIP, tran, True)
                        EnableDisableFinancialTrigger(True, tran)

                        clsDBFuncationality.ExecuteNonQuery("Delete from TEMP_Full_Production", tran)
                        Dim coll As New Hashtable()
                        clsCommon.AddColumnsForChange(coll, "FromDate", clsCommon.GetPrintDate(dtWIP.AddDays(1), "dd/MMM/yyyy"))
                        clsCommon.AddColumnsForChange(coll, "ToDate", clsCommon.GetPrintDate(txtFullProductionToDate.Value, "dd/MMM/yyyy"))
                        clsCommonFunctionality.UpdateDataTable(coll, "TEMP_Full_Production", OMInsertOrUpdate.Insert, "", tran)
                        clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count) + "[" + clsCommon.GetPrintDate(dtWIP, "dd/MM/yyyy") + "]")
                        If chkDoNotConsiderOutTypeDocForBalance.Checked Then
                            clsDBFuncationality.ExecuteNonQuery("Update TSPL_FIXED_PARAMETER set Description='" + clsCommon.myCstr(intSettingType) + "' where Type='" + clsFixedParameterType.IsConsiderOutTypeDocForBalance + "' and Code='" + clsFixedParameterCode.IsConsiderOutTypeDocForBalance + "'", tran)
                        End If
                        clsFixedParameter.UpdateFixedParameter(clsFixedParameterType.FATSNFRate, clsFixedParameterCode.FATSNFRate, "0", "0", tran)
                        tran.Commit()
                    Catch ex As Exception
                        tran.Rollback()
                        Throw New Exception(ex.Message)
                    End Try
                Next
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow("Task Completed", Me.Text)
            Else
                clsCommon.ProgressBarPercentHide()
                clsCommon.MyMessageBoxShow("No Document Found Completed", Me.Text)
            End If
        Catch ex As Exception
            flag = False
            clsCommon.ProgressBarPercentHide()
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        Finally
            If flag Then
                LoadFullProduControl()
            End If
        End Try
    End Sub

    Sub PEItemIssue(ByVal isFGItem As Boolean, ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean, ByVal BatchCodeToProcess As String)
        Dim settPickProductCostFromItemUOMDetail As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.PickProductCostFromItemUOMDetail, clsFixedParameterCode.PickProductCostFromItemUOMDetail, tran)) > 0)
        Dim settTankerDispatchAvgFATSNFPer As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.TankerDispatchAvgFATSNFPer, clsFixedParameterCode.TankerDispatchAvgFATSNFPer, tran)) = 1)

        Dim qry As String
        Dim tabName As String = "Temp_PEItemIssue" + IIf(isFGItem, "FG", "")
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table " + tabName, tran)
            qry = " select * from (" + Environment.NewLine +
                "select Issue_code,Issue_Date,TSPL_JOURNAL_MASTER.Voucher_No ,TSPL_JOURNAL_MASTER.Source_Code,TSPL_PP_ISSUE_HEAD.Batch_Code" + Environment.NewLine +
                "from TSPL_PP_ISSUE_HEAD " + Environment.NewLine +
                "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PP_ISSUE_HEAD.Issue_code  and TSPL_JOURNAL_MASTER.Source_Code='PR-IS'" + Environment.NewLine +
                "left outer join TSPL_PP_BATCH_ORDER_BOM_DETAIL on TSPL_PP_BATCH_ORDER_BOM_DETAIL.Batch_Code=TSPL_PP_ISSUE_HEAD.Batch_Code " + Environment.NewLine +
                "left outer join TSPL_PP_BOM_HEAD on TSPL_PP_BOM_HEAD.BOM_CODE=TSPL_PP_BATCH_ORDER_BOM_DETAIL.BOM_Code" + Environment.NewLine +
                "left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PP_BOM_HEAD.PROD_ITEM_CODE" + Environment.NewLine +
                "where  TSPL_PP_ISSUE_HEAD.Is_post=1 and  TSPL_PP_ISSUE_HEAD.Issue_Date>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "'  and TSPL_PP_ISSUE_HEAD.Issue_Date<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "'" + Environment.NewLine
            If isFGItem Then
                qry += " and TSPL_ITEM_MASTER.Item_Type='F'"
            Else
                qry += " and TSPL_ITEM_MASTER.Item_Type='S'"
            End If
            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PP_ISSUE_HEAD.Main_Location_Code in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            If TxtMultiSelectFinder12.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder12.arrValueMember.Count > 0 Then
                qry += " and exists (select 1 from TSPL_PP_ISSUE_ITEM_DETAIL where TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code=TSPL_PP_ISSUE_HEAD.Issue_Code and TSPL_PP_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))"
            End If
            qry += ")x "
            qry = "select * into " + tabName + " from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        Dim tExtraWhrClauseInvNew As String = ""
        Dim whrcla As String = ""
        If MyDateTimePicker4.Checked Then
            tExtraWhrClauseInvNew = " Punching_Date >='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(MyDateTimePicker4.Value), "dd/MMM/yyyy hh:mm tt") + "'"
            whrcla = " And " + tExtraWhrClauseInvNew
        End If

        qry = "Select * from " + tabName + " where 2=2 "
        If clsCommon.myLen(BatchCodeToProcess) > 0 Then
            qry += " and Batch_Code='" + BatchCodeToProcess + "'"
        End If
        qry += "  order by Issue_code"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("Issue_code"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                Dim strBatchCode As String = clsCommon.myCstr(dr("Batch_Code"))
                If isForPost Then
                    qry = "select TSPL_PP_ISSUE_ITEM_DETAIL.SNO,TSPL_PP_ISSUE_ITEM_DETAIL.Item_Code,TSPL_ITEM_MASTER.Product_Type, TSPL_PP_ISSUE_ITEM_DETAIL.Qty,TSPL_PP_ISSUE_ITEM_DETAIL.Unit_Code" + Environment.NewLine +
                ",TSPL_PP_ISSUE_ITEM_DETAIL.FAT_Pers,TSPL_PP_ISSUE_ITEM_DETAIL.FAT_KG,TSPL_PP_ISSUE_ITEM_DETAIL.Fat_Rate,TSPL_PP_ISSUE_ITEM_DETAIL.Fat_Amt " + Environment.NewLine +
                ",TSPL_PP_ISSUE_ITEM_DETAIL.SNF_Pers,TSPL_PP_ISSUE_ITEM_DETAIL.SNF_KG,TSPL_PP_ISSUE_ITEM_DETAIL.SNF_Rate,TSPL_PP_ISSUE_ITEM_DETAIL.SNF_Amt " + Environment.NewLine +
                ",TSPL_PP_ISSUE_HEAD.Main_Location_Code,TSPL_PP_ISSUE_ITEM_DETAIL.From_Loaction_Code,TSPL_PP_ISSUE_ITEM_DETAIL.To_Location_Code,TSPL_PP_ISSUE_HEAD.Issue_Date,TSPL_PP_ISSUE_ITEM_DETAIL.From_SubLocation_YN" + Environment.NewLine +
                "from TSPL_PP_ISSUE_ITEM_DETAIL" + Environment.NewLine +
                "left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PP_ISSUE_ITEM_DETAIL.Item_Code " + Environment.NewLine +
                "left outer join TSPL_PP_ISSUE_HEAD on TSPL_PP_ISSUE_HEAD.Issue_Code=TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code" + Environment.NewLine +
                "where TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code='" + strDocNo + "'"
                    Dim dtDetail As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                    If dtDetail IsNot Nothing AndAlso dtDetail.Rows.Count > 0 Then
                        For Each drDetail As DataRow In dtDetail.Rows
                            Dim objtr As New clsProcessProductionIssueItemDetail
                            If clsCommon.CompairString(clsCommon.myCstr(drDetail("Product_Type")), "MI") = CompairStringResult.Equal Then
                                ''Pick Std FAT SNF Per
                                Dim ItemMasterFATPer As Decimal = 0
                                Dim ItemMasterSNFPer As Decimal = 0
                                If settPickProductCostFromItemUOMDetail Then
                                    qry = "select TSPL_PARAMETER_MASTER.Type, TSPL_ITEM_QC_PARAMETER_MASTER.Actual_Range from TSPL_ITEM_QC_PARAMETER_MASTER " + Environment.NewLine +
                                    "left outer join TSPL_PARAMETER_MASTER on TSPL_PARAMETER_MASTER.Code=TSPL_ITEM_QC_PARAMETER_MASTER.Code" + Environment.NewLine +
                                    "where Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "'"
                                    Dim dtSTDFatSnf As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                                    If dtSTDFatSnf IsNot Nothing AndAlso dtSTDFatSnf.Rows.Count > 0 Then
                                        For Each drFATSNF As DataRow In dtSTDFatSnf.Rows
                                            If clsCommon.CompairString(clsCommon.myCstr(drFATSNF("Type")), "FAT") = CompairStringResult.Equal Then
                                                ItemMasterFATPer = clsCommon.myCdbl(drFATSNF("Actual_Range"))
                                                If clsCommon.myCdbl(ItemMasterFATPer) <= 0 Then
                                                    Throw New Exception("Please Provide FAT Actual Range of Item " + clsCommon.myCstr(drDetail("Item_Code")) + "")
                                                End If
                                            End If
                                            If clsCommon.CompairString(clsCommon.myCstr(drFATSNF("Type")), "SNF") = CompairStringResult.Equal Then
                                                ItemMasterSNFPer = clsCommon.myCdbl(drFATSNF("Actual_Range"))
                                                If clsCommon.myCdbl(ItemMasterSNFPer) <= 0 Then
                                                    Throw New Exception("Please Provide SNF Actual Range of Item " + clsCommon.myCstr(drDetail("Item_Code")) + "")
                                                End If
                                            End If
                                        Next
                                    End If
                                End If
                                ''End of Pick Std FAT SNF Per
                                Dim dtFatSndClosing As DataTable = clsProcessProductionPlanning.GetMilkAndALLItemStockBalance_With_FATSNFKG(tExtraWhrClauseInvNew, clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Main_Location_Code")), clsCommon.myCstr(drDetail("From_Loaction_Code")), clsCommon.myCDate(drDetail("Issue_Date")), tran, clsCommon.myCstr(drDetail("Unit_Code")), drDetail("From_SubLocation_YN"))
                                If dtFatSndClosing IsNot Nothing AndAlso dtFatSndClosing.Rows.Count > 0 Then
                                    'If isFGItem Then ''Comment by balwinder on 10/06/2019 becuase fat/snf % is comming zero.
                                    '    objtr.fat_pers = ItemMasterFATPer
                                    '    objtr.snf_pers = ItemMasterSNFPer
                                    'Else
                                    If (settPickProductCostFromItemUOMDetail AndAlso (clsCommon.myCdbl(dtFatSndClosing.Rows(0)("fat_kg")) <= 0 OrElse clsCommon.myCdbl(dtFatSndClosing.Rows(0)("snf_kg")) <= 0 OrElse clsCommon.myCdbl(dtFatSndClosing.Rows(0)("qty")) <= 0)) Then
                                        objtr.fat_pers = ItemMasterFATPer
                                        objtr.snf_pers = ItemMasterSNFPer
                                    Else
                                        If clsCommon.myCdbl(dtFatSndClosing.Rows(0)("qty")) <> 0 Then
                                            objtr.fat_pers = clsBOM.GetFatSNFPercentage_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(dtFatSndClosing.Rows(0)("qty")), clsCommon.myCdbl(dtFatSndClosing.Rows(0)("fat_kg")), tran, settTankerDispatchAvgFATSNFPer)
                                            objtr.snf_pers = clsBOM.GetFatSNFPercentage_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(dtFatSndClosing.Rows(0)("qty")), clsCommon.myCdbl(dtFatSndClosing.Rows(0)("snf_kg")), tran, settTankerDispatchAvgFATSNFPer)
                                            If MyCheckBox3.Checked AndAlso settPickProductCostFromItemUOMDetail Then
                                                If objtr.fat_pers > (1.5 * ItemMasterFATPer) Then
                                                    objtr.fat_pers = ItemMasterFATPer
                                                End If
                                                If objtr.snf_pers > (1.5 * ItemMasterSNFPer) Then
                                                    objtr.snf_pers = ItemMasterSNFPer
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                                objtr.fat_kg = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(drDetail("Qty")), objtr.fat_pers, tran)
                                objtr.snf_kg = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(drDetail("Qty")), objtr.snf_pers, tran)

                                Dim objCost As MIlkComponentType = clsInventoryMovementNew.GetAvgCost(False, False, False, whrcla, clsCommon.myCstr(drDetail("Product_Type")), clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("From_Loaction_Code")), clsCommon.myCdbl(drDetail("Qty")), clsCommon.myCstr(drDetail("Unit_Code")), objtr.fat_kg, objtr.snf_kg, clsCommon.myCDate(drDetail("Issue_Date")), clsCommon.myCDate(drDetail("Issue_Date")), False, tran)
                                objtr.Fat_Rate = Math.Abs(Math.Round(If(objtr.fat_kg <= 0, 0, objCost.FAT_Cost / objtr.fat_kg), 2))
                                objtr.SNF_Rate = Math.Abs(Math.Round(If(objtr.snf_kg <= 0, 0, objCost.SNF_Cost / objtr.snf_kg), 2))
                                objtr.Fat_Amt = Math.Abs(objCost.FAT_Cost)
                                objtr.SNF_Amt = Math.Abs(objCost.SNF_Cost)
                                If MyCheckBox2.Checked Then
                                    If objtr.fat_pers > 100 Then
                                        Throw New Exception("Production Issue Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",FAT %:" + clsCommon.myCstr(objtr.fat_pers))
                                    End If
                                    If objtr.snf_pers > 100 Then
                                        Throw New Exception("Production Issue Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",SNF %" + clsCommon.myCstr(objtr.snf_pers))
                                    End If
                                End If
                            Else
                                If clsCommon.CompairString(clsCommon.myCstr(drDetail("Product_Type")), "MP") = CompairStringResult.Equal Then
                                    ''Pick Std FAT SNF Per
                                    If clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.PickProductCostFromItemUOMDetail, clsFixedParameterCode.PickProductCostFromItemUOMDetail, tran)) > 0 Then
                                        qry = "select TSPL_PARAMETER_MASTER.Type, TSPL_ITEM_QC_PARAMETER_MASTER.Actual_Range from TSPL_ITEM_QC_PARAMETER_MASTER " + Environment.NewLine +
                                        "left outer join TSPL_PARAMETER_MASTER on TSPL_PARAMETER_MASTER.Code=TSPL_ITEM_QC_PARAMETER_MASTER.Code" + Environment.NewLine +
                                        "where Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "'"
                                        Dim dtSTDFatSnf As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                                        If dtSTDFatSnf IsNot Nothing AndAlso dtSTDFatSnf.Rows.Count > 0 Then
                                            For Each drFATSNF As DataRow In dtSTDFatSnf.Rows
                                                If clsCommon.CompairString(clsCommon.myCstr(drFATSNF("Type")), "FAT") = CompairStringResult.Equal Then
                                                    objtr.fat_pers = clsCommon.myCdbl(drFATSNF("Actual_Range"))
                                                    If clsCommon.myCdbl(objtr.fat_pers) <= 0 Then
                                                        Throw New Exception("Please Provide FAT Actual Range of Item " + clsCommon.myCstr(drDetail("Item_Code")) + "")
                                                    End If
                                                End If
                                                If clsCommon.CompairString(clsCommon.myCstr(drFATSNF("Type")), "SNF") = CompairStringResult.Equal Then
                                                    objtr.snf_pers = clsCommon.myCdbl(drFATSNF("Actual_Range"))
                                                    If clsCommon.myCdbl(objtr.snf_pers) <= 0 Then
                                                        Throw New Exception("Please Provide SNF Actual Range of Item " + clsCommon.myCstr(drDetail("Item_Code")) + "")
                                                    End If
                                                End If
                                            Next
                                        End If
                                    End If
                                    ''End of Pick Std FAT SNF Per
                                    objtr.fat_kg = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(drDetail("Qty")), objtr.fat_pers, tran)
                                    objtr.snf_kg = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drDetail("Item_Code")), clsCommon.myCstr(drDetail("Unit_Code")), clsCommon.myCdbl(drDetail("Qty")), objtr.snf_pers, tran)
                                End If
                                Dim objCost As New MIlkComponentType
                                objCost = clsInventoryMovementNew.GetAvgCost(whrcla, objtr.product_type, clsCommon.myCstr(drDetail("Item_Code")), If(clsCommon.myLen(clsCommon.myCstr(drDetail("From_Loaction_Code"))) <= 0, clsCommon.myCstr(drDetail("To_Location_Code")), clsCommon.myCstr(drDetail("From_Loaction_Code"))), clsCommon.myCdbl(drDetail("Qty")), clsCommon.myCstr(drDetail("Unit_Code")), objtr.fat_kg, objtr.snf_kg, clsCommon.myCDate(drDetail("Issue_Date")), clsCommon.myCDate(drDetail("Issue_Date")), False, tran)
                                objtr.Fat_Rate = If(objtr.fat_kg <= 0, 0, objCost.FAT_Cost / objtr.fat_kg)
                                objtr.SNF_Rate = If(objtr.snf_kg <= 0, 0, objCost.SNF_Cost / objtr.snf_kg)
                                objtr.Fat_Amt = objCost.FAT_Cost
                                objtr.SNF_Amt = objCost.SNF_Cost
                            End If

                            Dim coll As New Hashtable()
                            clsCommon.AddColumnsForChange(coll, "FAT_Pers", objtr.fat_pers)
                            clsCommon.AddColumnsForChange(coll, "FAT_KG", objtr.fat_kg)
                            clsCommon.AddColumnsForChange(coll, "SNF_Pers", objtr.snf_pers)
                            clsCommon.AddColumnsForChange(coll, "SNF_KG", objtr.snf_kg)
                            clsCommon.AddColumnsForChange(coll, "Fat_Rate", objtr.Fat_Rate)
                            clsCommon.AddColumnsForChange(coll, "SNF_Rate", objtr.SNF_Rate)
                            clsCommon.AddColumnsForChange(coll, "Fat_Amt", objtr.Fat_Amt)
                            clsCommon.AddColumnsForChange(coll, "SNF_Amt", objtr.SNF_Amt)
                            qry = "Issue_Code='" + strDocNo + "' and SNO='" + clsCommon.myCstr(drDetail("SNO")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "'"
                            Dim dttem As DataTable = clsDBFuncationality.GetDataTable("select 1 from TSPL_PP_ISSUE_ITEM_DETAIL where " + qry, tran)
                            If dttem Is Nothing OrElse dttem.Rows.Count <= 0 Then
                                qry = "Issue_Code='" + strDocNo + "' and   Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "'"
                            End If
                            clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_ISSUE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)

                            Dim dtIssue As DataTable = clsDBFuncationality.GetDataTable("select * from TSPL_PP_ISSUE_ITEM_DETAIL where  " + qry, tran)
                            If dtIssue Is Nothing OrElse dtIssue.Rows.Count <= 0 Then
                                Throw New Exception("Issue No [" + strDocNo + " ] Item details Not found for item [" + clsCommon.myCstr(drDetail("Item_Code")) + "]")
                            End If



                            'If isFGItem Then
                            qry = "select STAGE_PROCESS_CODE from TSPL_PP_STAGE_PROCESS_HEAD where Main_Batch_Code='" + strBatchCode + "'"
                            Dim strNewDocCode As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, tran))
                            If clsCommon.myLen(strNewDocCode) > 0 Then
                                coll = New Hashtable()
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_Per", objtr.fat_pers)
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_KG", objtr.fat_kg)
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_Per", objtr.snf_pers)
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_KG", objtr.snf_kg)
                                clsCommon.AddColumnsForChange(coll, "Fat_Rate", objtr.Fat_Rate)
                                clsCommon.AddColumnsForChange(coll, "SNF_Rate", objtr.SNF_Rate)
                                clsCommon.AddColumnsForChange(coll, "Fat_Amt", objtr.Fat_Amt)
                                clsCommon.AddColumnsForChange(coll, "SNF_Amt", objtr.SNF_Amt)
                                qry = "STAGE_PROCESS_CODE='" + strNewDocCode + "' and Issue_Code='" + strDocNo + "' and SNO='" + clsCommon.myCstr(drDetail("SNO")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "' and From_Loaction_Code='" + clsCommon.myCstr(drDetail("From_Loaction_Code")) + "' and To_Location_Code='" + clsCommon.myCstr(drDetail("To_Location_Code")) + "'"
                                dttem = clsDBFuncationality.GetDataTable("select 1 from TSPL_PP_SP_ISSUE_ITEM_DETAIL where " + qry, tran)
                                If dttem Is Nothing OrElse dttem.Rows.Count <= 0 Then
                                    qry = "STAGE_PROCESS_CODE='" + strNewDocCode + "' and Issue_Code='" + strDocNo + "'  and Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "' and From_Loaction_Code='" + clsCommon.myCstr(drDetail("From_Loaction_Code")) + "' and To_Location_Code='" + clsCommon.myCstr(drDetail("To_Location_Code")) + "'"
                                End If
                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_SP_ISSUE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)
                            End If

                            qry = "select PROD_ENTRY_CODE from TSPL_PP_PRODUCTION_ENTRY where Batch_Code='" + strBatchCode + "'"
                            strNewDocCode = clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, tran))
                            If clsCommon.myLen(strNewDocCode) > 0 Then
                                coll = New Hashtable()
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_Per", objtr.fat_pers)
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_KG", objtr.fat_kg)
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_Per", objtr.snf_pers)
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_KG", objtr.snf_kg)
                                clsCommon.AddColumnsForChange(coll, "Fat_Rate", objtr.Fat_Rate)
                                clsCommon.AddColumnsForChange(coll, "SNF_Rate", objtr.SNF_Rate)
                                clsCommon.AddColumnsForChange(coll, "Fat_Amt", objtr.Fat_Amt)
                                clsCommon.AddColumnsForChange(coll, "SNF_Amt", objtr.SNF_Amt)
                                qry = "PROD_ENTRY_CODE='" + strNewDocCode + "' and Issue_Code='" + strDocNo + "' and SNO='" + clsCommon.myCstr(drDetail("SNO")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "' and From_Loaction_Code='" + clsCommon.myCstr(drDetail("From_Loaction_Code")) + "' and To_Location_Code='" + clsCommon.myCstr(drDetail("To_Location_Code")) + "'"
                                dttem = clsDBFuncationality.GetDataTable("select 1 from TSPL_PP_PE_ISSUE_ITEM_DETAIL where " + qry, tran)
                                If dttem Is Nothing OrElse dttem.Rows.Count <= 0 Then
                                    qry = "PROD_ENTRY_CODE='" + strNewDocCode + "' and Issue_Code='" + strDocNo + "' and  Item_Code='" + clsCommon.myCstr(drDetail("Item_Code")) + "' and From_Loaction_Code='" + clsCommon.myCstr(drDetail("From_Loaction_Code")) + "' and To_Location_Code='" + clsCommon.myCstr(drDetail("To_Location_Code")) + "'"
                                End If
                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_PE_ISSUE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)
                            End If
                            'End If
                        Next
                    End If
                    clsProcessProductionIssueEntry.PostData(clsUserMgtCode.frmProcessProductionIssueEntry, False, "", strDocNo, tran, strVoucherNo, False)
                    clsDBFuncationality.ExecuteNonQuery("delete from " + tabName + " where Issue_code='" + strDocNo + "'", tran)
                Else
                    clsProcessProductionIssueEntry.UnpostData(strDocNo, clsUserMgtCode.frmProcessProductionIssueEntry, tran)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

    Sub PEStandard(ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean, ByVal BatchCodeToProcess As String)
        Dim qry As String
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEStandard", tran)
            qry = "select TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_PP_STANDARDIZATION_HEAD" + Environment.NewLine +
      "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code  and TSPL_JOURNAL_MASTER.Source_Code='PR-ER'" + Environment.NewLine +
      "where TSPL_PP_STANDARDIZATION_HEAD.Posted=1 and TSPL_PP_STANDARDIZATION_HEAD.Standardization_Date>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_PP_STANDARDIZATION_HEAD.Standardization_Date<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' "

            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PP_STANDARDIZATION_HEAD.Loaction_Code in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            If TxtMultiSelectFinder12.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder12.arrValueMember.Count > 0 Then
                'qry += " and exists (select 1 from TSPL_PP_STD_ISSUE_ITEM_DETAIL where TSPL_PP_STD_ISSUE_ITEM_DETAIL.Standardization_Code=TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code and TSPL_PP_STD_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))"
                qry += "and (exists (select 1 from TSPL_PP_STD_ISSUE_ITEM_DETAIL where TSPL_PP_STD_ISSUE_ITEM_DETAIL.Standardization_Code=TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code and TSPL_PP_STD_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + ")) " + Environment.NewLine +
                "or exists(select 1 from TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL where TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Standardization_Code=TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code and TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + ")))"
            End If
            qry = "select * into Temp_PEStandard from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEStandard where 2=2 "
        If clsCommon.myLen(BatchCodeToProcess) > 0 Then
            qry += " and exists( select  1 from TSPL_PP_STANDARDIZATION_HEAD where TSPL_PP_STANDARDIZATION_HEAD.Main_Batch_Code='" + BatchCodeToProcess + "' and TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code=Temp_PEStandard.Standardization_Code) "
        End If
        qry += " order by  Standardization_Code"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("Standardization_Code"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    qry = "select  TSPL_PP_STD_ISSUE_ITEM_DETAIL.Standardization_Code,TSPL_PP_STANDARDIZATION_HEAD.Loaction_Code, TSPL_PP_STANDARDIZATION_HEAD.Standardization_Date,TSPL_PP_STD_ISSUE_ITEM_DETAIL.item_code,TSPL_PP_STD_ISSUE_ITEM_DETAIL.SNO,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Avail_Qty,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Avail_FAT_Per,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Avail_SNF_Per,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Avail_FAT_KG,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Avail_SNF_KG ,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Fat_Rate,TSPL_PP_STD_ISSUE_ITEM_DETAIL.SNF_Rate,TSPL_PP_STD_ISSUE_ITEM_DETAIL.Fat_Amt,TSPL_PP_STD_ISSUE_ITEM_DETAIL.SNF_Amt,TSPL_PP_STANDARDIZATION_HEAD.Child_Batch_Code" + Environment.NewLine +
                "from TSPL_PP_STD_ISSUE_ITEM_DETAIL" + Environment.NewLine +
                "left outer join TSPL_PP_STANDARDIZATION_HEAD on TSPL_PP_STANDARDIZATION_HEAD.Standardization_Code=TSPL_PP_STD_ISSUE_ITEM_DETAIL.Standardization_Code" + Environment.NewLine +
                "left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PP_STD_ISSUE_ITEM_DETAIL.Item_Code	 " + Environment.NewLine +
                "where TSPL_PP_STD_ISSUE_ITEM_DETAIL.Standardization_Code='" + strDocNo + "'  "
                    Dim dtDetail As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                    If dtDetail IsNot Nothing AndAlso dtDetail.Rows.Count > 0 Then
                        For Each drDetail As DataRow In dtDetail.Rows
                            qry = "select TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code,Item_Code,Qty,FAT_Pers,SNF_Pers,FAT_KG,SNF_KG,Fat_Rate,SNF_Rate,Fat_Amt,SNF_Amt from TSPL_PP_ISSUE_ITEM_DETAIL " + Environment.NewLine +
                            "left outer join TSPL_PP_ISSUE_HEAD on TSPL_PP_ISSUE_HEAD.Issue_Code=TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code" + Environment.NewLine +
                            "where TSPL_PP_ISSUE_HEAD.Is_post=1 and TSPL_PP_ISSUE_HEAD.Batch_Code='" + clsCommon.myCstr(drDetail("Child_Batch_Code")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                            Dim dtIssue As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                            If dtIssue IsNot Nothing AndAlso dtIssue.Rows.Count > 0 Then
                                If dtIssue.Rows.Count > 1 Then
                                    qry = "select max(Issue_Code) as Issue_Code,max(Item_Code) as Item_Code,sum(Qty) as Qty,cast( case when sum(Qty)=0 then 0 else sum(FAT_KG)*100/sum(Qty) end as decimal(18,2))  as FAT_Pers,cast( case when sum(Qty)=0 then 0 else sum(SNF_KG)*100/sum(Qty) end as decimal(18,2))  as SNF_Pers,sum(FAT_KG) as FAT_KG,sum(SNF_KG) as SNF_KG,cast( case when sum(FAT_KG)=0 then 0 else sum(Fat_Amt)/sum(FAT_KG) end as decimal(18,2)) as Fat_Rate,cast( case when sum(SNF_KG)=0 then 0 else sum(SNF_Amt)/sum(SNF_KG) end as decimal(18,2)) as SNF_Rate,sum(Fat_Amt) as Fat_Amt,sum(SNF_Amt) as SNF_Amt  from (" + qry + ")xx group by Item_Code"
                                    dtIssue = clsDBFuncationality.GetDataTable(qry, tran)
                                End If

                                Dim coll As New Hashtable()
                                clsCommon.AddColumnsForChange(coll, "Avail_Qty", clsCommon.myCdbl(dtIssue.Rows(0)("Qty")))
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_Per", clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers")))
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_Per", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers")))
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_KG", clsCommon.myCdbl(dtIssue.Rows(0)("FAT_KG")))
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_KG", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_KG")))
                                clsCommon.AddColumnsForChange(coll, "Fat_Rate", clsCommon.myCdbl(dtIssue.Rows(0)("Fat_Rate")))
                                clsCommon.AddColumnsForChange(coll, "SNF_Rate", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Rate")))
                                clsCommon.AddColumnsForChange(coll, "Fat_Amt", clsCommon.myCdbl(dtIssue.Rows(0)("Fat_Amt")))
                                clsCommon.AddColumnsForChange(coll, "SNF_Amt", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Amt")))
                                If MyCheckBox2.Checked Then
                                    If clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers")) > 100 Then
                                        Throw New Exception("Standardization Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",FAT %" + clsCommon.myCstr(clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers"))))
                                    End If
                                    If clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers")) > 100 Then
                                        Throw New Exception("Standardization Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",SNF %" + clsCommon.myCstr(clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers"))))
                                    End If
                                End If
                                qry = "Standardization_Code='" + strDocNo + "' and SNO='" + clsCommon.myCstr(drDetail("SNO")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                                Dim dttem As DataTable = clsDBFuncationality.GetDataTable("select 1 from TSPL_PP_STD_ISSUE_ITEM_DETAIL where " + qry, tran)
                                If dttem Is Nothing OrElse dttem.Rows.Count <= 0 Then
                                    qry = "Standardization_Code='" + strDocNo + "' and Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                                End If
                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_STD_ISSUE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)
                            End If
                        Next




                        ''Add Qty Row
                        Dim settTankerDispatchAvgFATSNFPer As Boolean = (clsCommon.myCdbl(clsFixedParameter.GetData(clsFixedParameterType.TankerDispatchAvgFATSNFPer, clsFixedParameterCode.TankerDispatchAvgFATSNFPer, tran)) = 1)
                        Dim CheckStockServerDate As Boolean = clsCommon.CompairString(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.CheckLiveStockInProductionDuringTrans, clsFixedParameterCode.CheckLiveStockInProductionDuringTrans, tran)), "1") = CompairStringResult.Equal
                        If settTankerDispatchAvgFATSNFPer Then
                            qry = "select TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.SNO,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Loaction_Code,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Item_Code,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Unit_Code,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.ADD_REMOVE_QTY,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.AR_FAT_Per,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.AR_FAT_KG,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Fat_Rate,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Fat_Amt,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.AR_SNF_Per,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.AR_SNF_KG,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.SNF_Rate,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.SNF_Amt,TSPL_ITEM_MASTER.Product_Type,TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.ADD_REMOVE_TYPE from TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Item_Code where TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.Standardization_Code='" + strDocNo + "' and TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL.ADD_REMOVE_TYPE='Add' and TSPL_ITEM_MASTER.Product_Type in ('MI','MP')"
                            Dim dtAdd As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                            If dtAdd IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                                For Each drAdd As DataRow In dtAdd.Rows
                                    Dim loc_type As Integer = 0
                                    qry = "select case when (isnull(is_section,'N')='N' and isnull(is_sub_location,'N')='N') then 'MAIN' when (isnull(is_section,'N')='Y' and isnull(is_sub_location,'N')='N') then 'SEC' when (isnull(is_section,'N')='N' and isnull(is_sub_location,'Y')='Y') then 'SUB' else'MAIN' end as [type] from tspl_location_master where location_code='" + clsCommon.myCstr(drAdd("Loaction_Code")) + "'"
                                    If clsCommon.CompairString(clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, tran)), "MAIN") = CompairStringResult.Equal Then
                                        loc_type = 2
                                    ElseIf clsCommon.CompairString(clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, tran)), "SUB") = CompairStringResult.Equal Then
                                        loc_type = 1
                                    ElseIf clsCommon.CompairString(clsCommon.myCstr(clsDBFuncationality.getSingleValue(qry, tran)), "SEC") = CompairStringResult.Equal Then
                                        loc_type = 0
                                    End If
                                    Dim dtTemp As DataTable = clsProcessProductionPlanning.GetMilkAndALLItemStockBalance_With_FATSNFKG(clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(dtDetail.Rows(0)("Loaction_Code")), clsCommon.myCstr(drAdd("Loaction_Code")), IIf(CheckStockServerDate = True, clsCommon.GETSERVERDATE(tran), clsCommon.myCDate(dtDetail.Rows(0)("Standardization_Date"))), tran, clsCommon.myCstr(drAdd("Unit_Code")), loc_type, IIf(clsCommon.CompairString(clsCommon.myCstr(drAdd("ADD_REMOVE_TYPE")), "Remove") = CompairStringResult.Equal, True, False))
                                    If dtTemp IsNot Nothing AndAlso dtTemp.Rows.Count > 0 Then
                                        Dim dblAddQty As Decimal = clsCommon.myCdbl(drAdd("ADD_REMOVE_QTY"))
                                        Dim AddFATPer As Decimal = clsBOM.GetFatSNFPercentage_AfterConversion(clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(drAdd("Unit_Code")), clsCommon.myCdbl(dtTemp.Rows(0)("qty")), clsCommon.myCdbl(dtTemp.Rows(0)("fat_kg")), tran, settTankerDispatchAvgFATSNFPer)
                                        Dim AddSNFPer As Decimal = clsBOM.GetFatSNFPercentage_AfterConversion(clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(drAdd("Unit_Code")), clsCommon.myCdbl(dtTemp.Rows(0)("qty")), clsCommon.myCdbl(dtTemp.Rows(0)("snf_kg")), tran, settTankerDispatchAvgFATSNFPer)
                                        Dim AddFatKg As Decimal = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(drAdd("Unit_Code")), dblAddQty, AddFATPer, tran)
                                        Dim AddSNFKg As Decimal = clsBOM.GetFatSNFKG_AfterConversion(clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(drAdd("Unit_Code")), dblAddQty, AddSNFPer, tran)
                                        If dblAddQty > clsCommon.myCdbl(dtTemp.Rows(0)("qty")) Then
                                            Throw New Exception("Std. Doc No [" + strDocNo + "] Added Item Code [" & clsCommon.myCstr(drAdd("Item_Code")) & "] Required Qty [" & clsCommon.myCstr(dblAddQty) & "] Available Qty [" & clsCommon.myCstr(clsCommon.myCdbl((dtTemp.Rows(0)("qty")))) & "]")
                                        End If


                                        Dim coll As New Hashtable()
                                        clsCommon.AddColumnsForChange(coll, "ADD_REMOVE_QTY", dblAddQty)
                                        clsCommon.AddColumnsForChange(coll, "AR_FAT_Per", AddFATPer)
                                        clsCommon.AddColumnsForChange(coll, "AR_SNF_Per", AddSNFPer)
                                        clsCommon.AddColumnsForChange(coll, "AR_FAT_KG", AddFatKg)
                                        clsCommon.AddColumnsForChange(coll, "AR_SNF_KG", AddSNFKg)
                                        Dim objCost As New MIlkComponentType
                                        objCost = clsInventoryMovementNew.GetAvgCost(clsCommon.myCstr(drAdd("Product_Type")), clsCommon.myCstr(drAdd("Item_Code")), clsCommon.myCstr(drAdd("Loaction_Code")), dblAddQty, clsCommon.myCstr(drAdd("Unit_Code")), AddFatKg, AddSNFKg, clsCommon.myCDate(dtDetail.Rows(0)("Standardization_Date")), clsCommon.myCDate(dtDetail.Rows(0)("Standardization_Date")), False, tran)
                                        clsCommon.AddColumnsForChange(coll, "Fat_Rate", If(AddFatKg <= 0, 0, objCost.FAT_Cost / AddFatKg))
                                        clsCommon.AddColumnsForChange(coll, "SNF_Rate", If(AddSNFKg <= 0, 0, objCost.SNF_Cost / AddSNFKg))
                                        clsCommon.AddColumnsForChange(coll, "Fat_Amt", objCost.FAT_Cost)
                                        clsCommon.AddColumnsForChange(coll, "SNF_Amt", objCost.SNF_Cost)
                                        qry = "SNO='" + clsCommon.myCstr(drAdd("SNO")) + "' and Standardization_Code='" + strDocNo + "'"
                                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_STD_ADD_REMOVE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)

                                        qry = "Update TSPL_PP_STD_QC_DETAIL set Actual_Range='" + clsCommon.myCstr(AddFATPer) + "' where Standardization_Code='" + strDocNo + "' and QC_Type='Add/Remove'  and Parent_Line_No='" + clsCommon.myCstr(clsCommon.myCdbl(drAdd("SNO")) - 1) + "' and Parameter_Code='FAT'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        qry = "Update TSPL_PP_STD_QC_DETAIL set Actual_Range='" + clsCommon.myCstr(AddSNFPer) + "' where Standardization_Code='" + strDocNo + "' and QC_Type='Add/Remove'  and Parent_Line_No='" + clsCommon.myCstr(clsCommon.myCdbl(drAdd("SNO")) - 1) + "' and Parameter_Code='SNF'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        ''Update in Final QC
                                        qry = "select qc_code from TSPL_PP_STD_FINALQC_HEAD where Against_STD_Code ='" + strDocNo + "'"
                                        Dim strFinalQCNo As String = clsDBFuncationality.getSingleValue(qry, tran)

                                        qry = "SNO='" + clsCommon.myCstr(drAdd("SNO")) + "' and qc_code='" + strFinalQCNo + "'"
                                        clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_STD_FINALQC_ADD_REMOVE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)

                                        qry = "Update TSPL_PP_STD_FINALQC_QC_DETAIL set Actual_Range='" + clsCommon.myCstr(AddFATPer) + "' where QC_Code='" + strFinalQCNo + "' and QC_Type='Add/Remove'  and Parent_Line_No='" + clsCommon.myCstr(clsCommon.myCdbl(drAdd("SNO")) - 1) + "' and Parameter_Code='FAT'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        qry = "Update TSPL_PP_STD_FINALQC_QC_DETAIL set Actual_Range='" + clsCommon.myCstr(AddSNFPer) + "' where QC_Code='" + strFinalQCNo + "' and QC_Type='Add/Remove'  and Parent_Line_No='" + clsCommon.myCstr(clsCommon.myCdbl(drAdd("SNO")) - 1) + "' and Parameter_Code='SNF'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        qry = "Update TSPL_PP_STD_FINALQC_DETAIL set FAT_Per='" + clsCommon.myCstr(AddFATPer) + "',SNF_Per='" + clsCommon.myCstr(AddSNFPer) + "' where QC_Code='" + strFinalQCNo + "'  and qc_from='Add/Remove' and item_code='" + clsCommon.myCstr(drAdd("Item_Code")) + "'"
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        Dim LinNo As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue("select Line_No-1  from TSPL_PP_STD_FINALQC_DETAIL where QC_Code='" + strFinalQCNo + "'  and qc_from='Add/Remove' and item_code='" + clsCommon.myCstr(drAdd("Item_Code")) + "'", tran))
                                        qry = "Update TSPL_PP_STD_FINALQC_QC_PARAMETER set Param_Field_Value='" + clsCommon.myCstr(AddFATPer) + "' where QC_Code='" + strFinalQCNo + "' and Param_Type='FAT' and LINE_NO=" + clsCommon.myCstr(LinNo) + ""
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        qry = "Update TSPL_PP_STD_FINALQC_QC_PARAMETER set Param_Field_Value='" + clsCommon.myCstr(AddSNFPer) + "' where QC_Code='" + strFinalQCNo + "' and Param_Type='SNF' and LINE_NO=" + clsCommon.myCstr(LinNo) + ""
                                        clsDBFuncationality.ExecuteNonQuery(qry, tran)

                                        ''End of Update in Final QC
                                    End If
                                Next
                            End If
                        End If

                        ''End of Add Qty Row




                    End If

                    Dim obj As clsProcessProductionStandardization = clsProcessProductionStandardization.GetData(strDocNo, "", NavigatorType.Current, tran)
                    Dim dblQty As Decimal = 0
                    Dim dblFATKG As Decimal = 0
                    Dim dblSNFKG As Decimal = 0


                    dblQty = 0
                    dblFATKG = 0
                    dblSNFKG = 0
                    Dim dblFATAmt As Decimal = 0
                    Dim dblSNFAmt As Decimal = 0
                    For ii As Integer = 0 To obj.ArrIssueItem.Count - 1
                        dblQty += obj.ArrIssueItem(ii).Avail_Qty
                        If obj.ArrIssueItem(ii).Avail_FAT_KG > 0 Then
                            dblFATKG += obj.ArrIssueItem(ii).Avail_FAT_KG
                            dblFATAmt += obj.ArrIssueItem(ii).Fat_Amt
                        End If

                        If obj.ArrIssueItem(ii).Avail_SNF_KG > 0 Then
                            dblSNFKG += obj.ArrIssueItem(ii).Avail_SNF_KG
                            dblSNFAmt += obj.ArrIssueItem(ii).SNF_Amt
                        End If
                    Next
                    obj.Tot_Issue_Qty = clsCommon.myFormat(Math.Round(dblQty, 2, MidpointRounding.ToEven))
                    obj.Tot_Issue_FATKG = clsCommon.myFormat(Math.Round(dblFATKG, 2, MidpointRounding.ToEven))
                    obj.Tot_Issue_SNFKG = clsCommon.myFormat(Math.Round(dblSNFKG, 2, MidpointRounding.ToEven))
                    If dblFATAmt <= 0 OrElse dblFATKG <= 0 Then
                        obj.Avg_Rate_FAT = clsCommon.myFormat(Math.Round(0, 2, MidpointRounding.ToEven))
                    Else
                        obj.Avg_Rate_FAT = clsCommon.myFormat(Math.Round(dblFATAmt / dblFATKG, 2, MidpointRounding.ToEven))
                    End If
                    If dblSNFAmt <= 0 OrElse dblSNFKG <= 0 Then
                        obj.Avg_Rate_SNF = clsCommon.myFormat(Math.Round(0, 2, MidpointRounding.ToEven))
                    Else
                        obj.Avg_Rate_SNF = clsCommon.myFormat(Math.Round(dblSNFAmt / dblSNFKG, 2, MidpointRounding.ToEven))
                    End If

                    obj.Tot_Difference_Qty = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_Qty) - clsCommon.myCdbl(obj.Tot_Produce_Qty), 2, MidpointRounding.ToEven))
                    obj.Tot_Difference_FATKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_FATKG) - clsCommon.myCdbl(obj.Tot_Produce_FATKG), 2, MidpointRounding.ToEven))
                    obj.Tot_Difference_SNFKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_SNFKG) - clsCommon.myCdbl(obj.Tot_Produce_SNFKG), 2, MidpointRounding.ToEven))




                    obj.Tot_Net_Qty = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_Qty) + clsCommon.myCdbl(obj.Tot_AddRemove_Qty), 2, MidpointRounding.ToEven))
                    obj.Tot_Net_FATKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_FATKG) + clsCommon.myCdbl(obj.Tot_AddRemove_FATKG), 2, MidpointRounding.ToEven))
                    obj.Tot_Net_SNFKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_SNFKG) + clsCommon.myCdbl(obj.Tot_AddRemove_SNFKG), 2, MidpointRounding.ToEven))


                    clsProcessProductionStandardization.SaveData(False, obj, tran)
                    clsProcessProductionStandardization.PostData(clsUserMgtCode.frmProcessProductionStandardization, strDocNo, "", tran, strVoucherNo)
                    clsDBFuncationality.ExecuteNonQuery("delete from Temp_PEStandard where Standardization_Code='" + strDocNo + "'", tran)
                Else
                    clsProcessProductionStandardization.UnpostData(strDocNo, clsUserMgtCode.frmProcessProductionStandardization, tran)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

    Sub PEStandardFinalQC(ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean, ByVal BatchCodeToProcess As String)
        Dim qry As String
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEStandardFinalQC", tran)
            qry = "select TSPL_PP_STD_FINALQC_HEAD.QC_Code,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_PP_STD_FINALQC_HEAD" + Environment.NewLine +
       "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PP_STD_FINALQC_HEAD.QC_Code  and TSPL_JOURNAL_MASTER.Source_Code='PS-FQ'" + Environment.NewLine +
       "where TSPL_PP_STD_FINALQC_HEAD.Posted=1 and TSPL_PP_STD_FINALQC_HEAD.QC_Date>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_PP_STD_FINALQC_HEAD.QC_Date<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "'"
            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PP_STD_FINALQC_HEAD.Loaction_Code in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            If TxtMultiSelectFinder12.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder12.arrValueMember.Count > 0 Then
                'qry += " and exists (select 1 from TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL where TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.QC_Code=TSPL_PP_STD_FINALQC_HEAD.QC_Code and TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))"
                qry += " and (exists (select 1 from TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL where TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.QC_Code=TSPL_PP_STD_FINALQC_HEAD.QC_Code and TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))" + Environment.NewLine +
                " or exists (select 1 from TSPL_PP_STD_FINALQC_ADD_REMOVE_ITEM_DETAIL where TSPL_PP_STD_FINALQC_ADD_REMOVE_ITEM_DETAIL.QC_Code=TSPL_PP_STD_FINALQC_HEAD.QC_Code and TSPL_PP_STD_FINALQC_ADD_REMOVE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + ")))"
            End If
            qry = "select * into Temp_PEStandardFinalQC from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEStandardFinalQC where 2=2"
        If clsCommon.myLen(BatchCodeToProcess) > 0 Then
            qry += " and exists( select 1 from TSPL_PP_STD_FINALQC_HEAD where Main_Batch_Code='" + BatchCodeToProcess + "' and TSPL_PP_STD_FINALQC_HEAD.QC_Code=Temp_PEStandardFinalQC.QC_Code)"
        End If
        qry += " order by QC_Code"

        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("QC_Code"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    qry = "select  TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.QC_Code,TSPL_PP_STD_FINALQC_HEAD.QC_Date,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.item_code,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.SNO,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Avail_Qty,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Avail_FAT_Per,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Avail_SNF_Per,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Avail_FAT_KG,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Avail_SNF_KG ,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Fat_Rate,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.SNF_Rate,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Fat_Amt,TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.SNF_Amt,TSPL_PP_STD_FINALQC_HEAD.Child_Batch_Code" + Environment.NewLine +
                "from TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL" + Environment.NewLine +
                "left outer join TSPL_PP_STD_FINALQC_HEAD on TSPL_PP_STD_FINALQC_HEAD.QC_Code=TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.QC_Code" + Environment.NewLine +
                "left outer join TSPL_ITEM_MASTER on TSPL_ITEM_MASTER.Item_Code=TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.Item_Code	 " + Environment.NewLine +
                "where TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL.QC_Code='" + strDocNo + "'"
                    Dim dtDetail As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                    If dtDetail IsNot Nothing AndAlso dtDetail.Rows.Count > 0 Then
                        For Each drDetail As DataRow In dtDetail.Rows
                            qry = "select TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code,Item_Code,Qty,FAT_Pers,SNF_Pers,FAT_KG,SNF_KG,Fat_Rate,SNF_Rate,Fat_Amt,SNF_Amt from TSPL_PP_ISSUE_ITEM_DETAIL " + Environment.NewLine +
                            "left outer join TSPL_PP_ISSUE_HEAD on TSPL_PP_ISSUE_HEAD.Issue_Code=TSPL_PP_ISSUE_ITEM_DETAIL.Issue_Code" + Environment.NewLine +
                            "where TSPL_PP_ISSUE_HEAD.Is_post=1 and TSPL_PP_ISSUE_HEAD.Batch_Code='" + clsCommon.myCstr(drDetail("Child_Batch_Code")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                            Dim dtIssue As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                            If dtIssue IsNot Nothing AndAlso dtIssue.Rows.Count > 0 Then
                                If dtIssue.Rows.Count > 1 Then
                                    qry = "select max(Issue_Code) as Issue_Code,max(Item_Code) as Item_Code,sum(Qty) as Qty,cast( case when sum(Qty)=0 then 0 else sum(FAT_KG)*100/sum(Qty) end as decimal(18,2))  as FAT_Pers,cast( case when sum(Qty)=0 then 0 else sum(SNF_KG)*100/sum(Qty) end as decimal(18,2))  as SNF_Pers,sum(FAT_KG) as FAT_KG,sum(SNF_KG) as SNF_KG,cast( case when sum(FAT_KG)=0 then 0 else sum(Fat_Amt)/sum(FAT_KG) end as decimal(18,2)) as Fat_Rate,cast( case when sum(SNF_KG)=0 then 0 else sum(SNF_Amt)/sum(SNF_KG) end as decimal(18,2)) as SNF_Rate,sum(Fat_Amt) as Fat_Amt,sum(SNF_Amt) as SNF_Amt  from (" + qry + ")xx group by Item_Code"
                                    dtIssue = clsDBFuncationality.GetDataTable(qry, tran)
                                End If
                                Dim coll As New Hashtable()
                                clsCommon.AddColumnsForChange(coll, "Avail_Qty", clsCommon.myCdbl(dtIssue.Rows(0)("Qty")))
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_Per", clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers")))
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_Per", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers")))
                                clsCommon.AddColumnsForChange(coll, "Avail_FAT_KG", clsCommon.myCdbl(dtIssue.Rows(0)("FAT_KG")))
                                clsCommon.AddColumnsForChange(coll, "Avail_SNF_KG", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_KG")))
                                clsCommon.AddColumnsForChange(coll, "Fat_Rate", clsCommon.myCdbl(dtIssue.Rows(0)("Fat_Rate")))
                                clsCommon.AddColumnsForChange(coll, "SNF_Rate", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Rate")))
                                clsCommon.AddColumnsForChange(coll, "Fat_Amt", clsCommon.myCdbl(dtIssue.Rows(0)("Fat_Amt")))
                                clsCommon.AddColumnsForChange(coll, "SNF_Amt", clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Amt")))
                                If MyCheckBox2.Checked Then
                                    If clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers")) > 100 Then
                                        Throw New Exception("Standardization Final QC Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",FAT %" + clsCommon.myCstr(clsCommon.myCdbl(dtIssue.Rows(0)("FAT_Pers"))))
                                    End If
                                    If clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers")) > 100 Then
                                        Throw New Exception("Standardization Final QC Document No:" + strDocNo + ",Item:" + clsCommon.myCstr(drDetail("Item_Code")) + ",SNF %" + clsCommon.myCstr(clsCommon.myCdbl(dtIssue.Rows(0)("SNF_Pers"))))
                                    End If
                                End If
                                qry = "QC_Code='" + strDocNo + "' and SNO='" + clsCommon.myCstr(drDetail("SNO")) + "' and Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                                Dim dttem As DataTable = clsDBFuncationality.GetDataTable("select 1 from TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL where " + qry, tran)
                                If dttem Is Nothing OrElse dttem.Rows.Count <= 0 Then
                                    qry = "QC_Code='" + strDocNo + "' and  Item_Code='" + clsCommon.myCstr(drDetail("item_code")) + "'"
                                End If
                                clsCommonFunctionality.UpdateDataTable(coll, "TSPL_PP_STD_FINALQC_ISSUE_ITEM_DETAIL", OMInsertOrUpdate.Update, qry, tran)
                            End If
                        Next
                    End If

                    Dim obj As clsPPStdFinalQCHead = clsPPStdFinalQCHead.GetData(strDocNo, "", NavigatorType.Current, tran)
                    Dim dblQty As Decimal = 0
                    Dim dblFATKG As Decimal = 0
                    Dim dblSNFKG As Decimal = 0


                    dblQty = 0
                    dblFATKG = 0
                    dblSNFKG = 0
                    Dim dblFATAmt As Decimal = 0
                    Dim dblSNFAmt As Decimal = 0
                    For ii As Integer = 0 To obj.ArrIssueItem.Count - 1
                        dblQty += obj.ArrIssueItem(ii).Avail_Qty
                        If obj.ArrIssueItem(ii).Avail_FAT_KG > 0 Then
                            dblFATKG += obj.ArrIssueItem(ii).Avail_FAT_KG
                            dblFATAmt += obj.ArrIssueItem(ii).Fat_Amt
                        End If

                        If obj.ArrIssueItem(ii).Avail_SNF_KG > 0 Then
                            dblSNFKG += obj.ArrIssueItem(ii).Avail_SNF_KG
                            dblSNFAmt += obj.ArrIssueItem(ii).SNF_Amt
                        End If
                    Next
                    obj.Tot_Issue_Qty = clsCommon.myFormat(Math.Round(dblQty, 2, MidpointRounding.ToEven))
                    obj.Tot_Issue_FATKG = clsCommon.myFormat(Math.Round(dblFATKG, 2, MidpointRounding.ToEven))
                    obj.Tot_Issue_SNFKG = clsCommon.myFormat(Math.Round(dblSNFKG, 2, MidpointRounding.ToEven))
                    If dblFATAmt <= 0 OrElse dblFATKG <= 0 Then
                        obj.Avg_Rate_FAT = clsCommon.myFormat(Math.Round(0, 2, MidpointRounding.ToEven))
                    Else
                        obj.Avg_Rate_FAT = clsCommon.myFormat(Math.Round(dblFATAmt / dblFATKG, 2, MidpointRounding.ToEven))
                    End If
                    If dblSNFAmt <= 0 OrElse dblSNFKG <= 0 Then
                        obj.Avg_Rate_SNF = clsCommon.myFormat(Math.Round(0, 2, MidpointRounding.ToEven))
                    Else
                        obj.Avg_Rate_SNF = clsCommon.myFormat(Math.Round(dblSNFAmt / dblSNFKG, 2, MidpointRounding.ToEven))
                    End If

                    obj.Tot_Difference_Qty = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_Qty) - clsCommon.myCdbl(obj.Tot_Produce_Qty), 2, MidpointRounding.ToEven))
                    obj.Tot_Difference_FATKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_FATKG) - clsCommon.myCdbl(obj.Tot_Produce_FATKG), 2, MidpointRounding.ToEven))
                    obj.Tot_Difference_SNFKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Issue_SNFKG) - clsCommon.myCdbl(obj.Tot_Produce_SNFKG), 2, MidpointRounding.ToEven))

                    obj.Tot_Net_Qty = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_Qty) + clsCommon.myCdbl(obj.Tot_AddRemove_Qty), 2, MidpointRounding.ToEven))
                    obj.Tot_Net_FATKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_FATKG) + clsCommon.myCdbl(obj.Tot_AddRemove_FATKG), 2, MidpointRounding.ToEven))
                    obj.Tot_Net_SNFKG = clsCommon.myFormat(Math.Round(clsCommon.myCdbl(obj.Tot_Difference_SNFKG) + clsCommon.myCdbl(obj.Tot_AddRemove_SNFKG), 2, MidpointRounding.ToEven))

                    clsPPStdFinalQCHead.SaveData(False, obj, tran)
                    clsPPStdFinalQCHead.PostData(clsUserMgtCode.ProcessProductionStandardizationFinalQC, strDocNo, "", tran, strVoucherNo)
                    clsDBFuncationality.ExecuteNonQuery("delete from Temp_PEStandardFinalQC where QC_Code='" + strDocNo + "'", tran)
                Else
                    clsPPStdFinalQCHead.UnpostData(strDocNo, clsUserMgtCode.ProcessProductionStandardizationFinalQC, tran, False)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

    Sub PEProductionEntry(ByVal WIPDate As Date, ByVal tran As SqlTransaction, ByVal isForPost As Boolean, ByVal BatchCodeToProcess As String)
        Dim qry As String
        If Not isForPost Then
            ExecuteQeuryWithCatch("drop table Temp_PEProductionEntry", tran)
            qry = "select TSPL_PP_PRODUCTION_ENTRY.PROD_ENTRY_CODE,TSPL_JOURNAL_MASTER.Voucher_No from TSPL_PP_PRODUCTION_ENTRY" + Environment.NewLine +
      "left outer join TSPL_JOURNAL_MASTER on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_PP_PRODUCTION_ENTRY.PROD_ENTRY_CODE  and TSPL_JOURNAL_MASTER.Source_Code='PR-ER'" + Environment.NewLine +
      "where TSPL_PP_PRODUCTION_ENTRY.Posted=1 and TSPL_PP_PRODUCTION_ENTRY.PROD_DATE>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' and TSPL_PP_PRODUCTION_ENTRY.PROD_DATE<='" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(WIPDate), "dd/MMM/yyyy hh:mm:ss tt") + "' "
            If txtLocation.arrValueMember IsNot Nothing AndAlso txtLocation.arrValueMember.Count > 0 Then
                qry += " and TSPL_PP_PRODUCTION_ENTRY.LOCATION_CODE in (" + clsCommon.GetMulcallString(txtLocation.arrValueMember) + ") "
            End If
            If TxtMultiSelectFinder12.arrValueMember IsNot Nothing AndAlso TxtMultiSelectFinder12.arrValueMember.Count > 0 Then
                qry += " and exists (select 1 from TSPL_PP_PE_ISSUE_ITEM_DETAIL where TSPL_PP_PE_ISSUE_ITEM_DETAIL.PROD_ENTRY_CODE=TSPL_PP_PRODUCTION_ENTRY.PROD_ENTRY_CODE and TSPL_PP_PE_ISSUE_ITEM_DETAIL.Item_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder12.arrValueMember) + "))"
            End If
            qry = "select * into Temp_PEProductionEntry from (" + qry + ")xx"
            clsDBFuncationality.ExecuteNonQuery(qry, tran)
        End If
        qry = "Select * from Temp_PEProductionEntry where 2=2 "
        If clsCommon.myLen(BatchCodeToProcess) > 0 Then
            qry += " and exists(select 1 from TSPL_PP_PRODUCTION_ENTRY where TSPL_PP_PRODUCTION_ENTRY.batch_code='" + BatchCodeToProcess + "' and TSPL_PP_PRODUCTION_ENTRY.PROD_ENTRY_CODE=Temp_PEProductionEntry.PROD_ENTRY_CODE)"
        End If
        qry += " order by  PROD_ENTRY_CODE"
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                Dim strDocNo As String = clsCommon.myCstr(dr("PROD_ENTRY_CODE"))
                Dim strVoucherNo As String = clsCommon.myCstr(dr("Voucher_No"))
                If isForPost Then
                    Dim objPE As clsProductionEntry = clsProductionEntry.GetData(strDocNo, "", NavigatorType.Current, tran)
                    clsPPPEWFItemDetail.SaveData(objPE, tran) ''To update Cost of wreakage or back to silo qty.
                    clsProductionEntry.PostData(clsUserMgtCode.frmProductionEntry, strDocNo, "", False, tran, strVoucherNo)
                    clsDBFuncationality.ExecuteNonQuery("Delete from Temp_PEProductionEntry where PROD_ENTRY_CODE='" + strDocNo + "' ", tran)
                Else
                    clsProductionEntry.UnpostData(strDocNo, clsUserMgtCode.frmProductionEntry, tran, False)
                End If
                UpdateInveMovPostingDateToPunchaingDate(strDocNo, tran)
            Next
        End If
    End Sub

