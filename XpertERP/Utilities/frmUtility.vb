    Private Sub btnSave_Click(sender As Object, e As EventArgs) Handles btnSave.Click
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            Dim strVal As String = IIf(chkPurchaseAccounting.Checked, "1", "0")
            Dim strRevVal As String = IIf(chkPurchaseAccounting.Checked, "0", "1")

            clsFixedParameter.UpdateData(clsFixedParameterType.AllowPurchaseAccounting, clsFixedParameterCode.AllowPurchaseAccounting, strVal, trans)
            clsFixedParameter.UpdateData(clsFixedParameterType.SkipCogsEntry, clsFixedParameterCode.SkipCogsEntry, strVal, trans)
            clsFixedParameter.UpdateData(clsFixedParameterType.SkipDiffGLOnPI, clsFixedParameterCode.SkipDiffGLOnPI, strVal, trans)

            Dim qry As String = "update TSPL_INV_PARAMETERS  set    IsCreateJEForStoreAdj='" + strRevVal + "',IsCreateJEForProductionEntry='" + strRevVal + "',  IsCreateJEForSRN='" + strRevVal + "' "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            clsFixedParameter.UpdateData(clsFixedParameterType.CreateJEForProvisionEntry, "", "0", trans)
            If txtJEProvisionEntry.arrValueMember IsNot Nothing AndAlso txtJEProvisionEntry.arrValueMember.Count > 0 Then
                For Each Str As String In txtJEProvisionEntry.arrValueMember
                    clsFixedParameter.UpdateData(clsFixedParameterType.CreateJEForProvisionEntry, Str, "1", trans)
                Next
            End If

            trans.Commit()
            clsCommon.MyMessageBoxShow(Me, "Successfully Applied Purchase Account Setting", Me.Text)
        Catch ex As Exception
            trans.Rollback()
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try

    End Sub


