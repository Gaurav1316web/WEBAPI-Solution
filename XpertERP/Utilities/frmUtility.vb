    Private Sub RadButton286_Click(sender As Object, e As EventArgs) Handles RadButton286.Click
        Try
            If TxtMultiSelectFinder15.arrValueMember Is Nothing OrElse TxtMultiSelectFinder15.arrValueMember.Count <= 0 Then
                Throw New Exception("Please select At least One Document To Delete")
            End If
            Dim StrAllException As String = ""


            Dim qry As String = "select Acquisition_Code from TSPL_ACQUISITION_HEAD where Acquisition_Code in (" + clsCommon.GetMulcallString(TxtMultiSelectFinder15.arrValueMember) + ")"
            Dim dtAcq As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dtAcq IsNot Nothing AndAlso dtAcq.Rows.Count > 0 Then
                For Each drAcq As DataRow In dtAcq.Rows
                    Dim strDocNo As String = clsCommon.myCstr(drAcq("Acquisition_Code"))
                    Dim tran As SqlTransaction = clsDBFuncationality.GetTransactin()
                    Try
                        qry = "select Asset_Code from TSPL_ACQUISITION_DETAIL where Acquisition_Code='" + strDocNo + "' "
                        Dim dtAsset As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                        If dtAsset IsNot Nothing AndAlso dtAsset.Rows.Count > 0 Then
                            For Each drAsset As DataRow In dtAsset.Rows
                                qry = "select Document_Code from TSPL_ASSET_DEPRECIATION where Asset_Code='" + clsCommon.myCstr(drAsset("Asset_Code")) + "'"
                                If MyDateTimePicker6.Checked Then
                                    qry += " and TSPL_ASSET_DEPRECIATION.Document_Date>='" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(MyDateTimePicker6.Value), "dd/MMM/yyyy hh:mm:ss tt") + "'"
                                End If
                                qry += "order by Document_Date"
                                Dim dtDep As DataTable = clsDBFuncationality.GetDataTable(qry, tran)
                                If dtDep IsNot Nothing AndAlso dtDep.Rows.Count > 0 Then
                                    For Each drDep As DataRow In dtDep.Rows
                                        clsAssetDepreciation.RevereAndDelete(clsUserMgtCode.FAAssetDepreciation, "Reverse And Recreate", clsCommon.myCstr(drDep("Document_Code")), tran)
                                    Next
                                End If
                            Next
                        End If
                        If MyCheckBox13.Checked Then
                            clsAcquisitionHead.ReverseAndUnpost(strDocNo, tran)
                            clsAcquisitionHead.DeleteData(strDocNo, tran)
                        End If

                        tran.Commit()
                    Catch ex As Exception
                        tran.Rollback()
                        StrAllException += "Error In Document no:" + strDocNo + Environment.NewLine + ex.Message
                    End Try
                Next
            End If
            If clsCommon.myLen(StrAllException) > 0 Then
                clsCommon.MyMessageBoxShow(StrAllException, Me.Text)
            Else
                clsCommon.MyMessageBoxShow("Successfully reverse and unposted", Me.Text)
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message, Me.Text)
        End Try
    End Sub

