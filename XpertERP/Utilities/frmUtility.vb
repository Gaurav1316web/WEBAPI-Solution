            Dim qry As String = "update TSPL_INVENTORY_MOVEMENT set fat_per=coalesce(TSPL_WRECKAGE_BOOKING.avail_FAT_per,0),Fat_kg=coalesce(TSPL_WRECKAGE_BOOKING.avail_FAT_KG,0),snf_per=coalesce(TSPL_WRECKAGE_BOOKING.avail_SNF_per,0),snf_kg=coalesce(TSPL_WRECKAGE_BOOKING.avail_SNF_KG,0),fat_rate=TSPL_WRECKAGE_BOOKING.Fat_Rate,fat_amt=TSPL_WRECKAGE_BOOKING.Fat_Amt,snf_rate=TSPL_WRECKAGE_BOOKING.SNF_Rate,snf_amt=TSPL_WRECKAGE_BOOKING.SNF_Amt,Avg_Cost=(TSPL_WRECKAGE_BOOKING.Fat_Amt+TSPL_WRECKAGE_BOOKING.SNF_Amt),FIFO_Cost=(TSPL_WRECKAGE_BOOKING.Fat_Amt+TSPL_WRECKAGE_BOOKING.SNF_Amt),LIFO_Cost=(TSPL_WRECKAGE_BOOKING.Fat_Amt+TSPL_WRECKAGE_BOOKING.SNF_Amt),Basic_Cost=((TSPL_WRECKAGE_BOOKING.Fat_Amt+TSPL_WRECKAGE_BOOKING.SNF_Amt)/(case when TSPL_INVENTORY_MOVEMENT.Qty<=0 then 1 else TSPL_INVENTORY_MOVEMENT.Qty end)),Net_Cost=(TSPL_WRECKAGE_BOOKING.Fat_Amt+TSPL_WRECKAGE_BOOKING.SNF_Amt) from TSPL_WRECKAGE_BOOKING where TSPL_INVENTORY_MOVEMENT.Trans_Type='" + clsUserMgtCode.frmWreckageBooking + "' and cast(TSPL_INVENTORY_MOVEMENT.Punching_Date as date)>='" & clsCommon.GetPrintDate(dtpFatSNFUpdateFromDate.Value, "dd-MMM-yyyy") & "' and TSPL_INVENTORY_MOVEMENT.Source_Doc_No=TSPL_WRECKAGE_BOOKING.WRECKAGE_CODE and TSPL_INVENTORY_MOVEMENT.Item_Code=TSPL_WRECKAGE_BOOKING.Item_Code and TSPL_INVENTORY_MOVEMENT.UOM=TSPL_WRECKAGE_BOOKING.Unit_Code "
            clsDBFuncationality.ExecuteNonQuery(qry)

            clsCommon.ProgressBarPercentHide()

            clsCommon.MyMessageBoxShow("Wreckage Booking FAT/SNF updated sucessfully.")
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
        Finally
            clsCommon.ProgressBarPercentHide()
        End Try
    End Sub
