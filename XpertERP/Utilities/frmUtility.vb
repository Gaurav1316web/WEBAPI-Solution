                'obj = clsProcessProductionIssueEntry.GetData(drIssue.Item("Issue_Code"), "", NavigatorType.Current, Nothing)
                'If drInv.Item("Trans_Id") = 57592 Then
                '    clsCommon.MyMessageBoxShow("57592")
                'End If
                '' production costing columns
                Dim Trans_Id As Integer = drInv.Item("Trans_Id")
                Dim Location_Code As String = clsCommon.myCstr(drInv.Item("Location_Code"))
                Dim Item_Code As String = clsCommon.myCstr(drInv.Item("Item_Code"))
