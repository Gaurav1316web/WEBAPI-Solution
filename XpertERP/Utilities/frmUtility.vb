                            qry = "delete from TSPL_Customer_Invoice_Detail where Document_No in ('" + strARNo + "')"
                            clsDBFuncationality.ExecuteNonQuery(qry, trans)

                            qry = "delete from TSPL_Customer_Invoice_Head where Document_No = '" + strARNo + "'"
