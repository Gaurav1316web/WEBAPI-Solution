    Private Sub RadButton141_Click(sender As Object, e As EventArgs) Handles RadButton141.Click

        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin
        Try
            Dim custDes = clsDBFuncationality.getSingleValue("select Customer_Name from TSPL_CUSTOMER_MASTER where cust_code='" & txtNewCustomer.Value & "'", trans)
            'Bank Reverse
            Dim qry = "update TSPL_BANK_REVERSE  set Cust_Code= '" & txtNewCustomer.Value & "',Cust_Name='" & Mid(custDes, 1, 30) & "'  where Cust_Code='" & txtOldCustomer.Value & "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            ' Receipt
            qry = "update TSPL_RECEIPT_HEADER  set Cust_Code= '" & txtNewCustomer.Value & "',Customer_Name='" & custDes & "'  where Cust_Code='" & txtOldCustomer.Value & "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_BANK_BOOK  set SOURCE_CODE= '" & txtNewCustomer.Value & "',SOURCE_NAME='" & custDes & "'  where SOURCE_CODE='" & txtOldCustomer.Value & "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            ' Return
            qry = "update TSPL_JOURNAL_MASTER  set CustVend_Code= '" & txtNewCustomer.Value & "',CustVend_Name='" & custDes & "'   where CustVend_Code='" & txtOldCustomer.Value & "' and Source_Code='AR-CR'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_Customer_Invoice_Head  set Customer_Code= '" & txtNewCustomer.Value & "',Customer_Name='" & custDes & "'  where Customer_Code='" + txtOldCustomer.Value + "' "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_SD_SALE_RETURN_HEAD  set Customer_Code= '" & txtNewCustomer.Value & "'  where Customer_Code='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            ' Invoice
            qry = "update TSPL_JOURNAL_MASTER  set CustVend_Code= '" & txtNewCustomer.Value & "',CustVend_Name='" & custDes & "',Remarks=' AR invoice for customer: -  " + txtNewCustomer.Value + "  For Sale Invoice No '   + TSPL_Customer_Invoice_Head.Against_Sale_No  from TSPL_JOURNAL_MASTER join TSPL_Customer_Invoice_Head on TSPL_JOURNAL_MASTER.Source_Doc_No=TSPL_Customer_Invoice_Head.Document_No   where CustVend_Code='" & txtOldCustomer.Value & "' and Source_Code='AR-IN'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_Customer_Invoice_Head  set Customer_Code= '" & txtNewCustomer.Value & "',Customer_Name='" & custDes & "'  where Customer_Code='" + txtOldCustomer.Value + "' "
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_SD_SALE_INVOICE_HEAD  set Customer_Code= '" & txtNewCustomer.Value & "',Is_CustomerChanged=1  where Customer_Code='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            'Dispatch
            qry = "update TSPL_JOURNAL_MASTER  set CustVend_Code= '" & txtNewCustomer.Value & "',CustVend_Name='" & custDes & "'  where CustVend_Code='" + txtOldCustomer.Value + "' and Source_Code='SD-SH'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_INVENTORY_MOVEMENT  set Cust_Code= '" & txtNewCustomer.Value & "',Cust_Name='" & custDes & "'  where Cust_Code='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_SD_SHIPMENT_HEAD  set Customer_Code= '" & txtNewCustomer.Value & "',Is_CustomerChanged=1  where Customer_Code='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_DELIVERY_NOTE_MASTER_FRESHSALE  set Customer_Code= '" & txtNewCustomer.Value & "',Is_CustomerChanged=1  where Customer_Code='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            qry = "update TSPL_BOOKING_DETAIL  set Cust_Code= '" & txtNewCustomer.Value & "',Is_CustomerChanged=1  where Document_No='" + txtOldCustomer.Value + "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            ' FOr Receipt/bank reverse
            qry = "update TSPL_JOURNAL_MASTER  set CustVend_Code= '" & txtNewCustomer.Value & "',CustVend_Name='" & custDes & "'  where CustVend_Code='" & txtOldCustomer.Value & "'"
            clsDBFuncationality.ExecuteNonQuery(qry, trans)

            trans.Commit()
            clsCommon.MyMessageBoxShow("Customer Updated successfully", Me.Text)

        Catch ex As Exception
            clsCommon.MyMessageBoxShow(ex.Message)
            trans.Rollback()
        End Try
    End Sub

