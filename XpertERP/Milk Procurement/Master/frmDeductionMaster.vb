        AddNew()
    End Sub



    Private Sub FrmDeductionMaster_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnSave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            'DeleteData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.C Then
            Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            AddNew()
        End If
    End Sub

    Private Sub rmImport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmImport.Click
        Dim gv As New RadGridView()
        Dim IsNewEntry As Boolean
        Me.Controls.Add(gv)
        If transportSql.importExcel(gv, "Code", "Description", "Deduction Group Code", "GL Account", "Security", "Company", "VSP", "Tranporter", "Default Security", "Default TIP", "Sequence No") Then
            Dim i As Integer = 1
            Try
                For Each grow As GridViewRowInfo In gv.Rows

                    Dim obj As New ClsDeductionMaster()
                    i = i + 1
                    Dim strCode As String = clsCommon.myCstr(grow.Cells("Code").Value)
                    Dim strDescription As String = clsCommon.myCstr(grow.Cells("Description").Value)
                    Dim strDedGroupCode As String = clsCommon.myCstr(grow.Cells("Deduction Group Code").Value)
                    Dim strGLAccount As String = clsCommon.myCstr(grow.Cells("GL Account").Value)
                    Dim strSecurity As String = clsCommon.myCstr(grow.Cells("Security").Value)

                    If clsCommon.myLen(strCode) <= 0 Then
                        Throw New Exception("Code should not be left blank")
                    End If
                    If clsCommon.myLen(strCode) > 30 Then
                        Throw New Exception("Code can not be larger then 30 charachter")
                    End If
                    If clsCommon.myLen(strDescription) <= 0 Then
                        Throw New Exception("Description should not be left blank")
                    End If
                    If clsCommon.myLen(strDescription) > 100 Then
                        Throw New Exception("Description can not be larger then 100 charachter")
                    End If
                    If clsCommon.myLen(strDedGroupCode) <= 0 Then
                        Throw New Exception("Deduction Group Code can not be left blank")
                    End If
                    If clsCommon.myLen(strDedGroupCode) > 30 Then
                        Throw New Exception("Deduction Group Code can not be larger then 30 charachter")
                    End If
                    If clsDBFuncationality.getSingleValue("select count(*) from TSPL_DEDUCTION_GROUP where Ded_Code='" & strDedGroupCode & "'") = 0 Then
                        Throw New Exception("Deduction Group Code could not found in master")
                    End If
                    If clsCommon.myLen(strGLAccount) <= 0 Then
                        Throw New Exception("Deduction Group Code can not be left blank")
                    End If
                    If clsCommon.myLen(strGLAccount) > 50 Then
                        Throw New Exception("GL Account can not be larger then 50 charachter")
                    End If
                    If clsDBFuncationality.getSingleValue("select count(*) from TSPL_GL_ACCOUNTS where Account_Code='" & strGLAccount & "'") = 0 Then
                        Throw New Exception("GL Account Code could not found in master")
                    End If
                    If clsCommon.CompairString(strSecurity, "0") <> CompairStringResult.Equal AndAlso clsCommon.CompairString(strSecurity, "1") <> CompairStringResult.Equal Then
                        Throw New Exception("Status Of Security Should Be Either 0 Or 1")
                    End If

                    Dim reccount As Integer = 0
                    Dim seqNo As Int64 = 0
                    seqNo = clsCommon.myCdbl(grow.Cells("Sequence No").Value)
                    If seqNo > 0 Then
                        reccount = clsCommon.myCdbl(clsDBFuncationality.getSingleValue("select COUNT(*) from tspl_deduction_master where Sequence_No=" & seqNo & " and code<>'" & strCode & "'"))
                        If reccount > 0 Then
                            Throw New Exception("Duplicate Sequence No")
                        End If
                    End If

                    If clsCommon.myLen(strCode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_DEDUCTION_MASTER where Code='" + strCode + "' ") > 0 Then
                        IsNewEntry = False
                    Else
                        IsNewEntry = True

                    End If
                    obj.Code = strCode
                    obj.Description = strDescription
                    obj.Ded_Grp_Code = strDedGroupCode
                    obj.GL_Account_Code = strGLAccount
                    obj.Security = strSecurity
                    obj.Is_Default_Company_Deduction = IIf(clsCommon.myCdbl(grow.Cells("Company").Value) > 0, True, False)
                    obj.Is_Default_VSP_Deduction = IIf(clsCommon.myCdbl(grow.Cells("VSP").Value) > 0, True, False)
                    obj.Is_Default_Transporter_Deduction = IIf(clsCommon.myCdbl(grow.Cells("Tranporter").Value) > 0, True, False)
                    obj.Is_Default_Security_Deduction = IIf(clsCommon.myCdbl(grow.Cells("Default Security").Value) > 0, True, False)
                    obj.Is_Default_TIP = IIf(clsCommon.myCdbl(grow.Cells("Default TIP").Value) > 0, True, False)
                    obj.Sequence_No = seqNo
                    ClsDeductionMaster.SaveData(obj, IsNewEntry)
                Next

                clsCommon.MyMessageBoxShow(Me, "Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception

                clsCommon.MyMessageBoxShow(Me, ex.Message & " At Line No : " & i, Me.Text)
            End Try
        End If
    End Sub

    Private Sub rmExport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmExport.Click
