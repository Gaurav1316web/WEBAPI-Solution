    Sub setValueSplicContrainer()
        If clsCommon.CompairString(clsCommon.myCstr(cboPCType.SelectedValue), "Week") = CompairStringResult.Equal Then
            SplitContainer2.Panel1Collapsed = True
            SplitContainer2.Panel2Collapsed = False
        Else
            SplitContainer2.Panel1Collapsed = False
            SplitContainer2.Panel2Collapsed = True
        End If
    End Sub
