    Private Sub btnSave_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnSave.Click
        Save()
    End Sub

    Public Sub Save()
        If AllowToSave() Then
            If MyBase.isModifyonPasswordFlag Then
                If clsPasswordCheckForMasters.CheckMasterPwd(clsUserMgtCode.frmPaymentCycleMaster, clsCommon.myCstr(objCommonVar.CurrentCompanyCode)) Then
                Else
                    Return
                End If
            End If
            Dim obj As New clsPaymentCycleMaster()
            obj.PC_CODE = txtCode.Value
            obj.Description = txtDescription.Text
            obj.PC_TYPE = cboPCType.SelectedValue
            If clsCommon.CompairString(clsCommon.myCstr(cboPCType.SelectedValue), "Week") = CompairStringResult.Equal Then
                obj.PC_VALUE = clsCommon.myCstr(CboFirstDay.SelectedValue)
            Else
                obj.PC_VALUE = clsCommon.myCdbl(txtValue.Text)
            End If
            obj.IsDefault = IIf(chkIsDefault.Checked = True, 1, 0)
            If (obj.SaveData(obj, isNewEntry)) Then
                common.clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                LoadData(obj.PC_CODE, NavigatorType.Current)
            End If
        End If
    End Sub

    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        txtCode.MyReadOnly = True
        btnSave.Enabled = True
        btnDelete.Enabled = True
        Dim obj As New clsPaymentCycleMaster()
        obj = clsPaymentCycleMaster.GetData(strCode, NavTyep)
        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.PC_CODE) > 0) Then
            funReset()
            isNewEntry = False
            btnSave.Text = "Update"
            txtCode.Value = obj.PC_CODE
            txtDescription.Text = obj.Description
            cboPCType.SelectedValue = obj.PC_TYPE
            chkIsDefault.Checked = IIf(obj.IsDefault = 1, True, False)
            setValueSplicContrainer()
            If clsCommon.CompairString(clsCommon.myCstr(cboPCType.SelectedValue), "Week") = CompairStringResult.Equal Then
                CboFirstDay.SelectedValue = clsCommon.myCstr(obj.PC_VALUE)
            Else
                txtValue.Text = obj.PC_VALUE
            End If
        End If
    End Sub

    Function AllowToSave() As Boolean
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso clsCommon.myLen(txtCode.Value) <= 0 Then
            myMessages.blankValue("Code")
            txtCode.Focus()
            Return False
        ElseIf clsCommon.myLen(cboPCType.Text) <= 0 Then
            myMessages.blankValue("Type")
            cboPCType.Focus()
            Return False
        End If
        If clsCommon.CompairString(clsCommon.myCstr(cboPCType.SelectedValue), "Week") = CompairStringResult.Equal Then
            If clsCommon.myLen(CboFirstDay.SelectedValue) <= 0 Then
                myMessages.blankValue("First Day")
                cboPCType.Focus()
                Return False
            End If
        Else
            If clsCommon.myLen(txtValue.Text) <= 0 Then
                myMessages.blankValue("Value")
                txtValue.Focus()
                Return False
            End If
        End If
        Return True
    End Function

    Private Sub btnDelete_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnDelete.Click
        DeleteData()
    End Sub

    Sub DeleteData()
        If clsCommon.myLen(txtCode.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "Select Code", Me.Text)
            Exit Sub
        End If
        
        funDelete()
    End Sub

    Sub funDelete()
        Try
            If (myMessages.deleteConfirm()) Then
                If (clsPaymentCycleMaster.DeleteData(txtCode.Value)) Then
                    common.clsCommon.MyMessageBoxShow(Me, "Data Deleted Successfully ", Me.Text)
                    funReset()
                End If
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try

    End Sub

    Private Sub frmPaymentCycleMaster_Load(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MyBase.Load
        SetUserMgmtNew()
        isNewEntry = True
        funReset()
        loadPCType()
        loadFirstDay()
        ButtonToolTip.SetToolTip(btnSave, "Press Alt+S for Save/Update ")
        ButtonToolTip.SetToolTip(btnDelete, "Press Alt+D  for Delete ")
        ButtonToolTip.SetToolTip(btnClose, "Press Alt+C Close the Window")
        ButtonToolTip.SetToolTip(btnNew, "Press Alt+N Adding New ")
    End Sub

    Sub loadPCType()
        Dim dt As DataTable = New DataTable()
        dt.Columns.Add("Code", GetType(String))
        dt.Columns.Add("Name", GetType(String))

        Dim dr As DataRow
        dr = dt.NewRow()
        dr("Code") = "Day"
        dr("Name") = "Day"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "Week"
        dr("Name") = "Week"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "Month"
        dr("Name") = "Month"
        dt.Rows.Add(dr)

        dr = dt.NewRow()
        dr("Code") = "Year"
        dr("Name") = "Year"
        dt.Rows.Add(dr)

        dt.AcceptChanges()
        Me.cboPCType.DataSource = dt
        Me.cboPCType.ValueMember = "Code"
        Me.cboPCType.DisplayMember = "Name"
    End Sub

