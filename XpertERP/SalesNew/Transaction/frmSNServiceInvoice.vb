                            Return False
                        End If
                    Next
                End If
            Next

            If clsLocation.isLocatinExcisable(txtBillToLocation.Value) Then
                Dim qry As String = "select Type  from TSPL_TAX_MASTER where Tax_Code ='" + clsCommon.myCstr(gv2.Rows(0).Cells(colTTaxAutCode).Value) + "' "
