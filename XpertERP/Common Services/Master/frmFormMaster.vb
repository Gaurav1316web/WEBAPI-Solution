    Private Sub FrmFormMaster_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnSave.Enabled Then
            savedata()

        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            deletedata()
        ElseIf e.Alt And e.KeyCode = Keys.C Then
            Close()

        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funReset()
        End If
    End Sub

    Private Sub fndFormCode__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles fndFormCode._MYValidating

        Dim qst As String = "select count(*) from TSPL_Form_MASTER where Form_Code='" + fndFormCode.Value + "'"
        Dim count As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(qst))
        If count = 0 Then
            fndFormCode.MyReadOnly = False
        Else
            fndFormCode.MyReadOnly = True
        End If
        If fndFormCode.MyReadOnly OrElse isButtonClicked Then
            fndFormCode.Value = clsFormMaster.getFinder("", fndFormCode.Value, isButtonClicked)
            LoadData(fndFormCode.Value)
        End If
    End Sub
    Public Sub LoadData(ByVal formcode As String)
        If clsCommon.myLen(formcode) <= 0 Then
            funReset()
            Exit Sub
        End If
        Dim str As String = "select form_Code from TSPL_form_MASTER where form_code = '" + fndFormCode.Value + "'"
        Dim Code As String = Convert.ToString(connectSql.RunScalar(str))
        If Code = fndFormCode.Value Then
            FunFill()
        Else
            funReset()
        End If
    End Sub

    Private Sub fndFormCode__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavType As common.NavigatorType) Handles fndFormCode._MYNavigator
        Dim qst As String = " select Form_Code As [Form Code],Form_Name  as [Form Name]from TSPL_Form_MASTER  where 2=2"
        Select Case NavType
            Case NavigatorType.Current
                qst += " and TSPL_Form_MASTER .Form_Code in ('" + fndFormCode.Value + "')"
            Case NavigatorType.Next
                qst += " and TSPL_Form_MASTER .Form_Code in (select min(Form_Code) from TSPL_Form_MASTER where Form_Code  >'" + fndFormCode.Value + "')"
            Case NavigatorType.First
                qst += " and TSPL_Form_MASTER .Form_Code in (select MIN(Form_Code) from TSPL_Form_MASTER)"

            Case NavigatorType.Last
                qst += " and TSPL_Form_MASTER .Form_Code in (select Max(Form_Code) from TSPL_Form_MASTER)"
            Case NavigatorType.Previous
                qst += " and TSPL_Form_MASTER .Form_Code in (select Max(Form_Code) from TSPL_Form_MASTER where Form_Code  <'" + fndFormCode.Value + "')"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndFormCode.Value = clsCommon.myCstr(dt.Rows(0)("Form Code"))
            txtName.Text = clsCommon.myCstr(dt.Rows(0)("Form Name"))
            LoadData(fndFormCode.Value)
        Else
            funReset()
        End If

    End Sub






    Private Sub rmImport_Click_1(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmImport.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim currentdate As Date = Date.Today
        If transportSql.importExcel(gv, "Form Code", "Form Name", "Form Type", "Remarks") Then
            Dim linno As Integer = 0
            Try
                connectSql.OpenConnection()


                clsCommon.ProgressBarShow()


                For Each grow As GridViewRowInfo In gv.Rows
                    Dim trans As SqlTransaction
                    trans = clsDBFuncationality.GetTransactin()
                    Dim obj As New clsFormMaster()

                    linno += 1
                    Dim strcode As String = clsCommon.myCstr(grow.Cells("Form Code").Value)
                    If (String.IsNullOrEmpty(strcode)) Or clsCommon.myLen(strcode) > 30 Then
                        Throw New Exception("Length of Form Code should be max. 30 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Form_Code = strcode

                    Dim strname As String = clsCommon.myCstr(grow.Cells("Form Name").Value)
                    If (String.IsNullOrEmpty(strname)) Or clsCommon.myLen(strname) > 50 Then
                        Throw New Exception("Length of Form Name should be max. 50 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Form_Name = strname
                    '' Anubhooti 06-Oct-2014 (Added 'E','E1','D','H') BM00000003993
                    Dim strType As String = clsCommon.myCstr(grow.Cells("Form Type").Value)
                    If (String.IsNullOrEmpty(strType)) Or clsCommon.myLen(strType) > 10 Then
                        Throw New Exception("Length of Type should be max. 10 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    ElseIf clsCommon.CompairString(strType, "C") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "F") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "38-Inward") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "38-Outward") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "Others") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "E") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "E1") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "D") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "H") = CompairStringResult.Equal Then
                    Else
                        Throw New Exception("Type should be amoung 'C','F','38-Inward','38-Outward,'E','E1','D','H','Others' At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    If clsCommon.CompairString(strType, "C") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "F") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "E") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "E1") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "D") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "H") = CompairStringResult.Equal Then
                        strType = strType.ToUpper()
                    End If
                    obj.Form_Type = strType

                    Dim strRemarks As String = clsCommon.myCstr(grow.Cells("Remarks").Value)
                    If clsCommon.myLen(strRemarks) > 100 Then
                        Throw New Exception("Length of Remarks should be max. 100 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Remarks = strRemarks
                    If clsCommon.myLen(strcode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_Form_Master where Form_Code='" + strcode + "' ", trans) > 0 Then
                        isnewentry = False
                    Else
                        isnewentry = True

                    End If
                    obj.save_data(obj, isnewentry, trans)
                Next
                ' trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow("Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception

                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)
            End Try
        End If
        Me.Controls.Remove(gv)
    End Sub

    Private Sub rmexport_Click_1(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmexport.Click
        Dim str As String = "select count(*) from tspl_form_master"
        Dim check As Integer = CInt(clsDBFuncationality.getSingleValue(str))
        '' Anubhooti 06-Oct-2014 (Fetched 'E','E1','D','H') BM00000003993
        If check > 0 Then
            str = "select Form_Code as [Form Code] ,Form_Name as [Form Name],Form_type as [Form Type],Remarks as [Remarks] from TSPL_Form_Master"
        Else
            str = "select '' as [Form Code] ,'' as [Form Name],'C,F,38-Inward,38-Outward,Others,E,E1,D,H' as [Form Type],'' as [Remarks]"
        End If
        transportSql.ExporttoExcel(str, Me)
    End Sub
