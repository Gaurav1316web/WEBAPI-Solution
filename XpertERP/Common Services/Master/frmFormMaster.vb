    Public Sub New(ByVal user As String, ByVal company As String)
        InitializeComponent()
        userCode = user
        companyCode = company
    End Sub
    Sub savedata()
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) Then
            If clsCommon.myLen(fndFormCode.Value) <= 0 Then
                clsCommon.MyMessageBoxShow("Form Code can not be left blank", Me.Text)
                fndFormCode.Focus()
                fndFormCode.Select()
                Errorcontrol.SetError(fndFormCode, "Form Code can not be left blank")
                Exit Sub
            Else
                Errorcontrol.ResetError(fndFormCode)
            End If
        End If
        If clsCommon.myLen(ddlFormType.Text) <= 0 Then
            common.clsCommon.MyMessageBoxShow("Form Type can not be left blank", Me.Text)
            ddlFormType.Focus()
            ddlFormType.Select()
            Errorcontrol.SetError(ddlFormType, "Form Type can not be left blank")
            Exit Sub
        Else
            Errorcontrol.ResetError(ddlFormType)
        End If
        If MyBase.isModifyonPasswordFlag Then
            If clsPasswordCheckForMasters.CheckMasterPwd(clsUserMgtCode.FormMaster, clsCommon.myCstr(objCommonVar.CurrentCompanyCode)) Then
            Else
                Return
            End If
        End If

        If btnSave.Text = "Save" Then
            funInsert(True)
        ElseIf btnSave.Text = "Update" Then
            funInsert(False)
        End If
    End Sub
    Private Sub btnSave_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnSave.Click
        savedata()
    End Sub
    Public Sub funInsert(ByVal isNewEntry)
        Dim isSaved As Boolean = True
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
           
            Dim coll As New Hashtable()
            clsCommon.AddColumnsForChange(coll, "Form_Name", txtName.Text)
            clsCommon.AddColumnsForChange(coll, "Form_Type", ddlFormType.Text)
            clsCommon.AddColumnsForChange(coll, "Remarks", txtRemarks.Text)
            clsCommon.AddColumnsForChange(coll, "Modified_By", objCommonVar.CurrentUserCode)
            clsCommon.AddColumnsForChange(coll, "Modified_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))
            clsCommon.AddColumnsForChange(coll, "Comp_Code", fndFormCode.Value.ToString())
            If isNewEntry Then
                If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, trans)) = "1", True, False)) Then
                    Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_Form_Master where Form_Code='" & fndFormCode.Value & "'", trans)
                    If ChkNewEntry = 0 Then
                        fndFormCode.Value = clsERPFuncationality.GetNextCode(trans, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"), clsDocType.FormMaster, "", "")
                        If clsCommon.myLen(fndFormCode.Value) <= 0 Then
                            Throw New Exception("Error in Code Generation")
                        End If
                    End If
                End If
                clsCommon.AddColumnsForChange(coll, "Form_Code", fndFormCode.Value.ToString())
                clsCommon.AddColumnsForChange(coll, "Created_By", userCode)
                clsCommon.AddColumnsForChange(coll, "Created_Date", clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy"))

                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_Form_Master", OMInsertOrUpdate.Insert, "", trans)
            Else
                isSaved = isSaved AndAlso clsCommonFunctionality.UpdateDataTable(coll, "TSPL_Form_Master", OMInsertOrUpdate.Update, "Form_Code='" + fndFormCode.Value + "' ", trans)
            End If

            trans.Commit()
            myMessages.insert()
            FunFill()
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(ex.Message, "Form Master", MessageBoxButtons.OK)
            trans.Rollback()
        End Try
    End Sub
    Public Sub funUpdate()
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            connectSql.RunSpTransaction(trans, "sp_Form_Master_Update", New SqlParameter("@Form_Code", fndFormCode.Value.ToString()), New SqlParameter("@Form_Name", txtName.Text.ToString()), New SqlParameter("@Remarks", txtRemarks.Text.ToString()), New SqlParameter("@created_by", userCode), New SqlParameter("@created_date", connectSql.serverDate(trans)), New SqlParameter("@modified_by", userCode), New SqlParameter("@modified_date", connectSql.serverDate(trans)), New SqlParameter("@comp_code", companyCode))
            clsDBFuncationality.ExecuteNonQuery("update TSPL_Form_Master set Form_Type='" + ddlFormType.Text + "' where Form_Code='" + fndFormCode.Value.ToString() + "' ", trans)
            trans.Commit()
            myMessages.update()
            FunFill()
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(ex.Message, "Form Master", MessageBoxButtons.OK)
            trans.Rollback()
        End Try
    End Sub
    Public Sub funDelete()
        Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
        Try
            'connectSql.RunSpTransaction(trans, "sp_Form_Master_Delete", New SqlParameter("@Form_Code", fndFormCode.Value.ToString()))
            clsDBFuncationality.ExecuteNonQuery("Delete From TSPL_Form_Master Where Form_Code='" + clsCommon.myCstr(fndFormCode.Value) + "'", trans)
            trans.Commit()
            myMessages.delete()
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(ex.Message, "Form Master", MessageBoxButtons.OK)
            trans.Rollback()
        End Try
    End Sub
    Public Sub FunFill()
        Dim str As String = "select Form_Code  from TSPL_Form_Master where Form_Code ='" + fndFormCode.Value + "'"
        Dim strChk As String = connectSql.RunScalar(str)
        If strChk = "" Then
            Exit Sub
        End If
        Dim strQ As String = "select  form_name ,Form_Type, remarks from tspl_form_master where form_code='" + fndFormCode.Value + "' "
        Dim dt As DataTable
        dt = clsDBFuncationality.GetDataTable(strQ)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            txtName.Text = dt.Rows(0)("form_name").ToString()
            ddlFormType.SelectedValue = dt.Rows(0)("Form_Type").ToString()
            txtRemarks.Text = dt.Rows(0)("remarks").ToString()

            btnSave.Text = "Update"
            btnDelete.Enabled = True
        Else
            btnSave.Text = "Save"
            btnDelete.Enabled = False
        End If
       
    End Sub
    Private Sub btnDelete_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnDelete.Click
        deletedata()
    End Sub
    Sub deletedata()
        If clsCommon.myLen(fndFormCode.Value) <= 0 Then
            Exit Sub
        End If
        If fndFormCode.Value = "" Then
            Return
        Else
            Dim qry As String = "select count(*) from TSPL_FORM_SERIAL_NO_MASTER where form_code='" + fndFormCode.Value + "'"
            Dim check As Integer = clsDBFuncationality.getSingleValue(qry)
            If check > 0 Then
                clsCommon.MyMessageBoxShow("Form Code is used in transaction,first delete all references", Me.Text)
                Exit Sub
            End If

            If myMessages.deleteConfirm() = True Then
                funDelete()
                funReset()
            Else
                Return
            End If
        End If
    End Sub
