Public Class RptPendingDocumentList
    Inherits FrmMainTranScreen
    Dim ButtonToolTip As ToolTip = New ToolTip()
    Dim dt As DataTable = Nothing
    Dim qry As String
    Public arrLoc As Dictionary(Of String, Object) = Nothing
    Private Sub SetUserMgmtNew()
        ''MyBase.SetUserMgmt(clsUserMgtCode.frmTransferRegister)
        If Not (MyBase.isReadFlag) Then
            Throw New Exception("Permission Denied")
        End If
        btnExport.Visible = MyBase.isExport

    End Sub

    Private Sub RptPendingDocumentList_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        Reset()
        gv.AllowEditRow = False
        gv.AllowDragToGroup = False
        gv.AllowAddNewRow = False
    End Sub

    Private Sub btnReset_Click(sender As Object, e As EventArgs) Handles btnReset.Click
        Reset()
    End Sub
    Private Sub Reset()
        ToDate.Value = clsCommon.GETSERVERDATE()
        fromDate.Value = ToDate.Value.AddMonths(-1)
        RadPageView1.SelectedPage = RadPageViewPage1
        gv.DataSource = Nothing
        txtModule.arrValueMember = Nothing
        txtModule.arrDispalyMember = Nothing
    End Sub
    Private Sub btnClose_Click(sender As Object, e As EventArgs) Handles btnClose.Click
        Me.Close()
    End Sub

    Private Sub btnRefresh_Click(sender As Object, e As EventArgs) Handles btnRefresh.Click
        PageSetupReport_ID = MyBase.Form_ID
        TemplateGridview = gv
        Load_Report()
    End Sub

    Enum Exporter
        Excel = 0
        PDF = 1
        Print = 2
        Refresh = 3
    End Enum
    Private Sub Load_Report()
        Try
            If fromDate.Value > ToDate.Value Then
                common.clsCommon.MyMessageBoxShow(Me, "From date can not be greater then to Date", Me.Text)
                fromDate.Focus()
                Exit Sub
            End If


            Dim StrQuery As String = ""
            ''If txtModule.arrDispalyMember IsNot Nothing AndAlso txtModule.arrDispalyMember.Count > 0 Then
            '  StrQuery += " and [Module] in (" + clsCommon.GetMulcallString(txtModule.arrValueMember) + ")"
            'End If
            'StrQuery += " and [date] >= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and [date] <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "'"
            StrQuery = LoadQuery()
            Dim dtgv As New DataTable
            dtgv = clsDBFuncationality.GetDataTable(StrQuery)
            If dtgv IsNot Nothing And dtgv.Rows.Count > 0 Then
                gv.DataSource = Nothing
                gv.Rows.Clear()
                gv.Columns.Clear()
                gv.DataSource = dtgv
                RadPageView1.SelectedPage = RadPageViewPage2
                gv.TableElement.TableHeaderHeight = 40
                gv.MasterTemplate.ShowRowHeaderColumn = False
                gv.EnableFiltering = True
                gv.ShowFilteringRow = True
                gv.BestFitColumns()
                ReStoreGridLayout()
            Else
                gv.DataSource = Nothing
                clsCommon.MyMessageBoxShow(Me, "No data found", Me.Text)
                RadPageView1.SelectedPage = RadPageViewPage1
            End If

        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Private Sub RptPendingDocumentList_KeyDown(sender As Object, e As KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.R Then
            Load_Report()
        ElseIf e.Alt And e.KeyCode = Keys.C Then
            Me.Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            Reset()
        End If
    End Sub

    Private Function LoadQuery() As String
        Dim StrBuilder As New System.Text.StringBuilder
        StrBuilder.Append(" select DISTINCT  * from (Select final.Module, final.Screen, final.Invoice_Entry_Date As date, Convert(varchar,final.Invoice_Entry_Date,103) As [Doc Date], final.Document_No As [Doc Code], final.[Vendor Code],TSPL_VENDOR_MASTER.Vendor_Name as [Vendor Name],final.[Customer Code],TSPL_CUSTOMER_MASTER.Customer_Name as [Customer Name],final.[Amount],Case When final.Status = 'Y' Then 'Posted' Else 'Pending' End Status, final.Created_By As [Created By] From (  ")
        Dim IsAllModule As Boolean = False
        If txtModule.arrValueMember Is Nothing OrElse txtModule.arrValueMember.Count <= 0 Then
            IsAllModule = True
        End If
        StrBuilder.Append(" Select '' As Module, '' As Screen, '' as Document_No, '' As Invoice_Entry_Date, '' As Status, '' as Created_By,'' as [Vendor Code], '' as [Customer Code],0 as [Amount]  where 1=2")
        If IsAllModule OrElse txtModule.arrValueMember.Contains("Payable") Then
            StrBuilder.Append(" Union All Select 'Payable' As Module, 'AP Invoice Entry' As Screen, TSPL_VENDOR_INVOICE_HEAD.Document_No, Convert(date,TSPL_VENDOR_INVOICE_HEAD.Invoice_Entry_Date,103) As Invoice_Entry_Date, (Case When Len(TSPL_VENDOR_INVOICE_HEAD.Posting_Date) Is Null Then 'N' Else 'Y' End) As Status, TSPL_VENDOR_INVOICE_HEAD.Created_By ,Vendor_Code as [Vendor Code] ,'' as [Customer Code], Document_Total as [Amount]  From TSPL_VENDOR_INVOICE_HEAD   where Convert(date,TSPL_VENDOR_INVOICE_HEAD.Invoice_Entry_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_VENDOR_INVOICE_HEAD.Invoice_Entry_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and Len(TSPL_VENDOR_INVOICE_HEAD.Posting_Date) Is Null")
            StrBuilder.Append(" Union All  Select 'Payable' As Module, 'Payment Entry' As Screen, TSPL_PAYMENT_HEADER.Payment_No, TSPL_PAYMENT_HEADER.Payment_Date, Case When TSPL_PAYMENT_HEADER.Posted = 1 Then 'Y' Else 'N' End As posted, TSPL_PAYMENT_HEADER.Created_By, TSPL_PAYMENT_HEADER.Vendor_Code as [Vendor Code] ,'' as [Customer Code], TSPL_PAYMENT_HEADER.Payment_Amount as [Amount]   From TSPL_PAYMENT_HEADER   where Convert(date,TSPL_PAYMENT_HEADER.Payment_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_PAYMENT_HEADER.Payment_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_PAYMENT_HEADER.Posted <>1")
            StrBuilder.Append(" Union All  Select 'Payable' As Module, 'Payment Adjustment Entry' As Screen, TSPL_Payment_Adjustment_Header.Adjustment_No, TSPL_Payment_Adjustment_Header.Adjustment_Date, TSPL_Payment_Adjustment_Header.Is_Post As posted, TSPL_Payment_Adjustment_Header.Created_By, TSPL_Payment_Adjustment_Header.Vendor_No as [Vendor Code],'' as [Customer Code], TSPL_Payment_Adjustment_Header.Doc_Amount as [Amount]   From TSPL_Payment_Adjustment_Header   where Convert(date,TSPL_Payment_Adjustment_Header.Adjustment_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_Payment_Adjustment_Header.Adjustment_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_Payment_Adjustment_Header.Is_Post='N'")
        End If
        If IsAllModule OrElse txtModule.arrValueMember.Contains("Receivable") Then
            StrBuilder.Append(" Union ALL ")
            StrBuilder.Append(" Select 'Receivable' As Module, 'AR Invoice' As Screen, TSPL_Customer_Invoice_Head.Document_No as Document_No, TSPL_Customer_Invoice_Head.Document_Date as Invoice_Entry_Date, Case When TSPL_Customer_Invoice_Head.Status = 0 Then 'N' Else 'Y' End Status, TSPL_Customer_Invoice_Head.Created_By , '' as [Vendor Code], Customer_Code  as [Customer Code], Document_Total  as [Amount]   From TSPL_Customer_Invoice_Head where Convert(date,TSPL_Customer_Invoice_Head.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_Customer_Invoice_Head.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_Customer_Invoice_Head.Status = 0  ")
            StrBuilder.Append(" Union All Select 'Receivable' As Module, 'Receipt Entry' As Screen, TSPL_RECEIPT_HEADER.Receipt_No as Document_No, TSPL_RECEIPT_HEADER.Receipt_Date as Invoice_Entry_Date, TSPL_RECEIPT_HEADER.Posted, TSPL_RECEIPT_HEADER.Created_By ,'' as [Vendor Code], Cust_Code as [Customer Code], Receipt_Amount as [Amount]   From TSPL_RECEIPT_HEADER where Convert(date,TSPL_RECEIPT_HEADER.Receipt_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_RECEIPT_HEADER.Receipt_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_RECEIPT_HEADER.Posted='N'")
            StrBuilder.Append(" Union All Select 'Receivable' As Module, 'Receipt Adjustment Entry' As Screen, TSPL_Receipt_Adjustment_Header.adjustment_no as Document_No, TSPL_Receipt_Adjustment_Header.adjustment_date as Invoice_Entry_Date, TSPL_Receipt_Adjustment_Header.is_post, TSPL_Receipt_Adjustment_Header.Created_By, '' as [Vendor Code], Customer_No as [Customer Code],Doc_Amount as [Amount]    From TSPL_Receipt_Adjustment_Header where Convert(date,TSPL_Receipt_Adjustment_Header.Adjustment_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_Receipt_Adjustment_Header.Adjustment_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_Receipt_Adjustment_Header.is_post='N'")
            StrBuilder.Append(" Union All Select 'Receivable' As Module, 'Receipt Invoice Mapping' As Screen, TSPL_Receipt_InvoiceMapping_Head.Doc_Code as Document_No, TSPL_Receipt_InvoiceMapping_Head.Document_Date as Invoice_Entry_Date, Case When TSPL_Receipt_InvoiceMapping_Head.isPosted = 0 Then 'N' Else 'Y' End Status, TSPL_Receipt_InvoiceMapping_Head.Created_By,'' as [Vendor Code],'' as [Customer Code],0  as [Amount]   From TSPL_Receipt_InvoiceMapping_Head where Convert(date,TSPL_Receipt_InvoiceMapping_Head.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_Receipt_InvoiceMapping_Head.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_Receipt_InvoiceMapping_Head.isposted=0")
        End If
        If IsAllModule OrElse txtModule.arrValueMember.Contains("General Ledger") Then
            StrBuilder.Append(" Union ALL ")
            StrBuilder.Append(" Select 'General Ledger' As Module, 'Journal Entry' As Screen, TSPL_JOURNAL_MASTER.Voucher_No as Document_No, TSPL_JOURNAL_MASTER.Voucher_Date as Invoice_Entry_Date, Case When TSPL_JOURNAL_MASTER.Authorized = 'A' Then 'Y' Else 'N' End As Status, TSPL_JOURNAL_MASTER.Created_By , case when Source_Type = 'V' then  CustVend_Code end as [Vendor Code] ,case when Source_Type = 'C' then  CustVend_Code end as [Customer Code],Total_Debit_Amt as [Amount]   From TSPL_JOURNAL_MASTER where Convert(date, TSPL_JOURNAL_MASTER.Voucher_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date, TSPL_JOURNAL_MASTER.Voucher_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and TSPL_JOURNAL_MASTER.Authorized <> 'A'   ")
            StrBuilder.Append(" Union All  Select 'General Ledger' As Module, 'VCGL' As Screen, TSPL_VCGL_Head.Document_No , TSPL_VCGL_Head.Document_Date as Invoice_Entry_Date, Case When TSPL_VCGL_Head.Status = 1 Then 'Y' Else 'N' End As status, TSPL_VCGL_Head.Created_By, case when Document_Type = 'V' then  VC_Code end as [Vendor Code] ,case when Document_Type = 'C' then  VC_Code end as [Customer Code],Amount as [Amount]    From TSPL_VCGL_Head  where Convert(date,TSPL_VCGL_Head.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_VCGL_Head.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_VCGL_Head.Status <> 1 ")
            StrBuilder.Append(" union all Select 'General Ledger' As Module, 'Reverse Journal Entry' As Screen, TSPL_JOURNAL_MASTER.Voucher_No as Document_No, TSPL_JOURNAL_MASTER.Voucher_Date as Invoice_Entry_Date, Case When TSPL_JOURNAL_MASTER.Authorized = 'A' Then 'Y' Else 'N' End As Status, TSPL_JOURNAL_MASTER.Created_By, case when Source_Type = 'V' then  CustVend_Code end as [Vendor Code] ,case when Source_Type = 'C' then  CustVend_Code end as [Customer Code],Total_Debit_Amt as [Amount]    From TSPL_JOURNAL_MASTER where Convert(date, TSPL_JOURNAL_MASTER.Voucher_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date, TSPL_JOURNAL_MASTER.Voucher_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and TSPL_JOURNAL_MASTER.Authorized <> 'A' and Auto_Reverse='Y' ")
        End If
        If IsAllModule OrElse txtModule.arrValueMember.Contains("Product Sale") Then
            StrBuilder.Append(" Union ALL ")
            StrBuilder.Append(" Select 'Product Sale' As Module, 'Booking' As Screen, TSPL_BOOKING_MASTER_PRODUCTSALE.Document_Code as Document_No, TSPL_BOOKING_MASTER_PRODUCTSALE.Document_Date as Invoice_Entry_Date, Case When " & _
                          " TSPL_BOOKING_MASTER_PRODUCTSALE.Status = 1 Then 'Y' Else 'N' End As Status, TSPL_BOOKING_MASTER_PRODUCTSALE.Created_By , '' as [Vendor Code] , TSPL_BOOKING_MASTER_PRODUCTSALE.Customer_Code as [Customer Code], TSPL_BOOKING_MASTER_PRODUCTSALE.Total_Amt as [Amount]   From TSPL_BOOKING_MASTER_PRODUCTSALE  where Convert(date,TSPL_BOOKING_MASTER_PRODUCTSALE.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_BOOKING_MASTER_PRODUCTSALE.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_BOOKING_MASTER_PRODUCTSALE.Status <> 1 ")
            StrBuilder.Append(" Union All 	 Select 'Product Sale' As Module, 'Sale order Product Sale' As Screen, TSPL_SD_SALES_ORDER_HEAD.Document_Code as Document_No, TSPL_SD_SALES_ORDER_HEAD.Document_Date as Invoice_Entry_Date, Case When TSPL_SD_SALES_ORDER_HEAD.Status = 1 Then 'Y' Else 'N' End As status, TSPL_SD_SALES_ORDER_HEAD.Created_By , '' as [Vendor Code]  , TSPL_SD_SALES_ORDER_HEAD.Customer_Code as [Customer Code] , TSPL_SD_SALES_ORDER_HEAD.Total_Amt as [Amount]   From TSPL_SD_SALES_ORDER_HEAD    Where TSPL_SD_SALES_ORDER_HEAD.Trans_Type = 'PS'   and  Convert(date,TSPL_SD_SALES_ORDER_HEAD.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_SD_SALES_ORDER_HEAD.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_SD_SALES_ORDER_HEAD.Status <> 1 ")
