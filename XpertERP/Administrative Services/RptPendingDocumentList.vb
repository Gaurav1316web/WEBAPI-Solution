            StrBuilder.Append(" Union All Select 'Product Sale' As Module, 'Dispatch Product Sale' As Screen, TSPL_SD_SHIPMENT_HEAD.Document_Code as Document_No, TSPL_SD_SHIPMENT_HEAD.Document_Date as Invoice_Entry_Date, Case When TSPL_SD_SHIPMENT_HEAD.Status = 1 Then 'Y' Else 'N' End As Status, TSPL_SD_SHIPMENT_HEAD.Created_By , '' as [Vendor Code] , TSPL_SD_SHIPMENT_HEAD.Customer_Code as [Customer Code],TSPL_SD_SHIPMENT_HEAD.Total_Amt as [Amount]    From TSPL_SD_SHIPMENT_HEAD    Where TSPL_SD_SHIPMENT_HEAD.Trans_Type = 'PS'  and Convert(date,TSPL_SD_SHIPMENT_HEAD.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_SD_SHIPMENT_HEAD.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_SD_SHIPMENT_HEAD.Status <> 1 ")
            StrBuilder.Append(" Union All Select 'Product Sale' As Module, 'Product Invoice' As Screen, TSPL_SD_SALE_INVOICE_HEAD.Document_Code as Document_No, TSPL_SD_SALE_INVOICE_HEAD.Document_Date as Invoice_Entry_Date, Case When TSPL_SD_SALE_INVOICE_HEAD.Status = 1 Then 'Y' Else 'N' End As Status, TSPL_SD_SALE_INVOICE_HEAD.Created_By  , '' as [Vendor Code] ,TSPL_SD_SALE_INVOICE_HEAD. Customer_Code as [Customer Code],TSPL_SD_SALE_INVOICE_HEAD.Total_Amt as [Amount]  From TSPL_SD_SALE_INVOICE_HEAD    Where TSPL_SD_SALE_INVOICE_HEAD.Trans_Type = 'PS' And IsNull(TSPL_SD_SALE_INVOICE_HEAD.Invoice_No_For_Supplementary, '') <> '' and Convert(date,TSPL_SD_SALE_INVOICE_HEAD.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_SD_SALE_INVOICE_HEAD.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_SD_SALE_INVOICE_HEAD.Status <> 1")

        End If
