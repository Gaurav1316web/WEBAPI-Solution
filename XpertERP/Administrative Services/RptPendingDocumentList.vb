            StrBuilder.Append(" Union ALL  Select 'Fresh Sale' As Module,'Fresh Crate Received' As Screen, TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Document_No, TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Document_Date as Invoice_Entry_Date, Case When TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Posted = 1 Then 'Y' Else 'N' End As Status, TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Created_By , '' as [Vendor Code],''  as [Customer Code], 0  as [Amount]   From TSPL_CRATE_RECEIVED_HEAD_FRESHSALE   Where Convert(date,TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_CRATE_RECEIVED_HEAD_FRESHSALE.Posted <> 1 ")
            StrBuilder.Append(" Union ALL  Select 'Fresh Sale' As Module,'Fresh Sale Return' As Screen, TSPL_SD_SALE_RETURN_HEAD.Document_Code, TSPL_SD_SALE_RETURN_HEAD.Document_Date as Invoice_Entry_Date, Case When TSPL_SD_SALE_RETURN_HEAD.Status = 1 Then 'Y' Else 'N' End As Status, TSPL_SD_SALE_RETURN_HEAD.Created_By , '' as [Vendor Code], Customer_Code as [Customer Code], Total_Amt  as [Amount]  From TSPL_SD_SALE_RETURN_HEAD  Where Convert(date,TSPL_SD_SALE_RETURN_HEAD.Document_Date,103)>= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithStartTime(fromDate.Value), "dd/MMM/yyyy hh:mm tt") + "'  and Convert(date,TSPL_SD_SALE_RETURN_HEAD.Document_Date,103) <= '" + clsCommon.GetPrintDate(clsCommon.GetDateWithEndTime(ToDate.Value), "dd/MMM/yyyy hh:mm tt") + "' and TSPL_SD_SALE_RETURN_HEAD.Status <> 1 and TSPL_SD_SALE_RETURN_HEAD.Trans_Type='FS' ")
        End If
        If IsAllModule OrElse txtModule.arrValueMember.Contains("Purchase") Then
