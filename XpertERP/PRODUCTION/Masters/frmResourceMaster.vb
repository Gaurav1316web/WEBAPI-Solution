        If cboUOM.SelectedIndex > -1 Then
            Selected_val = cboUOM.SelectedValue
        End If

        cboUOM.DataSource = GetCboUOMDataTable()
        cboUOM.ValueMember = "RESOURCE_CODE"
        cboUOM.DisplayMember = "Value"

        If Selected_val.Length > 0 Then
            cboUOM.SelectedValue = Selected_val
        End If
