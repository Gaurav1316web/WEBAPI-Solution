    Private Sub cboUOM_SelectedValueChanged(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles cboUOM.SelectedValueChanged
        If (clsCommon.CompairString(clsCommon.myCstr(cboType.SelectedValue), "Setup Labor") = CompairStringResult.Equal) Or (clsCommon.CompairString(clsCommon.myCstr(cboType.SelectedValue), "Run Labor") = CompairStringResult.Equal) Then
            If clsCommon.CompairString(clsCommon.myCstr(cboUOM.SelectedValue), "Others") = CompairStringResult.Equal Then
                clsCommon.MyMessageBoxShow("Invalid Input. For resource with setup labor or run labor types, the UOM must be either per hour or per minute.")
                cboUOM.SelectedText = ""
                cboUOM.SelectedIndex = -1
                txtOtherUOM.Enabled = False
                txtOtherUOM.Text = ""
            End If
        End If
        If (clsCommon.CompairString(clsCommon.myCstr(cboUOM.SelectedValue), "Others") = CompairStringResult.Equal AndAlso clsCommon.CompairString(clsCommon.myCstr(cboType.SelectedValue), "Overhead") = CompairStringResult.Equal) Then
            txtOtherUOM.Enabled = True
            txtOtherUOM.Text = ""
        Else
            txtOtherUOM.Enabled = False
            txtOtherUOM.Text = clsCommon.myCstr(cboUOM.SelectedValue)
        End If
    End Sub

