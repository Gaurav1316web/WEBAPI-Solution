    Public Sub Save()
        If AllowToSave() Then

            If MyBase.isModifyonPasswordFlag Then
                If clsPasswordCheckForMasters.CheckMasterPwd(strCatStrPass, clsCommon.myCstr(objCommonVar.CurrentCompanyCode)) Then
                Else
                    Return
                End If
            End If
            Dim obj As New clsItemCategoryStructure()
            obj.ITEM_CATEGORY_STRUCT_CODE = txtCode.Value
            obj.DESCRIPTION = Me.txtDescription.Text
            obj.ObjList = New List(Of clsItemCategoryStructureDetails)
            obj.formtype = FormType

            For Each grow As GridViewRowInfo In gvStructLevels.Rows
                Dim objTr As New clsItemCategoryStructureDetails()
                objTr.ITEM_CATEGORY_STRUCT_CODE = clsCommon.myCstr(Me.txtCode.Value)
                objTr.ITEM_CATEGORY_CODE = clsCommon.myCstr(grow.Cells(colCategoryLevelCode).Value)
                objTr.CATEGORY_LEVEL = clsCommon.myCstr(grow.Cells(colCategoryLevel).Value)
                objTr.formtype_detail = FormType
                objTr.Line_No = CInt(clsCommon.myCdbl(grow.Cells(colLineNo).Value))

                obj.ObjList.Add(objTr)
            Next
            Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
            If (obj.SaveData(obj, isNewEntry, trans)) Then
                trans.Commit()
                common.clsCommon.MyMessageBoxShow("Data Saved Successfully")
                LoadData(obj.ITEM_CATEGORY_STRUCT_CODE, NavigatorType.Current)
            Else
                trans.Rollback()
                '    common.clsCommon.MyMessageBoxShow("This '" & obj.Code & "' already exist ")
            End If

        End If
    End Sub

    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        txtCode.MyReadOnly = True
        btnsave.Enabled = True
        btndelete.Enabled = False
        isNewEntry = False


        Dim obj As New clsItemCategoryStructure()
        obj = clsItemCategoryStructure.GetData(strCode, FormType, NavTyep)

        If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.ITEM_CATEGORY_STRUCT_CODE) > 0) Then
            funReset()
            isNewEntry = False
            btnsave.Text = "Update"
            btndelete.Enabled = True
            txtCode.Value = obj.ITEM_CATEGORY_STRUCT_CODE
            txtDescription.Text = obj.DESCRIPTION

            txtCode.MyReadOnly = True
            LoadItemCategoryLevels()
            Dim ii As Int16 = 0
            If obj.ObjList IsNot Nothing AndAlso obj.ObjList.Count > 0 Then
                LoadGridColumns(gvStructLevels)
                For Each objTr As clsItemCategoryStructureDetails In obj.ObjList
                    gvStructLevels.Rows.AddNew()
                    ii = ii + 1
                    gvStructLevels.Rows(gvStructLevels.Rows.Count - 1).Cells(colCategoryLevelCode).Value = objTr.ITEM_CATEGORY_CODE
                    gvStructLevels.Rows(gvStructLevels.Rows.Count - 1).Cells(colDescription).Value = objTr.ITEM_CATEGORY_DESCRIPTION
                    gvStructLevels.Rows(gvStructLevels.Rows.Count - 1).Cells(colCategoryLevel).Value = objTr.CATEGORY_LEVEL
                    gvStructLevels.Rows(gvStructLevels.Rows.Count - 1).Cells(colLineNo).Value = objTr.Line_No
                Next
            End If
        End If
    End Sub

    Function AllowToSave() As Boolean
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) Then
            If clsCommon.myLen(txtCode.Value) <= 0 Then
                clsCommon.MyMessageBoxShow("Fill Code", Me.Text)
                txtCode.Focus()
                txtCode.Select()
                Errorcontrol.SetError(txtCode, "Fill Code")
                Return False
            Else
                Errorcontrol.ResetError(txtCode)
            End If
        End If
        
        If clsCommon.myLen(txtDescription.Text) <= 0 Then
            clsCommon.MyMessageBoxShow("Fill Description", Me.Text)
            txtDescription.Focus()
            txtDescription.Select()
            Errorcontrol.SetError(txtDescription, "Fill Description")
            Return False
        Else
            Errorcontrol.ResetError(txtDescription)
        End If
        If Me.gvStructLevels.Rows.Count = 0 Then
            myMessages.blankValue("Second List is Empty")
            gvStructLevels.Focus()
            Errorcontrol.SetError(gvStructLevels, "Second List is Empty")
            Return False
        Else
            Errorcontrol.ResetError(gvStructLevels)
        End If

        RefershLineNo()

        Return True
    End Function

