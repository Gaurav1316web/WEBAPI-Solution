        CategoryLevelCode.Width = 100
        CategoryLevelCode.ReadOnly = True
        CategoryLevelCode.TextAlignment = System.Drawing.ContentAlignment.MiddleLeft
        gv.Columns.Add(CategoryLevelCode)

        Description = New GridViewTextBoxColumn()
