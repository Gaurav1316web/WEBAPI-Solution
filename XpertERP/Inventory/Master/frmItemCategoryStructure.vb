    Sub funReset()
        isNewEntry = True
        txtCode.MyReadOnly = False
        txtDescription.ReadOnly = False
        txtCode.Value = Nothing
        txtCode.Focus()
        txtDescription.Text = ""
        Me.gvCategoryLevels.Rows.Clear()
        Me.gvStructLevels.Rows.Clear()
        Me.gvCategoryLevels.Rows.AddNew()
        LoadItemCategoryLevels()

        btnsave.Text = "Save"
        btnsave.Enabled = True
        btndelete.Enabled = False
    End Sub

