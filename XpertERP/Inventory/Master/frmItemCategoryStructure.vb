    Private Sub txtCode__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles txtCode._MYValidating
        Try
            Dim str As String = "select count(*) from TSPL_ITEM_CATEGORY_STRUCTURE where ITEM_CATEGORY_STRUCT_CODE ='" + txtCode.Value + "' and isnull(form_type,'item')='" + FormType + "' "
            Dim no As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(str))
            If no = 0 AndAlso isButtonClicked = False Then
                txtCode.MyReadOnly = False
                'txtCode.Value = ""
                '' common.clsCommon.MyMessageBoxShow("Value doesn't exist ")
            Else
                txtCode.MyReadOnly = True
            End If
            If txtCode.MyReadOnly OrElse isButtonClicked Then

                'Dim qry As String = " select ITEM_CATEGORY_STRUCT_CODE as Code,  description from TSPL_ITEM_CATEGORY_STRUCTURE "
                'txtCode.Value = clsCommon.ShowSelectForm("TSPL_ITEM_CATEGORY_STRUCTURE", qry, "Code", "", txtCode.Value, "ITEM_CATEGORY_STRUCT_CODE", isButtonClicked)
                txtCode.Value = clsItemCategoryStructure.getFinder(" isnull(form_type,'item')='" + FormType + "'", txtCode.Value, isButtonClicked)
                txtCode.Text = clsItemCategoryStructure.GetData(txtCode.Value, FormType, Nothing).ITEM_CATEGORY_STRUCT_CODE
                If txtCode.Value <> "" Then
                    LoadData(txtCode.Value, NavigatorType.Current)
                Else
                    funReset()
                End If
            End If
        Catch ex As Exception

        End Try
       
    End Sub

    Private Sub txtCode__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavType As common.NavigatorType) Handles txtCode._MYNavigator
        Try
            LoadData(txtCode.Value, NavType)
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(ex.Message)
        End Try
    End Sub

    Private Sub frmItemCategoryStructure_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.N AndAlso btnNew.Enabled Then
            funReset()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnsave.Enabled Then
            Save()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btndelete.Enabled Then
            DeleteData()
        ElseIf e.Alt And e.KeyCode = Keys.C Then
            funClose()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funReset()
        End If
    End Sub

    Sub LoadGridColumns(ByVal gv As RadGridView)
        gv.DataSource = Nothing
        gv.Rows.Clear()
        gv.Columns.Clear()

        'gv.ReadOnly = True

        CategoryLevelCode = New GridViewTextBoxColumn()
        CategoryLevelCode.FormatString = ""
        CategoryLevelCode.HeaderText = "S.No."
        CategoryLevelCode.Name = colLineNo
        CategoryLevelCode.Width = 60
        CategoryLevelCode.ReadOnly = True
        CategoryLevelCode.TextAlignment = System.Drawing.ContentAlignment.MiddleLeft
        gv.Columns.Add(CategoryLevelCode)

        CategoryLevelCode = New GridViewTextBoxColumn()
        CategoryLevelCode.FormatString = ""
        CategoryLevelCode.HeaderText = "Category Level"
