        CategoryLevel.Name = colCategoryLevel
        CategoryLevel.Width = 100
        CategoryLevel.ReadOnly = True
        CategoryLevel.TextAlignment = System.Drawing.ContentAlignment.MiddleLeft
        gv.Columns.Add(CategoryLevel)


    End Sub
    Sub LoadItemCategoryLevels()
        Dim strq As String
        If isNewEntry = True Then
            strq = " select * from TSPL_ITEM_CATEGORY_LEVEL where isnull(form_type,'item')='" + FormType + "'"
        Else
            strq = " select * from TSPL_ITEM_CATEGORY_LEVEL WHERE isnull(form_type,'item')='" + FormType + "' and CATEGORY_LEVEL NOT IN (SELECT CATEGORY_LEVEL FROM  TSPL_ITEM_CATEGORY_STRUCT_DETAIL WHERE ITEM_CATEGORY_STRUCT_CODE='" & clsCommon.myCstr(Me.txtCode.Value) & "' and isnull(form_type,'item')='" + FormType + "')"
        End If

        Dim dt As DataTable
        dt = clsDBFuncationality.GetDataTable(strq)
        Me.gvCategoryLevels.Rows.Clear()

        For intloop As Integer = 0 To dt.Rows.Count - 1
            Me.gvCategoryLevels.Rows.AddNew()
            Me.gvCategoryLevels.Rows(intloop).Cells(colLineNo).Value = Me.gvCategoryLevels.Rows.Count
            Me.gvCategoryLevels.Rows(intloop).Cells(colCategoryLevelCode).Value = dt.Rows(intloop).Item("ITEM_CATEGORY_CODE")
            Me.gvCategoryLevels.Rows(intloop).Cells(colDescription).Value = dt.Rows(intloop).Item("DESCRIPTION")
            Me.gvCategoryLevels.Rows(intloop).Cells(colCategoryLevel).Value = dt.Rows(intloop).Item("CATEGORY_LEVEL")
        Next
    End Sub




