    Private Sub rdbNext_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rdbNext.Click
        Try
            If gvCategoryLevels.CurrentRow.Index >= 0 Then
                Me.gvStructLevels.Rows.AddNew()
                Me.gvStructLevels.Rows(Me.gvStructLevels.Rows.Count - 1).Cells(colLineNo).Value = Me.gvStructLevels.Rows.Count
                Me.gvStructLevels.Rows(Me.gvStructLevels.Rows.Count - 1).Cells(colCategoryLevelCode).Value = Me.gvCategoryLevels.CurrentRow.Cells(colCategoryLevelCode).Value
                Me.gvStructLevels.Rows(Me.gvStructLevels.Rows.Count - 1).Cells(colDescription).Value = Me.gvCategoryLevels.CurrentRow.Cells(colDescription).Value
                Me.gvStructLevels.Rows(Me.gvStructLevels.Rows.Count - 1).Cells(colCategoryLevel).Value = Me.gvCategoryLevels.CurrentRow.Cells(colCategoryLevel).Value
                gvCategoryLevels.Rows.RemoveAt(Me.gvCategoryLevels.CurrentRow.Index)
            End If
        Catch ex As Exception
        End Try
    End Sub

    Private Sub btnBack_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnBack.Click
        Try
            If gvStructLevels.CurrentRow.Index >= 0 Then
                Me.gvCategoryLevels.Rows.AddNew()
                Me.gvCategoryLevels.Rows(Me.gvCategoryLevels.Rows.Count - 1).Cells(colCategoryLevelCode).Value = Me.gvStructLevels.CurrentRow.Cells(colCategoryLevelCode).Value
                Me.gvCategoryLevels.Rows(Me.gvCategoryLevels.Rows.Count - 1).Cells(colDescription).Value = Me.gvStructLevels.CurrentRow.Cells(colDescription).Value
                Me.gvCategoryLevels.Rows(Me.gvCategoryLevels.Rows.Count - 1).Cells(colCategoryLevel).Value = Me.gvStructLevels.CurrentRow.Cells(colCategoryLevel).Value
                gvStructLevels.Rows.RemoveAt(Me.gvStructLevels.CurrentRow.Index)
                RefershLineNo()
            End If
        Catch ex As Exception
        End Try

    End Sub

    Private Sub RefershLineNo()
        For Each grow As GridViewRowInfo In gvStructLevels.Rows
            grow.Cells(colLineNo).Value = grow.Index + 1
        Next
        For Each grow As GridViewRowInfo In gvCategoryLevels.Rows
            grow.Cells(colLineNo).Value = grow.Index + 1
        Next
    End Sub
End Class
