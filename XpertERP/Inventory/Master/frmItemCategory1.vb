    Private Sub TxtCategoryCode__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles TxtCategoryCode._MYValidating
        Dim str As String = "select count(*) from TSPL_Item_Category where Category_Code ='" + TxtCategoryCode.Value + "' "
        Dim no As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(str))
        If no = 0 Then
            TxtCategoryCode.MyReadOnly = False
        Else
            TxtCategoryCode.MyReadOnly = True
        End If
        If TxtCategoryCode.MyReadOnly OrElse isButtonClicked Then
            Dim qry As String = "select Category_Code as CategoryCode,Category_Name as CategoryName  from TSPL_Item_Category "
            TxtCategoryCode.Value = clsCommon.ShowSelectForm("Category_Selector", qry, "CategoryCode", "", TxtCategoryCode.Value, "CategoryCode", isButtonClicked)
            'tbCategoryName.Text = clsCommon.myCstr(clsDBFuncationality.getSingleValue("select category_name from tspl_Item_category where category_code='" + TxtCategoryCode.Value + "'"))
            LoadData(TxtCategoryCode.Value, NavigatorType.Current)
        End If
    End Sub


