    Public Sub Import()
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim currentdate As Date = Date.Today
        If transportSql.importExcel(gv, "Category Code", "Category Name") Then
            Dim trans As SqlTransaction = Nothing
            Try
                'connectSql.OpenConnection()
                trans = clsDBFuncationality.GetTransactin()
                clsCommon.ProgressBarShow()
                For Each grow As GridViewRowInfo In gv.Rows
                    Dim strCtgryCode As String = clsCommon.myCstr(grow.Cells(0).Value)
                    Dim strCtgryName As String = clsCommon.myCstr(grow.Cells(1).Value)

                    If (String.IsNullOrEmpty(strCtgryCode)) Or clsCommon.myLen(strCtgryCode) > 12 Then
                        Throw New Exception("Category Code can not be blank or incorrect")
                    End If

                    If (String.IsNullOrEmpty(strCtgryName)) Or clsCommon.myLen(strCtgryName) > 50 Then
                        Throw New Exception(" Category Name  can not be blank or incorrect")
                    End If

                    Dim sql1 As String = "select count(*) from TSPL_Item_Category where Category_Code='" + strCtgryCode + "'"
                    Dim i As Integer = CInt(clsDBFuncationality.getSingleValue(sql1, trans))
                    If (i = 0) Then
                        Qry = "INSERT Into TSPL_Item_Category values('" + strCtgryCode + "','" + strCtgryName + "','" + userCode + "','" + clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy") + "','" + userCode + "','" + clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy") + "','" + companyCode + "')"
                        clsDBFuncationality.ExecuteNonQuery(Qry, trans)
                        'connectSql.RunSql(Qry)
                        'connectSql.RunSpTransaction(trans, "sp_DesignationMaster_insert", New SqlParameter("@Category Code", strCtgryCode), New SqlParameter("@Category Name", strCtgryName), New SqlParameter("@createdby", userCode), New SqlParameter("@createddate", connectSql.serverDate()), New SqlParameter("@modifiedby", userCode), New SqlParameter("@modifieddate", connectSql.serverDate()), New SqlParameter("@compcode", companyCode))
                    Else
                        Qry = "UPDATE TSPL_Item_CAtegory set Category_Code='" + strCtgryCode + "', Category_Name='" + strCtgryName + "', Modify_By='" + userCode + "', Modify_Date='" + clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(trans), "dd/MM/yyyy") + "', Comp_Code='" + companyCode + "' WHERE Category_Code='" + strCtgryCode + "'"
                        clsDBFuncationality.ExecuteNonQuery(Qry, trans)
                        'connectSql.RunSql(Qry)
                        'connectSql.RunSpTransaction(trans, "sp_DesignationMaster_update", New SqlParameter("@CAtegory Code", strCtgryCode), New SqlParameter("@Category Name", strCtgryName), New SqlParameter("@modifiedby", userCode), New SqlParameter("@modifieddate", connectSql.serverDate()), New SqlParameter("@compcode", companyCode))

                    End If
                Next
                trans.Commit()
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow(Me, "Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                trans.Rollback()
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)

            End Try

        End If
        Me.Controls.Remove(gv)
    End Sub

