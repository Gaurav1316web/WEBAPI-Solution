    Private Sub frmvendoraccountset_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso rdbtnsave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.P AndAlso MyBase.isPostFlag Then
            'PostData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso rdbtndelete.Enabled Then
            DeleteData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.C Then
            Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funreset()
        End If
    End Sub

    Private Sub fndaccountsetcode__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles fndaccountsetcode._MYValidating

        If isButtonClicked Then
            Dim whrcls As String = String.Empty
            If clsCommon.CompairString(Form_ID, clsUserMgtCode.Farmeraccountset) = CompairStringResult.Equal Then
                whrcls = " tspl_vendor_account_set.IsFarmer=1 "
            Else
                whrcls = " tspl_vendor_account_set.IsFarmer=0 "
            End If
            fndaccountsetcode.Value = clsVendorAccountSet.getFinder(whrcls, fndaccountsetcode.Value, isButtonClicked)
            rdtxtdescription.Text = clsDBFuncationality.getSingleValue("Select acct_set_desc from tspl_vendor_account_set where acct_set_code='" + fndaccountsetcode.Value + "'")
            If fndaccountsetcode.Value IsNot Nothing Then
                rdbtndelete.Enabled = True
            Else
                rdbtndelete.Enabled = False
            End If
            textchangedsub()

        ElseIf fndaccountsetcode.MyReadOnly OrElse fndaccountsetcode.Value IsNot Nothing Then
            Dim qry As String = "Select * from TSPL_User_Group_Master where group_Code ='" + fndaccountsetcode.Value + "' "
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt.Rows.Count < 0 Then
                rdtxtdescription.Text = ""
                rdbtnsave.Text = "Save"
                rdtxtadvance.Text = ""
                rdtxtpayablescontrol.Text = ""
                rdtxtpurchasediscount.Text = ""
                fndiscount.Value = ""
                fndpayable.Value = ""
                txtadvance.Value = ""

            Else
                textchangedsub()
                rdbtndelete.Enabled = True

            End If

        End If
    End Sub

    Private Sub fndaccountsetcode__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavigatorType As common.NavigatorType) Handles fndaccountsetcode._MYNavigator
        Dim whrcls As String = String.Empty
        If clsCommon.CompairString(Form_ID, clsUserMgtCode.Farmeraccountset) = CompairStringResult.Equal Then
            whrcls = " AND tspl_vendor_account_set.IsFarmer=1 "
        Else
            whrcls = " AND tspl_vendor_account_set.IsFarmer=0 "
        End If

        Dim qst As String = "select acct_set_code as [Account Set Code],acct_set_desc as [Description]  from tspl_vendor_account_set   where  2=2 " & whrcls & ""
        Select Case NavigatorType
            Case NavigatorType.Current
            Case NavigatorType.Next
                qst += "and acct_set_code in (select min(acct_set_code) from tspl_vendor_account_set where acct_set_code>'" + fndaccountsetcode.Value + "' " & whrcls & ") "
            Case NavigatorType.First
                qst += "and acct_set_code in (select MIN(acct_set_code) from tspl_vendor_account_set WHERE 1=1 " & whrcls & ")"
            Case NavigatorType.Last
                qst += "and acct_set_code in (select Max(acct_set_code) from tspl_vendor_account_set WHERE 1=1 " & whrcls & ")"
            Case NavigatorType.Previous
                qst += "and acct_set_code in (select max(acct_set_code) from tspl_vendor_account_set where acct_set_code<'" + fndaccountsetcode.Value + "' " & whrcls & ")"
        End Select
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndaccountsetcode.Value = clsCommon.myCstr(dt.Rows(0)("Account Set Code"))
            rdtxtdescription.Text = clsCommon.myCstr(dt.Rows(0)("Description"))
        End If
        If fndaccountsetcode.Value IsNot Nothing Then
            rdbtndelete.Enabled = True
        Else
            rdbtndelete.Enabled = False
        End If
        textchangedsub()
    End Sub

