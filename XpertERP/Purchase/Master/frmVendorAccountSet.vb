    Public Function accountqry() As String
        arrlist = clsERPFuncationality.glaccountquery(objCommonVar.CurrentUserCode)
        qry = arrlist.Item(0)
        whrcls = arrlist.Item(1)
        If whrcls <> "" Then
            qry = qry + " where " + whrcls + " and account_type <>'Retained Earnings'and ControlAccount  ='N' "
        Else
            qry = qry + " where account_type <>'Retained Earnings'and ControlAccount  ='N' "
        End If

        Return qry
    End Function

