    Private Sub frmvendoraccountset_Load(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MyBase.Load
        SetUserMgmtNew()
        If fndaccountsetcode.Value = "" Then
            rdbtndelete.Enabled = False
        End If
        textchangedsub()

        ButtonToolTip.SetToolTip(rdbtnsave, "Press Alt+S for Save/Update Trasnaction")
        ButtonToolTip.SetToolTip(rdbtndelete, "Press Alt+D Delete Trasnaction")
        ButtonToolTip.SetToolTip(rdbtnclose, "Press Alt+C Close the Window")
        ButtonToolTip.SetToolTip(rdbtnreset, "Press Alt+N Adding New Trasnaction")
        If CheckMultiCurrency() = True Then
            Me.fndBaseCurrency.Enabled = True
            Me.fndExchangeLoss.Enabled = True
            Me.fndExchangeGain.Enabled = True
        Else
            Me.fndBaseCurrency.Enabled = False
            Me.fndExchangeLoss.Enabled = False
            Me.fndExchangeGain.Enabled = False
        End If

        ' For dril down open 
        If clsCommon.myLen(Me.Tag) > 0 Then
            fndaccountsetcode.Value = clsCommon.myCstr(Me.Tag)
            textchangedsub()
        End If
        If clsCommon.CompairString(Form_ID, clsUserMgtCode.Farmeraccountset) = CompairStringResult.Equal Then
            chkFarmer.Visible = True
            rdlblpurchasediscount.Text = "Load Advance"
        Else
            chkFarmer.Visible = False
            rdlblpurchasediscount.Text = "Discount"
        End If
    End Sub
    Function CheckMultiCurrency() As Boolean
        Dim strq As String
        strq = "select * from tspl_module_currency_mapping where comp_code='" + objCommonVar.CurrentCompanyCode + "' and module_code='" & Me.Module_Code & "'"
        Dim dt As DataTable
        dt = clsDBFuncationality.GetDataTable(strq)
        If dt.Rows.Count > 0 Then
            If dt.Rows(0).Item("Apply") = True Then
                Return True
            Else
                Return False
            End If
        Else
            Return False
        End If
    End Function
    Private Sub SetUserMgmtNew()
        If Not (MyBase.isReadFlag) Then
            Throw New Exception("Permission Denied")
        End If
        rdbtnsave.Visible = MyBase.isModifyFlag
        If rdbtnsave.Visible = True Then
            rdmenuimport.Enabled = True
            rdmenuexport.Enabled = True
        Else
            rdmenuimport.Enabled = False
            rdmenuexport.Enabled = False
        End If
        rdbtndelete.Visible = MyBase.isDeleteFlag
    End Sub
    Public Sub funinsert()
        Try
            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from TSPL_VENDOR_ACCOUNT_SET where Acct_Set_Code='" & fndaccountsetcode.Value & "'")
                If ChkNewEntry = 0 Then
                    fndaccountsetcode.Value = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy"), clsDocType.VendorAccountSet, "", "")
                    If clsCommon.myLen(fndaccountsetcode.Value) <= 0 Then
                        Throw New Exception("Error in Code Generation")
                    End If
                End If
            End If
            connectSql.RunSp("sp_vendoraccountset_insert", New SqlParameter("@acctsetcode", fndaccountsetcode.Value), New SqlParameter("@desc", rdtxtdescription.Text), New SqlParameter("@Payablescontrol", fndpayable.Value), New SqlParameter("@discountaccount", fndiscount.Value), New SqlParameter("@advance", txtadvance.Value), New SqlParameter("@createdby", userCode), New SqlParameter("createddate", connectSql.serverDate()), New SqlParameter("@modifyby", userCode), New SqlParameter("@modifydate", connectSql.serverDate()), New SqlParameter("@comcode", companyCode))
            UpdateNewColumns()
            myMessages.insert()


        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub

    Public Sub funupdate()
        Try
            clsCommonFunctionality.SaveHistoryData(objCommonVar.CurrentUserCode, fndaccountsetcode.Value, "TSPL_VENDOR_ACCOUNT_SET", "Acct_set_code", Nothing)
            connectSql.RunSp("sp_vendoraccountset_update", New SqlParameter("@acctsetcode", fndaccountsetcode.Value), New SqlParameter("@desc", rdtxtdescription.Text), New SqlParameter("@Payablescontrol", fndpayable.Value), New SqlParameter("@discountaccount", fndiscount.Value), New SqlParameter("@advance", txtadvance.Value), New SqlParameter("@createdby", userCode), New SqlParameter("createddate", connectSql.serverDate()), New SqlParameter("@modifyby", userCode), New SqlParameter("@modifydate", connectSql.serverDate()), New SqlParameter("@comcode", companyCode))
            UpdateNewColumns()
            myMessages.update()

            Dim STRQ As String
            STRQ = "UPDATE TSPL_VENDOR_MASTER SET CURRENCY_CODE=TSPL_VENDOR_ACCOUNT_SET.CURRENCY_CODE FROM  " &
                " TSPL_VENDOR_ACCOUNT_SET WHERE TSPL_VENDOR_MASTER.Vendor_Account=TSPL_VENDOR_ACCOUNT_SET.Acct_Set_Code AND TSPL_VENDOR_ACCOUNT_SET.Acct_Set_Code='" & fndaccountsetcode.Value & "' "
            clsDBFuncationality.ExecuteNonQuery(STRQ)

        Catch ex As Exception
            myMessages.myExceptions(ex)

        End Try
    End Sub

