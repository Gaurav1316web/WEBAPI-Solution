    Sub DeleteData()
        If clsCommon.myLen(fndaccountsetcode.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "You Cannot Delete Record", Me.Text)
            Exit Sub
        End If
        If myMessages.deleteConfirm Then
            fundelete()
            myMessages.delete()
            rdbtnsave.Text = "Save"
            rdbtndelete.Enabled = False
            funreset()
        End If
