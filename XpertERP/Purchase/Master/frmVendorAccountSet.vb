    Sub textchangedsub()
        Dim query As String = "select acct_set_code from tspl_vendor_account_set where acct_set_code ='" + fndaccountsetcode.Value() + "'"
        Dim var As String
        var = clsDBFuncationality.getSingleValue(query)
        If (var <> "") Then
            funfill()
            rdbtnsave.Text = "Update"
            rdbtndelete.Enabled = True
        Else
            rdbtnsave.Text = "Save"
            rdtxtdescription.Text = ""
            rdbtndelete.Enabled = False
            fndpayable.Value = ""
            fndiscount.Value = ""
            txtadvance.Value = ""
        End If
