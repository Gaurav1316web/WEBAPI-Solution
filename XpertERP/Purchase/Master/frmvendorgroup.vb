    Private Sub fndgroupcode__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavigatorType As common.NavigatorType) Handles fndgroupcode._MYNavigator
        Dim qst As String = "select ven_group_code as [Vendor Group Code],group_desc as [Description] from tspl_vendor_group   where  2=2 "
        Select Case NavigatorType
            Case NavigatorType.Current
                '  qst += "and assign_to='" + txtassign.Value + "' "
                ' qst += "and job_code in ('" + txtcode1.Value + "')"
            Case NavigatorType.Next
                qst += "and ven_group_code in (select min(ven_group_code) from tspl_vendor_group where ven_group_code>'" + fndgroupcode.Value + "'   ) "
            Case NavigatorType.First
                qst += "and ven_group_code in (select MIN(ven_group_code) from tspl_vendor_group  )"
            Case NavigatorType.Last
                qst += "and ven_group_code in (select Max(ven_group_code) from tspl_vendor_group  )"
            Case NavigatorType.Previous
                qst += "and ven_group_code in (select max(ven_group_code) from tspl_vendor_group where ven_group_code<'" + fndgroupcode.Value + "'   )"
        End Select
        ' fun_gridfill()
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndgroupcode.Value = clsCommon.myCstr(dt.Rows(0)("Vendor Group Code"))
            rdtxtgroupdesc.Text = clsCommon.myCstr(dt.Rows(0)("Description"))
        End If
        'TextChanged()
        If fndgroupcode.Value IsNot Nothing Then
            rdbtndelete.Enabled = True
        Else
            rdbtndelete.Enabled = False

        End If
        groupcode_textchanged()

    End Sub

