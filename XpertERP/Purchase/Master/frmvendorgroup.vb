    Public Sub funfill()
        Dim query As String = "Select group_desc,acct_set_code,acct_set_desc,terms_code,terms_desc,payment_code,payment_desc,bank_code,description,tax_group_code,tax_group_desc,Is_TDSApplicable,Vendor_Sub_Group,Default_VSP from tspl_vendor_group where ven_group_code='" + fndgroupcode.Value + "'"
        Dim adp As New SqlDataAdapter(query, connectSql.SqlCon())
        Dim dt As New DataTable()
        adp.Fill(dt)
        Dim dr As DataRow = dt.Rows(0)
        rdtxtgroupdesc.Text = dr(0).ToString()
        fndaccountset.Value = dr(1).ToString()
        rdtxtaccountset.Text = dr(2).ToString()
        fndtermscode.Value = dr(3).ToString()
        rdtxttermscode.Text = dr(4).ToString()
        fndpayamentcode.Value = dr(5).ToString()
        rdtxtpayametcode.Text = dr(6).ToString()
        fndbankcode.Value = dr(7).ToString()
        rdtxtbankcode.Text = dr(8).ToString()
        fndtaxgroup.Value = dr(9).ToString()
        rdtxttaxgroup.Text = dr(10).ToString()
        chk_istdsapplicable.Checked = IIf(clsCommon.myCstr(dr("Is_TDSApplicable").ToString()) = 1, True, False)
        fndSubGroup.Value = dr(12).ToString()
        txtSubGroup.Text = clsDBFuncationality.getSingleValue("Select SubGroup_Desc from TSPL_VENDOR_SUB_GROUP where Ven_Sub_Group_Code='" + fndSubGroup.Value + "'")
        chkDefaultVSP.Checked = IIf(clsCommon.myCstr(dr("Default_VSP").ToString()) = 1, True, False)
        rdbtnsave.Text = "Update"


    End Sub
