#Region "Functions"
    Private Sub SetUserMgmtNew()
        'MyBase.SetUserMgmt(clsUserMgtCode.FrmHirerachyLevelMaster)
        If Not (MyBase.isReadFlag) Then
            Throw New Exception("Permission Denied")
        End If
        btnSave.Visible = MyBase.isModifyFlag
        btnDelete.Visible = MyBase.isDeleteFlag
    End Sub
    Sub Reset()
        HirerachyLevel = ""
        txtCode.Value = ""
        txtDesc.Text = ""
        cmblevel.SelectedIndex = 0
        cmblevel.Text = "1"
        btnSave.Text = "Save"
        btnSave.Enabled = True
        btnDelete.Enabled = False
        txtCode.MyReadOnly = False

        txtCode.Focus()
        txtCode.Select()
    End Sub
    Function AllowToSave() As Boolean
        Try
            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) Then
                If clsCommon.myLen(txtCode.Value) <= 0 Then
                    clsCommon.MyMessageBoxShow(Me, "Please fill Code", Me.Text)
                    txtCode.Focus()
                    txtCode.Select()
                    Return False
                End If
            End If
            If clsCommon.myLen(txtDesc.Text) <= 0 Then
                clsCommon.MyMessageBoxShow(Me, "Please fill description", Me.Text)
                txtDesc.Focus()
                txtDesc.Select()
                Return False
            End If
            If clsCommon.myLen(cmblevel.Text) <= 0 Then
                clsCommon.MyMessageBoxShow(Me, "Please select level", Me.Text)
                cmblevel.Focus()
                cmblevel.Select()
                Return False
            End If
            If clsCommon.CompairString(cmblevel.Text, HirerachyLevel) <> CompairStringResult.Equal Then
                If clsCommon.myCdbl(clsDBFuncationality.getSingleValue("select count(level) as LevelCount from TSPL_HIRERACHY_LEVEL_MASTER where level='" + cmblevel.Text + "'")) > 0 Then
                    clsCommon.MyMessageBoxShow(Me, "Level is Already Used with Other Hirerachy Code", Me.Text)
                    cmblevel.Focus()
                    cmblevel.Select()
                    Return False
                End If
            End If
            If clsCommon.CompairString(cmblevel.Text, HirerachyLevel) <> CompairStringResult.Equal Then
                Dim Qry As String = Nothing
                If EnableHirerachyCostCentre = 0 Then
                    Qry = "select count(Hirerachy_Level_Code) as HLC_Count  from TSPL_COST_CENTRE_FINANCIAL WHERE Hirerachy_Level_Code='" + txtCode.Value + "' and Hirerachy_Level ='" + HirerachyLevel + "'"
                Else
                    Qry = "select count(Hirerachy_Level_Code) as HLC_Count  from TSPL_COST_CENTRE_FINANCIAL_DETAIL WHERE Hirerachy_Level_Code='" + txtCode.Value + "' and Hirerachy_Level ='" + HirerachyLevel + "'"
                End If
                Dim CheckHirerchyLCode As Double = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(Qry))
                If CheckHirerchyLCode > 0 Then
                    clsCommon.MyMessageBoxShow(Me, "Level is in Use So you can not Update", Me.Text)
                    cmblevel.Focus()
                    cmblevel.Select()
                    Return False
                End If
            End If

            Return True
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Function
    Sub SaveData()
        Try
            If MyBase.isModifyonPasswordFlag Then
                If clsPasswordCheckForMasters.CheckMasterPwd(clsUserMgtCode.FrmHirerachyLevelMaster, clsCommon.myCstr(objCommonVar.CurrentCompanyCode)) Then
                Else
                    Return
                End If
            End If

            Dim obj As New ClsHirerachyLevelMaster()

            obj.HIRERACHY_CODE = clsCommon.myCstr(txtCode.Value)
            obj.Description = clsCommon.myCstr(txtDesc.Text).Replace("'", "`")
            obj.Level = clsCommon.myCstr(cmblevel.Text)
            If ClsHirerachyLevelMaster.SaveData(obj, txtCode.Value) Then
                clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                btnSave.Text = "Update"
                btnDelete.Enabled = True
                txtCode.Value = obj.HIRERACHY_CODE
                LoadData(txtCode.Value, NavigatorType.Current)
                txtCode.MyReadOnly = True
            Else
                txtCode.MyReadOnly = False
                btnSave.Text = "Save"
                btnDelete.Enabled = False
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Public Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        Try
            Dim obj As New ClsHirerachyLevelMaster()
            txtCode.Value = strCode
            obj = ClsHirerachyLevelMaster.GetData(strCode, NavTyep)

            If obj IsNot Nothing AndAlso clsCommon.myLen(obj.HIRERACHY_CODE) > 0 Then
                txtCode.Value = obj.HIRERACHY_CODE
                txtDesc.Text = obj.Description
                cmblevel.Text = obj.Level
                HirerachyLevel = obj.Level
                txtCode.MyReadOnly = True
                btnSave.Text = "Update"
                btnDelete.Enabled = True
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
