Public Class FrmHirerachyLevelMaster
    Inherits FrmMainTranScreen

#Region "Variables"
    Dim ButtonToolTip As ToolTip = New ToolTip()
    Dim HirerachyLevel As String = Nothing
    Dim EnableHirerachyCostCentre As Double = 0
