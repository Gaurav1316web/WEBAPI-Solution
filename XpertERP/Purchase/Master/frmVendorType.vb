    Private Sub text_changed()
        Dim var As String
        var = clsDBFuncationality.getSingleValue("select ven_type_code from tspl_vendor_type_master where ven_type_code='" + fndvendorid.Value + "'")

       
        If clsCommon.CompairString(var, fndvendorid.Value) <> CompairStringResult.Equal Then
