    Private Sub funInsert()
        Try
            If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False)) Then
                Dim ChkNewEntry As String = clsDBFuncationality.getSingleValue("Select count(*) from tspl_vendor_type_master where ven_type_code='" & fndvendorid.Value & "'")
                If ChkNewEntry = 0 Then
                    fndvendorid.Value = clsERPFuncationality.GetNextCode(Nothing, clsCommon.GetPrintDate(clsCommon.GETSERVERDATE(), "dd/MM/yyyy"), clsDocType.VendorType, "", "")
                    If clsCommon.myLen(fndvendorid.Value) <= 0 Then
                        Throw New Exception("Error in Code Generation")
                    End If
                End If
            End If
            connectSql.RunSp("sp_vendortype_insert", New SqlParameter("@vendortype", fndvendorid.Value), New SqlParameter("@vendortypedesc", rdtxtvendordesc.Text), New SqlParameter("@CreatedBy", userCode), New SqlParameter("@CreatedDate", connectSql.serverDate()), New SqlParameter("@ModifyBy", userCode), New SqlParameter("@ModifyDate", connectSql.serverDate()), New SqlParameter("@ComCode", companyCode))
            myMessages.insert()
            rdbtnSave.Text = "Update"
            rdbtnDelete.Enabled = True
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub
    Private Sub rdbtnSave_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rdbtnSave.Click
        SaveData()
    End Sub
    Sub SaveData()
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso fndvendorid.Value = "" Then
            myMessages.blankValue("Vendor Type")
            fndvendorid.Focus()
            Return
        Else
            If rdbtnSave.Text = "Save" Then
                funInsert()
            ElseIf rdbtnSave.Text = "Update" Then
                funUpdate()
            End If
        End If
    End Sub
    'update vendor Type Details
    Private Sub funUpdate()
        If fndvendorid.Value = "" Then
            myMessages.blankValue("Vendor Type")
        Else
            Try
                connectSql.RunSp("sp_vendortype_update", New SqlParameter("@vendortype", fndvendorid.Value), New SqlParameter("@vendortypedesc", rdtxtvendordesc.Text), New SqlParameter("@CreatedBy", userCode), New SqlParameter("@CreatedDate", connectSql.serverDate()), New SqlParameter("@ModifyBy", userCode), New SqlParameter("@ModifyDate", connectSql.serverDate()), New SqlParameter("@ComCode", companyCode))
                myMessages.update()
                rdbtnSave.Text = "Update"
            Catch ex As Exception
                myMessages.myExceptions(ex)
            End Try
        End If
    End Sub
    Private Sub funReset()
        fndvendorid.Value = ""
        rdtxtvendordesc.Text = ""
        rdbtnSave.Text = "Save"
        rdbtnDelete.Enabled = False
        rdtxtvendordesc.Focus()
        'If userCode <> "ADMIN" Then
        '    If funSetUserAccess() = False Then Exit Sub
        'End If
    End Sub
    Private Sub funDelete()
        Try
            connectSql.RunSp("sp_vendortype_delete", New SqlParameter("@vendortype", fndvendorid.Value))
            myMessages.delete()
            rdbtnSave.Text = "Save"
            rdbtnDelete.Enabled = False
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub
    Public Sub funfill()
        Dim dt As DataTable
        Dim query As String = "select ven_type_code ,ven_type_desc from tspl_vendor_type_master where ven_type_code='" + fndvendorid.Value() + "'"
        dt = clsDBFuncationality.GetDataTable(query)
        If (dt IsNot Nothing AndAlso dt.Rows.Count > 0) Then

            For Each row As DataRow In dt.Rows
                fndvendorid.Value = row(0).ToString()
                rdtxtvendordesc.Text = row(1).ToString()
                rdbtnSave.Text = "Update"
                rdbtnDelete.Enabled = True
            Next
End if
    End Sub
