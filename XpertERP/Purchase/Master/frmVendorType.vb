    Private Sub frmVendorType_KeyDown(ByVal sender As System.Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso rdbtnSave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.P AndAlso MyBase.isPostFlag Then
            'PostData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso rdbtnDelete.Enabled Then
            DeleteData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.C Then
            Close()
        ElseIf e.Alt And e.KeyCode = Keys.N Then
            funReset()
        End If
    End Sub



    Private Sub fndvendorid__MYValidating(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal isButtonClicked As System.Boolean) Handles fndvendorid._MYValidating
        If isButtonClicked Then
            Dim qry As String = "select ven_Type_Code as [Vendor Type],ven_Type_Desc as [Description] from tspl_vendor_type_master"
            fndvendorid.Value = clsCommon.ShowSelectForm("FmVendorfndd", qry, "Vendor Type", "", fndvendorid.Value, "", isButtonClicked)
            rdtxtvendordesc.Text = clsDBFuncationality.getSingleValue("Select ven_Type_Desc from tspl_vendor_type_master where ven_Type_Code='" + fndvendorid.Value + "'")
            If fndvendorid.Value IsNot Nothing Then
                rdbtnDelete.Enabled = True
            Else
                rdbtnDelete.Enabled = False
            End If
            text_changed()
        ElseIf fndvendorid.MyReadOnly OrElse fndvendorid.Value IsNot Nothing Then
            Dim qry As String = "Select * from tspl_vendor_type_master where ven_Type_Code ='" + fndvendorid.Value + "' "
            Dim dt As DataTable = clsDBFuncationality.GetDataTable(qry)
            If dt.Rows.Count <= 0 Then
                rdtxtvendordesc.Text = ""
                rdbtnSave.Text = "Save"
            Else
                text_changed()
                'rdtxtvendordesc.Text = clsDBFuncationality.getSingleValue("Select ven_Type_Desc from tspl_vendor_type_master where ven_Type_Code='" + fndvendorid.Value + "'")
            End If

                                    
        End If
                            End Sub

    Private Sub fndvendorid__MYNavigator(ByVal sender As System.Object, ByVal e As System.EventArgs, ByVal NavigatorType As common.NavigatorType) Handles fndvendorid._MYNavigator
        Dim qst As String = "select ven_Type_Code as [Vendor Type],ven_Type_Desc as [Description] from tspl_vendor_type_master   where  2=2 "
        Select Case NavigatorType
            Case NavigatorType.Current
                '  qst += "and assign_to='" + txtassign.Value + "' "
                ' qst += "and job_code in ('" + txtcode1.Value + "')"
            Case NavigatorType.Next
                qst += "and ven_Type_Code in (select min(ven_Type_Code) from tspl_vendor_type_master where ven_Type_Code>'" + fndvendorid.Value + "'   ) "
            Case NavigatorType.First
                qst += "and ven_Type_Code in (select MIN(ven_Type_Code) from tspl_vendor_type_master  )"
            Case NavigatorType.Last
                qst += "and ven_Type_Code in (select Max(ven_Type_Code) from tspl_vendor_type_master  )"
            Case NavigatorType.Previous
                qst += "and ven_Type_Code in (select max(ven_Type_Code) from tspl_vendor_type_master where ven_Type_Code<'" + fndvendorid.Value + "'   )"
        End Select
        ' fun_gridfill()
        Dim dt As DataTable = clsDBFuncationality.GetDataTable(qst)
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            fndvendorid.Value = clsCommon.myCstr(dt.Rows(0)("Vendor Type"))
            rdtxtvendordesc.Text = clsCommon.myCstr(dt.Rows(0)("Description"))
        End If
        'TextChanged()
        If fndvendorid.Value IsNot Nothing Then
            rdbtnDelete.Enabled = True
        Else
            rdbtnDelete.Enabled = False

        End If
        text_changed()
    End Sub
