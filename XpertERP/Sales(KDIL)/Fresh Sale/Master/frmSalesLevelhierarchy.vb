Public Class FrmSalesLevelhierarchy
    Inherits FrmMainTranScreen
    Dim ButtonToolTip As ToolTip = New ToolTip()
    Dim isnewentry As Boolean
    Dim isAllowValueChanged As Boolean = False
    Dim isFlag As Boolean = False
    Dim Errorcontrol As clsErrorControl = New clsErrorControl()
    Private Sub SetUserMgmtNew()
        'MyBase.SetUserMgmt(clsUserMgtCode.FrmSalesLevelhierarchy)
        If Not (MyBase.isReadFlag) Then
            common.clsCommon.MyMessageBoxShow("Permission Denied")
            Me.Close()
            Exit Sub
        End If
        btnsave.Visible = MyBase.isModifyFlag

    End Sub
    Function allowtosave()
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) AndAlso clsCommon.myLen(txtCode.Value) <= 0 Then
            myMessages.blankValue(Me, "Document Code", Me.Text)
            txtCode.Focus()
            Return False
        ElseIf clsCommon.myLen(txtDescription.Text) <= 0 Then
            myMessages.blankValue(Me, "Description", Me.Text)
            txtDescription.Focus()
            Return False
        ElseIf clsCommon.myLen(txtSeqNo.Text) <= 0 Then
            myMessages.blankValue(Me, "Sequence No.", Me.Text)
            txtSeqNo.Focus()
            Return False
        ElseIf clsCommon.myLen(cboLevelType.Text) <= 0 Then
            myMessages.blankValue(Me, "Select Level Type.", Me.Text)
            cboLevelType.Focus()
            Return False
        ElseIf clsCommon.myLen(cboSubType.Text) <= 0 Then
            myMessages.blankValue(Me, "Select Sub Type.", Me.Text)
            cboSubType.Focus()
            Return False
            'Else
            '    If clsCommon.myLen(cboSubType.Text) > 0 Then
            '        If clsCommon.CompairString(cboLevelType.Text, "Sales Person") = CompairStringResult.Equal Then
            '            If clsCommon.CompairString(cboSubType.SelectedValue, "EMP") = CompairStringResult.Equal Then

            '            End If
            '        Else

            '        End If
            '    End If
        End If
        Return True
    End Function
    Public Sub SaveData()

        Try
            If allowtosave() Then
                Dim obj As New ClsSaleLevelHierarchy()
                obj.Level_Code = txtCode.Value
                obj.Description = txtDescription.Text
                obj.Level_Type = cboLevelType.Text
                obj.Sub_Type = cboSubType.SelectedValue
                obj.Seq_No = txtSeqNo.Text
                If chkIsFirstLevel.Checked Then
                    obj.Is_First_Level = 1
                Else
                    obj.Is_First_Level = 0
                End If
                If chkIsLastLevel.Checked Then
                    obj.Is_Last_Level = 1
                Else
                    obj.Is_Last_Level = 0
                End If
                Dim qry As Integer = clsDBFuncationality.getSingleValue("select count(Level_Code) from TSPL_Sales_Hierarchy_Levels where Level_Code='" + obj.Level_Code + "'")
                If (qry = 0) Then
                    isnewentry = True
                Else
                    isnewentry = False
                End If
                Dim count As Integer = clsDBFuncationality.getSingleValue("select count(Seq_No) from TSPL_Sales_Hierarchy_Levels where Level_Code <>'" + obj.Level_Code + "' and Seq_No='" + txtSeqNo.Text + "' and Level_Type='" + cboLevelType.Text + "'")
                If (count > 0) Then
                    clsCommon.MyMessageBoxShow(Me, "This Sequence no. is already exist for this Type of Level", Me.Text)
                    Exit Sub
                End If
                If chkIsFirstLevel.Checked Then
                    Dim CheckFirst As String = clsDBFuncationality.getSingleValue("select count(Is_First_Level) from TSPL_Sales_Hierarchy_Levels where Level_Code <>'" & obj.Level_Code & "' and Level_Type='" & cboLevelType.Text & "' and Is_First_Level='" & obj.Is_First_Level & "' ")
                    If clsCommon.myCdbl(CheckFirst) > 0 Then
                        clsCommon.MyMessageBoxShow(Me, "First Level is Already exist for this Type of Level", Me.Text)
                        Exit Sub
                    End If
                End If
                If chkIsLastLevel.Checked Then
                    Dim CheckLast As String = clsDBFuncationality.getSingleValue("select count(Is_Last_Level) from TSPL_Sales_Hierarchy_Levels where Level_Code <>'" & obj.Level_Code & "' and Level_Type='" & cboLevelType.Text & "'and Is_Last_Level='" & obj.Is_Last_Level & "' ")
                    If clsCommon.myCdbl(CheckLast) > 0 Then
                        clsCommon.MyMessageBoxShow(Me, "Last Level is Already exist for this Type of Level", Me.Text)
                        Exit Sub
                    End If
                End If
                If ClsSaleLevelHierarchy.SaveData(obj, isnewentry) Then

                    clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)

                    LoadData(obj.Level_Code, NavigatorType.Current)
                    btnsave.Text = "Update"
                    btndelete.Enabled = True
                Else
                    btnsave.Text = "Save"
                    btndelete.Enabled = False

                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)

        End Try
    End Sub
    Sub LoadSubType()
        Dim dt As DataTable = New DataTable()
        dt.Columns.Add("Code", GetType(String))
        dt.Columns.Add("Name", GetType(String))
        Dim dr As DataRow = dt.NewRow()
        If clsCommon.CompairString(cboLevelType.Text, "Sales Person") = CompairStringResult.Equal Then
            dr("Code") = "EMP"
            dr("Name") = "Employee"
            dt.Rows.Add(dr)
        Else
            dr = dt.NewRow()
            dr("Code") = "COMP"
            dr("Name") = "Company"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "C"
            dr("Name") = "Country"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "ST"
            dr("Name") = "State"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "CT"
            dr("Name") = "City"
            dt.Rows.Add(dr)

            dr = dt.NewRow()
            dr("Code") = "Z"
            dr("Name") = "Zone"
            dt.Rows.Add(dr)
        End If
        

        dr = dt.NewRow()
        dr("Code") = "O"
        dr("Name") = "Other"
        dt.Rows.Add(dr)

        cboSubType.DataSource = dt
        cboSubType.ValueMember = "Code"
        cboSubType.DisplayMember = "Name"
    End Sub
    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        txtCode.MyReadOnly = True

        btnsave.Enabled = True
        btndelete.Enabled = True
        Dim obj As ClsSaleLevelHierarchy = ClsSaleLevelHierarchy.GetData(strCode, Nothing, NavTyep)

        If obj IsNot Nothing Then
            AddNew()
            isnewentry = False
            btnsave.Text = "Update"
            txtCode.Value = obj.Level_Code
            txtDescription.Text = obj.Description
            cboLevelType.Text = obj.Level_Type
            LoadSubType()
            cboSubType.SelectedValue = obj.Sub_Type
            txtSeqNo.Text = obj.Seq_No

            If obj.Is_First_Level = True Then

                chkIsFirstLevel.Checked = True
            Else
                chkIsFirstLevel.Checked = False
            End If


            If obj.Is_Last_Level = True Then
                chkIsLastLevel.Checked = True
            Else
                chkIsLastLevel.Checked = False
            End If
        End If
    End Sub
    Private Sub DeleteData()
        Try
            If clsCommon.myLen(txtCode.Value) <= 0 Then
                Throw New Exception("Code not found to delete")
            End If
            If clsCommon.MyMessageBoxShow("are you sure? do you want to delete this Code ('" + txtcode.Value + "')", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then

                Dim qry As String = "DELETE FROM TSPL_Sales_Hierarchy_Levels WHERE Level_code='" + txtCode.Value + "'"
                clsDBFuncationality.ExecuteNonQuery(qry)
                clsCommon.MyMessageBoxShow(Me, "Deleted Successfully", Me.Text)
                AddNew()
            End If
        Catch ex As Exception
            If (clsCommon.CompairString(clsCommon.myCstr(ex.Message), "Code not found to delete") <> CompairStringResult.Equal) Then
                clsCommon.MyMessageBoxShow("Current Code is in use")
            Else
                clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
            End If
        End Try
    End Sub
    Private Sub txtCode__MYValidating(sender As Object, e As EventArgs, isButtonClicked As Boolean) Handles txtCode._MYValidating

        Dim str As String = "select count(*) from TSPL_Sales_Hierarchy_Levels where Level_code ='" + txtCode.Value + "' "
        Dim no As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(str))
        If no = 0 AndAlso isButtonClicked = False Then
            txtCode.MyReadOnly = False
        Else
            txtCode.MyReadOnly = True
        End If

        If txtCode.MyReadOnly OrElse isButtonClicked Then
            Dim qry As String = ""
            qry = "Select Level_code As [Code],Description As [ Description],Level_Type as [Level Type],Sub_Type as [Sub Type],Seq_No as [Sequence No]," _
                & " case when Is_First_Level=1 then 'True' else '' end as [First Level],case when Is_Last_Level=1 then 'True' else '' end as [Last Level] " _
                & " from TSPL_Sales_Hierarchy_Levels"
            txtCode.Value = clsCommon.ShowSelectForm("LEV", qry, "Code", "", txtCode.Value, "TSPL_Sales_Hierarchy_Levels.Level_code", isButtonClicked)
            If clsCommon.myLen(txtCode.Value) > 0 Then
                Dim objOT As ClsSaleLevelHierarchy
                objOT = ClsSaleLevelHierarchy.GetData(txtCode.Value, Nothing, NavigatorType.Current)
                If Not objOT Is Nothing Then
                    LoadData(txtCode.Value, NavigatorType.Current)
                End If
            Else
                AddNew()
            End If
        End If
    End Sub
    Sub AddNew()
        txtCode.Value = ""
        txtDescription.Text = ""
        cboLevelType.Text = "Sales Person"
        LoadSubType()
        chkIsFirstLevel.Checked = False
        chkIsLastLevel.Checked = False
        txtSeqNo.Text = ""
        btnsave.Text = "Save"
        txtCode.MyReadOnly = False
    End Sub
    Private Sub btnnew_Click(sender As Object, e As EventArgs) Handles btnnew.Click
        AddNew()
    End Sub

    

    Private Sub btndelete_Click(sender As Object, e As EventArgs) Handles btndelete.Click
        DeleteData()
    End Sub

    Private Sub btnclose_Click(sender As Object, e As EventArgs) Handles btnclose.Click
        Me.Close()
    End Sub

    Private Sub txtCode__MYNavigator(sender As Object, e As EventArgs, NavType As NavigatorType) Handles txtCode._MYNavigator
        Try
            LoadData(txtCode.Value, NavType)
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub

    Private Sub FrmSalesLevelhierarchy_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        SetUserMgmtNew()
        ButtonToolTip.SetToolTip(btnsave, "Press Alt+S for Save/Update ")

        ButtonToolTip.SetToolTip(btnclose, "Press Alt+C Close the Window")
        ButtonToolTip.SetToolTip(btnnew, "Press Alt+N Adding New ")


        AddNew()
    End Sub

    Private Sub FrmSalesLevelhierarchy_KeyDown(sender As Object, e As KeyEventArgs) Handles MyBase.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.N AndAlso btnnew.Enabled Then
            AddNew()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnsave.Enabled Then
            SaveData()

        ElseIf e.Alt And e.KeyCode = Keys.C Then
            Me.Close()
        End If
    End Sub

    Private Sub btnsave_Click(sender As Object, e As EventArgs) Handles btnsave.Click
        SaveData()
    End Sub

    Private Sub cboLevelType_SelectedIndexChanged(sender As Object, e As UI.Data.PositionChangedEventArgs) Handles cboLevelType.SelectedIndexChanged
        Try
            LoadSubType()
        Catch ex As Exception

        End Try
    End Sub
End Class
