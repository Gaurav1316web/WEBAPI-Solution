                lblRSM.Text = clsDBFuncationality.getSingleValue("Select Emp_Name as Name from  TSPL_EMPLOYEE_MASTER  where EMP_CODE = '" + fndRSM.Value + "'")
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try

    End Sub

