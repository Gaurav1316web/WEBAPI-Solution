    Private Sub rmImport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmImport.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim obj As clsJWParameterMaster = Nothing
        Dim currentdate As Date = Date.Today
        If transportSql.importExcel(gv, "Code", "Description", "Type") Then
            Dim linno As Integer = 0
            Try
                Dim arr As New List(Of clsJWParameterMaster)
                clsCommon.ProgressBarShow()
                For Each grow As GridViewRowInfo In gv.Rows
                    obj = New clsJWParameterMaster
                    linno += 1
                    Dim strcode As String = clsCommon.myCstr(grow.Cells("Code").Value)
                    If (String.IsNullOrEmpty(strcode)) Or clsCommon.myLen(strcode) > 30 Then
                        Throw New Exception("Length of Code should be max. 12 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Code = strcode

                    Dim strDesp As String = clsCommon.myCstr(grow.Cells("Description").Value)
                    If (String.IsNullOrEmpty(strDesp)) Or clsCommon.myLen(strDesp) > 100 Then
                        Throw New Exception("Length of Description should be max. 100 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Description = strDesp

                    Dim strType As String = clsCommon.myCstr(grow.Cells("Type").Value)
                    If clsCommon.myLen(strType) <= 0 Or clsCommon.CompairString(strType, "NONE") = CompairStringResult.Equal Then
                        strType = "N"
                    ElseIf clsCommon.CompairString(strType, "N") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "NONE") = CompairStringResult.Equal Then
                        strType = "N"
                    ElseIf clsCommon.CompairString(strType, "F") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "FAT") = CompairStringResult.Equal Then
                        strType = "F"
                    ElseIf clsCommon.CompairString(strType, "S") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "SNF") = CompairStringResult.Equal Then
                        strType = "S"
                    Else
                        Throw New Exception("Type Should be blank , 'F', 'S' , 'NONE' At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If

                    Dim chkSNFType As Boolean = clsCommon.myCdbl(clsDBFuncationality.getSingleValue("Select count(*) from  TSPL_JW_Parameter_MASTER where Type = 'S' "))
                    Dim chkSNFCode As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue("Select Code from  TSPL_JW_Parameter_MASTER where Type = 'S' "))
                    If clsCommon.CompairString(chkSNFCode, strcode) <> CompairStringResult.Equal Then
                        If clsCommon.CompairString(strType, "S") = CompairStringResult.Equal AndAlso chkSNFType = True AndAlso strType = "S" Then
                            Throw New Exception("SNF Type Parameter already exist.Only One Parameter Code type will be SNF Type. At Line No. " + clsCommon.myCstr(linno) + ".")
                        End If
                    End If


                    Dim chkFATType As Boolean = clsCommon.myCdbl(clsDBFuncationality.getSingleValue("Select count(*) from  TSPL_JW_Parameter_MASTER where Type = 'F'"))
                    Dim chkFATCode As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue("Select Code from  TSPL_JW_Parameter_MASTER where Type = 'F' "))
                    If clsCommon.CompairString(chkFATCode, strcode) <> CompairStringResult.Equal Then
                        If clsCommon.CompairString(strType, "F") = CompairStringResult.Equal AndAlso chkFATType = True AndAlso strType = "F" Then
                            Throw New Exception("FAT Type Parameter already exist.Only One Parameter Code type will be FAT Type. At Line No. " + clsCommon.myCstr(linno) + ".")
                        End If
                    End If
                    obj.Type = strType

                    'Dim strIS_MOISTURE As String = clsCommon.myCstr(grow.Cells("IS_MOISTURE").Value)
                    'If clsCommon.myLen(strIS_MOISTURE) <= 0 OrElse clsCommon.CompairString(strIS_MOISTURE, "0") = CompairStringResult.Equal Then
                    '    strIS_MOISTURE = 0
                    'ElseIf clsCommon.CompairString(strIS_MOISTURE, "1") = CompairStringResult.Equal Then
                    '    strIS_MOISTURE = 1
                    'Else
                    '    Throw New Exception("IS_MOISTURE Should be blank , '1', '0'  At Line No. " + clsCommon.myCstr(linno) + ".")
                    'End If

                    'Dim chkMOISTUREType As Boolean = clsCommon.myCdbl(clsDBFuncationality.getSingleValue("Select count(*) from  TSPL_JW_Parameter_MASTER where IS_MOISTURE = 1"))
                    'Dim chkMOISTURECode As String = clsCommon.myCstr(clsDBFuncationality.getSingleValue("Select Code from  TSPL_JW_Parameter_MASTER where IS_MOISTURE = 1 "))
                    'If clsCommon.CompairString(chkMOISTURECode, strcode) <> CompairStringResult.Equal Then
                    '    If clsCommon.CompairString(strIS_MOISTURE, 1) = CompairStringResult.Equal AndAlso chkMOISTUREType = True Then
                    '        Throw New Exception("MOISTURE Type Parameter already exist.Only One Parameter Code type will be MOISTURE Type. At Line No. " + clsCommon.myCstr(linno) + ".")
                    '    End If
                    'End If

                    'obj.IS_MOISTURE = strIS_MOISTURE

                    If clsCommon.myLen(strcode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_JW_Parameter_MASTER  where Code='" + strcode + "' ") > 0 Then
                        isNewEntry = False
                    Else
                        isNewEntry = True
                    End If
                    arr.Add(obj)
                Next
                obj.SaveData(arr, isNewEntry)
                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow(Me, "Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception
                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)
            End Try
        End If
        Me.Controls.Remove(gv)
    End Sub

