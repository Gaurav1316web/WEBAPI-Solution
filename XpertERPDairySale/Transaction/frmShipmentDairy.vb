        Dim qryUomTotal As String = "select Final.Sale_Invoice_No,  Final.Unit_Code, sum( Final.Batch_Qty ) as Total_Batch_Qty from ( " + qry + " ) Final group by Final.Sale_Invoice_No, Final.Unit_Code"
