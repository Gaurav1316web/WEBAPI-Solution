    Private Sub btnCreateJEAR_Click(sender As Object, e As EventArgs) Handles btnCreateJEAR.Click
        '' done by Panch raj against TicketNo : BM00000008301
        Dim qry As String = ""
        Dim dt As New DataTable()
        Try
            qry = "select * from TEMP_Delete_DairyDispatch where Doc_No not in (select Doc_No from TEMP_Create_DairyDispatch)"
            dt = New DataTable()
            dt = clsDBFuncationality.GetDataTable(qry)
            Dim strErro As String = ""
            strMessages = ""
            Dim blnCreateNewno As Boolean = False
            Dim blnChangeTaxgroup As Boolean = False
            If clsCommon.MyMessageBoxShow(Me, "DO you want to Create New documents Numbers", "Dispatch", MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                blnCreateNewno = True
                'If clsCommon.MyMessageBoxShow(Me, "DO you want to Change existing Tax group with default tax group for New documents Numbers", "Dispatch", MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                '    blnChangeTaxgroup = True
                'End If
            End If
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                blnReverse = True
                If clsCommon.MyMessageBoxShow(Me, "Recreate Journal Entry of " + clsCommon.myCstr(dt.Rows.Count) + " AR Invoice", Me.Text, MessageBoxButtons.YesNo) = System.Windows.Forms.DialogResult.Yes Then
                    clsCommon.ProgressBarPercentShow()
                    For ii As Integer = 0 To dt.Rows.Count - 1
                        Dim strDocNo As String = clsCommon.myCstr(dt.Rows(ii)("Doc_No"))
                        Dim strInvoiceNo As String = clsCommon.myCstr(dt.Rows(ii)("Invoice_No"))
                        Dim strARInvoiceNo As String = clsCommon.myCstr(dt.Rows(ii)("ARInvoice_No"))
                        Dim strVoucherNo As String = clsCommon.myCstr(dt.Rows(ii)("voucher_no"))
                        Dim strDispatchVoucherNo As String = clsCommon.myCstr(dt.Rows(0)("Dispatch_Voucher_No"))
                        Try
                            LoadData(strDocNo, NavigatorType.Current)
                            If blnChangeTaxgroup = True Then
                                'SetTax()
                            End If
                            If AllowToSave(True) Then
                                Dim trans As SqlTransaction = clsDBFuncationality.GetTransactin()
                                Try
                                    If blnCreateNewno = True Then
                                        If clsPSShipmentHead.ReverseAndUnpost(txtDocNo.Value, trans) Then
                                            If (clsPSShipmentHead.DeleteData(txtDocNo.Value, txtInvoiceNo.Text, trans)) Then
                                                txtDocNo.Value = ""
                                                txtInvoiceNo.Text = ""
                                                isNewEntry = True
                                                If SaveData(False, trans) Then
                                                    PostData(trans, "", "", "")
                                                    clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_Create_DairyDispatch values('" + strDocNo + "','" + strInvoiceNo + "','" + strARInvoiceNo + "','" + strVoucherNo + "','" + strDispatchVoucherNo + "')", trans)
                                                End If
                                            End If
                                        End If
                                    Else
                                        If clsPSShipmentHead.ReverseAndUnpost(txtDocNo.Value, trans) Then
                                            SaveData(False, trans)
                                            PostData(trans, strVoucherNo, strARInvoiceNo, strDispatchVoucherNo)
                                            clsDBFuncationality.ExecuteNonQuery("Insert into TEMP_Create_DairyDispatch values('" + strDocNo + "','" + strInvoiceNo + "','" + strARInvoiceNo + "','" + strVoucherNo + "','" + strDispatchVoucherNo + "')", trans)
                                        End If
                                    End If
                                    trans.Commit()
                                Catch ex As Exception
                                    trans.Rollback()
                                    strErro += "Dispatch No - " + strDocNo + " Invoice - " + strInvoiceNo + " Exception -" + ex.Message + Environment.NewLine
                                End Try
                            End If
                            clsCommon.ProgressBarPercentUpdate((ii + 1) * 100 / dt.Rows.Count, "Recreate journal entry " + clsCommon.myCstr(ii + 1) + "/" + clsCommon.myCstr(dt.Rows.Count))
                        Catch ex As Exception
                            strErro += "Dispatch No - " + strDocNo + " Invoice - " + strInvoiceNo + " Exception -" + ex.Message + Environment.NewLine
                        End Try
                    Next
                    clsCommon.ProgressBarPercentHide()
                    If clsCommon.myLen(strErro) > 0 Then
                        clsCommon.MyMessageBoxShow(Me, strErro, Me.Text)
                    Else
                        clsCommon.MyMessageBoxShow(Me, "Task completed", Me.Text)
                    End If
                    If clsCommon.myLen(strMessages) > 0 Then
                        clsCommon.MyMessageBoxShow(Me, strMessages & "Posted Succesfully", Me.Text)
                    End If
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
