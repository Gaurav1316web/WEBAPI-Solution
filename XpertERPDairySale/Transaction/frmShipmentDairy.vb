                If dblDisAmt < 0 Then
                    gv1.Rows(IntRowNo).Cells(colActualCost).Value = dblRate
                End If
                'If clsCommon.myCdbl(gv1.Rows(IntRowNo).Cells(colCash_Amt).Value) > dblAmt Then
                '    gv1.Rows(IntRowNo).Cells(colCash_Amt).Value = 0
