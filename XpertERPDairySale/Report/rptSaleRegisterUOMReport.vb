='EXP' and TSPL_SD_SALE_INVOICE_HEAD.Document_Type ='MT' then 'Merchant Trade' WHEN TSPL_SD_SALE_INVOICE_HEAD.Trans_Type ='SD' then 'General Sale'  else  TSPL_SD_SALE_INVOICE_HEAD.Trans_Type end) in ('Fresh Sale','Fresh Sale Return','MCC Sale','MCC Sale Return','Product Sale','Product Sale Return','Misc Sale','MCC Sale Farmer','MCC Sale Return Farmer','Dairy Sale','Dairy Sale Return','MCC Transfer','Tanker Dispatch Return','Transfer','Transfer Return') 
