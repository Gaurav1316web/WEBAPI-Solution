    Private Sub FrmAMAcquisitionCode_KeyDown(ByVal sender As Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles Me.KeyDown
        If e.Alt AndAlso e.KeyCode = Keys.N AndAlso btnAddNew.Enabled Then
            AddNew()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.S AndAlso MyBase.isModifyFlag AndAlso btnSave.Enabled Then
            SaveData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.D AndAlso MyBase.isDeleteFlag AndAlso btnDelete.Enabled Then
            DeleteData()
        ElseIf e.Alt AndAlso e.KeyCode = Keys.C AndAlso btnClose.Enabled Then
            CloseForm()
        End If
    End Sub
    Private Sub FrmAMAcquisitionCode_Load(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MyBase.Load
        SetUserMgmtNew()
        ButtonToolTip.SetToolTip(btnSave, "Press Alt+S for Save/Update Trasnaction")
        ButtonToolTip.SetToolTip(btnClose, "Press Alt+C Close the Window")
        ButtonToolTip.SetToolTip(btnDelete, "Press Alt+D Delete Trasnaction")
        ButtonToolTip.SetToolTip(btnAddNew, "Press Alt+N Adding New Trasnaction")
        AddNew()
        SetLength()
    End Sub
    Sub SetLength()
        txtAcqCode.MyMaxLength = 30
        txtDesc.MaxLength = 100

    End Sub

    Sub AddNew()
        txtAcqCode.MyReadOnly = False
        BlankAllControls()
        isNewEntry = True
        btnSave.Text = "Save"
    End Sub

    Sub BlankAllControls()
        txtAcqCode.Value = ""
        txtDesc.Text = ""
        cmbAcqWith.Text = "AP"
        cmbType.Text = "Create A/P Invoice"
        txtAccount.Value = ""
        txtVendor.Value = ""
        lblDefaultAcct.Text = ""
        lblVendorName.Text = ""
    End Sub
    Function AllowToSave() As Boolean
        If (IIf(clsCommon.myCstr(clsFixedParameter.GetData(clsFixedParameterType.AllowAutoGenerateDocNoInMaster, clsFixedParameterCode.AllowAutoGenerateDocNoInMaster, Nothing)) = "1", True, False) = False) Then
            If clsCommon.myLen(txtAcqCode.Value) <= 0 Then
                common.clsCommon.MyMessageBoxShow(Me, "Please Enter Code", Me.Text)
                txtAcqCode.Focus()
                Return False
            End If
        End If
        If clsCommon.myLen(txtDesc.Text) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "Please Enter Description", Me.Text)
            txtDesc.Focus()
            Return False
        End If
        If clsCommon.myLen(txtAccount.Value) <= 0 Then
            common.clsCommon.MyMessageBoxShow(Me, "Please Enter Default Account", Me.Text)
            txtAccount.Focus()
            Return False
        End If

        Return True
    End Function

    Private Sub SaveData()
        Try
            If (AllowToSave()) Then
                Dim obj As New clsAcquisitionCodes()
                obj.Code = txtAcqCode.Value
                obj.Description = txtDesc.Text
                obj.Acqu_with = cmbAcqWith.Text
                obj.Type = cmbType.Text
                obj.Default_Account = txtAccount.Value
                obj.Vendor_Code = txtVendor.Value

                If obj.SaveData(obj, isNewEntry) Then
                    clsCommon.MyMessageBoxShow(Me, "Data Saved Successfully", Me.Text)
                    LoadData(obj.Code, NavigatorType.Current)
                End If
            End If
        Catch ex As Exception
            clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Sub LoadData(ByVal strCode As String, ByVal NavTyep As NavigatorType)
        Try
            isNewEntry = False
            btnSave.Text = "Update"
            BlankAllControls()
            txtAcqCode.MyReadOnly = True
            Dim obj As New clsAcquisitionCodes()
            obj = clsAcquisitionCodes.GetData(strCode, NavTyep, Nothing)
            If (obj IsNot Nothing AndAlso clsCommon.myLen(obj.Code) > 0) Then
                txtAcqCode.Value = obj.Code
                txtDesc.Text = obj.Description
                cmbAcqWith.Text = obj.Acqu_with
                cmbType.Text = obj.Type

                txtAccount.Value = obj.Default_Account
                lblDefaultAcct.Text = clsGLAccount.GetName(obj.Default_Account)
                txtVendor.Value = obj.Vendor_Code
                If txtVendor.Value <> "" Then
                    lblVendorName.Text = clsVendorMaster.GetName(obj.Vendor_Code, Nothing)
                End If
            End If
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub

    Private Sub txtAcqCode__MYNavigator(ByVal sender As Object, ByVal e As System.EventArgs, ByVal NavType As common.NavigatorType) Handles txtAcqCode._MYNavigator
        LoadData(txtAcqCode.Value, NavType)
    End Sub

    Private Sub txtAcqCode__MYValidating(ByVal sender As Object, ByVal e As System.EventArgs, ByVal isButtonClicked As Boolean) Handles txtAcqCode._MYValidating
        Try
            strSql = "select count(*) from TSPL_ACQUISITION_CODES where Code='" + txtAcqCode.Value + "'"
            Dim count As Integer = clsCommon.myCdbl(clsDBFuncationality.getSingleValue(strSql))
            If count = 0 Then
                txtAcqCode.MyReadOnly = False
            Else
                txtAcqCode.MyReadOnly = True
            End If
            If txtAcqCode.MyReadOnly OrElse isButtonClicked Then

                'strSql = "select Code,Description from TSPL_ACQUISITION_CODES"
                'LoadData(clsCommon.ShowSelectForm("AcquisitionCode", strSql, "Code", "", txtAcqCode.Value, "Code", isButtonClicked), NavigatorType.Current)
                LoadData(clsAcquisitionCodes.getFinder("", txtAcqCode.Value, isButtonClicked), NavigatorType.Current)
                LoadData(txtAcqCode.Value, NavigatorType.Current)
            End If
        Catch ex As Exception
            common.clsCommon.MyMessageBoxShow(Me, ex.Message, Me.Text)
        End Try
    End Sub
    Private Sub btnDelete_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btnDelete.Click
        DeleteData()
    End Sub

    Sub DeleteData()
        Try
            If (myMessages.deleteConfirm()) Then
                If (clsAcquisitionCodes.DeleteData(txtAcqCode.Value)) Then
                    common.clsCommon.MyMessageBoxShow(Me, "Data Deleted Successfully", Me.Text)
                    AddNew()
                End If
            End If
        Catch ex As Exception
            myMessages.myExceptions(ex)
        End Try
    End Sub

