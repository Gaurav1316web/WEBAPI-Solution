    End Sub

    Private Sub rmImport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmImport.Click
        Dim gv As New RadGridView()
        Me.Controls.Add(gv)
        Dim trans As SqlTransaction = Nothing
        'trans = clsDBFuncationality.GetTransactin()
        If transportSql.importExcel(gv, "code", "Description", "Acqu with", "Type", "Default Account", "Vendor Code") Then
            Dim linno As Integer = 0
            Try

                connectSql.OpenConnection()

                clsCommon.ProgressBarShow()

                For Each grow1 As GridViewRowInfo In gv.Rows

                    Dim strDefaultAccount As String = clsCommon.myCstr(grow1.Cells("Default Account").Value)
                    Dim strDefaultVendor As String = clsCommon.myCstr(grow1.Cells("Vendor Code").Value)
                    If (String.IsNullOrEmpty(strDefaultAccount)) Or clsCommon.myLen(strDefaultAccount) > 0 Then
                        If CheckDefaultAccount(strDefaultAccount, trans) = False Then
                            Exit Sub
                        End If

                    End If
                    If (String.IsNullOrEmpty(strDefaultVendor)) Or clsCommon.myLen(strDefaultVendor) > 0 Then
                        If CheckDefaultVendor(strDefaultVendor, trans) = False Then
                            Exit Sub
                        End If

                    End If

                Next

                Dim obj As New clsAcquisitionCodes()


                For Each grow As GridViewRowInfo In gv.Rows


                    linno += 1
                    Dim strcode As String = clsCommon.myCstr(grow.Cells("Code").Value)
                    If (String.IsNullOrEmpty(strcode)) Or clsCommon.myLen(strcode) > 30 Then
                        Throw New Exception("Length of  Code should be max. 30 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Code = strcode

                    Dim strDescription As String = clsCommon.myCstr(grow.Cells("Description").Value)
                    If (String.IsNullOrEmpty(strDescription)) Or clsCommon.myLen(strDescription) > 100 Then
                        Throw New Exception("Length of Name should be max. 100 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Description = strDescription

                    Dim strAcquWith As String = clsCommon.myCstr(grow.Cells("Acqu with").Value)
                    If (String.IsNullOrEmpty(strAcquWith)) Or clsCommon.myLen(strAcquWith) > 30 Then
                        Throw New Exception("Length of  Code should be max. 30 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    ElseIf clsCommon.CompairString(strAcquWith, "AP") = CompairStringResult.Equal Or clsCommon.CompairString(strAcquWith, "GL") = CompairStringResult.Equal Then
                    Else
                        Throw New Exception("Acquisition With should be amoung 'AP','GL' At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Acqu_with = strAcquWith

                    Dim strType As String = clsCommon.myCstr(grow.Cells("Type").Value)
                    If (String.IsNullOrEmpty(strType)) Or clsCommon.myLen(strType) > 30 Then
                        Throw New Exception("Length of Name should be max. 30 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    ElseIf clsCommon.CompairString(strType, "Create A/P Invoice") = CompairStringResult.Equal Or clsCommon.CompairString(strType, "Create Misc Payment") = CompairStringResult.Equal Then
                    Else
                        Throw New Exception("Type should be amoung 'Create A/P Invoice','Create Misc Payment' At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If

                    obj.Type = strType

                    Dim strDefaultAccount As String = clsCommon.myCstr(grow.Cells("Default Account").Value)
                    If (String.IsNullOrEmpty(strDefaultAccount)) Or clsCommon.myLen(strDefaultAccount) > 50 Then
                        Throw New Exception("Length of  Code should be max. 50 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Default_Account = strDefaultAccount

                    Dim strVendorCode As String = clsCommon.myCstr(grow.Cells("Vendor Code").Value)
                    If (String.IsNullOrEmpty(strVendorCode)) Or clsCommon.myLen(strVendorCode) > 50 Then
                        Throw New Exception("Length of Name should be max. 50 character At Line No. " + clsCommon.myCstr(linno) + ".")
                    End If
                    obj.Vendor_Code = strVendorCode
                    'Dim trans As SqlTransaction
                    If clsCommon.myLen(strcode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_ACQUISITION_CODES where code='" + strcode + "' ", trans) > 0 Then
                        isNewEntry = False
                    Else
                        isNewEntry = True

                    End If


                    obj.SaveData(obj, isNewEntry)

                Next

                clsCommon.ProgressBarHide()
                common.clsCommon.MyMessageBoxShow(Me, "Data Transfer Completed!", Me.Text, MessageBoxButtons.OK)
            Catch ex As Exception

                clsCommon.ProgressBarHide()
                myMessages.myExceptions(ex)
            End Try
        End If
        Me.Controls.Remove(gv)
    End Sub

    Private Sub rmExport_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles rmExport.Click
        Dim str As String
        str = "select code as [code],Description as [Description],Acqu_with as [Acqu with],Type as [Type],"
        str += " Default_Account as [Default Account],Vendor_Code as [Vendor Code]  from TSPL_ACQUISITION_CODES"
        transportSql.ExporttoExcel(str, Me)
    End Sub

    Private Function CheckDefaultAccount(ByVal AccountCode As String, ByVal trans As SqlTransaction) As Boolean

        Try
            If clsCommon.myLen(AccountCode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_GL_ACCOUNTS where Account_Code='" + AccountCode + "' ", trans) > 0 Then
                Return True
            Else
                Throw New Exception("Default Account is Invalid,It Could Not Found in  Master")
                Return False
            End If

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function
    Private Function CheckDefaultVendor(ByVal VendorCode As String, ByVal trans As SqlTransaction) As Boolean

        Try
            If clsCommon.myLen(VendorCode) > 0 AndAlso clsDBFuncationality.getSingleValue("Select count(*) from TSPL_VENDOR_MASTER where Vendor_Code='" + VendorCode + "' ", trans) > 0 Then
                Return True
            Else
                Throw New Exception("Default Vendor is Invalid,It Could Not Found in Vendor Master")
                Return False
            End If

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try
    End Function

